# Hosted PostgreSQL connection, preferred on Render.
# In Render web service environment variables, set DATABASE_URL to the
# internal database URL from Render's database page.
# DATABASE_URL=postgresql://user:password@host/database
# DB_SSL=true

# Optional full database replacement target for local scripts.
# TARGET_DATABASE_URL=postgresql://user:password@host/database

# Google Sign-In OAuth client id. This must be the Web client id ending
# with .apps.googleusercontent.com, not the Firebase apiKey or appId.
# GOOGLE_WEB_CLIENT_ID=1012871345847-xxxxx.apps.googleusercontent.com

