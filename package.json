{
  "name": "jaipur-db-node",
  "version": "1.0.0",
  "description": "Default Node.js project with superadmin login and MySQL UI.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "migrate": "node scripts/run-migrations.js",
    "schema:sync": "node app.js --sync-schema-only",
    "db:dump:local": "node scripts/full-db-migration.js dump",
    "db:replace:target": "node scripts/full-db-migration.js replace",
    "db:snapshot:export": "node scripts/db-snapshot.js export",
    "db:snapshot:restore": "node scripts/db-snapshot.js restore"
  },
  "keywords": [
    "node",
    "express",
    "mysql",
    "login",
    "superadmin"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.4",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1",
    "xlsx": "^0.18.5"
  }
}
