<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Vehicle Categories</title><link rel="stylesheet" href="/styles.css"></head>
<body class="system-theme"><%- include('partials/system_sidebar',{shell}) %><main class="system-main"><header class="topbar"><div><p class="crumb">Delivery Dashboard / Vehicle Categories</p><h1>Vehicle Categories</h1></div><button class="settings-save" onclick="openForm()">Add Vehicle</button></header>
<section class="settings-shell pricing-page"><div class="pricing-hero"><div><span>Fleet pricing</span><h2>Delivery vehicle categories</h2><p>Configure base charges, supported weight and availability for each vehicle type.</p></div></div><div id="vehicleGrid" class="pricing-grid"></div></section></main>
<div class="user-modal" id="modal" aria-hidden="true"><div class="user-modal-card"><div class="user-modal-header"><h2 id="title">Add Vehicle</h2><button onclick="closeForm()">Close</button></div><form class="user-modal-grid" id="form"><input type="hidden" id="id"><label>Name<input id="name" required placeholder="Bike"></label><label>Code<input id="code" placeholder="bike"></label><label>Base Delivery Charge<input id="base" type="number" min="0" step=".01" required></label><label>Maximum Supported Weight (kg)<input id="max" type="number" min="0" step=".001" required></label><label>Display Priority<input id="priority" type="number" value="100"></label><label class="settings-toggle"><input id="active" type="checkbox" checked>Active</label><div class="settings-wide"><button class="settings-save">Save Vehicle</button> <button type="button" class="product-secondary-button" onclick="closeForm()">Cancel</button></div></form></div></div>
<script>let rows=[];const el=id=>document.getElementById(id),esc=v=>String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));const money=v=>'₹'+Number(v||0).toFixed(2);async function load(){const r=await fetch('/api/delivery-pricing/vehicles'),d=await r.json();rows=d.vehicles||[];el('vehicleGrid').innerHTML=rows.map(v=>`<article class="pricing-card"><div class="pricing-card-head"><div><small>${esc(v.code)}</small><h3>${esc(v.name)}</h3></div><span class="status-pill ${v.is_active?'status-active':'status-inactive'}">${v.is_active?'Active':'Inactive'}</span></div><div class="pricing-stats"><div><span>Base charge</span><strong>${money(v.base_delivery_charge)}</strong></div><div><span>Max weight</span><strong>${Number(v.max_supported_weight_kg)} kg</strong></div></div><div class="pricing-actions"><button onclick="openForm(${v.id})">Edit</button><button class="danger" onclick="removeRow(${v.id})">Delete</button></div></article>`).join('')||'<p>No vehicle categories.</p>'}function openForm(id){const v=rows.find(x=>Number(x.id)===Number(id));el('title').textContent=v?'Edit Vehicle':'Add Vehicle';el('form').reset();document.getElementById('id').value=v?v.id:'';el('name').value=v?v.name:'';el('code').value=v?v.code:'';el('base').value=v?v.base_delivery_charge:0;el('max').value=v?v.max_supported_weight_kg:100;el('priority').value=v?v.priority:100;el('active').checked=v?!!v.is_active:true;el('modal').style.display='flex'}function closeForm(){el('modal').style.display='none'}el('form').onsubmit=async e=>{e.preventDefault();const rowId=document.getElementById('id').value,p={name:el('name').value,code:el('code').value,base_delivery_charge:el('base').value,max_supported_weight_kg:el('max').value,priority:el('priority').value,is_active:el('active').checked};const r=await fetch('/api/delivery-pricing/vehicles'+(rowId?'/'+rowId:''),{method:rowId?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)}),d=await r.json();if(!d.success)return alert(d.message);closeForm();load()};async function removeRow(id){if(!confirm('Delete this vehicle category?'))return;const r=await fetch('/api/delivery-pricing/vehicles/'+id,{method:'DELETE'}),d=await r.json();if(!d.success)return alert(d.message);load()}load();</script>
<style>.pricing-page{display:grid;gap:18px}.pricing-hero{padding:24px;border-radius:18px;color:#fff;background:linear-gradient(135deg,#0f766e,#0891b2)}.pricing-hero span{font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.12em}.pricing-hero h2{margin:5px 0;color:#fff}.pricing-hero p{margin:0;opacity:.85}.pricing-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:14px}.pricing-card{padding:18px;border:1px solid #e2e8f0;border-radius:16px;background:#fff;box-shadow:0 10px 30px rgba(15,23,42,.06)}.pricing-card-head,.pricing-actions{display:flex;justify-content:space-between;gap:10px}.pricing-card h3{margin:2px 0}.pricing-card small{color:#0d9488;font-weight:900}.pricing-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:16px 0}.pricing-stats div{padding:10px;border-radius:10px;background:#f8fafc}.pricing-stats span,.pricing-stats strong{display:block}.pricing-stats span{font-size:10px;color:#64748b}.pricing-actions button{padding:8px 12px;border:1px solid #99f6e4;border-radius:8px;background:#f0fdfa;color:#0f766e;font-weight:800}.pricing-actions .danger{border-color:#fecaca;background:#fff7f7;color:#b91c1c}</style></body></html>
