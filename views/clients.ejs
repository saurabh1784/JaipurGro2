<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Client Management</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Clients</p>
        <h1>Client Management</h1>
      </div>
      <div class="topbar-actions">
        <label class="system-search" aria-label="Search clients">
          <input id="clientSearch" type="search" placeholder="Search clients" />
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/></svg>
        </label>
      </div>
    </header>

    <section class="vendor-management-shell">
      <div class="users-toolbar">
        <div>
          <h2>All Clients</h2>
          <p>Register clients, update profile details, and control account status.</p>
        </div>
        <div class="vendor-toolbar-actions">
          <label>
            Country
            <select id="countryFilter"></select>
          </label>
          <label>
            State
            <select id="stateFilter"></select>
          </label>
          <label>
            City
            <select id="cityFilter"></select>
          </label>
          <label>
            Status
            <select id="statusFilter">
              <option value="">All Status</option>
              <option value="active">active</option>
              <option value="inactive">inactive</option>
            </select>
          </label>
          <button class="product-secondary-button" type="button" id="clearClientFilters">Clear</button>
          <button class="settings-save" type="button" id="addClientButton">Add New Client</button>
        </div>
      </div>

      <div class="users-table-card">
        <table class="users-table clients-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Client</th>
              <th>Phone</th>
              <th>Location</th>
              <th>Age</th>
              <th>Gender</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="clientsTableBody">
            <tr><td colspan="8">Loading clients...</td></tr>
          </tbody>
        </table>
      </div>

      <div class="users-pagination">
        <button type="button" id="prevPage">Previous</button>
        <span id="pageInfo">Page 1</span>
        <button type="button" id="nextPage">Next</button>
      </div>
    </section>
  </main>

  <div class="user-modal" id="clientModal" aria-hidden="true">
    <div class="user-modal-card">
      <div class="user-modal-header">
        <h2 id="clientModalTitle">Add Client</h2>
        <button type="button" onclick="closeClientModal()">Close</button>
      </div>
      <form id="clientForm" class="user-modal-grid">
        <input type="hidden" id="clientId" />
        <label>
          Name
          <input id="clientName" type="text" required minlength="2" />
        </label>
        <label>
          Email
          <input id="clientEmail" type="email" required />
        </label>
        <label>
          Phone
          <input id="clientPhone" type="text" required />
        </label>
        <label>
          Password
          <input id="clientPassword" type="password" minlength="6" />
        </label>
        <label>
          Status
          <select id="clientStatus" required>
            <option value="active">active</option>
            <option value="inactive">inactive</option>
          </select>
        </label>
        <label>
          Age
          <input id="clientAge" type="number" min="1" max="120" />
        </label>
        <label>
          Gender
          <select id="clientGender">
            <option value="">Select Gender</option>
            <option value="Female">Female</option>
            <option value="Male">Male</option>
            <option value="Other">Other</option>
          </select>
        </label>
        <label>
          Country
          <select id="clientCountry" required></select>
        </label>
        <label>
          State
          <select id="clientState" required></select>
        </label>
        <label>
          City
          <select id="clientCity" required></select>
        </label>
        <label class="settings-wide">
          Address
          <textarea id="clientAddress" rows="3"></textarea>
        </label>
        <label class="settings-wide">
          Notes
          <textarea id="clientNotes" rows="3"></textarea>
        </label>
        <button class="settings-save" type="submit" id="clientSubmit">Save Client</button>
      </form>
    </div>
  </div>

  <div class="user-modal" id="deleteClientModal" aria-hidden="true">
    <div class="confirm-card">
      <h2>Delete client?</h2>
      <div class="confirm-actions">
        <button type="button" id="deleteClientYes">Yes</button>
        <button type="button" id="deleteClientNo">No</button>
      </div>
    </div>
  </div>

  <script>
    const locationOptions = <%- JSON.stringify(locationOptions) %>;
    let clients = [];
    let currentPage = 1;
    let totalPages = 1;
    let pendingDeleteId = null;

    const tableBody = document.getElementById('clientsTableBody');
    const clientSearch = document.getElementById('clientSearch');
    const statusFilter = document.getElementById('statusFilter');
    const countryFilter = document.getElementById('countryFilter');
    const stateFilter = document.getElementById('stateFilter');
    const cityFilter = document.getElementById('cityFilter');
    const pageInfo = document.getElementById('pageInfo');
    const prevPage = document.getElementById('prevPage');
    const nextPage = document.getElementById('nextPage');

    function debounce(fn, delay) {
      let timer;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => fn(...args), delay);
      };
    }

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
    }

    function optionList(items, emptyLabel) {
      return `<option value="">${emptyLabel}</option>` + items
        .map((item) => `<option value="${escapeHtml(item)}">${escapeHtml(item)}</option>`)
        .join('');
    }

    function updateStateOptions(selectedState) {
      const country = document.getElementById('clientCountry').value;
      const states = country && locationOptions.tree[country] ? Object.keys(locationOptions.tree[country]) : [];
      const stateSelect = document.getElementById('clientState');
      stateSelect.innerHTML = optionList(states, 'Select State');
      if (selectedState) stateSelect.value = selectedState;
      updateCityOptions();
    }

    function updateCityOptions(selectedCity) {
      const country = document.getElementById('clientCountry').value;
      const state = document.getElementById('clientState').value;
      const cities = country && state && locationOptions.tree[country] && locationOptions.tree[country][state]
        ? locationOptions.tree[country][state]
        : [];
      const citySelect = document.getElementById('clientCity');
      citySelect.innerHTML = optionList(cities, 'Select City');
      if (selectedCity) citySelect.value = selectedCity;
    }

    function renderLocationOptions() {
      document.getElementById('clientCountry').innerHTML = optionList(locationOptions.countries, 'Select Country');
      updateStateOptions();
    }

    function updateFilterStates(selectedState) {
      const country = countryFilter.value;
      const states = country && locationOptions.tree[country] ? Object.keys(locationOptions.tree[country]) : locationOptions.states;
      stateFilter.innerHTML = optionList(states, 'All States');
      if (selectedState) stateFilter.value = selectedState;
      updateFilterCities();
    }

    function updateFilterCities(selectedCity) {
      const country = countryFilter.value;
      const state = stateFilter.value;
      let cities = locationOptions.cities;
      if (country && state && locationOptions.tree[country] && locationOptions.tree[country][state]) {
        cities = locationOptions.tree[country][state];
      } else if (country && locationOptions.tree[country]) {
        cities = [...new Set(Object.values(locationOptions.tree[country]).flat())];
      }
      cityFilter.innerHTML = optionList(cities, 'All Cities');
      if (selectedCity) cityFilter.value = selectedCity;
    }

    function renderFilterOptions() {
      countryFilter.innerHTML = optionList(locationOptions.countries, 'All Countries');
      updateFilterStates();
      updateFilterCities();
    }

    function clientLocation(client) {
      return [client.city, client.state].filter(Boolean).join(', ') || '-';
    }

    async function loadClients(page = 1) {
      const params = new URLSearchParams({
        format: 'json',
        page,
        limit: 10,
        search: clientSearch.value.trim(),
        status: statusFilter.value,
        country: countryFilter.value,
        state: stateFilter.value,
        city: cityFilter.value,
      });
      const response = await fetch(`/clients?${params.toString()}`, { headers: { Accept: 'application/json' } });
      const data = await response.json();
      if (!data.success) {
        tableBody.innerHTML = `<tr><td colspan="8">${escapeHtml(data.message || 'Unable to load clients')}</td></tr>`;
        return;
      }
      clients = data.clients || [];
      currentPage = data.pagination.page;
      totalPages = data.pagination.totalPages;
      renderClients();
    }

    function renderClients() {
      if (!clients.length) {
        tableBody.innerHTML = '<tr><td colspan="8">No clients found</td></tr>';
      } else {
        tableBody.innerHTML = clients.map((client) => `
          <tr>
            <td>#${client.id}</td>
            <td>
              <strong>${escapeHtml(client.name)}</strong>
              <span class="vendor-subtext">${escapeHtml(client.email)}</span>
            </td>
            <td>${escapeHtml(client.phone)}</td>
            <td>${escapeHtml(clientLocation(client))}</td>
            <td>${escapeHtml(client.age || '-')}</td>
            <td>${escapeHtml(client.gender || '-')}</td>
            <td><span class="user-status-pill ${client.status === 'active' ? 'active' : 'inactive'}">${escapeHtml(client.status)}</span></td>
            <td>
              <div class="user-actions">
                <button type="button" onclick="toggleClientStatus(${client.id})">${client.status === 'active' ? 'Deactivate' : 'Active'}</button>
                <button type="button" onclick="openEditClient(${client.id})">Edit</button>
                <button type="button" onclick="askDeleteClient(${client.id})">Delete</button>
              </div>
            </td>
          </tr>
        `).join('');
      }

      pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
      prevPage.disabled = currentPage <= 1;
      nextPage.disabled = currentPage >= totalPages;
    }

    function openClientModal() {
      document.getElementById('clientModal').classList.add('active');
    }

    function closeClientModal() {
      document.getElementById('clientModal').classList.remove('active');
    }

    function resetClientForm() {
      document.getElementById('clientForm').reset();
      document.getElementById('clientId').value = '';
      document.getElementById('clientPassword').required = true;
      document.getElementById('clientModalTitle').textContent = 'Add Client';
      document.getElementById('clientSubmit').textContent = 'Save Client';
      renderLocationOptions();
    }

    function openAddClient() {
      resetClientForm();
      openClientModal();
    }

    function openEditClient(id) {
      const client = clients.find((item) => item.id === id);
      if (!client) return;
      document.getElementById('clientId').value = client.id;
      document.getElementById('clientName').value = client.name;
      document.getElementById('clientEmail').value = client.email;
      document.getElementById('clientPhone').value = client.phone;
      document.getElementById('clientPassword').value = '';
      document.getElementById('clientPassword').required = false;
      document.getElementById('clientStatus').value = client.status;
      document.getElementById('clientAge').value = client.age || '';
      document.getElementById('clientGender').value = client.gender || '';
      document.getElementById('clientCountry').value = client.country || '';
      updateStateOptions(client.state || '');
      updateCityOptions(client.city || '');
      document.getElementById('clientAddress').value = client.address || '';
      document.getElementById('clientNotes').value = client.notes || '';
      document.getElementById('clientModalTitle').textContent = 'Edit Client';
      document.getElementById('clientSubmit').textContent = 'Update Client';
      openClientModal();
    }

    async function toggleClientStatus(id) {
      const client = clients.find((item) => item.id === id);
      if (!client) return;
      const nextStatus = client.status === 'active' ? 'inactive' : 'active';
      const response = await fetch(`/clients/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: nextStatus }),
      });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to update client status');
        return;
      }
      loadClients(currentPage);
    }

    function askDeleteClient(id) {
      pendingDeleteId = id;
      document.getElementById('deleteClientModal').classList.add('active');
    }

    async function deleteClient() {
      if (!pendingDeleteId) return;
      const id = pendingDeleteId;
      pendingDeleteId = null;
      document.getElementById('deleteClientModal').classList.remove('active');
      const response = await fetch(`/clients/${id}`, { method: 'DELETE' });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to delete client');
        return;
      }
      loadClients(currentPage);
    }

    document.getElementById('clientForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = document.getElementById('clientId').value;
      const payload = {
        name: document.getElementById('clientName').value,
        email: document.getElementById('clientEmail').value,
        phone: document.getElementById('clientPhone').value,
        password: document.getElementById('clientPassword').value,
        status: document.getElementById('clientStatus').value,
        age: document.getElementById('clientAge').value,
        gender: document.getElementById('clientGender').value,
        country: document.getElementById('clientCountry').value,
        state: document.getElementById('clientState').value,
        city: document.getElementById('clientCity').value,
        address: document.getElementById('clientAddress').value,
        notes: document.getElementById('clientNotes').value,
      };
      if (id && !payload.password) delete payload.password;

      const response = await fetch(`/clients${id ? `/${id}` : ''}`, {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || (data.errors || []).join(', ') || 'Unable to save client');
        return;
      }
      closeClientModal();
      resetClientForm();
      loadClients(id ? currentPage : 1);
    });

    document.getElementById('addClientButton').addEventListener('click', openAddClient);
    document.getElementById('clientCountry').addEventListener('change', () => updateStateOptions());
    document.getElementById('clientState').addEventListener('change', () => updateCityOptions());
    document.getElementById('deleteClientYes').addEventListener('click', deleteClient);
    document.getElementById('deleteClientNo').addEventListener('click', () => {
      pendingDeleteId = null;
      document.getElementById('deleteClientModal').classList.remove('active');
    });
    clientSearch.addEventListener('input', debounce(() => loadClients(1), 300));
    statusFilter.addEventListener('change', () => loadClients(1));
    countryFilter.addEventListener('change', () => {
      updateFilterStates();
      updateFilterCities();
      loadClients(1);
    });
    stateFilter.addEventListener('change', () => {
      updateFilterCities();
      loadClients(1);
    });
    cityFilter.addEventListener('change', () => loadClients(1));
    document.getElementById('clearClientFilters').addEventListener('click', () => {
      clientSearch.value = '';
      statusFilter.value = '';
      countryFilter.value = '';
      updateFilterStates();
      updateFilterCities();
      loadClients(1);
    });
    prevPage.addEventListener('click', () => loadClients(currentPage - 1));
    nextPage.addEventListener('click', () => loadClients(currentPage + 1));

    renderLocationOptions();
    renderFilterOptions();
    loadClients();
  </script>
</body>
</html>
