<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Orders</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / My Orders</p>
        <h1>My Orders</h1>
      </div>
    </header>

    <section class="vendor-management-shell">
      <div class="users-toolbar">
        <div>
          <h2>Order History</h2>
          <p>View all your orders and their current delivery status.</p>
        </div>
        <div class="vendor-toolbar-actions">
          <label>
            Status
            <select id="statusFilter">
              <option value="">All Statuses</option>
              <option value="pending">Pending</option>
              <option value="accepted">Accepted</option>
              <option value="processing">Processing</option>
              <option value="ready_for_pickup">Ready for Pickup</option>
              <option value="picked_up">Picked Up</option>
              <option value="on_the_way">On the Way</option>
              <option value="delivered">Delivered</option>
            </select>
          </label>
        </div>
      </div>

      <div class="users-table-card">
        <table class="users-table orders-table">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Date</th>
              <th>Vendor</th>
              <th>Total Amount</th>
              <th>Order Status</th>
              <th>Delivery Status</th>
              <th>Delivery Partner</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="ordersTableBody">
            <tr><td colspan="8">Loading orders...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <!-- Order Detail Modal -->
  <div class="user-modal" id="detailModal" aria-hidden="true">
    <div class="user-modal-card" style="max-width: 800px;">
      <div class="user-modal-header">
        <h2>Order Details</h2>
        <button type="button" onclick="closeDetailModal()">Close</button>
      </div>
      <div id="orderDetailContent">
        <!-- Populated dynamically -->
      </div>
    </div>
  </div>

  <!-- Invoice Preview Modal -->
  <div class="user-modal" id="invoiceModal" aria-hidden="true">
    <div class="user-modal-card invoice-modal-card">
      <div class="user-modal-header">
        <h2 id="invoiceModalTitle">Invoice</h2>
        <button type="button" onclick="closeInvoice()">Close</button>
      </div>
      <div class="invoice-toolbar">
        <button class="settings-save" type="button" onclick="printInvoice()">Print</button>
        <a class="product-secondary-button" id="invoiceDownloadLink" href="#" download>Download</a>
      </div>
      <iframe id="invoiceFrame" class="invoice-frame" title="Invoice preview"></iframe>
    </div>
  </div>

  <script>
    let orders = [];

    async function loadOrders() {
      try {
        const res = await fetch('/api/orders/client', {
          headers: { 'Accept': 'application/json' }
        });
        const data = await res.json();
        if (data.success) {
          orders = data.orders || [];
          renderOrders();
        }
      } catch (e) { console.error('Failed to load orders', e); }
    }

    function renderOrders() {
      const tbody = document.getElementById('ordersTableBody');
      const selectedStatus = document.getElementById('statusFilter')?.value || '';
      const visibleOrders = selectedStatus ? orders.filter(o => o.status === selectedStatus) : orders;
      if (!visibleOrders.length) {
        tbody.innerHTML = '<tr><td colspan="8">No orders found</td></tr>';
        return;
      }
      tbody.innerHTML = visibleOrders.map(o => `
        <tr>
          <td>${orderDisplayNumber(o)}</td>
          <td>${new Date(o.created_at).toLocaleDateString()}</td>
          <td>${o.vendor_business_name || o.vendor_name || 'N/A'}</td>
          <td>₹${Number(o.total_amount).toFixed(2)}</td>
          <td>${statusBadge(o.status, o.status_label)}</td>
          <td><span class="badge ${o.delivery_status}">${o.delivery_status.replace('_', ' ')}</span></td>
          <td>${o.delivery_partner_name || 'Not assigned'}</td>
          <td>
            <button class="product-secondary-button" style="padding: 4px 8px; font-size: 12px;" onclick="viewDetails(${o.id})">View Details</button>
            <button class="product-secondary-button" style="padding: 4px 8px; font-size: 12px;" onclick="openInvoice(${o.id})">Invoice</button>
          </td>
        </tr>
      `).join('');
    }

    function statusLabel(status) {
      const labels = {
        pending: 'Pending',
        accepted: 'Accepted',
        processing: 'Processing',
        ready_for_pickup: 'Ready for Pickup',
        picked_up: 'Picked Up',
        on_the_way: 'On the Way',
        delivered: 'Delivered',
      };
      return labels[status] || String(status || '').replaceAll('_', ' ');
    }

    function statusBadge(status, label) {
      return `<span class="order-status-badge ${status}">${label || statusLabel(status)}</span>`;
    }

    function orderDisplayNumber(order) {
      return order.order_number || order.orderNumber || String(order.id || '').padStart(10, '0');
    }

    function renderTimeline(history = []) {
      if (!history.length) return '<p>No status history yet.</p>';
      return `<ol class="order-timeline">${history.map(item => `
        <li>
          <strong>${item.new_status_label || statusLabel(item.new_status)}</strong>
          <span>${new Date(item.created_at).toLocaleString()}</span>
          <small>${item.changed_by_name || 'System'}</small>
        </li>
      `).join('')}</ol>`;
    }

    async function viewDetails(orderId) {
      try {
        const res = await fetch(`/api/orders/client/${orderId}`, {
          headers: { 'Accept': 'application/json' }
        });
        const data = await res.json();
        if (data.success) {
          const order = data.order;
          const items = data.items || [];
          const history = data.history || [];
          const content = document.getElementById('orderDetailContent');
          content.innerHTML = `
            <div style="margin-bottom: 20px;">
              <h3>Order #${orderDisplayNumber(order)}</h3>
              <p>
                <button class="product-secondary-button" type="button" onclick="openInvoice(${order.id})">Open Invoice</button>
              </p>
              <p><strong>Vendor:</strong> ${order.vendor_business_name || order.vendor_name || 'N/A'}</p>
              <p><strong>Shipping Address:</strong> ${order.shipping_name || order.client_name || 'Client'} (${order.shipping_phone || order.client_phone || 'No phone'}) - ${order.shipping_address || order.client_address || 'No shipping address'}</p>
              <p><strong>Subtotal:</strong> ₹${Number(order.subtotal_amount || order.total_amount).toFixed(2)}</p>
              <p><strong>Discount:</strong> ₹${Number(order.discount_amount || 0).toFixed(2)} ${order.coupon_code ? `(${order.coupon_code})` : order.discount_label ? `(${order.discount_label})` : ''}</p>
              <p><strong>Delivery Charge:</strong> ₹${Number(order.delivery_charge || 0).toFixed(2)}</p>
              <p><strong>Platform Fee:</strong> ₹${Number(order.platform_fee || 0).toFixed(2)}</p>
              <p><strong>Grand Total:</strong> ₹${Number(order.total_amount).toFixed(2)}</p>
              <p><strong>Order Status:</strong> ${order.status}</p>
              <p><strong>Delivery Status:</strong> ${order.delivery_status}</p>
              <p><strong>Delivery Partner:</strong> ${order.delivery_partner_name || 'Not assigned'}</p>
              <p><strong>Delivery OTP:</strong> ${order.delivery_otp || '-'}</p>
              ${order.otp_set_by_name ? `<p><strong>OTP Set By:</strong> ${order.otp_set_by_name} (${order.otp_set_by_role || 'staff'})</p>` : ''}
              ${order.otp_set_at ? `<p><strong>OTP Set At:</strong> ${new Date(order.otp_set_at).toLocaleString()}</p>` : ''}
              ${order.assigned_at ? `<p><strong>Assigned At:</strong> ${new Date(order.assigned_at).toLocaleString()}</p>` : ''}
              ${order.ready_at ? `<p><strong>Ready At:</strong> ${new Date(order.ready_at).toLocaleString()}</p>` : ''}
              ${order.delivered_at ? `<p><strong>Delivered At:</strong> ${new Date(order.delivered_at).toLocaleString()}</p>` : ''}
            <h4>Status Timeline</h4>
            ${renderTimeline(history)}
            <h4>Order Items</h4>
            <table class="users-table">
              <thead><tr><th>#</th><th>Product</th><th>Quantity</th><th>Unit Price</th><th>Total</th></tr></thead>
              <tbody>
                ${items.map((item, i) => `
                  <tr>
                    <td>${i+1}</td>
                    <td>${item.product_name}</td>
                    <td>${item.quantity}</td>
                    <td>₹${Number(item.unit_price).toFixed(2)}</td>
                    <td>₹${Number(item.line_total).toFixed(2)}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
          `;
          document.getElementById('detailModal').style.display = 'flex';
          document.getElementById('detailModal').setAttribute('aria-hidden', 'false');
        }
      } catch (e) { alert('Failed to load order details'); console.error(e); }
    }

    function closeDetailModal() {
      document.getElementById('detailModal').style.display = 'none';
      document.getElementById('detailModal').setAttribute('aria-hidden', 'true');
    }

    function openInvoice(orderId) {
      const viewUrl = `/orders/client/${orderId}/invoice?disposition=inline`;
      const downloadUrl = `/orders/client/${orderId}/invoice?download=1`;
      document.getElementById('invoiceModalTitle').textContent = `Invoice #${orderId}`;
      document.getElementById('invoiceFrame').src = viewUrl;
      document.getElementById('invoiceDownloadLink').href = downloadUrl;
      document.getElementById('invoiceModal').style.display = 'flex';
      document.getElementById('invoiceModal').setAttribute('aria-hidden', 'false');
    }

    function closeInvoice() {
      document.getElementById('invoiceModal').style.display = 'none';
      document.getElementById('invoiceModal').setAttribute('aria-hidden', 'true');
      document.getElementById('invoiceFrame').src = 'about:blank';
    }

    function printInvoice() {
      const frame = document.getElementById('invoiceFrame');
      frame.contentWindow?.focus();
      frame.contentWindow?.print();
    }

    document.getElementById('statusFilter')?.addEventListener('change', renderOrders);

    // Initial load
    loadOrders();
    setInterval(loadOrders, 30000);
  </script>
  <style>
    .order-status-badge { display: inline-block; padding: 5px 9px; border-radius: 999px; color: #fff; font-weight: 800; font-size: 0.8rem; text-transform: capitalize; }
    .order-status-badge.pending { background: #64748b; }
    .order-status-badge.accepted { background: #2563eb; }
    .order-status-badge.processing { background: #7c3aed; }
    .order-status-badge.ready_for_pickup { background: #f59e0b; }
    .order-status-badge.picked_up, .order-status-badge.on_the_way { background: #0891b2; }
    .order-status-badge.delivered { background: #16a34a; }
    .order-timeline { display: grid; gap: 10px; padding-left: 20px; }
    .order-timeline li strong { display: block; color: #263238; }
    .order-timeline li span, .order-timeline li small { display: block; color: #64748b; }
    .invoice-modal-card { width: min(96vw, 980px); max-width: 980px; height: 90vh; display: flex; flex-direction: column; }
    .invoice-toolbar { display: flex; justify-content: flex-end; gap: 10px; margin-bottom: 12px; }
    .invoice-frame { flex: 1; width: 100%; min-height: 520px; border: 1px solid #d8dee6; border-radius: 6px; background: #fff; }
  </style>
</body>
</html>
