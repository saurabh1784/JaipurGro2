<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= dashboard.roleTitle %> Dashboard</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>
  <% const vendorQuotationNotice = (dashboard.notifications || []).find((notification) => notification.href === '/vendor/quotations'); %>
  <% const money = (value) => `INR ${Number(value || 0).toFixed(2)}`; %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / <%= dashboard.roleTitle %></p>
        <h1><%= dashboard.roleTitle %> Dashboard</h1>
      </div>
      <div class="topbar-actions">
        <label class="system-search" aria-label="Search dashboard">
          <input type="search" placeholder="Search" />
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/></svg>
        </label>
        <button class="icon-button" type="button" aria-label="Apps">
          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="6" height="6" rx="1"/><rect x="14" y="4" width="6" height="6" rx="1"/><rect x="4" y="14" width="6" height="6" rx="1"/><rect x="14" y="14" width="6" height="6" rx="1"/></svg>
        </button>
        <button class="icon-button alert" type="button" aria-label="Notifications">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9"/><path d="M10 20h4"/></svg>
        </button>
        <button class="icon-button" type="button" aria-label="Account">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
        </button>
      </div>
    </header>

    <% if (error) { %>
      <div class="system-alert"><%= error %></div>
    <% } %>

    <% if (dashboard.notifications && dashboard.notifications.length) { %>
      <section class="dashboard-notifications" aria-label="Notifications">
        <% dashboard.notifications.forEach((notification) => { %>
          <a href="<%= notification.href %>" class="dashboard-notification">
            <span><%= notification.message %></span>
            <strong><%= notification.count %></strong>
          </a>
        <% }) %>
      </section>
    <% } %>

    <% if (dashboard.vendorStats) { %>
      <section class="vendor-quotation-summary" aria-label="Vendor quotation summary">
        <% dashboard.vendorStats.quotations.forEach((stat) => { %>
          <a class="vendor-quote-stat <%= stat.tone %>" href="/vendor/quotations">
            <span><%= stat.label %> Quotations</span>
            <strong><%= stat.count %></strong>
            <small><%= money(stat.amount) %></small>
          </a>
        <% }) %>
        <article class="vendor-health-card <%= dashboard.vendorStats.accountHealth.tone %>">
          <div class="vendor-health-header">
            <span>Account Health</span>
            <strong><%= dashboard.vendorStats.accountHealth.score %>%</strong>
          </div>
          <div class="vendor-health-track" aria-hidden="true">
            <span style="width: <%= dashboard.vendorStats.accountHealth.score %>%"></span>
          </div>
          <p><%= dashboard.vendorStats.accountHealth.activeProducts %> active products / minimum <%= dashboard.vendorStats.accountHealth.minimum %></p>
        </article>
      </section>
    <% } %>

    <% if (dashboard.supportSummary) { %>
      <section class="support-dashboard-card">
        <div>
          <span>Support</span>
          <h2><%= dashboard.supportSummary.openTicket ? `Ticket #${dashboard.supportSummary.openTicket.id} is Open` : 'No open support ticket' %></h2>
          <p><%= dashboard.supportSummary.openTicket ? dashboard.supportSummary.openTicket.subject : `${dashboard.supportSummary.total} total ticket${dashboard.supportSummary.total === 1 ? '' : 's'}` %></p>
        </div>
        <a class="settings-save" href="<%= dashboard.supportSummary.href %>">Open Support</a>
      </section>
      <% if (dashboard.supportTickets && dashboard.supportTickets.length) { %>
        <section class="support-ticket-strip">
          <% dashboard.supportTickets.forEach((ticket) => { %>
            <a href="<%= dashboard.supportSummary.href %>" class="support-ticket-chip">
              <span class="<%= ticket.status === 'Open' ? 'open' : 'closed' %>"><%= ticket.status %></span>
              <strong>#<%= ticket.id %> <%= ticket.subject %></strong>
              <small><%= ticket.message_count %> message<%= ticket.message_count === 1 ? '' : 's' %></small>
            </a>
          <% }) %>
        </section>
      <% } %>
    <% } %>

    <section class="metric-grid" aria-label="Role dashboard metrics">
      <% dashboard.metrics.forEach((metric) => { %>
        <article class="metric-card">
          <div class="metric-icon <%= metric.tone %>">
            <% if (metric.icon === 'users') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg>
            <% } else if (metric.icon === 'revenue') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v18M7 8h10M9 13h6"/></svg>
            <% } else if (metric.icon === 'alerts') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8"/><path d="M12 8v5M12 16h.01"/></svg>
            <% } else if (metric.icon === 'orders') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h14v16H5z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>
            <% } else if (metric.icon === 'products') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 7h11v13H8z"/><path d="M5 4h11v13"/></svg>
            <% } else { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 18h14M7 15l3-6 4 4 3-8"/></svg>
            <% } %>
          </div>
          <span class="metric-label"><%= metric.label %></span>
          <strong><%= metric.value %></strong>
          <p><%= metric.note %></p>
        </article>
      <% }) %>
    </section>

    <section class="chart-grid" aria-label="Role charts">
      <% dashboard.charts.forEach((chart) => { %>
        <article class="panel chart-panel <%= chart.tone %>">
          <div class="chart-card">
            <% if (chart.type === 'bars') { %>
              <div class="bar-chart" aria-hidden="true">
                <% [46, 70, 42, 82, 55, 76, 48, 66, 58, 73, 88, 95].forEach((height) => { %>
                  <span style="height: <%= height %>%"></span>
                <% }) %>
              </div>
            <% } else if (chart.type === 'line-down') { %>
              <svg viewBox="0 0 320 120" aria-hidden="true">
                <path class="grid-line" d="M10 25H310M10 55H310M10 85H310"/>
                <path class="line-chart" d="M22 90L61 18L100 58L139 68L178 72L217 76L256 79L298 82"/>
              </svg>
            <% } else { %>
              <svg viewBox="0 0 320 120" aria-hidden="true">
                <path class="grid-line" d="M10 25H310M10 55H310M10 85H310"/>
                <path class="line-chart" d="M22 80L61 63L100 77L139 58L178 48L217 59L256 39L298 13"/>
              </svg>
            <% } %>
          </div>
          <h2><%= chart.title %></h2>
          <p><%= chart.subtitle %></p>
          <span><%= chart.footer %></span>
        </article>
      <% }) %>
    </section>

    <section class="work-grid">
      <article class="panel tasks-panel">
        <div class="panel-header purple-header">
          <h2>Tasks</h2>
          <div class="tabs" aria-label="Permission summary">
            <% dashboard.permissions.slice(0, 3).forEach((permission) => { %>
              <button type="button"><%= permission %></button>
            <% }) %>
          </div>
        </div>
        <ul class="task-list">
          <% dashboard.tasks.forEach((task, index) => { %>
            <li>
              <input type="checkbox" <%= index === 0 || index === 3 ? 'checked' : '' %> aria-label="Complete task" />
              <span><%= task %></span>
              <a href="#" aria-label="Edit task">Edit</a>
              <a href="#" aria-label="Remove task">Remove</a>
            </li>
          <% }) %>
        </ul>
      </article>

      <article class="panel employees-panel">
        <div class="panel-header orange-header">
          <h2>Team Stats</h2>
          <p>Visible for <%= dashboard.roleTitle %> access</p>
        </div>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Salary</th>
              <th>Role</th>
            </tr>
          </thead>
          <tbody>
            <% dashboard.employees.forEach((employee) => { %>
              <tr>
                <td><%= employee.id %></td>
                <td><%= employee.name %></td>
                <td><%= employee.salary %></td>
                <td><%= employee.country %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </article>
    </section>
  </main>
  <style>
    .dashboard-notifications {
      display: grid;
      gap: 10px;
      margin-bottom: 18px;
    }

    .dashboard-notification {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 16px;
      border-radius: 8px;
      background: #fff7ed;
      color: #9a3412;
      border: 1px solid #fed7aa;
      text-decoration: none;
      font-weight: 800;
    }

    .dashboard-notification strong {
      display: grid;
      place-items: center;
      min-width: 28px;
      height: 28px;
      border-radius: 999px;
      background: #ea580c;
      color: #fff;
      padding: 0 8px;
    }

    .theme-dark .dashboard-notification {
      background: #332114;
      border-color: #7c2d12;
      color: #fed7aa;
    }

    .vendor-quotation-summary {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 18px;
    }

    .support-dashboard-card {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      padding: 16px 18px;
      margin-bottom: 14px;
      background: #eef9fb;
      border: 1px solid #bae6fd;
      border-radius: 8px;
    }

    .support-dashboard-card span {
      color: #0891b2;
      font-weight: 900;
      text-transform: uppercase;
      font-size: 0.78rem;
    }

    .support-dashboard-card h2 {
      margin: 4px 0;
      color: #0f172a;
    }

    .support-dashboard-card p {
      margin: 0;
      color: #475569;
    }

    .support-ticket-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px;
      margin-bottom: 18px;
    }

    .support-ticket-chip {
      display: grid;
      gap: 6px;
      padding: 12px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      background: #fff;
      color: inherit;
      text-decoration: none;
    }

    .support-ticket-chip span {
      justify-self: start;
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 0.76rem;
      font-weight: 900;
    }

    .support-ticket-chip span.open {
      background: #dcfce7;
      color: #166534;
    }

    .support-ticket-chip span.closed {
      background: #e2e8f0;
      color: #334155;
    }

    .vendor-quote-stat,
    .vendor-health-card {
      display: grid;
      gap: 8px;
      padding: 16px;
      border-radius: 8px;
      background: #fff;
      border: 1px solid #e2e8f0;
      text-decoration: none;
      color: #263238;
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
    }

    .vendor-quote-stat span,
    .vendor-health-header span {
      color: #64748b;
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .vendor-quote-stat strong,
    .vendor-health-header strong {
      color: #0f172a;
      font-size: 1.8rem;
      line-height: 1;
    }

    .vendor-quote-stat small,
    .vendor-health-card p {
      margin: 0;
      color: #475569;
      font-weight: 800;
    }

    .vendor-quote-stat.pending { border-top: 4px solid #f59e0b; }
    .vendor-quote-stat.processed { border-top: 4px solid #16a34a; }
    .vendor-quote-stat.rejected { border-top: 4px solid #dc2626; }

    .vendor-health-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .vendor-health-track {
      height: 12px;
      overflow: hidden;
      border-radius: 999px;
      background: #e2e8f0;
    }

    .vendor-health-track span {
      display: block;
      height: 100%;
      border-radius: inherit;
      transition: width 0.25s ease;
    }

    .vendor-health-card.low .vendor-health-track span { background: #dc2626; }
    .vendor-health-card.fair .vendor-health-track span { background: #f59e0b; }
    .vendor-health-card.good .vendor-health-track span { background: #16a34a; }
    .vendor-health-card.low { border-top: 4px solid #dc2626; }
    .vendor-health-card.fair { border-top: 4px solid #f59e0b; }
    .vendor-health-card.good { border-top: 4px solid #16a34a; }

    .theme-dark .vendor-quote-stat,
    .theme-dark .vendor-health-card {
      background: #172033;
      border-color: #334155;
      color: #f8fafc;
    }

    .theme-dark .vendor-quote-stat strong,
    .theme-dark .vendor-health-header strong {
      color: #f8fafc;
    }

    @media (max-width: 980px) {
      .vendor-quotation-summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 620px) {
      .vendor-quotation-summary {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <% if (user.role === 'Vendor') { %>
    <script>
      const currentVendorQuotationNotice = <%= vendorQuotationNotice ? Number(vendorQuotationNotice.count || 0) : 0 %>;

      async function refreshVendorQuotationNotice() {
        try {
          const response = await fetch('/vendor/quotations?format=json&peek=1', {
            headers: { Accept: 'application/json' },
          });
          const data = await response.json();
          if (!response.ok || !data.success) return;

          const newQuotationCount = data.quotations.filter((quotation) => quotation.recipient_status === 'new').length;
          if (newQuotationCount > currentVendorQuotationNotice) {
            location.reload();
          }
        } catch (error) {
          console.error('Vendor quotation dashboard refresh failed:', error);
        }
      }

      setInterval(refreshVendorQuotationNotice, 15000);
    </script>
  <% } %>
</body>
</html>
