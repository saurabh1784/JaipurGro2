<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= dashboard.roleTitle %> Dashboard</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>
  <% const vendorQuotationNotice = (dashboard.notifications || []).find((notification) => notification.href === '/vendor/quotations'); %>
  <% const money = (value) => `INR ${Number(value || 0).toFixed(2)}`; %>
  <% const clientLiveQuotations = dashboard.clientLiveQuotations || []; %>
  <% const vendorNewOrders = dashboard.vendorNewOrders || []; %>
  <% const vendorNewQuotations = dashboard.vendorNewQuotations || []; %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / <%= dashboard.roleTitle %></p>
        <h1><%= dashboard.roleTitle %> Dashboard</h1>
      </div>
      <div class="topbar-actions">
        <label class="system-search" aria-label="Search dashboard">
          <input type="search" placeholder="Search" />
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/></svg>
        </label>
        <button class="icon-button" type="button" aria-label="Apps">
          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="6" height="6" rx="1"/><rect x="14" y="4" width="6" height="6" rx="1"/><rect x="4" y="14" width="6" height="6" rx="1"/><rect x="14" y="14" width="6" height="6" rx="1"/></svg>
        </button>
        <button class="icon-button alert" type="button" aria-label="Notifications">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9"/><path d="M10 20h4"/></svg>
        </button>
        <button class="icon-button" type="button" aria-label="Account">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
        </button>
      </div>
    </header>

    <% if (error) { %>
      <div class="system-alert"><%= error %></div>
    <% } %>

    <% if (typeof message !== 'undefined' && message) { %>
      <div class="system-alert system-alert-success"><%= message %></div>
    <% } %>

    <% if (dashboard.notifications && dashboard.notifications.length) { %>
      <section class="dashboard-notifications" aria-label="Notifications">
        <% dashboard.notifications.forEach((notification) => { %>
          <a href="<%= notification.href %>" class="dashboard-notification">
            <span><%= notification.message %></span>
            <strong><%= notification.count %></strong>
          </a>
        <% }) %>
      </section>
    <% } %>

    <% if (user.role === 'Client') { %>
      <section class="client-live-bid-home-card" id="clientLiveBidHomeCard" aria-live="polite" hidden>
        <button class="client-live-bid-close" type="button" id="clientLiveBidHomeClose" aria-label="Hide live bid card">x</button>
        <div class="client-live-bid-copy">
          <span id="clientLiveBidStatus">Active bidding</span>
          <h2 id="clientLiveBidTitle">Live Bid</h2>
          <p id="clientLiveBidVendor">Vendor response</p>
        </div>
        <div class="client-live-bid-metrics">
          <div>
            <span>Base Price</span>
            <strong id="clientLiveBidBase">INR 0.00</strong>
          </div>
          <div>
            <span>Bid Price</span>
            <strong id="clientLiveBidPrice">INR 0.00</strong>
          </div>
          <div>
            <span>Saving</span>
            <strong id="clientLiveBidSaving">INR 0.00</strong>
          </div>
        </div>
        <a class="client-live-bid-link" id="clientLiveBidLink" href="/client/quotations">Open Quotation</a>
      </section>
    <% } %>

    <% if (user.role === 'Vendor') { %>
      <section class="vendor-new-order-card" id="vendorNewOrderCard" aria-live="polite" hidden>
        <div class="vendor-new-order-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M6 7h12l-1 14H7z"/><path d="M9 7a3 3 0 0 1 6 0"/></svg>
        </div>
        <div class="vendor-new-order-copy">
          <span id="vendorNewOrderStatus">New order found</span>
          <h2 id="vendorNewOrderTitle">Order #</h2>
          <p id="vendorNewOrderMeta">Client order request</p>
        </div>
        <div class="vendor-new-order-metrics">
          <div>
            <span>Order Amount</span>
            <strong id="vendorNewOrderAmount">INR 0.00</strong>
          </div>
          <div>
            <span>Order Type</span>
            <strong id="vendorNewOrderType">Direct</strong>
          </div>
          <div>
            <span>Status</span>
            <strong id="vendorNewOrderState">Pending</strong>
          </div>
        </div>
        <a class="vendor-new-order-link" id="vendorNewOrderLink" href="/orders/vendor">Open Order</a>
      </section>

      <section class="vendor-new-quotation-card" id="vendorNewQuotationCard" aria-live="polite" hidden>
        <div class="vendor-new-quotation-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M6 3h12v18H6z"/><path d="M9 8h6M9 12h6M9 16h4"/></svg>
        </div>
        <div class="vendor-new-quotation-copy">
          <span id="vendorNewQuotationStatus">New quotation found</span>
          <h2 id="vendorNewQuotationTitle">Quotation #</h2>
          <p id="vendorNewQuotationMeta">Client quotation request</p>
        </div>
        <div class="vendor-new-quotation-metrics">
          <div>
            <span>Base Price</span>
            <strong id="vendorNewQuotationBase">INR 0.00</strong>
          </div>
          <div>
            <span>Minimum Bid</span>
            <strong id="vendorNewQuotationBid">No bids yet</strong>
          </div>
          <div>
            <span>Items</span>
            <strong id="vendorNewQuotationItems">0</strong>
          </div>
        </div>
        <a class="vendor-new-quotation-link" id="vendorNewQuotationLink" href="/vendor/quotations">Open Quotation</a>
      </section>
    <% } %>

    <% if (dashboard.vendorStats) { %>
      <section class="vendor-quotation-summary" aria-label="Vendor quotation summary">
        <% dashboard.vendorStats.quotations.forEach((stat) => { %>
          <a class="vendor-quote-stat <%= stat.tone %>" href="/vendor/quotations">
            <span><%= stat.label %> Quotations</span>
            <strong><%= stat.count %></strong>
            <small><%= money(stat.amount) %></small>
          </a>
        <% }) %>
        <article class="vendor-health-card <%= dashboard.vendorStats.accountHealth.tone %>">
          <div class="vendor-health-header">
            <span>Account Health</span>
            <strong><%= dashboard.vendorStats.accountHealth.score %>%</strong>
          </div>
          <div class="vendor-health-track" aria-hidden="true">
            <span style="width: <%= dashboard.vendorStats.accountHealth.score %>%"></span>
          </div>
          <p><%= dashboard.vendorStats.accountHealth.activeProducts %> active products / minimum <%= dashboard.vendorStats.accountHealth.minimum %></p>
        </article>
      </section>
    <% } %>

    <% if (dashboard.supportSummary) { %>
      <section class="support-dashboard-card">
        <div>
          <span>Support</span>
          <h2><%= dashboard.supportSummary.openTicket ? `Ticket #${dashboard.supportSummary.openTicket.id} is Open` : 'No open support ticket' %></h2>
          <p><%= dashboard.supportSummary.openTicket ? dashboard.supportSummary.openTicket.subject : `${dashboard.supportSummary.total} total ticket${dashboard.supportSummary.total === 1 ? '' : 's'}` %></p>
        </div>
        <a class="settings-save" href="<%= dashboard.supportSummary.href %>">Open Support</a>
      </section>
      <% if (dashboard.supportTickets && dashboard.supportTickets.length) { %>
        <section class="support-ticket-strip">
          <% dashboard.supportTickets.forEach((ticket) => { %>
            <a href="<%= dashboard.supportSummary.href %>" class="support-ticket-chip">
              <span class="<%= ticket.status === 'Open' ? 'open' : 'closed' %>"><%= ticket.status %></span>
              <strong>#<%= ticket.id %> <%= ticket.subject %></strong>
              <small><%= ticket.message_count %> message<%= ticket.message_count === 1 ? '' : 's' %></small>
            </a>
          <% }) %>
        </section>
      <% } %>
    <% } %>

    <% if (dashboard.catalogStats) { %>

      <section class="dashboard-catalog-card" aria-label="Product Data Summary">
        <div class="catalog-summary-header">
          <div class="catalog-summary-badge">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <div class="catalog-summary-text">
            <h2>Product & Catalog Overview</h2>
            <p>Live total counts for Main Categories, SubCategories, Brands, and Products</p>
          </div>
          <a href="/products" class="catalog-manage-btn">
            Manage Products
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="catalog-stats-grid">
          <div class="catalog-stat-item green">
            <div class="catalog-stat-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h7"/></svg>
            </div>
            <div class="catalog-stat-data">
              <span>Main Categories</span>
              <strong><%= dashboard.catalogStats.categories %></strong>
              <small>Active Categories</small>
            </div>
          </div>

          <div class="catalog-stat-item blue">
            <div class="catalog-stat-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            </div>
            <div class="catalog-stat-data">
              <span>Sub Categories</span>
              <strong><%= dashboard.catalogStats.subcategories %></strong>
              <small>Catalog SubCategories</small>
            </div>
          </div>

          <div class="catalog-stat-item purple">
            <div class="catalog-stat-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 7h10v10H7z"/><path d="M12 3v4M12 17v4M3 12h4M17 12h4"/></svg>
            </div>
            <div class="catalog-stat-data">
              <span>Brands</span>
              <strong><%= dashboard.catalogStats.brands %></strong>
              <small>Registered Brands</small>
            </div>
          </div>

          <div class="catalog-stat-item orange">
            <div class="catalog-stat-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
            <div class="catalog-stat-data">
              <span>Total Products</span>
              <strong><%= dashboard.catalogStats.products %></strong>
              <small><%= dashboard.catalogStats.pendingProducts %> pending approval</small>
            </div>
          </div>
        </div>
      </section>
    <% } %>

    <section class="metric-grid" aria-label="Role dashboard metrics">

      <% dashboard.metrics.forEach((metric) => { %>
        <article class="metric-card">
          <div class="metric-icon <%= metric.tone %>">
            <% if (metric.icon === 'users') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg>
            <% } else if (metric.icon === 'revenue') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v18M7 8h10M9 13h6"/></svg>
            <% } else if (metric.icon === 'alerts') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8"/><path d="M12 8v5M12 16h.01"/></svg>
            <% } else if (metric.icon === 'orders') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h14v16H5z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>
            <% } else if (metric.icon === 'products') { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 7h11v13H8z"/><path d="M5 4h11v13"/></svg>
            <% } else { %>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 18h14M7 15l3-6 4 4 3-8"/></svg>
            <% } %>
          </div>
          <span class="metric-label"><%= metric.label %></span>
          <strong><%= metric.value %></strong>
          <p><%= metric.note %></p>
        </article>
      <% }) %>
    </section>

    <section class="chart-grid" aria-label="Role charts">
      <% dashboard.charts.forEach((chart) => { %>
        <article class="panel chart-panel <%= chart.tone %>">
          <div class="chart-card">
            <% if (chart.type === 'bars') { %>
              <div class="bar-chart" aria-hidden="true">
                <% [46, 70, 42, 82, 55, 76, 48, 66, 58, 73, 88, 95].forEach((height) => { %>
                  <span style="height: <%= height %>%"></span>
                <% }) %>
              </div>
            <% } else if (chart.type === 'line-down') { %>
              <svg viewBox="0 0 320 120" aria-hidden="true">
                <path class="grid-line" d="M10 25H310M10 55H310M10 85H310"/>
                <path class="line-chart" d="M22 90L61 18L100 58L139 68L178 72L217 76L256 79L298 82"/>
              </svg>
            <% } else { %>
              <svg viewBox="0 0 320 120" aria-hidden="true">
                <path class="grid-line" d="M10 25H310M10 55H310M10 85H310"/>
                <path class="line-chart" d="M22 80L61 63L100 77L139 58L178 48L217 59L256 39L298 13"/>
              </svg>
            <% } %>
          </div>
          <h2><%= chart.title %></h2>
          <p><%= chart.subtitle %></p>
          <span><%= chart.footer %></span>
        </article>
      <% }) %>
    </section>

    <section class="work-grid">
      <article class="panel tasks-panel">
        <div class="panel-header purple-header">
          <h2>Tasks</h2>
          <div class="tabs" aria-label="Permission summary">
            <% dashboard.permissions.slice(0, 3).forEach((permission) => { %>
              <button type="button"><%= permission %></button>
            <% }) %>
          </div>
        </div>
        <ul class="task-list">
          <% dashboard.tasks.forEach((task, index) => { %>
            <li>
              <input type="checkbox" <%= index === 0 || index === 3 ? 'checked' : '' %> aria-label="Complete task" />
              <span><%= task %></span>
              <a href="#" aria-label="Edit task">Edit</a>
              <a href="#" aria-label="Remove task">Remove</a>
            </li>
          <% }) %>
        </ul>
      </article>

      <article class="panel employees-panel">
        <div class="panel-header orange-header">
          <h2>Team Stats</h2>
          <p>Visible for <%= dashboard.roleTitle %> access</p>
        </div>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Status</th>
              <th>Role</th>
            </tr>
          </thead>
          <tbody>
            <% dashboard.employees.forEach((employee) => { %>
              <tr>
                <td><%= employee.id %></td>
                <td><%= employee.name %></td>
                <td><%= employee.salary %></td>
                <td><%= employee.country %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </article>
    </section>
  </main>
  <style>
    .system-alert-success {
      background: #ecfdf5;
      color: #047857;
      border-color: #a7f3d0;
    }

    .dashboard-notifications {
      display: grid;
      gap: 10px;
      margin-bottom: 18px;
    }

    .dashboard-notification {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 16px;
      border-radius: 8px;
      background: #fff7ed;
      color: #9a3412;
      border: 1px solid #fed7aa;
      text-decoration: none;
      font-weight: 800;
    }

    .dashboard-notification strong {
      display: grid;
      place-items: center;
      min-width: 28px;
      height: 28px;
      border-radius: 999px;
      background: #ea580c;
      color: #fff;
      padding: 0 8px;
    }

    .theme-dark .dashboard-notification {
      background: #332114;
      border-color: #7c2d12;
      color: #fed7aa;
    }

    .client-live-bid-home-card {
      position: relative;
      display: grid;
      grid-template-columns: minmax(220px, 1fr) minmax(360px, 1.4fr) auto;
      gap: 16px;
      align-items: center;
      padding: 18px 54px 18px 20px;
      margin-bottom: 18px;
      border: 1px solid #8ed05b;
      border-radius: 8px;
      background: #f2fae8;
      box-shadow: 0 14px 30px rgba(22, 136, 50, 0.12);
    }

    .client-live-bid-home-card[hidden] {
      display: none;
    }

    .client-live-bid-close {
      position: absolute;
      top: 10px;
      right: 12px;
      width: 30px;
      height: 30px;
      border: 0;
      border-radius: 999px;
      background: #dcfce7;
      color: #166534;
      cursor: pointer;
      font-size: 18px;
      font-weight: 900;
    }

    .client-live-bid-copy span {
      color: #168832;
      font-size: 0.78rem;
      font-weight: 900;
      text-transform: uppercase;
    }

    .client-live-bid-copy h2 {
      margin: 5px 0;
      color: #263238;
      font-size: 1.25rem;
    }

    .client-live-bid-copy p {
      margin: 0;
      color: #475569;
      font-weight: 800;
    }

    .client-live-bid-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .client-live-bid-metrics div {
      padding: 11px 12px;
      border: 1px solid #bbf7d0;
      border-radius: 8px;
      background: #fff;
    }

    .client-live-bid-metrics span {
      display: block;
      color: #64748b;
      font-size: 0.78rem;
      font-weight: 900;
      margin-bottom: 4px;
    }

    .client-live-bid-metrics strong {
      color: #166534;
      font-size: 1rem;
    }

    .client-live-bid-link {
      align-self: stretch;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 14px;
      border-radius: 6px;
      background: #168832;
      color: #fff;
      text-decoration: none;
      font-weight: 900;
      white-space: nowrap;
    }

    .theme-dark .client-live-bid-home-card {
      background: #16301f;
      border-color: #166534;
    }

    .theme-dark .client-live-bid-copy h2,
    .theme-dark .client-live-bid-metrics strong {
      color: #f8fafc;
    }

    .theme-dark .client-live-bid-copy p {
      color: #cbd5e1;
    }

    .theme-dark .client-live-bid-metrics div {
      background: #111827;
      border-color: #166534;
    }

    .vendor-new-quotation-card {
      display: grid;
      grid-template-columns: auto minmax(220px, 1fr) minmax(360px, 1.35fr) auto;
      gap: 16px;
      align-items: center;
      padding: 18px 20px;
      margin-bottom: 18px;
      border: 1px solid #8ed05b;
      border-radius: 8px;
      background: #f2fae8;
      box-shadow: 0 14px 30px rgba(22, 136, 50, 0.12);
    }

    .vendor-new-quotation-card[hidden] {
      display: none;
    }

    .vendor-new-quotation-icon {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 12px;
      background: #dcfce7;
      color: #168832;
    }

    .vendor-new-quotation-icon svg {
      width: 25px;
      height: 25px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .vendor-new-quotation-copy span {
      color: #168832;
      font-size: 0.78rem;
      font-weight: 900;
      text-transform: uppercase;
    }

    .vendor-new-quotation-copy h2 {
      margin: 5px 0;
      color: #263238;
      font-size: 1.25rem;
    }

    .vendor-new-quotation-copy p {
      margin: 0;
      color: #475569;
      font-weight: 800;
    }

    .vendor-new-quotation-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .vendor-new-quotation-metrics div {
      padding: 11px 12px;
      border: 1px solid #bbf7d0;
      border-radius: 8px;
      background: #fff;
    }

    .vendor-new-quotation-metrics span {
      display: block;
      color: #64748b;
      font-size: 0.78rem;
      font-weight: 900;
      margin-bottom: 4px;
    }

    .vendor-new-quotation-metrics strong {
      color: #166534;
      font-size: 1rem;
    }

    .vendor-new-quotation-link {
      align-self: stretch;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 14px;
      border-radius: 6px;
      background: #168832;
      color: #fff;
      text-decoration: none;
      font-weight: 900;
      white-space: nowrap;
    }

    .theme-dark .vendor-new-quotation-card {
      background: #16301f;
      border-color: #166534;
    }

    .theme-dark .vendor-new-quotation-copy h2,
    .theme-dark .vendor-new-quotation-metrics strong {
      color: #f8fafc;
    }

    .theme-dark .vendor-new-quotation-copy p {
      color: #cbd5e1;
    }

    .theme-dark .vendor-new-quotation-metrics div {
      background: #111827;
      border-color: #166534;
    }

    .vendor-new-order-card {
      display: grid;
      grid-template-columns: auto minmax(220px, 1fr) minmax(360px, 1.35fr) auto;
      gap: 16px;
      align-items: center;
      padding: 18px 20px;
      margin-bottom: 18px;
      border: 1px solid #fbbf24;
      border-radius: 8px;
      background: #fff7e6;
      box-shadow: 0 14px 30px rgba(230, 134, 25, 0.12);
    }

    .vendor-new-order-card[hidden] {
      display: none;
    }

    .vendor-new-order-icon {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 12px;
      background: #ffedd5;
      color: #e68619;
    }

    .vendor-new-order-icon svg {
      width: 25px;
      height: 25px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .vendor-new-order-copy span {
      color: #e68619;
      font-size: 0.78rem;
      font-weight: 900;
      text-transform: uppercase;
    }

    .vendor-new-order-copy h2 {
      margin: 5px 0;
      color: #263238;
      font-size: 1.25rem;
    }

    .vendor-new-order-copy p {
      margin: 0;
      color: #475569;
      font-weight: 800;
    }

    .vendor-new-order-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .vendor-new-order-metrics div {
      padding: 11px 12px;
      border: 1px solid #fed7aa;
      border-radius: 8px;
      background: #fff;
    }

    .vendor-new-order-metrics span {
      display: block;
      color: #64748b;
      font-size: 0.78rem;
      font-weight: 900;
      margin-bottom: 4px;
    }

    .vendor-new-order-metrics strong {
      color: #c2410c;
      font-size: 1rem;
    }

    .vendor-new-order-link {
      align-self: stretch;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 14px;
      border-radius: 6px;
      background: #e68619;
      color: #fff;
      text-decoration: none;
      font-weight: 900;
      white-space: nowrap;
    }

    .theme-dark .vendor-new-order-card {
      background: #332114;
      border-color: #92400e;
    }

    .theme-dark .vendor-new-order-copy h2,
    .theme-dark .vendor-new-order-metrics strong {
      color: #f8fafc;
    }

    .theme-dark .vendor-new-order-copy p {
      color: #cbd5e1;
    }

    .theme-dark .vendor-new-order-metrics div {
      background: #111827;
      border-color: #92400e;
    }

    .vendor-quotation-summary {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 18px;
    }

    .support-dashboard-card {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      padding: 16px 18px;
      margin-bottom: 14px;
      background: #eef9fb;
      border: 1px solid #bae6fd;
      border-radius: 8px;
    }

    .support-dashboard-card span {
      color: #0891b2;
      font-weight: 900;
      text-transform: uppercase;
      font-size: 0.78rem;
    }

    .support-dashboard-card h2 {
      margin: 4px 0;
      color: #0f172a;
    }

    .support-dashboard-card p {
      margin: 0;
      color: #475569;
    }

    .support-ticket-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px;
      margin-bottom: 18px;
    }

    .support-ticket-chip {
      display: grid;
      gap: 6px;
      padding: 12px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      background: #fff;
      color: inherit;
      text-decoration: none;
    }

    .support-ticket-chip span {
      justify-self: start;
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 0.76rem;
      font-weight: 900;
    }

    .support-ticket-chip span.open {
      background: #dcfce7;
      color: #166534;
    }

    .support-ticket-chip span.closed {
      background: #e2e8f0;
      color: #334155;
    }

    .vendor-quote-stat,
    .vendor-health-card {
      display: grid;
      gap: 8px;
      padding: 16px;
      border-radius: 8px;
      background: #fff;
      border: 1px solid #e2e8f0;
      text-decoration: none;
      color: #263238;
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
    }

    .vendor-quote-stat span,
    .vendor-health-header span {
      color: #64748b;
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .vendor-quote-stat strong,
    .vendor-health-header strong {
      color: #0f172a;
      font-size: 1.8rem;
      line-height: 1;
    }

    .vendor-quote-stat small,
    .vendor-health-card p {
      margin: 0;
      color: #475569;
      font-weight: 800;
    }

    .vendor-quote-stat.pending { border-top: 4px solid #f59e0b; }
    .vendor-quote-stat.processed { border-top: 4px solid #16a34a; }
    .vendor-quote-stat.rejected { border-top: 4px solid #dc2626; }

    .vendor-health-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .vendor-health-track {
      height: 12px;
      overflow: hidden;
      border-radius: 999px;
      background: #e2e8f0;
    }

    .vendor-health-track span {
      display: block;
      height: 100%;
      border-radius: inherit;
      transition: width 0.25s ease;
    }

    .vendor-health-card.low .vendor-health-track span { background: #dc2626; }
    .vendor-health-card.fair .vendor-health-track span { background: #f59e0b; }
    .vendor-health-card.good .vendor-health-track span { background: #16a34a; }
    .vendor-health-card.low { border-top: 4px solid #dc2626; }
    .vendor-health-card.fair { border-top: 4px solid #f59e0b; }
    .vendor-health-card.good { border-top: 4px solid #16a34a; }

    .theme-dark .vendor-quote-stat,
    .theme-dark .vendor-health-card {
      background: #172033;
      border-color: #334155;
      color: #f8fafc;
    }

    .theme-dark .vendor-quote-stat strong,
    .theme-dark .vendor-health-header strong {
      color: #f8fafc;
    }

    @media (max-width: 980px) {
      .client-live-bid-home-card {
        grid-template-columns: 1fr;
        align-items: stretch;
      }

      .client-live-bid-link {
        align-self: auto;
      }

      .vendor-new-quotation-card {
        grid-template-columns: auto 1fr;
        align-items: stretch;
      }

      .vendor-new-order-card {
        grid-template-columns: auto 1fr;
        align-items: stretch;
      }

      .vendor-new-quotation-metrics,
      .vendor-new-quotation-link,
      .vendor-new-order-metrics,
      .vendor-new-order-link {
        grid-column: 1 / -1;
      }

      .vendor-new-quotation-link,
      .vendor-new-order-link {
        align-self: auto;
      }

      .vendor-quotation-summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

    }

    @media (max-width: 620px) {
      .client-live-bid-metrics {
        grid-template-columns: 1fr;
      }

      .vendor-new-quotation-card {
        grid-template-columns: 1fr;
      }

      .vendor-new-order-card {
        grid-template-columns: 1fr;
      }

      .vendor-new-quotation-metrics,
      .vendor-new-order-metrics {
        grid-template-columns: 1fr;
      }

      .vendor-quotation-summary {
        grid-template-columns: 1fr;
      }

    }
  </style>
  <% if (user.role === 'Vendor') { %>
    <script>
      let vendorNewOrders = <%- JSON.stringify(vendorNewOrders).replace(/</g, '\\u003c') %>;
      let vendorNewOrderIndex = 0;
      let vendorNewQuotations = <%- JSON.stringify(vendorNewQuotations).replace(/</g, '\\u003c') %>;
      let vendorNewQuotationIndex = 0;

      function vendorMoney(value) {
        return `INR ${Number(value || 0).toFixed(2)}`;
      }

      function pendingVendorOrders() {
        return vendorNewOrders.filter((order) => order.status === 'pending');
      }

      function pendingVendorQuotations() {
        return vendorNewQuotations.filter((quotation) => (
          quotation.recipient_status === 'new' || quotation.recipient_status === 'seen'
        ));
      }

      function renderVendorNewOrderCard() {
        const card = document.getElementById('vendorNewOrderCard');
        if (!card) return;

        const orders = pendingVendorOrders();
        if (!orders.length) {
          card.hidden = true;
          return;
        }

        if (vendorNewOrderIndex >= orders.length) {
          vendorNewOrderIndex = 0;
        }

        const order = orders[vendorNewOrderIndex];
        const amount = Number(order.total_amount || order.amount || 0);
        const orderType = String(order.order_type || 'direct').replace(/_/g, ' ');
        document.getElementById('vendorNewOrderStatus').textContent = orders.length === 1
          ? 'New order found'
          : `${orders.length} new orders found`;
        document.getElementById('vendorNewOrderTitle').textContent = `Order #${order.order_number || order.orderNumber || order.id}`;
        document.getElementById('vendorNewOrderMeta').textContent = [
          order.client_name || order.customer || 'Client',
          order.city || order.area || '',
          order.client_phone || '',
        ].filter(Boolean).join(' - ');
        document.getElementById('vendorNewOrderAmount').textContent = vendorMoney(amount);
        document.getElementById('vendorNewOrderType').textContent = orderType.charAt(0).toUpperCase() + orderType.slice(1);
        document.getElementById('vendorNewOrderState').textContent = order.status || 'pending';
        document.getElementById('vendorNewOrderLink').href = '/orders/vendor';
        card.hidden = false;
      }

      function renderVendorNewQuotationCard() {
        const card = document.getElementById('vendorNewQuotationCard');
        if (!card) return;

        const quotations = pendingVendorQuotations();
        if (!quotations.length) {
          card.hidden = true;
          return;
        }

        if (vendorNewQuotationIndex >= quotations.length) {
          vendorNewQuotationIndex = 0;
        }

        const quotation = quotations[vendorNewQuotationIndex];
        const category = quotation.category_name || 'Category quotation';
        const city = quotation.client_city || '';
        const itemCount = Array.isArray(quotation.items)
          ? quotation.items.length
          : Number(quotation.item_count || 0);
        const minimumBid = Number(quotation.min_bid_price || 0);

        document.getElementById('vendorNewQuotationStatus').textContent = quotations.length === 1
          ? 'New quotation found'
          : `${quotations.length} new quotations found`;
        document.getElementById('vendorNewQuotationTitle').textContent = `Quotation #${quotation.id}`;
        document.getElementById('vendorNewQuotationMeta').textContent = [
          quotation.client_name || 'Client',
          category,
          city,
        ].filter(Boolean).join(' - ');
        document.getElementById('vendorNewQuotationBase').textContent = vendorMoney(quotation.total_amount || quotation.actual_total || 0);
        document.getElementById('vendorNewQuotationBid').textContent = minimumBid > 0 ? vendorMoney(minimumBid) : 'No bids yet';
        document.getElementById('vendorNewQuotationItems').textContent = `${itemCount} item${itemCount === 1 ? '' : 's'}`;
        document.getElementById('vendorNewQuotationLink').href = `/vendor/quotations?recipient_id=${quotation.recipient_id || ''}`;
        card.hidden = false;
      }

      async function refreshVendorQuotationNotice() {
        try {
          const response = await fetch('/vendor/quotations?format=json&peek=1', {
            headers: { Accept: 'application/json' },
          });
          const data = await response.json();
          if (!response.ok || !data.success || !Array.isArray(data.quotations)) return;
          vendorNewQuotations = data.quotations;
          renderVendorNewQuotationCard();
        } catch (error) {
          console.error('Vendor quotation dashboard refresh failed:', error);
        }
      }

      async function refreshVendorOrderNotice() {
        try {
          const response = await fetch('/api/orders/vendor?status=pending', {
            headers: { Accept: 'application/json' },
          });
          const data = await response.json();
          if (!response.ok || !data.success || !Array.isArray(data.orders)) return;
          vendorNewOrders = data.orders;
          renderVendorNewOrderCard();
        } catch (error) {
          console.error('Vendor order dashboard refresh failed:', error);
        }
      }

      renderVendorNewOrderCard();
      renderVendorNewQuotationCard();
      setInterval(() => {
        const orders = pendingVendorOrders();
        if (orders.length > 1) {
          vendorNewOrderIndex = (vendorNewOrderIndex + 1) % orders.length;
          renderVendorNewOrderCard();
        }

        const quotations = pendingVendorQuotations();
        if (quotations.length > 1) {
          vendorNewQuotationIndex = (vendorNewQuotationIndex + 1) % quotations.length;
          renderVendorNewQuotationCard();
        }
      }, 15000);
      setInterval(refreshVendorOrderNotice, 5000);
      setInterval(refreshVendorQuotationNotice, 5000);
    </script>
  <% } %>
  <% if (user.role === 'Client') { %>
    <script>
      const clientLiveBidStorageKey = 'jaipurgro.client.liveBidCardVisible';
      let clientLiveQuotations = <%- JSON.stringify(clientLiveQuotations).replace(/</g, '\\u003c') %>;
      let clientLiveBidIndex = 0;

      function clientMoney(value) {
        return `INR ${Number(value || 0).toFixed(2)}`;
      }

      function isClientLiveBidVisible() {
        return localStorage.getItem(clientLiveBidStorageKey) !== 'hidden';
      }

      function activeClientLiveQuotations() {
        return clientLiveQuotations.filter((quotation) => (
          quotation.recipient_status === 'submitted' && quotation.bid_editable
        ));
      }

      function renderClientLiveBidCard() {
        const card = document.getElementById('clientLiveBidHomeCard');
        if (!card) return;

        const active = activeClientLiveQuotations();
        if (!isClientLiveBidVisible() || active.length === 0) {
          card.hidden = true;
          return;
        }

        if (clientLiveBidIndex >= active.length) {
          clientLiveBidIndex = 0;
        }

        const quotation = active[clientLiveBidIndex];
        const baseTotal = Number(quotation.actual_total || quotation.total_amount || 0);
        const bidTotal = Number(quotation.response_total || 0);
        const saving = Math.max(0, Number(quotation.savings || (baseTotal - bidTotal) || 0));
        const vendor = quotation.vendor_store_name || quotation.vendor_name || 'Vendor response';
        const category = quotation.category_name ? `${quotation.category_name} active bidding` : 'Active bidding';

        document.getElementById('clientLiveBidStatus').textContent = category;
        document.getElementById('clientLiveBidTitle').textContent = `Quotation #${quotation.id}`;
        document.getElementById('clientLiveBidVendor').textContent = vendor;
        document.getElementById('clientLiveBidBase').textContent = clientMoney(baseTotal);
        document.getElementById('clientLiveBidPrice').textContent = clientMoney(bidTotal);
        document.getElementById('clientLiveBidSaving').textContent = clientMoney(saving);
        document.getElementById('clientLiveBidLink').href = `/client/quotations?recipient_id=${quotation.recipient_id}`;
        card.hidden = false;
      }

      async function refreshClientLiveBids() {
        try {
          const response = await fetch('/api/client/quotations', {
            headers: { Accept: 'application/json' },
          });
          const data = await response.json();
          if (!response.ok || !data.success || !Array.isArray(data.quotations)) return;
          clientLiveQuotations = data.quotations;
          renderClientLiveBidCard();
        } catch (error) {
          console.error('Client live bid refresh failed:', error);
        }
      }

      document.getElementById('clientLiveBidHomeClose')?.addEventListener('click', () => {
        localStorage.setItem(clientLiveBidStorageKey, 'hidden');
        renderClientLiveBidCard();
      });

      renderClientLiveBidCard();
      setInterval(() => {
        if (!isClientLiveBidVisible()) return;
        const active = activeClientLiveQuotations();
        if (active.length <= 1) return;
        clientLiveBidIndex = (clientLiveBidIndex + 1) % active.length;
        renderClientLiveBidCard();
      }, 15000);
      setInterval(refreshClientLiveBids, 5000);
    </script>
  <% } %>
</body>
</html>
