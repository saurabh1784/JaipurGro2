<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Area Delivery Rules</title><link rel="stylesheet" href="/styles.css"></head><body class="system-theme"><%- include('partials/system_sidebar',{shell}) %><main class="system-main"><header class="topbar"><div><p class="crumb">Delivery Dashboard / Delivery Charge Settings</p><h1>Area Delivery Rules</h1></div><button class="settings-save" onclick="openRule()">Add Area Slab</button></header><section class="settings-shell"><div class="area-rule-banner"><div><span>Area overrides</span><h2>Independent pricing for every delivery area</h2><p>Rules copied from defaults can be edited without changing any other area.</p></div></div><div class="delivery-charge-toolbar"><label>Area<select id="filterArea"><option value="">All areas</option></select></label><label>Vehicle<select id="filterVehicle"><option value="">All vehicles</option></select></label><button class="product-secondary-button" onclick="load()">Refresh</button></div><div class="catalog-table-card"><table class="catalog-table"><thead><tr><th>Area</th><th>Vehicle</th><th>Weight</th><th>Base + Slab</th><th>Per Km</th><th>Night</th><th>Status</th><th>Actions</th></tr></thead><tbody id="body"><tr><td colspan="8">Loading area rules...</td></tr></tbody></table></div></section></main>
<div class="user-modal" id="modal" aria-hidden="true"><div class="user-modal-card"><div class="user-modal-header"><h2 id="title">Add Area Slab</h2><button onclick="closeRule()">Close</button></div><form class="user-modal-grid" id="form"><input id="id" type="hidden"><label>Area<select id="area" required></select></label><label>Vehicle<select id="vehicle" required></select></label><label>Rule Name<input id="ruleName" required></label><label>Minimum Weight Kg<input id="min" type="number" min="0" max="100" step=".001" required></label><label>Maximum Weight Kg<input id="max" type="number" min="0" max="100" step=".001" required></label><label>Slab Charge<input id="slab" type="number" min="0" step=".01" required></label><label>Price Per Kilometer<input id="perKm" type="number" min="0" step=".01" required></label><label>Additional Charge<input id="additional" type="number" min="0" step=".01" required></label><label>Night Increment<input id="night" type="number" min="0" step=".01" required></label><label class="settings-toggle"><input id="active" type="checkbox" checked>Active</label><div class="settings-wide"><button class="settings-save">Save Area Rule</button> <button type="button" class="product-secondary-button" onclick="closeRule()">Cancel</button></div></form></div></div>
<script>const el=id=>document.getElementById(id),esc=v=>String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c])),money=v=>'₹'+Number(v||0).toFixed(2);let rules=[],areas=[],vehicles=[];async function load(){const r=await fetch('/api/delivery-pricing/area-rules'),d=await r.json();if(!d.success)return alert(d.message);rules=d.rules||[];areas=d.areas||[];vehicles=d.vehicles||[];const ao=areas.map(a=>`<option value="${a.id}">${esc(a.city)} — ${esc(a.name)}</option>`).join(''),vo=vehicles.map(v=>`<option value="${v.id}">${esc(v.name)}</option>`).join('');el('area').innerHTML=ao;el('vehicle').innerHTML=vo;el('filterArea').innerHTML='<option value="">All areas</option>'+ao;el('filterVehicle').innerHTML='<option value="">All vehicles</option>'+vo;render()}function render(){const a=el('filterArea').value,v=el('filterVehicle').value,rows=rules.filter(r=>(!a||String(r.area_definition_id)===a)&&(!v||String(r.vehicle_category_id)===v));el('body').innerHTML=rows.map(r=>`<tr><td><strong>${esc(r.area_name)}</strong><span class="commission-subtext">${esc(r.city)}</span></td><td>${esc(r.vehicle_name)}</td><td>${r.min_weight_kg}–${r.max_weight_kg} kg</td><td>${money(Number(r.base_delivery_charge)+Number(r.slab_charge))}</td><td>${money(r.price_per_km)}</td><td>+${money(r.night_charge_increment)}</td><td><span class="status-pill ${r.is_active?'status-active':'status-inactive'}">${r.is_active?'Active':'Inactive'}</span></td><td><button class="product-secondary-button" onclick="openRule(${r.id})">Edit</button> <button class="reject-button" onclick="removeRule(${r.id})">Delete</button></td></tr>`).join('')||'<tr><td colspan="8">No area delivery rules found.</td></tr>'}function openRule(id){const r=rules.find(x=>Number(x.id)===Number(id));el('form').reset();el('title').textContent=r?'Edit Area Slab':'Add Area Slab';el('id').value=r?r.id:'';el('area').value=r?r.area_definition_id:(areas[0]?.id||'');el('vehicle').value=r?r.vehicle_category_id:(vehicles[0]?.id||'');el('ruleName').value=r?r.rule_name:'';el('min').value=r?r.min_weight_kg:0;el('max').value=r?r.max_weight_kg:5;el('slab').value=r?r.slab_charge:0;el('perKm').value=r?r.price_per_km:0;el('additional').value=r?r.additional_charge:0;el('night').value=r?r.night_charge_increment:0;el('active').checked=r?!!r.is_active:true;el('modal').style.display='flex'}function closeRule(){el('modal').style.display='none'}el('form').onsubmit=async e=>{e.preventDefault();const id=el('id').value,p={area_definition_id:el('area').value,vehicle_category_id:el('vehicle').value,rule_name:el('ruleName').value,min_weight_kg:el('min').value,max_weight_kg:el('max').value,slab_charge:el('slab').value,price_per_km:el('perKm').value,additional_charge:el('additional').value,night_charge_increment:el('night').value,is_active:el('active').checked};const r=await fetch('/api/delivery-pricing/area-rules'+(id?'/'+id:''),{method:id?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)}),d=await r.json();if(!d.success)return alert(d.message);closeRule();load()};async function removeRule(id){if(!confirm('Delete this area slab?'))return;const r=await fetch('/api/delivery-pricing/area-rules/'+id,{method:'DELETE'}),d=await r.json();if(!d.success)return alert(d.message);load()}el('filterArea').onchange=render;el('filterVehicle').onchange=render;load();</script><style>.area-rule-banner{padding:24px;border-radius:18px;color:#fff;background:linear-gradient(135deg,#0f766e,#16a34a)}.area-rule-banner span{font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.12em}.area-rule-banner h2{margin:5px 0;color:#fff}.area-rule-banner p{margin:0;opacity:.86}.delivery-charge-toolbar select{min-width:220px}</style></body></html>
