<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Default Delivery Rules</title><link rel="stylesheet" href="/styles.css"></head><body class="system-theme"><%- include('partials/system_sidebar',{shell}) %><main class="system-main"><header class="topbar"><div><p class="crumb">Delivery Dashboard / Default Delivery Rules</p><h1>Default Delivery Rules</h1></div><button class="settings-save" onclick="openRule()">Add Weight Slab</button></header><section class="settings-shell"><div class="rule-banner"><div><span>New-area template</span><h2>Default pricing up to 100 kg</h2><p>Changes here apply only to areas created later. Existing areas keep their copied rules.</p></div></div><div class="delivery-charge-toolbar"><label>Vehicle<select id="filter"><option value="">All vehicles</option></select></label><button class="product-secondary-button" onclick="load()">Refresh</button></div><div id="list" class="rule-grid"></div></section></main>
<div class="user-modal" id="modal" aria-hidden="true"><div class="user-modal-card"><div class="user-modal-header"><h2 id="title">Add Default Slab</h2><button onclick="closeRule()">Close</button></div><form class="user-modal-grid" id="form"><input id="id" type="hidden"><label>Vehicle Category<select id="vehicle" required></select></label><label>Rule Name<input id="ruleName" required></label><label>Minimum Weight Kg<input id="min" type="number" min="0" max="100" step=".001" required></label><label>Maximum Weight Kg<input id="max" type="number" min="0" max="100" step=".001" required></label><label>Slab Charge<input id="slab" type="number" min="0" step=".01" required></label><label>Price Per Kilometer<input id="perKm" type="number" min="0" step=".01" required></label><label>Additional Charge<input id="additional" type="number" min="0" step=".01" required></label><label>Night Increment<input id="night" type="number" min="0" step=".01" required></label><label class="settings-toggle"><input id="active" type="checkbox" checked>Active</label><div class="settings-wide"><button class="settings-save">Save Default Rule</button> <button type="button" class="product-secondary-button" onclick="closeRule()">Cancel</button></div></form></div></div>
<script>const el=id=>document.getElementById(id),esc=v=>String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c])),money=v=>'₹'+Number(v||0).toFixed(2);let rules=[],vehicles=[];async function load(){const [rr,vr]=await Promise.all([fetch('/api/delivery-pricing/default-rules'),fetch('/api/delivery-pricing/vehicles')]),[rd,vd]=await Promise.all([rr.json(),vr.json()]);rules=rd.rules||[];vehicles=vd.vehicles||[];const opts=vehicles.map(v=>`<option value="${v.id}">${esc(v.name)}</option>`).join('');el('vehicle').innerHTML=opts;el('filter').innerHTML='<option value="">All vehicles</option>'+opts;render()}function render(){const f=el('filter').value;const rows=f?rules.filter(r=>String(r.vehicle_category_id)===f):rules;el('list').innerHTML=rows.map(r=>`<article class="rule-card"><div class="rule-top"><div><small>${esc(r.vehicle_name)}</small><h3>${esc(r.rule_name)}</h3><p>${r.min_weight_kg}–${r.max_weight_kg} kg</p></div><span class="status-pill ${r.is_active?'status-active':'status-inactive'}">${r.is_active?'Active':'Inactive'}</span></div><div class="rule-values"><span>Base ${money(r.base_delivery_charge)}</span><span>Slab ${money(r.slab_charge)}</span><span>${money(r.price_per_km)}/km</span><span>Night +${money(r.night_charge_increment)}</span></div><div class="rule-actions"><button onclick="openRule(${r.id})">Edit</button><button class="danger" onclick="removeRule(${r.id})">Delete</button></div></article>`).join('')||'<p>No default rules found.</p>'}function openRule(id){const r=rules.find(x=>Number(x.id)===Number(id));el('form').reset();el('title').textContent=r?'Edit Default Slab':'Add Default Slab';el('id').value=r?r.id:'';el('vehicle').value=r?r.vehicle_category_id:(vehicles[0]?.id||'');el('ruleName').value=r?r.rule_name:'';el('min').value=r?r.min_weight_kg:0;el('max').value=r?r.max_weight_kg:5;el('slab').value=r?r.slab_charge:0;el('perKm').value=r?r.price_per_km:0;el('additional').value=r?r.additional_charge:0;el('night').value=r?r.night_charge_increment:0;el('active').checked=r?!!r.is_active:true;el('modal').style.display='flex'}function closeRule(){el('modal').style.display='none'}el('form').onsubmit=async e=>{e.preventDefault();const id=el('id').value,p={vehicle_category_id:el('vehicle').value,rule_name:el('ruleName').value,min_weight_kg:el('min').value,max_weight_kg:el('max').value,slab_charge:el('slab').value,price_per_km:el('perKm').value,additional_charge:el('additional').value,night_charge_increment:el('night').value,is_active:el('active').checked};const r=await fetch('/api/delivery-pricing/default-rules'+(id?'/'+id:''),{method:id?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)}),d=await r.json();if(!d.success)return alert(d.message);closeRule();load()};async function removeRule(id){if(!confirm('Delete this default slab? Existing areas will not be changed.'))return;const r=await fetch('/api/delivery-pricing/default-rules/'+id,{method:'DELETE'}),d=await r.json();if(!d.success)return alert(d.message);load()}el('filter').onchange=render;load();</script>
<style>.rule-banner{padding:24px;border-radius:18px;color:#fff;background:linear-gradient(135deg,#1d4ed8,#0891b2)}.rule-banner span{font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.12em}.rule-banner h2{margin:5px 0;color:#fff}.rule-banner p{margin:0;opacity:.88}.rule-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:14px}.rule-card{padding:17px;border:1px solid #e2e8f0;border-radius:15px;background:#fff;box-shadow:0 8px 25px rgba(15,23,42,.06)}.rule-top,.rule-actions{display:flex;justify-content:space-between;gap:10px}.rule-top small{color:#0d9488;font-weight:900}.rule-top h3{margin:3px 0}.rule-top p{margin:0;color:#64748b}.rule-values{display:flex;flex-wrap:wrap;gap:6px;margin:14px 0}.rule-values span{padding:6px 8px;border-radius:8px;background:#f1f5f9;font-size:11px;font-weight:800}.rule-actions button{padding:7px 11px;border:1px solid #99f6e4;border-radius:8px;background:#f0fdfa;color:#0f766e;font-weight:800}.rule-actions .danger{border-color:#fecaca;background:#fff7f7;color:#b91c1c}</style></body></html>
