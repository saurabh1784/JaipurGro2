    .suggestion-item:hover {
      background: #f0f9fb;
    }

    .suggestion-item small {
      color: #64748b;
      font-size: 0.7rem;
      text-transform: uppercase;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
      min-height: 100%;
    }

    .product-card:hover {
      border-color: #b6dfe7;
      box-shadow: 0 14px 32px rgba(15, 23, 42, 0.12);
    }

    .product-media {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 170px;
      padding: 12px;
      background: #f8fafc;
      border-bottom: 1px solid #edf0f2;
    }

    .product-thumb-image {
      width: 100%;
