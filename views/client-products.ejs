      color: #475569;
      line-height: 1.4;
    }

    .payment-line {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid #e2e8f0;
      color: #475569;
      font-weight: 800;
    }

    .payment-total {
      color: #0f172a;
      font-size: 1.08rem;
      border-bottom: 0;
    }

    .payment-total strong {
      color: #059669;
      font-size: 1.3rem;
    }

    .vendor-delivery-breakdown {
      display: grid;
      gap: 8px;
      padding: 10px;
      border-radius: 8px;
      background: #ecfdf5;
    }

