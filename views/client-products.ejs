      color: #1f2937;
      font-size: 1rem;
      line-height: 1.25;
      font-weight: 700;
    }

    .product-description {
      margin: 0 0 10px;
      color: #606a73;
      font-size: 0.85rem;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-meta {
      display: flex;
      gap: 8px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }

    .product-meta span {
      padding: 4px 8px;
      background: #f1f5f9;
      border-radius: 4px;
      font-size: 0.75rem;
      color: #475569;
    }

    .product-price {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      padding-top: 8px;
      border-top: 1px solid #f1f5f9;
    }

    .product-price span {
      color: #64748b;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .product-price strong {
      font-size: 1.25rem;
      color: #059669;
    }

    .custom-price-tag {
      padding: 2px 6px;
      background: #fef3c7;
      color: #92400e;
      border-radius: 4px;
      font-size: 0.65rem;
      text-transform: uppercase;
    }

    .stock-badge {
      display: inline-block;
      padding: 5px 8px;
      border-radius: 4px;
      font-size: 0.72rem;
      font-weight: 600;
      white-space: nowrap;
    }

    .in-stock {
      background: #dcfce7;
      color: #166534;
    }

    .low-stock {
      background: #fef3c7;
      color: #92400e;
    }

    .out-stock {
      background: #fee2e2;
      color: #991b1b;
    }

    .product-actions {
      display: grid;
      grid-template-columns: 118px 1fr;
      align-items: center;
      gap: 10px;
      margin-top: 14px;
      padding: 14px;
      border-top: 1px solid #edf0f2;
      background: #fbfdff;
    }

    .quantity-selector {
      display: flex;
      align-items: center;
      width: 118px;
      height: 38px;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      overflow: hidden;
      background: #fff;
    }

    .qty-btn {
      width: 36px;
      height: 100%;
      border: 0;
      background: #e0f7fb;
      color: #0f7180;
      font-size: 1.15rem;
      font-weight: 800;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
    }

    .qty-btn:hover:not(:disabled) { background: #bfedf5; }

    .qty-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .qty-input {
      width: 46px;
      height: 100%;
      text-align: center;
      padding: 0;
      border: 0;
      border-left: 1px solid #cbd5e1;
      border-right: 1px solid #cbd5e1;
      font-weight: 700;
      color: #1f2937;
      appearance: textfield;
    }

    .qty-input::-webkit-outer-spin-button,
