      top: 0;
      right: 0;
      bottom: 0;
      width: 380px;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      overflow: hidden;
    }

    .payment-section {
      position: fixed;
      inset: 0;
      z-index: 1100;
      background: rgba(15, 23, 42, 0.56);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .payment-panel {
      width: min(460px, 100%);
      max-height: calc(100vh - 40px);
      overflow-y: auto;
      background: #fff;
      border-radius: 8px;
      padding: 20px;
      box-shadow: 0 20px 50px rgba(15, 23, 42, 0.24);
    }

    .payment-summary {
      display: grid;
      gap: 12px;
      margin-bottom: 16px;
