<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= shell.roleTitle %> - Product Catalog</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Products</p>
        <h1>Product Catalog</h1>
      </div>
      <div class="topbar-actions">
        <button class="icon-button" type="button" aria-label="Cart" onclick="openCart()">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h14v16H5z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>
          <span id="cart-count" class="cart-count-badge">0</span>
        </button>
      </div>
    </header>

    <section class="promo-scroll-shell" id="promoScrollShell" hidden>
      <div class="promo-scroll-track" id="promoScrollTrack"></div>
    </section>

    <section class="cart-section" id="cart-section" style="display: none;">
      <div class="cart-panel">
        <div class="cart-header">
          <h2>Your Cart</h2>
          <button type="button" onclick="closeCart()" class="cart-close">&times;</button>
        </div>
        <div id="cart-items" class="cart-items">
          <p class="cart-empty">Your cart is empty</p>
        </div>
        <div class="cart-summary" id="cart-summary" style="display: none;">
          <label class="cart-coupon-field">
            Coupon Code
            <input id="cart-coupon-code" type="text" placeholder="Optional coupon" />
          </label>
          <div class="cart-total">
            <span>Total:</span>
            <strong id="cart-total-amount">₹0.00</strong>
          </div>
          <div class="checkout-options">
            <button class="btn-checkout" onclick="directOrder()">Direct Order</button>
            <button class="btn-quotation" onclick="sendQuotation()">Send Quotation</button>
          </div>
        </div>
      </div>
    </section>

    <section class="payment-section" id="payment-section" style="display: none;">
      <div class="payment-panel">
        <div class="cart-header">
          <h2>Payment Summary</h2>
          <button type="button" onclick="closePaymentPage()" class="cart-close">&times;</button>
        </div>
        <div id="payment-summary" class="payment-summary">
          <p class="cart-empty">Calculating payment details...</p>
        </div>
        <div class="checkout-options">
          <button class="btn-checkout" id="confirm-payment-button" type="button" onclick="confirmDirectOrder()">Pay & Place Order</button>
          <button class="btn-quotation" type="button" onclick="closePaymentPage()">Back to Cart</button>
        </div>
      </div>
    </section>

    <section class="products-section">
      <div class="products-header">
        <h2>Available Products</h2>
        <div class="client-filter-bar">
          <select id="category-filter" aria-label="Category filter">
            <option value="">All Categories</option>
            <% categories.forEach(function(category) { %>
              <option value="<%= category.id %>"><%= category.name %></option>
            <% }); %>
          </select>
          <select id="subcategory-filter" aria-label="Subcategory filter">
            <option value="">All Subcategories</option>
          </select>
          <select id="brand-filter" aria-label="Brand filter">
            <option value="">All Brands</option>
          </select>
          <div class="search-box-container">
            <input type="search" id="search-input" placeholder="Search products..." />
            <div class="suggestions-panel" id="suggestions-panel" hidden></div>
          </div>
        </div>
      </div>

      <div class="products-grid" id="products-grid">
        <% products.forEach(function(product) { %>
          <div class="product-card" data-product-id="<%= product.id %>" data-master-product-id="<%= product.product_id %>" data-product-name="<%= product.product_name.toLowerCase() %>" data-product-description="<%= (product.description || '').toLowerCase() %>">
            <div class="product-media">
              <img class="product-thumb-image" src="<%= product.image_url || '/default.png' %>" alt="<%= product.product_name %>" loading="lazy" />
            </div>
            <div class="product-info">
              <div class="product-title-row">
                <h3 class="product-name"><%= product.product_name %></h3>
                <span class="stock-badge <%= product.quantity > 10 ? 'in-stock' : product.quantity > 0 ? 'low-stock' : 'out-stock' %>">
                  <%= product.quantity > 0 ? product.quantity + ' left' : 'Out' %>
                </span>
              </div>
              <% if (product.description) { %>
                <p class="product-description"><%= product.description %></p>
              <% } %>
              <div class="product-meta">
                <span class="product-category"><%= product.category_name %></span>
                <span class="product-brand"><%= product.brand_name %></span>
              </div>
              <div class="product-price">
                <span>Unit price</span>
                <strong>INR <%= product.visible_price.toFixed(2) %></strong>
              </div>
            </div>
            <div class="product-actions">
              <div class="quantity-selector">
                <button type="button" class="qty-btn" onclick="decreaseQty(this)" aria-label="Decrease quantity" <%= product.quantity <= 0 ? 'disabled' : '' %>>-</button>
                <input type="number" class="qty-input" value="1" min="1" max="<%= product.quantity %>" <%= product.quantity <= 0 ? 'disabled' : '' %> />
                <button type="button" class="qty-btn" onclick="increaseQty(this)" aria-label="Increase quantity" <%= product.quantity <= 0 ? 'disabled' : '' %>>+</button>
              </div>
              <button
                type="button"
                class="btn-add-cart"
                data-id="<%= product.id %>"
                data-vendor-product-id="<%= product.id %>"
                data-master-product-id="<%= product.product_id %>"
                data-name="<%= product.product_name %>"
                data-price="<%= product.visible_price %>"
                data-max-qty="<%= product.quantity %>"
                onclick="addToCartFromButton(this)"
                <%= product.quantity <= 0 ? 'disabled' : '' %>>
                Add to Cart
              </button>
            </div>
          </div>
        <% }); %>
      </div>
    </section>
  </main>

  <script>
    let cart = JSON.parse(localStorage.getItem('clientCart') || '[]');
    let pendingPaymentPreview = null;
    const catalog = {
      subcategories: <%- JSON.stringify(subcategories || []) %>,
      brands: <%- JSON.stringify(brands || []) %>,
    };
    const productsGrid = document.getElementById('products-grid');
    const categoryFilter = document.getElementById('category-filter');
    const subcategoryFilter = document.getElementById('subcategory-filter');
    const brandFilter = document.getElementById('brand-filter');
    const searchInput = document.getElementById('search-input');
    const suggestionsPanel = document.getElementById('suggestions-panel');

    function saveCart() {
      localStorage.setItem('clientCart', JSON.stringify(cart));
    }

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
    }

    function debounce(fn, delay) {
      let timer;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => fn(...args), delay);
      };
    }

    function optionList(items, emptyLabel) {
      return `<option value="">${emptyLabel}</option>` + items
        .slice()
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
        .map((item) => `<option value="${item.id}">${escapeHtml(item.name)}</option>`)
        .join('');
    }

    function subcategoryKey(item) {
      return item.sub_category_id || item.subcategory_id;
    }

    function uniqueBrands(items) {
      const seen = new Set();
      return items.filter((item) => {
        const key = String(item.name || '').trim().toLowerCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
    }

    function brandOptionList(items) {
      return '<option value="">All Brands</option>' + items
        .slice()
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
        .map((item) => `<option value="${escapeHtml(item.name)}">${escapeHtml(item.name)}</option>`)
        .join('');
    }

    function updateSubcategoryFilter() {
      const categoryId = categoryFilter.value;
      const items = categoryId
        ? catalog.subcategories.filter((item) => String(item.category_id) === String(categoryId))
        : catalog.subcategories;
      subcategoryFilter.innerHTML = optionList(items, 'All Subcategories');
    }

    function updateBrandFilter() {
      const categoryId = categoryFilter.value;
      const subcategoryId = subcategoryFilter.value;
      const items = uniqueBrands(catalog.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(subcategoryKey(item)) === String(subcategoryId)));
      brandFilter.innerHTML = brandOptionList(items);
    }

    function productCard(product) {
      const stockClass = product.quantity > 10 ? 'in-stock' : product.quantity > 0 ? 'low-stock' : 'out-stock';
      const stockText = product.quantity > 0 ? `${product.quantity} in stock` : 'Out of stock';
      const disabled = product.quantity <= 0 ? 'disabled' : '';
      return `
        <div class="product-card" data-product-id="${product.id}" data-master-product-id="${product.product_id}" data-product-name="${escapeHtml(product.product_name || '').toLowerCase()}" data-product-description="${escapeHtml(product.description || '').toLowerCase()}">
          <div class="product-media">
            <img class="product-thumb-image" src="${escapeHtml(product.image_url || '/default.png')}" alt="${escapeHtml(product.product_name)}" loading="lazy" />
          </div>
          <div class="product-info">
            <div class="product-title-row">
              <h3 class="product-name">${escapeHtml(product.product_name)}</h3>
              <span class="stock-badge ${stockClass}">${stockText}</span>
            </div>
            ${product.description ? `<p class="product-description">${escapeHtml(product.description)}</p>` : ''}
            <div class="product-meta">
              <span class="product-category">${escapeHtml(product.category_name)}</span>
              <span class="product-brand">${escapeHtml(product.brand_name)}</span>
            </div>
            <div class="product-price"><span>Unit price</span><strong>INR ${Number(product.visible_price || 0).toFixed(2)}</strong></div>
          </div>
          <div class="product-actions">
            <div class="quantity-selector">
              <button type="button" class="qty-btn" onclick="decreaseQty(this)" aria-label="Decrease quantity" ${disabled}>-</button>
              <input type="number" class="qty-input" value="1" min="1" max="${product.quantity}" ${disabled} />
              <button type="button" class="qty-btn" onclick="increaseQty(this)" aria-label="Increase quantity" ${disabled}>+</button>
            </div>
            <button type="button" class="btn-add-cart"
              data-id="${product.id}"
              data-vendor-product-id="${product.id}"
              data-master-product-id="${product.product_id}"
              data-name="${escapeHtml(product.product_name)}"
              data-price="${Number(product.visible_price || 0)}"
              data-max-qty="${product.quantity}"
              onclick="addToCartFromButton(this)"
              ${disabled}>Add to Cart</button>
          </div>
        </div>`;
    }

    async function loadProducts() {
      const params = new URLSearchParams();
      if (categoryFilter.value) params.set('category_id', categoryFilter.value);
      if (subcategoryFilter.value) params.set('sub_category_id', subcategoryFilter.value);
      if (brandFilter.value) params.set('brand_name', brandFilter.value);
      const searchTerm = searchInput.value.trim();
      if (searchTerm) params.set('search', searchTerm);
      const response = await fetch(`/api/vendor-products/client-visible?${params.toString()}`, { headers: { Accept: 'application/json' } });
      const data = await response.json();
      if (!data.success) {
        productsGrid.innerHTML = `<p class="cart-empty">${escapeHtml(data.message || 'Unable to load products')}</p>`;
        return;
      }
      productsGrid.innerHTML = data.products.length
        ? data.products.map(productCard).join('')
        : '<p class="cart-empty">No products found</p>';
      trackVisibleProducts(data.products || []);
    }

    async function loadSuggestions() {
      const q = searchInput.value.trim();
      if (!q) {
        suggestionsPanel.hidden = true;
        suggestionsPanel.innerHTML = '';
        return;
      }

      const response = await fetch(`/api/vendor-products/client-visible/suggestions?q=${encodeURIComponent(q)}`, { headers: { Accept: 'application/json' } });
      const data = await response.json();
      const suggestions = data.success ? data.suggestions || [] : [];
      if (!suggestions.length) {
        suggestionsPanel.hidden = true;
        suggestionsPanel.innerHTML = '';
        return;
      }

      suggestionsPanel.innerHTML = suggestions.map((item) => `
        <button type="button" class="suggestion-item" onclick="selectSuggestion('${escapeAttr(item.label)}')">
          <span>${escapeHtml(item.label)}</span>
          <small>${escapeHtml(item.type)}</small>
        </button>
      `).join('');
      suggestionsPanel.hidden = false;
    }

    async function loadPromotionScroll() {
      try {
        const response = await fetch('/api/promotions/active-display', { headers: { Accept: 'application/json' } });
        const data = await response.json();
        const promotions = data.success ? data.promotions || [] : [];
        const shell = document.getElementById('promoScrollShell');
        const track = document.getElementById('promoScrollTrack');
        if (!promotions.length) {
          shell.hidden = true;
          return;
        }

        const items = promotions.map((promo) => `
          <span class="promo-scroll-item" style="background:${escapeHtml(promo.background_color || '#0f766e')};color:${escapeHtml(promo.text_color || '#ffffff')}">
            ${promo.image_path ? `<img src="${escapeHtml(promo.image_path)}" alt="">` : ''}
            <strong>${escapeHtml(promo.scroll_message)}</strong>
            ${promo.code ? `<em>Code: ${escapeHtml(promo.code)}</em>` : ''}
          </span>
        `).join('');
        track.innerHTML = items + items;
        shell.hidden = false;
      } catch (error) {
        document.getElementById('promoScrollShell').hidden = true;
      }
    }

    function escapeAttr(value) {
      return String(value || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/\r?\n/g, ' ');
    }

    function selectSuggestion(value) {
      searchInput.value = value;
      suggestionsPanel.hidden = true;
      loadProducts();
    }

    function trackProductActivity(type, productId) {
      if (!productId) return;
      fetch('/api/vendor-products/client-visible/activity', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, product_id: productId, keyword: searchInput.value.trim() }),
      }).catch(() => {});
    }

    function trackVisibleProducts(items) {
      items.slice(0, 12).forEach((product) => trackProductActivity('view', product.product_id));
    }

    function updateCartCount() {
      const count = cart.reduce((sum, item) => sum + item.quantity, 0);
      document.getElementById('cart-count').textContent = count;
      document.getElementById('cart-count').style.display = count > 0 ? 'block' : 'none';
    }

    function addToCartFromButton(button) {
      const card = button.closest('.product-card');
      const quantityInput = card.querySelector('.qty-input');
      const id = Number(button.dataset.id);
      const vendorProductId = Number(button.dataset.vendorProductId);
      const masterProductId = Number(button.dataset.masterProductId);
      const name = button.dataset.name;
      const price = Number(button.dataset.price);
      const maxQty = Number(button.dataset.maxQty);
      const requestedQty = Math.min(Math.max(1, Number(quantityInput.value) || 1), maxQty);

      addToCart(id, name, price, maxQty, vendorProductId, requestedQty);
      trackProductActivity('click', masterProductId);
      quantityInput.value = 1;
    }

    function addToCart(id, name, price, maxQty, vendorProductId, requestedQty = 1) {
      const existingItem = cart.find(item => item.id === id);
      if (existingItem) {
        existingItem.quantity = Math.min(existingItem.quantity + requestedQty, maxQty);
      } else {
        cart.push({ id, vendorProductId, name, price, quantity: requestedQty, maxQty });
      }
      updateCartCount();
      renderCart();
      saveCart();
      openCart();
    }

    function removeFromCart(id) {
      cart = cart.filter(item => item.id !== id);
      updateCartCount();
      renderCart();
      saveCart();
    }

    function updateQuantity(id, newQty) {
      const item = cart.find(item => item.id === id);
      if (item) {
        item.quantity = Math.min(Math.max(1, newQty), item.maxQty);
        updateCartCount();
        renderCart();
        saveCart();
      }
    }

    function renderCart() {
      const cartItems = document.getElementById('cart-items');
      const cartSummary = document.getElementById('cart-summary');
      const cartTotal = document.getElementById('cart-total-amount');

      if (cart.length === 0) {
        cartItems.innerHTML = '<p class="cart-empty">Your cart is empty</p>';
        cartSummary.style.display = 'none';
      } else {
        cartItems.innerHTML = cart.map(item => `
          <div class="cart-item">
            <div class="cart-item-info">
              <strong>${escapeHtml(item.name)}</strong>
              <span>Unit price: ₹${item.price.toFixed(2)}</span>
            </div>
            <div class="cart-item-actions">
              <button type="button" onclick="updateQuantity(${item.id}, ${item.quantity - 1})" ${item.quantity <= 1 ? 'disabled' : ''}>-</button>
              <span>${item.quantity}</span>
              <button type="button" onclick="updateQuantity(${item.id}, ${item.quantity + 1})" ${item.quantity >= item.maxQty ? 'disabled' : ''}>+</button>
              <button type="button" onclick="removeFromCart(${item.id})" class="remove-btn">&times;</button>
            </div>
          </div>
        `).join('');

        const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
        cartTotal.textContent = '₹' + total.toFixed(2);
        cartSummary.style.display = 'block';
      }
    }

    function openCart() {
      document.getElementById('cart-section').style.display = 'block';
    }

    function closeCart() {
      document.getElementById('cart-section').style.display = 'none';
    }

    function clearCartAfterSuccess() {
      cart = [];
      updateCartCount();
      renderCart();
      saveCart();
      closeCart();
    }

    function money(value) {
      return 'INR ' + Number(value || 0).toFixed(2);
    }

    function paymentSummaryHtml(preview) {
      const vendors = preview.vendors || [];
      return `
        <div class="payment-card">
          <div class="payment-address">
            <span>Deliver to</span>
            <strong>${escapeHtml(preview.address && preview.address.recipient_name || 'Customer')}</strong>
            <p>${escapeHtml(preview.address && preview.address.display_address || '')}</p>
          </div>
          <div class="payment-line"><span>Item subtotal</span><strong>${money(preview.subtotal_amount)}</strong></div>
          <div class="payment-line"><span>Discount</span><strong>- ${money(preview.discount_amount)}</strong></div>
          <div class="payment-line"><span>Delivery charges</span><strong>${money(preview.delivery_charge)}</strong></div>
          <div class="payment-line payment-total"><span>Payable amount</span><strong>${money(preview.total_amount)}</strong></div>
          ${vendors.length ? `
            <div class="vendor-delivery-breakdown">
              ${vendors.map((vendor) => `
                <div>
                  <strong>Vendor #${vendor.vendor_id}</strong>
                  <span>${money(vendor.delivery_charge)} delivery${Number(vendor.distance_km || 0) > 0 ? ` - ${Number(vendor.distance_km).toFixed(2)} km` : ''}</span>
                </div>
              `).join('')}
            </div>
          ` : ''}
          <p class="payment-note">Temporary payment page. No online gateway is connected yet.</p>
        </div>
      `;
    }

    function openPaymentPage(preview) {
      pendingPaymentPreview = preview;
      document.getElementById('payment-summary').innerHTML = paymentSummaryHtml(preview);
      document.getElementById('payment-section').style.display = 'block';
    }

    function closePaymentPage() {
      document.getElementById('payment-section').style.display = 'none';
    }

    async function directOrder() {
      if (cart.length === 0) return;

      const button = document.querySelector('.btn-checkout');
      if (button) button.disabled = true;
      try {
        const response = await fetch('/client/orders/preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: cart, coupon_code: document.getElementById('cart-coupon-code').value.trim() })
        });
        const data = await response.json();
        if (!data.success) {
          alert(data.message || 'Unable to calculate delivery charge');
          return;
        }
        openPaymentPage(data.preview);
      } catch (error) {
        alert('Error opening payment page: ' + error.message);
      } finally {
        if (button) button.disabled = false;
      }
    }

    async function confirmDirectOrder() {
      if (cart.length === 0) return;
      const button = document.getElementById('confirm-payment-button');
      button.disabled = true;
      button.textContent = 'Processing...';

      fetch('/client/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: cart, coupon_code: document.getElementById('cart-coupon-code').value.trim() })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert(`Order placed successfully! Delivery charge: ${money(pendingPaymentPreview && pendingPaymentPreview.delivery_charge || 0)}`);
          closePaymentPage();
          clearCartAfterSuccess();
        } else {
          alert(data.message || 'Failed to place order');
        }
      })
      .catch(error => {
        alert('Error placing order: ' + error.message);
      })
      .finally(() => {
        button.disabled = false;
        button.textContent = 'Pay & Place Order';
      });
    }

    function sendQuotation() {
      if (cart.length === 0) return;

      fetch('/client/quotations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: cart, coupon_code: document.getElementById('cart-coupon-code').value.trim() })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert(data.message || 'Quotation sent successfully!');
          clearCartAfterSuccess();
        } else {
          alert(data.message || 'Failed to send quotation');
        }
      })
      .catch(error => {
        alert('Error sending quotation: ' + error.message);
      });
    }

    function decreaseQty(btn) {
      const input = btn.nextElementSibling;
      const newVal = Math.max(1, parseInt(input.value) - 1);
      input.value = newVal;
    }

    function increaseQty(btn) {
      const input = btn.previousElementSibling;
      const maxVal = parseInt(input.max);
      const newVal = Math.min(maxVal, parseInt(input.value) + 1);
      input.value = newVal;
    }

    updateCartCount();
    renderCart();
    loadPromotionScroll();
    updateSubcategoryFilter();
    updateBrandFilter();
    categoryFilter.addEventListener('change', () => {
      updateSubcategoryFilter();
      subcategoryFilter.value = '';
      updateBrandFilter();
      loadProducts();
    });
    subcategoryFilter.addEventListener('change', () => {
      updateBrandFilter();
      loadProducts();
    });
    brandFilter.addEventListener('change', loadProducts);
    const debouncedSearch = debounce(() => {
      loadSuggestions();
      loadProducts();
    }, 300);
    searchInput.addEventListener('input', debouncedSearch);
    document.addEventListener('click', (event) => {
      if (!event.target.closest('.search-box-container')) {
        suggestionsPanel.hidden = true;
      }
    });
  </script>

  <style>
    .products-section {
      padding: 0;
    }

    .promo-scroll-shell {
      overflow: hidden;
      margin-bottom: 18px;
      border-radius: 8px;
      border: 1px solid #dbeafe;
      background: #f8fafc;
    }

    .promo-scroll-track {
      display: inline-flex;
      gap: 12px;
      min-width: max-content;
      padding: 10px;
      animation: promo-scroll 28s linear infinite;
    }

    .promo-scroll-shell:hover .promo-scroll-track {
      animation-play-state: paused;
    }

    .promo-scroll-item {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-height: 44px;
      padding: 8px 14px;
      border-radius: 7px;
      font-weight: 900;
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
    }

    .promo-scroll-item img {
      width: 34px;
      height: 34px;
      border-radius: 5px;
      object-fit: cover;
    }

    .promo-scroll-item em {
      font-style: normal;
      opacity: 0.9;
    }

    @keyframes promo-scroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    .products-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      gap: 16px;
      flex-wrap: wrap;
    }

    .products-header h2 {
