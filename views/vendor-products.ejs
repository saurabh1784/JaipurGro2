<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= shell.roleTitle %> - My Products</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Products</p>
        <h1>My Products</h1>
      </div>
      <div class="topbar-actions">
        <button class="button" type="button" id="addProductBtn" style="width: auto; padding: 8px 16px;">
          Add Product
        </button>
      </div>
    </header>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="system-alert"><%= error %></div>
    <% } %>

    <section class="products-section">
      <div class="products-header">
        <h2>Vendor Products</h2>
        <div class="view-toggle-container">
          <button type="button" class="view-toggle-btn active" id="toggleViewBtn" onclick="toggleView()" aria-label="Toggle view">
            <svg id="listIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="8" y1="6" x2="21" y2="6"></line>
              <line x1="8" y1="12" x2="21" y2="12"></line>
              <line x1="8" y1="18" x2="21" y2="18"></line>
              <line x1="3" y1="6" x2="3.01" y2="6"></line>
              <line x1="3" y1="12" x2="3.01" y2="12"></line>
              <line x1="3" y1="18" x2="3.01" y2="18"></line>
            </svg>
            <svg id="gridIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
          </button>
          <div class="search-box-container">
            <input type="search" id="search-input" placeholder="Search products..." />
          </div>
        </div>
      </div>
      <div class="vendor-filter-bar">
        <select id="category-filter" aria-label="Category filter">
          <option value="">All Categories</option>
          <% categories.forEach(function(category) { %>
            <option value="<%= category.id %>"><%= category.name %></option>
          <% }); %>
        </select>
        <select id="subcategory-filter" aria-label="Subcategory filter">
          <option value="">All Subcategories</option>
        </select>
        <select id="brand-filter" aria-label="Brand filter">
          <option value="">All Brands</option>
        </select>
      </div>

      <div id="products-container">
        <% if (products.length === 0) { %>
          <div class="empty-state">
            <p>No products found. Add your first product to get started.</p>
          </div>
        <% } else { %>
          <div class="products-grid" id="products-grid">
            <% products.forEach(function(product) { %>
              <div class="product-card" data-product-id="<%= product.id %>" data-product-name="<%= product.product_name.toLowerCase() %>">
                <img class="product-thumb-image" src="<%= product.image_url || '/default.png' %>" alt="<%= product.product_name %>" loading="lazy" />
                <div class="product-info">
                  <h3 class="product-name"><%= product.product_name %></h3>
                  <% if (product.description) { %>
                    <p class="product-description"><%= product.description %></p>
                  <% } %>
                  <div class="product-meta">
                    <span class="product-category"><%= product.category_name %></span>
                    <span class="product-brand"><%= product.brand_name %></span>
                  </div>
                  <div class="product-price">
                    <strong>₹<%= product.price.toFixed(2) %></strong>
                  </div>
                  <div class="product-stock">
                    <span class="stock-badge <%= product.quantity > 10 ? 'in-stock' : product.quantity > 0 ? 'low-stock' : 'out-stock' %>">
                      <%= product.quantity > 0 ? product.quantity + ' in stock' : 'Out of stock' %>
                    </span>
                  </div>
                  <div class="product-status">
                    <span class="status-badge <%= product.status === 'active' ? 'status-active' : product.status === 'unavailable' ? 'status-unavailable' : 'status-inactive' %>">
                      <%= product.status %>
                    </span>
                    <button
                      type="button"
                      class="status-toggle-btn <%= product.status === 'active' ? 'status-toggle-active' : 'status-toggle-inactive' %>"
                      onclick="toggleVendorProductStatus(<%= product.id %>)">
                      Set <%= product.status === 'active' ? 'Inactive' : 'Active' %>
                    </button>
                    <button
                      type="button"
                      class="status-toggle-btn <%= product.status === 'unavailable' ? 'status-toggle-inactive' : 'status-toggle-unavailable' %>"
                      onclick="setVendorProductAvailability(<%= product.id %>)">
                      <%= product.status === 'unavailable' ? 'Make Available' : 'Unavailable' %>
                    </button>
                  </div>
                </div>
                <div class="product-actions">
                  <button type="button" class="btn-edit" onclick="openEditModal(<%= product.id %>)">Edit</button>
                  <button type="button" class="btn-delete" onclick="deleteVendorProduct(<%= product.id %>)">Delete</button>
                </div>
              </div>
            <% }); %>
          </div>

          <!-- List View -->
          <div class="products-list" id="products-list" style="display:none">
            <% products.forEach(function(product) { %>
              <div class="product-row" data-product-id="<%= product.id %>" data-product-name="<%= product.product_name.toLowerCase() %>">
                <img class="product-row-image" src="<%= product.image_url || '/default.png' %>" alt="<%= product.product_name %>" loading="lazy" />
                <div class="product-row-info">
                  <h3 class="product-row-name"><%= product.product_name %></h3>
                  <% if (product.description) { %>
                    <p class="product-row-description"><%= product.description %></p>
                  <% } %>
                  <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                    <span class="product-row-category"><%= product.category_name %></span>
                    <span class="product-row-brand"><%= product.brand_name %></span>
                  </div>
                </div>
                <div class="product-row-price">
                  ₹<%= product.price.toFixed(2) %>
                </div>
                <div class="product-row-stock">
                  <span class="stock-badge <%= product.quantity > 10 ? 'in-stock' : product.quantity > 0 ? 'low-stock' : 'out-stock' %>">
                    <%= product.quantity > 0 ? product.quantity + ' in stock' : 'Out of stock' %>
                  </span>
                </div>
                <div class="product-row-status">
                  <span class="status-badge <%= product.status === 'active' ? 'status-active' : product.status === 'unavailable' ? 'status-unavailable' : 'status-inactive' %>">
                    <%= product.status %>
                  </span>
                  <button
                    type="button"
                    class="status-toggle-btn <%= product.status === 'active' ? 'status-toggle-active' : 'status-toggle-inactive' %>"
                    onclick="toggleVendorProductStatus(<%= product.id %>)">
                    Set <%= product.status === 'active' ? 'Inactive' : 'Active' %>
                  </button>
                  <button
                    type="button"
                    class="status-toggle-btn <%= product.status === 'unavailable' ? 'status-toggle-inactive' : 'status-toggle-unavailable' %>"
                    onclick="setVendorProductAvailability(<%= product.id %>)">
                    <%= product.status === 'unavailable' ? 'Make Available' : 'Unavailable' %>
                  </button>
                </div>
                <div class="product-row-actions">
                  <button type="button" class="btn-edit" onclick="openEditModal(<%= product.id %>)">Edit</button>
                  <button type="button" class="btn-delete" onclick="deleteVendorProduct(<%= product.id %>)">Delete</button>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <div class="user-modal" id="productModal" aria-hidden="true">
    <div class="user-modal-card">
      <div class="user-modal-header">
        <h2 id="productModalTitle">Add Product</h2>
        <button type="button" onclick="closeModal()">Close</button>
      </div>
      <form id="productForm" class="user-modal-grid">
        <input type="hidden" id="vendorProductId" />
        <label>
          Product
          <select id="productId" required>
            <option value="">Select Product</option>
            <% approvedProducts.forEach(function(p) { %>
              <option value="<%= p.id %>"><%= p.name %> (<%= p.category_name %> - <%= p.brand_name %>)</option>
            <% }); %>
          </select>
        </label>
        <label>
          Price (₹)
          <input type="number" id="price" step="0.01" min="0" required />
        </label>
        <label>
          Quantity
          <input type="number" id="quantity" step="0.01" min="0" required />
        </label>
        <label>
          Status
          <select id="status" required>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
            <option value="unavailable">Unavailable</option>
          </select>
        </label>
        <button class="settings-save" type="submit">Save</button>
      </form>
    </div>
  </div>

  <style>
    .products-section { padding: 0; }
    .products-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .products-header h2 { margin: 0; color: #4f5963; }
    .search-box-container { width: 250px; }
    .search-box-container input { width: 100%; padding: 8px 12px; border: 1px solid #dfe4e8; border-radius: 4px; font-size: 0.9rem; }
    /* View toggle button */
    .view-toggle-container {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .vendor-filter-bar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .vendor-filter-bar select {
      min-width: 160px;
      padding: 8px 10px;
      border: 1px solid #dfe4e8;
      border-radius: 4px;
      background: #fff;
    }

    .view-toggle-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      width: 42px;
      height: 34px;
      padding: 0;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      background: #fff;
      color: #64748b;
      cursor: pointer;
      transition: all 0.15s ease;
      flex-shrink: 0;
    }

    .view-toggle-btn:hover {
      background: #f8fafc;
      border-color: #94a3b8;
      color: #475569;
    }

    .view-toggle-btn.active {
      background: #26bcd4;
      border-color: #26bcd4;
      color: #fff;
    }

    .view-toggle-btn:active {
      transform: scale(0.96);
    }

    .view-toggle-btn svg {
      width: 18px;
      height: 18px;
      stroke-width: 2;
      pointer-events: none;
    }

    .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 18px; }
    .product-card { display: flex; flex-direction: column; background: #fff; border: 1px solid rgba(204, 210, 215, 0.75); border-radius: 8px; padding: 16px; box-shadow: 0 2px 6px rgba(32, 42, 54, 0.08); }
    .product-thumb-image { width: 100%; height: 150px; object-fit: contain; border-radius: 6px; border: 1px solid #edf0f2; background: #fff; margin-bottom: 12px; }
    .product-info { flex: 1; }
    .product-name { margin: 0 0 6px; color: #3c4858; font-size: 1.1rem; }
    .product-description { margin: 0 0 10px; color: #606a73; font-size: 0.85rem; }
    .product-meta { display: flex; gap: 12px; margin-bottom: 10px; }
    .product-meta span { padding: 2px 8px; background: #f1f5f9; border-radius: 4px; font-size: 0.75rem; color: #475569; }
    .product-price { margin-bottom: 10px; }
    .product-price strong { font-size: 1.2rem; color: #059669; }
    .stock-badge, .status-badge { display: inline-block; padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }
    .in-stock { background: #dcfce7; color: #166534; }
    .low-stock { background: #fef3c7; color: #92400e; }
    .out-stock { background: #fee2e2; color: #991b1b; }
    .vendor-quantity-editor { display: grid; gap: 8px; align-items: start; }
    .vendor-quantity-controls { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .vendor-quantity-controls input {
      width: 96px;
      min-height: 32px;
      padding: 6px 8px;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      font-size: 0.86rem;
      font-weight: 700;
      color: #263238;
    }
    .quantity-save-btn {
      min-height: 32px;
      padding: 6px 10px;
      border: none;
      border-radius: 6px;
      background: #2563eb;
      color: #fff;
      font-size: 0.78rem;
      font-weight: 800;
      cursor: pointer;
    }
    .quantity-save-btn:disabled { opacity: 0.65; cursor: not-allowed; }
    .status-active { background: #dcfce7; color: #166534; }
    .status-inactive { background: #fee2e2; color: #991b1b; }
    .status-unavailable { background: #fef3c7; color: #92400e; }
    .status-toggle-btn { display: inline-flex; align-items: center; justify-content: center; margin-top: 8px; padding: 5px 9px; border: none; border-radius: 4px; color: #fff; font-size: 0.74rem; font-weight: 700; cursor: pointer; }
    .status-toggle-active { background: #64748b; }
    .status-toggle-active:hover { background: #475569; }
    .status-toggle-inactive { background: #16a34a; }
    .status-toggle-inactive:hover { background: #15803d; }
    .status-toggle-unavailable { background: #d97706; }
    .status-toggle-unavailable:hover { background: #b45309; }
    .product-actions { margin-top: 16px; padding-top: 12px; border-top: 1px solid #edf0f2; }
    .btn-edit, .btn-delete { width: 100%; padding: 8px; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
    .btn-edit { background: #26bcd4; }
    .btn-edit:hover { background: #18a7be; }
    .btn-delete { margin-top: 8px; background: #dc2626; }
    .btn-delete:hover { background: #b91c1c; }
    .empty-state { text-align: center; padding: 40px; background: #fff; border-radius: 8px; }
    .empty-state p { color: #64748b; margin-bottom: 16px; }
    .user-modal-grid { display: grid; gap: 12px; }
    .user-modal-grid label { display: flex; flex-direction: column; gap: 4px; font-size: 0.85rem; }
    .user-modal-grid input, .user-modal-grid select { padding: 8px; border: 1px solid #cbd5e1; border-radius: 4px; }

    /* List view styles */
    .products-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .product-row {
      display: grid;
      grid-template-columns: 64px 3fr 2fr 1fr 1fr 100px;
      align-items: center;
      gap: 16px;
      padding: 16px;
      background: #fff;
      border: 1px solid rgba(204, 210, 215, 0.75);
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(32, 42, 54, 0.08);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .product-row:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(32, 42, 54, 0.12);
    }

    .product-row-info {
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
    }

    .product-row-image {
      width: 56px;
      height: 56px;
      object-fit: contain;
      border-radius: 6px;
      border: 1px solid #edf0f2;
      background: #fff;
    }

    .product-row-name {
      margin: 0;
      color: #3c4858;
      font-size: 1rem;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .product-row-description {
      margin: 0;
      color: #606a73;
      font-size: 0.82rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .product-row-category,
    .product-row-brand {
      padding: 2px 8px;
      background: #f1f5f9;
      border-radius: 4px;
      font-size: 0.75rem;
      color: #475569;
      display: inline-block;
    }

    .product-row-price {
      font-size: 1.15rem;
      font-weight: 600;
      color: #059669;
    }

    .product-row-stock,
    .product-row-status {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .product-row-actions {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 8px;
    }

    .product-row-actions .btn-edit {
      width: auto;
      padding: 6px 12px;
      font-size: 0.8rem;
    }

    .product-row-actions .btn-delete {
      width: auto;
      margin-top: 0;
      padding: 6px 12px;
      font-size: 0.8rem;
    }

    /* Responsive */
    @media (max-width: 760px) {
      .products-list {
        gap: 8px;
      }

      .product-row {
        grid-template-columns: 1fr;
        gap: 10px;
        padding: 12px;
      }

      .product-row-price,
      .product-row-stock,
      .product-row-status {
        justify-content: flex-start;
        align-items: flex-start;
      }

      .product-row-actions {
        flex-direction: row;
        justify-content: flex-start;
      }
    }
  </style>

  <script>
    let vendorProducts = <%- JSON.stringify(products || []) %>;
    const catalog = {
      subcategories: <%- JSON.stringify(subcategories || []) %>,
      brands: <%- JSON.stringify(brands || []) %>,
    };
    const categoryFilter = document.getElementById('category-filter');
    const subcategoryFilter = document.getElementById('subcategory-filter');
    const brandFilter = document.getElementById('brand-filter');
    const searchInput = document.getElementById('search-input');

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
      }[char]));
    }

    function debounce(fn, delay) {
      let timer;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => fn(...args), delay);
      };
    }

    function optionList(items, emptyLabel) {
      return `<option value="">${emptyLabel}</option>` + items
        .slice()
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
        .map((item) => `<option value="${item.id}">${escapeHtml(item.name)}</option>`)
        .join('');
    }

    function subcategoryKey(item) {
      return item.sub_category_id || item.subcategory_id;
    }

    function uniqueBrands(items) {
      const seen = new Set();
      return items.filter((item) => {
        const key = String(item.name || '').trim().toLowerCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
    }

    function brandOptionList(items) {
      return '<option value="">All Brands</option>' + items
        .slice()
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
        .map((item) => `<option value="${escapeHtml(item.name)}">${escapeHtml(item.name)}</option>`)
        .join('');
    }

    function updateSubcategoryFilter() {
      const categoryId = categoryFilter.value;
      const items = categoryId
        ? catalog.subcategories.filter((item) => String(item.category_id) === String(categoryId))
        : catalog.subcategories;
      subcategoryFilter.innerHTML = optionList(items, 'All Subcategories');
    }

    function updateBrandFilter() {
      const categoryId = categoryFilter.value;
      const subcategoryId = subcategoryFilter.value;
      const items = uniqueBrands(catalog.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(subcategoryKey(item)) === String(subcategoryId)));
      brandFilter.innerHTML = brandOptionList(items);
    }

    function money(value) {
      return `INR ${Number(value || 0).toFixed(2)}`;
    }

    function unitPrice(product) {
      return Number(product.price || 0);
    }

    function stockBadgeMarkup(product) {
      const stockClass = product.quantity > 10 ? 'in-stock' : product.quantity > 0 ? 'low-stock' : 'out-stock';
      const stockText = product.quantity > 0 ? `${product.quantity} in stock` : 'Out of stock';
      return `<span class="stock-badge ${stockClass}">${stockText}</span>`;
    }

    function quantityEditorMarkup(product) {
      return `
        <div class="vendor-quantity-editor">
          ${stockBadgeMarkup(product)}
          <div class="vendor-quantity-controls">
            <input type="number" min="0" step="0.01" value="${Number(product.quantity || 0)}" aria-label="Product quantity" />
            <button type="button" class="quantity-save-btn" onclick="saveProductQuantity(${product.id}, this)">Save</button>
          </div>
        </div>
      `;
    }

    function statusMarkup(product) {
      const statusClass = product.status === 'active' ? 'status-active' : product.status === 'unavailable' ? 'status-unavailable' : 'status-inactive';
      return `
        <span class="status-badge ${statusClass}">${escapeHtml(product.status)}</span>
        <button
          type="button"
          class="status-toggle-btn ${product.status === 'active' ? 'status-toggle-active' : 'status-toggle-inactive'}"
          onclick="toggleVendorProductStatus(${product.id})">
          Set ${product.status === 'active' ? 'Inactive' : 'Active'}
        </button>
        <button
          type="button"
          class="status-toggle-btn ${product.status === 'unavailable' ? 'status-toggle-inactive' : 'status-toggle-unavailable'}"
          onclick="setVendorProductAvailability(${product.id})">
          ${product.status === 'unavailable' ? 'Make Available' : 'Unavailable'}
        </button>
      `;
    }

    function renderProducts() {
      const container = document.getElementById('products-container');
      if (!document.getElementById('products-grid') || !document.getElementById('products-list')) {
        container.innerHTML = '<div class="products-grid" id="products-grid"></div><div class="products-list" id="products-list" style="display:none"></div>';
      }
      const grid = document.getElementById('products-grid');
      const list = document.getElementById('products-list');

      grid.innerHTML = vendorProducts.map((product) => `
        <div class="product-card" data-product-id="${product.id}" data-product-name="${escapeHtml(product.product_name || '').toLowerCase()}">
          <img class="product-thumb-image" src="${escapeHtml(product.image_url || '/default.png')}" alt="${escapeHtml(product.product_name)}" loading="lazy" />
          <div class="product-info">
            <h3 class="product-name">${escapeHtml(product.product_name)}</h3>
            ${product.description ? `<p class="product-description">${escapeHtml(product.description)}</p>` : ''}
            <div class="product-meta">
              <span class="product-category">${escapeHtml(product.category_name)}</span>
              <span class="product-brand">${escapeHtml(product.brand_name)}</span>
            </div>
            <div class="product-price"><strong>${money(unitPrice(product))}</strong></div>
            <div class="product-stock">${quantityEditorMarkup(product)}</div>
            <div class="product-status">${statusMarkup(product)}</div>
          </div>
          <div class="product-actions">
            <button type="button" class="btn-edit" onclick="openEditModal(${product.id})">Edit</button>
            <button type="button" class="btn-delete" onclick="deleteVendorProduct(${product.id})">Delete</button>
          </div>
        </div>
      `).join('');

      list.innerHTML = vendorProducts.map((product) => `
        <div class="product-row" data-product-id="${product.id}" data-product-name="${escapeHtml(product.product_name || '').toLowerCase()}">
          <img class="product-row-image" src="${escapeHtml(product.image_url || '/default.png')}" alt="${escapeHtml(product.product_name)}" loading="lazy" />
          <div class="product-row-info">
            <h3 class="product-row-name">${escapeHtml(product.product_name)}</h3>
            ${product.description ? `<p class="product-row-description">${escapeHtml(product.description)}</p>` : ''}
            <div style="display: flex; gap: 8px; flex-wrap: wrap;">
              <span class="product-row-category">${escapeHtml(product.category_name)}</span>
              <span class="product-row-brand">${escapeHtml(product.brand_name)}</span>
            </div>
          </div>
          <div class="product-row-price">${money(unitPrice(product))}</div>
          <div class="product-row-stock">${quantityEditorMarkup(product)}</div>
          <div class="product-row-status">${statusMarkup(product)}</div>
          <div class="product-row-actions">
            <button type="button" class="btn-edit" onclick="openEditModal(${product.id})">Edit</button>
            <button type="button" class="btn-delete" onclick="deleteVendorProduct(${product.id})">Delete</button>
          </div>
        </div>
      `).join('');
      if (!vendorProducts.length) {
        grid.innerHTML = '<div class="empty-state"><p>No products found.</p></div>';
        list.innerHTML = '<div class="empty-state"><p>No products found.</p></div>';
      }
    }

    async function loadProducts() {
      const params = new URLSearchParams({
        format: 'json',
        category_id: categoryFilter.value,
        sub_category_id: subcategoryFilter.value,
        brand_name: brandFilter.value,
        search: searchInput.value.trim(),
      });
      const response = await fetch(`/api/vendor-products?${params.toString()}`, { headers: { Accept: 'application/json' } });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to load products');
        return;
      }
      vendorProducts = data.vendor_products || [];
      renderProducts();
    }

    function openModal(reset = true) {
      document.getElementById('productModal').classList.add('active');
      if (reset) {
        document.getElementById('productForm').reset();
        document.getElementById('vendorProductId').value = '';
        document.getElementById('productModalTitle').textContent = 'Add Product';
      }
    }

    function closeModal() {
      document.getElementById('productModal').classList.remove('active');
    }

    async function deleteVendorProduct(id) {
      const product = vendorProducts.find((item) => Number(item.id) === Number(id));
      const productName = product && product.product_name;
      const confirmed = window.confirm(`Delete ${productName || 'this product'} from your vendor products?`);
      if (!confirmed) return;

      const response = await fetch(`/vendor-products/${id}`, { method: 'DELETE' });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to delete product');
        return;
      }

      vendorProducts = vendorProducts.filter((product) => Number(product.id) !== Number(id));
      renderProducts();
    }

    async function toggleVendorProductStatus(id) {
      const product = vendorProducts.find((item) => Number(item.id) === Number(id));
      if (!product) return;

      const nextStatus = product.status === 'active' ? 'inactive' : 'active';
      updateVendorProductStatus(id, nextStatus);
    }

    async function updateVendorProductStatus(id, nextStatus) {
      const product = vendorProducts.find((item) => Number(item.id) === Number(id));
      if (!product) return;

      const response = await fetch(`/vendor-products/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: nextStatus }),
      });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to update status');
        return;
      }

      product.status = data.vendor_product && data.vendor_product.status ? data.vendor_product.status : nextStatus;
      product.quantity = data.vendor_product && data.vendor_product.quantity !== undefined ? data.vendor_product.quantity : product.quantity;
      renderProducts();
    }

    async function saveProductQuantity(id, button) {
      const product = vendorProducts.find((item) => Number(item.id) === Number(id));
      if (!product) return;

      const editor = button.closest('.vendor-quantity-editor');
      const input = editor && editor.querySelector('input[type="number"]');
      const quantity = Number(input ? input.value : NaN);
      if (!Number.isFinite(quantity) || quantity < 0) {
        alert('Please enter a valid quantity');
        input?.focus();
        return;
      }

      button.disabled = true;
      const previousText = button.textContent;
      button.textContent = 'Saving...';
      try {
        const response = await fetch(`/vendor-products/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quantity }),
        });
        const data = await response.json();
        if (!data.success) {
          alert(data.message || 'Unable to update quantity');
          return;
        }

        product.quantity = data.vendor_product && data.vendor_product.quantity !== undefined
          ? data.vendor_product.quantity
          : quantity;
        if (data.vendor_product && data.vendor_product.status) {
          product.status = data.vendor_product.status;
        }
        renderProducts();
      } catch (error) {
        alert('Unable to update quantity');
      } finally {
        button.disabled = false;
        button.textContent = previousText;
      }
    }

    function setVendorProductAvailability(id) {
      const product = vendorProducts.find((item) => Number(item.id) === Number(id));
      if (!product) return;
      updateVendorProductStatus(id, product.status === 'unavailable' ? 'active' : 'unavailable');
    }

    function openEditModal(id) {
      const product = vendorProducts.find(p => p.id === id);
      if (!product) return;
      document.getElementById('vendorProductId').value = product.id;
      document.getElementById('productId').value = product.product_id;
      document.getElementById('price').value = unitPrice(product);
      document.getElementById('quantity').value = product.quantity;
      document.getElementById('status').value = product.status;
      document.getElementById('productModalTitle').textContent = 'Edit Product';
      openModal(false);
    }

    function toggleView() {
      const grid = document.getElementById('products-grid');
      const list = document.getElementById('products-list');
      const toggleBtn = document.getElementById('toggleViewBtn');
      const listIcon = document.getElementById('listIcon');
      const gridIcon = document.getElementById('gridIcon');

      if (grid.style.display === 'none') {
        // Switch to grid view
        grid.style.display = 'grid';
        list.style.display = 'none';
        toggleBtn.classList.add('active');
        listIcon.style.display = 'none';
        gridIcon.style.display = 'block';
      } else {
        // Switch to list view
        grid.style.display = 'none';
        list.style.display = 'flex';
        toggleBtn.classList.remove('active');
        listIcon.style.display = 'block';
        gridIcon.style.display = 'none';
      }
    }

    document.getElementById('addProductBtn').addEventListener('click', openModal);

    document.getElementById('productForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('vendorProductId').value;
      const payload = {
        product_id: document.getElementById('productId').value,
        price: document.getElementById('price').value,
        status: document.getElementById('status').value,
      };
      payload.quantity = payload.status === 'unavailable' ? 0 : document.getElementById('quantity').value;
      const method = id ? 'PUT' : 'POST';
      const url = id ? `/vendor-products/${id}` : '/vendor-products';
      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await response.json();
      if (data.success) {
        closeModal();
        loadProducts();
      } else {
        alert(data.message || 'Failed to save product');
      }
    });

    window.openEditModal = openEditModal;
    window.deleteVendorProduct = deleteVendorProduct;
    window.toggleVendorProductStatus = toggleVendorProductStatus;
    window.setVendorProductAvailability = setVendorProductAvailability;
    window.saveProductQuantity = saveProductQuantity;
    renderProducts();
    updateSubcategoryFilter();
    updateBrandFilter();
    categoryFilter.addEventListener('change', () => {
      updateSubcategoryFilter();
      subcategoryFilter.value = '';
      updateBrandFilter();
      loadProducts();
    });
    subcategoryFilter.addEventListener('change', () => {
      updateBrandFilter();
      loadProducts();
    });
    brandFilter.addEventListener('change', loadProducts);
    searchInput.addEventListener('input', debounce(loadProducts, 300));
    document.getElementById('status').addEventListener('change', (event) => {
      if (event.target.value === 'unavailable') {
        document.getElementById('quantity').value = 0;
      }
    });
  </script>
</body>
</html>
