<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= user.name %> - Profile</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Profile</p>
        <h1><%= user.name %></h1>
      </div>
      <div class="topbar-actions">
        <span class="profile-role-badge"><%= profileRole %></span>
      </div>
    </header>

    <section class="profile-page-shell">
      <div class="profile-summary-panel">
        <div class="profile-avatar"><%= (user.name || 'U').slice(0, 1).toUpperCase() %></div>
        <div>
          <h2><%= user.name %></h2>
          <p><%= user.email %></p>
        </div>
        <dl>
          <div>
            <dt>Role</dt>
            <dd><%= profileRole %></dd>
          </div>
          <div>
            <dt>Status</dt>
            <dd><%= user.status || 'active' %></dd>
          </div>
          <% if (user.phone) { %>
            <div>
              <dt>Phone</dt>
              <dd><%= user.phone %></dd>
            </div>
          <% } %>
        </dl>
      </div>

      <div class="users-table-card profile-edit-panel">
        <div class="profile-form-header">
          <div>
            <h2>Profile Details</h2>
            <p id="profileSaveStatus">Update your account details here.</p>
          </div>
        </div>

        <form id="profilePageForm" class="user-modal-grid">
          <% const data = profile || {}; %>
          <% const arrayValue = (value) => Array.isArray(value) ? value.join(', ') : (value || ''); %>

          <% if (profileRole === 'Vendor') { %>
            <label>
              Business Name
              <input name="business_name" value="<%= data.business_name || '' %>" />
            </label>
            <label>
              GST Number
              <input name="gst_number" value="<%= data.gst_number || '' %>" />
            </label>
            <label class="profile-full-field">
              Address
              <textarea name="address"><%= data.address || '' %></textarea>
            </label>
            <label>
              Country
              <input name="country" value="<%= data.country || '' %>" />
            </label>
            <label>
              State
              <input name="state" value="<%= data.state || '' %>" />
            </label>
            <label>
              City
              <input name="city" value="<%= data.city || '' %>" />
            </label>
            <label class="profile-full-field">
              Services
              <textarea name="services"><%= arrayValue(data.services) %></textarea>
            </label>
          <% } else if (profileRole === 'Client') { %>
            <label class="profile-full-field">
              Address
              <textarea name="address"><%= data.address || '' %></textarea>
            </label>
            <label>
              Country
              <input name="country" value="<%= data.country || '' %>" />
            </label>
            <label>
              State
              <input name="state" value="<%= data.state || '' %>" />
            </label>
            <label>
              City
              <input name="city" value="<%= data.city || '' %>" />
            </label>
            <label>
              Age
              <input name="age" type="number" min="0" value="<%= data.age || '' %>" />
            </label>
            <label>
              Gender
              <select name="gender">
                <option value="">Select gender</option>
                <option value="male" <%= data.gender === 'male' ? 'selected' : '' %>>Male</option>
                <option value="female" <%= data.gender === 'female' ? 'selected' : '' %>>Female</option>
                <option value="other" <%= data.gender === 'other' ? 'selected' : '' %>>Other</option>
              </select>
            </label>
            <label class="profile-full-field">
              Notes
              <textarea name="notes"><%= data.notes || '' %></textarea>
            </label>
          <% } else if (profileRole === 'Admin') { %>
            <label class="profile-full-field">
              Permissions
              <textarea name="permissions"><%= arrayValue(data.permissions) %></textarea>
            </label>
          <% } else { %>
            <p>No editable profile fields are configured for this role.</p>
          <% } %>

          <button class="settings-save profile-full-field" type="submit">Save Profile</button>
        </form>
      </div>
    </section>
  </main>

  <script>
    const form = document.getElementById('profilePageForm');
    const statusText = document.getElementById('profileSaveStatus');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const profile = {};

      for (const [key, value] of formData.entries()) {
        profile[key] = key === 'services' || key === 'permissions'
          ? value.split(',').map((item) => item.trim()).filter(Boolean)
          : value.trim();
      }

      statusText.textContent = 'Saving...';

      try {
        const response = await fetch('/profiles/<%= user.id %>', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ profile }),
        });
        const data = await response.json();

        if (!data.success) {
          throw new Error(data.message || 'Unable to update profile');
        }

        statusText.textContent = 'Profile saved successfully.';
      } catch (error) {
        statusText.textContent = error.message;
      }
    });
  </script>

  <style>
    .profile-page-shell {
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      gap: 20px;
      align-items: start;
    }

    .profile-summary-panel,
    .profile-edit-panel {
      border: 1px solid var(--border-color, #d8dee6);
      background: var(--panel-bg, #fff);
      border-radius: 8px;
      padding: 20px;
    }

    .profile-avatar {
      width: 72px;
      height: 72px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      background: #1f8f4d;
      color: #fff;
      font-size: 2rem;
      font-weight: 800;
      margin-bottom: 16px;
    }

    .profile-summary-panel h2,
    .profile-form-header h2 {
      margin: 0;
      color: #263238;
    }

    .profile-summary-panel p,
    .profile-form-header p {
      margin: 6px 0 0;
      color: #64748b;
    }

    .profile-summary-panel dl {
      margin: 20px 0 0;
      display: grid;
      gap: 12px;
    }

    .profile-summary-panel dt {
      font-size: 0.78rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0;
    }

    .profile-summary-panel dd {
      margin: 3px 0 0;
      color: #263238;
      font-weight: 700;
    }

    .profile-role-badge {
      padding: 8px 12px;
      border-radius: 999px;
      background: #e8f5ee;
      color: #17643a;
      font-weight: 800;
    }

    .profile-edit-panel .user-modal-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 18px;
    }

    .profile-full-field {
      grid-column: 1 / -1;
    }

    .theme-dark .profile-summary-panel,
    .theme-dark .profile-edit-panel {
      background: #18212c;
      border-color: #2d3a48;
    }

    .theme-dark .profile-summary-panel h2,
    .theme-dark .profile-form-header h2,
    .theme-dark .profile-summary-panel dd {
      color: #f8fafc;
    }

    @media (max-width: 860px) {
      .profile-page-shell {
        grid-template-columns: 1fr;
      }

      .profile-edit-panel .user-modal-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</body>
</html>
