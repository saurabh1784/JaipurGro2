<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>groxen - Fresh Grocery Delivery</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="landing-page ecoshop-landing-page">
  <div class="ecoshop-topbar">
    <p>Fresh groceries, daily essentials, and local vendor services across Jaipur.</p>
    <div>
      <a href="/login/vendor">Vendor Login</a>
      <span>Free delivery above Rs.499</span>
    </div>
  </div>

  <main class="grocery-landing ecoshop-shell">
    <header class="grocery-nav ecoshop-header">
      <a class="grocery-logo ecoshop-logo" href="/" aria-label="groxen home">
        <span class="grocery-logo-mark">
          <svg viewBox="0 0 48 48" aria-hidden="true">
            <path d="M12 27h24l-3 12H15z" fill="none" />
            <path d="M15 26c0-7 4-12 9-12s9 5 9 12" fill="none" />
            <path d="M17 18c-3-3-3-7 1-10 5 1 8 4 7 9" fill="currentColor" stroke="none" />
            <path d="M27 17c-1-5 2-9 7-10 4 4 3 9-1 12" fill="#ff8a00" stroke="none" />
            <path d="M10 27h28M15 39h18M14 31h21" fill="none" />
          </svg>
        </span>
        <span>groxen</span>
      </a>

      <nav class="grocery-menu ecoshop-menu" aria-label="Landing navigation">
        <a class="active" href="/">Home</a>
        <a href="#categories">Categories</a>
        <a href="#deals">Deals</a>
        <a href="#products">Products</a>
        <a href="#contact">Contact</a>
      </nav>

      <div class="grocery-nav-actions ecoshop-actions">
        <a class="cart-button" href="/login/client" aria-label="Open grocery cart">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6h15l-2 8H8z" /><path d="M6 6 5 3H2" /><circle cx="9" cy="20" r="1.8" /><circle cx="18" cy="20" r="1.8" /></svg>
          <span>2</span>
        </a>
        <a class="landing-signup" href="/login/client">Shop Now</a>
      </div>
    </header>

    <section class="grocery-hero ecoshop-hero">
      <div class="grocery-copy ecoshop-copy">
        <span class="service-pill">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 8h11v8H4z" /><path d="M15 11h3l2 3v2h-5z" /><circle cx="8" cy="18" r="2" /><circle cx="18" cy="18" r="2" /></svg>
          Same-day grocery delivery
        </span>
        <h1>Organic food for your healthy lifestyle.</h1>
        <p>Order fresh fruits, vegetables, snacks, masalas, and household essentials from nearby Jaipur vendors with fast doorstep delivery.</p>
        <div class="ecoshop-hero-actions">
          <a class="shop-now" href="/login/client">Start Shopping</a>
          <a class="ecoshop-outline" href="/admin">Admin Portal</a>
        </div>
        <div class="ecoshop-stats" aria-label="Store highlights">
          <div><strong>30 min</strong><span>local delivery</span></div>
          <div><strong>12.5k</strong><span>happy customers</span></div>
          <div><strong>250+</strong><span>daily essentials</span></div>
        </div>
      </div>

      <div class="grocery-visual ecoshop-visual" aria-label="Fresh grocery display">
        <div class="ecoshop-discount">
          <strong>25%</strong>
          <span>off fresh picks</span>
        </div>
        <img class="ecoshop-hero-image" src="https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=1100&q=88" alt="Fresh vegetables and groceries in bags" />
        <div class="ecoshop-delivery-card">
          <span>Free Delivery</span>
          <strong>Today before 8 PM</strong>
        </div>
      </div>
    </section>

    <section id="categories" class="ecoshop-section ecoshop-categories" aria-label="Popular grocery categories">
      <div class="ecoshop-section-heading">
        <span>Shop by category</span>
        <h2>Featured Categories</h2>
      </div>
      <div class="ecoshop-category-grid">
        <a href="/login/client"><img src="https://images.unsplash.com/photo-1518977676601-b53f82aba655?auto=format&fit=crop&w=260&q=80" alt="" /><span>Vegetables</span></a>
        <a href="/login/client"><img src="https://images.unsplash.com/photo-1619566636858-adf3ef46400b?auto=format&fit=crop&w=260&q=80" alt="" /><span>Fruits</span></a>
        <a href="/login/client"><img src="https://images.unsplash.com/photo-1558961363-fa8fdf82db35?auto=format&fit=crop&w=260&q=80" alt="" /><span>Snacks</span></a>
        <a href="/login/client"><img src="https://images.unsplash.com/photo-1586201375761-83865001e31c?auto=format&fit=crop&w=260&q=80" alt="" /><span>Staples</span></a>
        <a href="/login/client"><img src="https://images.unsplash.com/photo-1596040033229-a9821ebd058d?auto=format&fit=crop&w=260&q=80" alt="" /><span>Masalas</span></a>
      </div>
    </section>

    <section id="deals" class="ecoshop-deal-grid" aria-label="Current grocery offers">
      <a class="ecoshop-deal ecoshop-deal-green" href="/login/client">
        <span>Weekend offer</span>
        <strong>Fresh vegetable basket</strong>
        <small>Save up to 20% on seasonal greens</small>
      </a>
      <a class="ecoshop-deal ecoshop-deal-orange" href="/login/client">
        <span>Daily needs</span>
        <strong>Breakfast essentials</strong>
        <small>Milk, bread, poha, tea, and snacks</small>
      </a>
    </section>

    <section id="products" class="ecoshop-section ecoshop-products" aria-label="Popular products">
      <div class="ecoshop-section-heading">
        <span>Fresh arrivals</span>
        <h2>Popular Products</h2>
      </div>
      <div class="ecoshop-product-grid">
        <article class="ecoshop-product-card">
          <img src="/uploads/products/maggi-2-minute-noodles-560g-1778482442650.jpg" alt="Maggi 2 Minute Noodles" />
          <span>Instant Food</span>
          <h3>Maggi 2 Minute Noodles</h3>
          <div><strong>Rs.86</strong><a href="/login/client">Add</a></div>
        </article>
        <article class="ecoshop-product-card">
          <img src="/uploads/products/haldiram-bhujia-sev-400g-1778482525929.jpg" alt="Haldiram Bhujia Sev" />
          <span>Snacks</span>
          <h3>Haldiram Bhujia Sev</h3>
          <div><strong>Rs.99</strong><a href="/login/client">Add</a></div>
        </article>
        <article class="ecoshop-product-card">
          <img src="/uploads/products/catch-kitchen-king-masala-100g-1778482784735.webp" alt="Catch Kitchen King Masala" />
          <span>Masala</span>
          <h3>Catch Kitchen King Masala</h3>
          <div><strong>Rs.74</strong><a href="/login/client">Add</a></div>
        </article>
        <article class="ecoshop-product-card">
          <img src="https://images.unsplash.com/photo-1522184216316-3c25379f9760?auto=format&fit=crop&w=420&q=80" alt="Fresh carrots" />
          <span>Vegetables</span>
          <h3>Farm Fresh Carrots</h3>
          <div><strong>Rs.48</strong><a href="/login/client">Add</a></div>
        </article>
      </div>
    </section>

    <section id="contact" class="ecoshop-service-band" aria-label="Store services">
      <div><strong>Fast Delivery</strong><span>Local riders and quick dispatch</span></div>
      <div><strong>Fresh Quality</strong><span>Picked from trusted vendors</span></div>
      <div><strong>Easy Returns</strong><span>Support for order issues</span></div>
      <div><strong>Secure Checkout</strong><span>Simple account login flow</span></div>
    </section>
  </main>
</body>
</html>
