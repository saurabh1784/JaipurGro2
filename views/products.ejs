<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Product Management</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Products</p>
        <h1>Product Management</h1>
      </div>
      <div class="topbar-actions" style="display:flex; align-items:center; gap:12px;">
        <label class="system-search" aria-label="Search products" style="position:relative; width:380px;">
          <input id="nameFilter" type="search" placeholder="🔍 Search by Product ID (#3902), Name, SKU, Brand..." style="width:100%; padding-left:38px; height:44px; border-radius:12px; border:1px solid #cbd5e1; font-size:0.88rem; background:#fff; box-shadow:0 2px 8px rgba(0,0,0,0.04); transition:all 0.2s ease;" />
          <svg viewBox="0 0 24 24" aria-hidden="true" style="position:absolute; left:12px; top:13px; width:18px; height:18px; fill:none; stroke:#64748b; stroke-width:2;"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/></svg>
        </label>
      </div>
    </header>

    <section class="product-management-shell">
      <!-- Modern Executive Stat Cards Banner -->
      <div class="product-stats-grid" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(210px, 1fr)); gap:16px; margin-bottom:24px;">
        <div class="stat-card" style="background:linear-gradient(135deg, #4f46e5, #3730a3); color:#fff; border-radius:16px; padding:20px; box-shadow:0 10px 25px -5px rgba(79,70,229,0.25);">
          <div style="font-size:0.82rem; opacity:0.9; font-weight:700; text-transform:uppercase; letter-spacing:0.6px;">Total Catalog Products</div>
          <div style="font-size:2rem; font-weight:800; margin-top:6px; font-family:Inter, sans-serif;" id="statTotalProducts">0</div>
        </div>
        <div class="stat-card" style="background:linear-gradient(135deg, #10b981, #059669); color:#fff; border-radius:16px; padding:20px; box-shadow:0 10px 25px -5px rgba(16,185,129,0.25);">
          <div style="font-size:0.82rem; opacity:0.9; font-weight:700; text-transform:uppercase; letter-spacing:0.6px;">Approved & Active</div>
          <div style="font-size:2rem; font-weight:800; margin-top:6px; font-family:Inter, sans-serif;" id="statApproved">0</div>
        </div>
        <div class="stat-card" style="background:linear-gradient(135deg, #f59e0b, #d97706); color:#fff; border-radius:16px; padding:20px; box-shadow:0 10px 25px -5px rgba(245,158,11,0.25);">
          <div style="font-size:0.82rem; opacity:0.9; font-weight:700; text-transform:uppercase; letter-spacing:0.6px;">Approval Requests</div>
          <div style="font-size:2rem; font-weight:800; margin-top:6px; font-family:Inter, sans-serif;" id="statPending">0</div>
        </div>
        <div class="stat-card" style="background:linear-gradient(135deg, #ef4444, #dc2626); color:#fff; border-radius:16px; padding:20px; box-shadow:0 10px 25px -5px rgba(239,68,68,0.25);">
          <div style="font-size:0.82rem; opacity:0.9; font-weight:700; text-transform:uppercase; letter-spacing:0.6px;">Rejected Products</div>
          <div style="font-size:2rem; font-weight:800; margin-top:6px; font-family:Inter, sans-serif;" id="statRejected">0</div>
        </div>
      </div>
      <div class="products-action-band">
        <form id="productForm" class="product-form" style="background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%); border: 1px solid #7dd3fc; border-radius: 14px; padding: 14px 18px; box-shadow: 0 4px 20px -2px rgba(56, 189, 248, 0.18), 0 2px 6px rgba(14, 165, 233, 0.08); display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px 14px;">
          <div class="product-form-header" style="grid-column: 1 / -1; display: flex; justify-content: space-between; align-items: center; padding-bottom: 8px; border-bottom: 1px solid #bae6fd; margin-bottom: 2px;">
            <div>
              <h2 id="productFormTitle" style="margin:0; color:#0369a1; font-size:1.02rem; font-weight:800; font-family:Inter, sans-serif;">Single Product</h2>
              <p style="margin:2px 0 0; color:#0284c7; font-size:0.75rem;">Create & edit catalog entries with live linked image preview.</p>
            </div>
            <button class="product-secondary-button" type="button" id="resetProductForm" style="background:#bae6fd; color:#0369a1; border:none; padding:4px 12px; font-weight:700; border-radius:6px; cursor:pointer;">Clear</button>
          </div>
          <input type="hidden" id="productId" />

          <!-- Linked Product Image Preview Container -->
          <div id="productImagePreviewWrapper" style="grid-column: 1 / -1; display: flex; align-items: center; gap: 12px; background: #ffffff; padding: 8px 12px; border-radius: 10px; border: 1px solid #7dd3fc; box-shadow: 0 2px 6px rgba(56, 189, 248, 0.12);">
            <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0; background: #e0f2fe; border-radius: 8px; overflow: hidden; border: 1px solid #7dd3fc; display: flex; align-items: center; justify-content: center;">
              <img id="productImagePreview" src="/default.png" alt="Linked Product Image" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.onerror=null; this.src='/default.png';" />
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px;">
                <strong style="font-size: 0.78rem; color: #0369a1; font-weight: 700;">Linked Product Image</strong>
                <span id="productImageStatusBadge" style="font-size: 0.68rem; padding: 2px 8px; border-radius: 10px; background: #f1f5f9; color: #64748b; font-weight: 700;">No Image</span>
              </div>
              <div id="productImageUrlDisplay" style="font-size: 0.72rem; color: #0284c7; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px;" title="No image linked yet">No image linked yet</div>
            </div>
          </div>

          <label class="settings-wide" style="grid-column: 1 / -1; font-size:0.76rem; font-weight:700; color:#0369a1;">
            Name
            <input id="productName" type="text" required minlength="2" style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;" />
          </label>
          <label class="settings-wide" style="grid-column: 1 / -1; font-size:0.76rem; font-weight:700; color:#0369a1;">
            Description
            <textarea id="productDescription" rows="2" style="width:100%; min-height:46px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff; resize:vertical;"></textarea>
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Price (₹)
            <input id="productPrice" type="number" min="0" step="0.01" required style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;" />
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Weight
            <input id="productWeightValue" type="number" min="0" step="0.001" placeholder="Delivery weight" style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;" />
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Weight Unit
            <select id="productWeightUnit" style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;">
              <option value="g">Gram (g)</option>
              <option value="kg" selected>Kilogram (kg)</option>
              <option value="L">Liter (L)</option>
              <option value="ml">Milliliter (ml)</option>
              <option value="other">Other</option>
            </select>
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Tax Name
            <input id="productTaxName" type="text" placeholder="Category tax default" style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;" />
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Tax %
            <input id="productTaxPercentage" type="number" min="0" max="100" step="0.01" placeholder="Category default" style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;" />
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Main Category
            <select id="productCategory" required style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;"></select>
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Subcategory
            <select id="productSubcategory" required style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;"></select>
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Brand
            <select id="productBrand" required style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;"></select>
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Product Image File
            <input id="productImage" type="file" accept="image/png,image/jpeg,image/webp,image/gif" style="width:100%; min-height:34px; padding:4px 8px; font-size:0.82rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;" />
          </label>
          <label style="font-size:0.76rem; font-weight:700; color:#0369a1;">
            Product Image URL (Link)
            <input id="productImageUrl" type="url" placeholder="https://example.com/image.jpg" style="width:100%; min-height:34px; padding:6px 10px; font-size:0.85rem; border-radius:8px; border:1px solid #7dd3fc; background:#fff;" />
          </label>
          <div style="grid-column: 1 / -1; display:flex; align-items:center; gap:16px; margin-top:2px; background:#ffffff; padding:6px 12px; border-radius:8px; border:1px solid #7dd3fc;">
            <label class="product-sponsored-field" style="display:inline-flex; align-items:center; gap:6px; font-size:0.78rem; font-weight:700; color:#0369a1; cursor:pointer; margin:0;">
              <input id="productSponsored" type="checkbox" style="width:16px; height:16px; cursor:pointer;" />
              <span>Sponsored</span>
            </label>
            <label style="display:inline-flex; align-items:center; gap:6px; font-size:0.78rem; font-weight:700; color:#0369a1; margin:0;">
              Sponsored Priority:
              <input id="productSponsoredPriority" type="number" step="1" value="0" style="width:70px; min-height:30px; padding:2px 6px; font-size:0.82rem; border-radius:6px; border:1px solid #7dd3fc;" />
            </label>
          </div>
          <button class="settings-save" type="submit" id="productSubmit" style="grid-column: 1 / -1; min-height:38px; font-size:0.88rem; font-weight:700; background:linear-gradient(135deg, #0284c7, #0369a1); color:#fff; border:none; border-radius:8px; cursor:pointer; box-shadow:0 3px 10px rgba(2,132,199,0.3); margin-top:4px;">Save Product</button>
        </form>

        <div class="product-bulk-stack">
          <form id="bulkUploadForm" class="bulk-upload-panel">
            <div>
              <h2>Bulk Upload</h2>
              <p>Select a main category, then upload CSV, XLS, or XLSX with name, description, price, weight_value, weight_unit, tax_name, tax_percentage, subcategory, brand, and image_url.</p>
            </div>
            <label>
              Main Category
              <select id="bulkCategory" required></select>
            </label>
            <label>
              File
              <input id="bulkFile" name="file" type="file" accept=".csv,.xls,.xlsx" required />
            </label>
            <div class="bulk-actions">
              <button class="settings-save" type="submit">Upload</button>
              <button class="product-secondary-button" type="button" id="downloadTemplate">Template CSV</button>
            </div>
            <div id="bulkResult" class="product-message" aria-live="polite"></div>
          </form>

          <form id="imageUploadForm" class="bulk-upload-panel">
            <div>
              <h2>Bulk Image Upload</h2>
              <p>Download the prefilled CSV, add Image URL values, then upload it to link JPG, JPEG, PNG, or WebP images to products.</p>
            </div>
            <label>
              Image CSV
              <input id="imageUploadFile" name="file" type="file" accept=".csv" required />
            </label>
            <div class="bulk-actions">
              <button class="settings-save" type="submit">Upload Images</button>
              <button class="product-secondary-button" type="button" id="downloadImageTemplate">Image Template CSV</button>
            </div>
            <div id="imageUploadResult" class="product-message image-upload-result" aria-live="polite"></div>
          </form>
        </div>
      </div>

      <div class="product-approval-tabs" role="tablist" aria-label="Product approval views">
        <button class="product-approval-tab active" type="button" data-product-tab="approved">Approved Products</button>
        <button class="product-approval-tab" type="button" data-product-tab="requests">Product Approval Requests</button>
        <button class="product-approval-tab" type="button" data-product-tab="rejected">Rejected Products</button>
      </div>

      <div class="products-filter-bar" style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;">
        <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
          <label>
            Main Category
            <select id="categoryFilter"></select>
          </label>
          <label>
            Subcategory
            <select id="subcategoryFilter"></select>
          </label>
          <label>
            Brand
            <select id="brandFilter"></select>
          </label>
          <button class="product-secondary-button" type="button" id="clearFilters">Clear Filters</button>
        </div>
        <div id="productBulkDeleteContainer">
          <button type="button" id="deleteSelectedProductsBtn" style="display:none; background:#ef4444; color:#fff; font-weight:700; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; align-items:center; gap:6px;" onclick="deleteSelectedProducts()">
            <span>🗑️</span> Delete Selected (<span id="selectedProductCount">0</span>)
          </button>
        </div>
      </div>

      <div class="users-table-card products-table-card">
        <table class="users-table products-table">
          <thead>
            <tr>
              <th style="width:38px; text-align:center;">
                <input type="checkbox" id="selectAllProducts" style="width:18px; height:18px; cursor:pointer;" title="Select all products" onchange="toggleSelectAllProducts(this.checked)" />
              </th>
              <th>ID</th>
              <th>Name</th>
              <th>Image</th>
              <th>Description</th>
              <th>Main Category</th>
              <th>Subcategory</th>
              <th>Brand</th>
              <th>Tax</th>
              <th>Weight</th>
              <th>Search Boost</th>
              <th>Price</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="productsTableBody">
            <tr><td colspan="14">Loading products...</td></tr>
          </tbody>
        </table>
      </div>

      <div class="users-pagination">
        <button type="button" id="prevPage">Previous</button>
        <span id="pageInfo">Page 1</span>
        <button type="button" id="nextPage">Next</button>
      </div>
    </section>
  </main>

  <div class="user-modal" id="deleteModal" aria-hidden="true">
    <div class="confirm-card">
      <h2>Are you sure?</h2>
      <div class="confirm-actions">
        <button type="button" id="confirmDeleteYes">Yes</button>
        <button type="button" id="confirmDeleteNo">No</button>
      </div>
    </div>
  </div>

  <style>
    .product-thumb {
      width: 52px;
      height: 52px;
      object-fit: contain;
      border-radius: 10px;
      border: 1px solid #e2e8f0;
      background: #f8fafc;
      display: block;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .product-thumb:hover {
      transform: scale(1.15);
      box-shadow: 0 8px 20px rgba(0,0,0,0.12);
    }
    tr.selected-row {
      background-color: #fef2f2 !important;
      border-left: 4px solid #ef4444 !important;
    }
    .products-table-card {
      border-radius: 16px;
      border: 1px solid #e2e8f0;
      box-shadow: 0 4px 25px rgba(0,0,0,0.04);
      overflow: hidden;
    }
    .image-helper {
      color: #64748b;
      font-size: 0.78rem;
      line-height: 1.3;
    }
    .product-sponsored-field {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      min-height: 74px;
    }
    .product-sponsored-field input {
      width: 18px;
      height: 18px;
      flex: 0 0 auto;
    }
    .search-boost-cell {
      display: grid;
      grid-template-columns: 1fr 70px;
      gap: 6px;
      min-width: 220px;
    }
    .sponsored-toggle {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.78rem;
      color: #475569;
    }
    .priority-input,
    .keywords-input {
      min-width: 0;
      padding: 6px 7px;
      border: 1px solid #cbd5e1;
      border-radius: 4px;
      font-size: 0.78rem;
    }
    .keywords-input {
      grid-column: 1 / -1;
    }
    .search-boost-cell button {
      grid-column: 1 / -1;
      padding: 6px 8px;
      border: 0;
      border-radius: 6px;
      background: linear-gradient(135deg, #2563eb, #1d4ed8);
      color: #fff;
      cursor: pointer;
      font-weight: 700;
      transition: opacity 0.2s ease;
    }
    .search-boost-cell button:hover {
      opacity: 0.9;
    }
    .product-status-cell {
      display: grid;
      gap: 7px;
      min-width: 135px;
    }
    .product-status-select {
      width: 100%;
      min-width: 0;
      padding: 7px 8px;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      background: #fff;
      color: #172033;
      font-size: 0.8rem;
      font-weight: 800;
    }
    .product-approval-tabs {
      display: flex;
      gap: 10px;
      overflow-x: auto;
      padding: 8px 0 16px;
    }
    .product-approval-tab {
      border: 1px solid #e2e8f0;
      background: #fff;
      color: #475569;
      border-radius: 12px;
      padding: 10px 18px;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s ease;
      box-shadow: 0 2px 6px rgba(0,0,0,0.02);
    }
    .product-approval-tab:hover {
      background: #f8fafc;
      color: #1e293b;
    }
    .product-approval-tab.active {
      background: linear-gradient(135deg, #4f46e5, #3730a3);
      border-color: #4f46e5;
      color: #fff;
      box-shadow: 0 4px 14px rgba(79,70,229,0.25);
    }
    .approval-status-badge {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 5px 10px;
      font-weight: 800;
      font-size: 0.78rem;
      background: #eef2ff;
      color: #3730a3;
    }
    .approval-status-badge.approved { background: #dcfce7; color: #166534; }
    .approval-status-badge.rejected { background: #fee2e2; color: #991b1b; }
    .approval-status-badge.in_review { background: #fef3c7; color: #92400e; }
    .approval-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }
    .approval-actions button {
      border: 0;
      border-radius: 6px;
      padding: 6px 9px;
      cursor: pointer;
      font-weight: 700;
      background: #ede9fe;
      color: #4c1d95;
      transition: background 0.2s ease;
    }
    .approval-actions button:hover {
      background: #ddd6fe;
    }
  </style>

  <script>
    let catalog = { categories: [], subcategories: [], brands: [] };
    let products = [];
    let currentPage = 1;
    let totalPages = 1;
    let pendingDeleteId = null;
    let activeProductTab = 'approved';
    let selectedProductIds = new Set();

    function updateProductBulkDeleteUI() {
      const btn = document.getElementById('deleteSelectedProductsBtn');
      const countSpan = document.getElementById('selectedProductCount');
      const count = selectedProductIds.size;

      if (countSpan) countSpan.textContent = count;
      if (btn) btn.style.display = count > 0 ? 'inline-flex' : 'none';

      const selectAllCb = document.getElementById('selectAllProducts');
      if (selectAllCb) {
        const visibleCbs = Array.from(document.querySelectorAll('.product-select-cb'));
        selectAllCb.checked = visibleCbs.length > 0 && visibleCbs.every(cb => cb.checked);
      }
    }

    function toggleProductSelection(id, checked) {
      const strId = String(id);
      if (checked) {
        selectedProductIds.add(strId);
      } else {
        selectedProductIds.delete(strId);
      }
      const row = document.getElementById(`product-row-${id}`);
      if (row) {
        row.classList.toggle('selected-row', checked);
      }
      updateProductBulkDeleteUI();
    }

    function toggleSelectAllProducts(checked) {
      document.querySelectorAll('.product-select-cb').forEach(cb => {
        cb.checked = checked;
        const id = cb.getAttribute('data-id');
        if (id) {
          if (checked) selectedProductIds.add(String(id));
          else selectedProductIds.delete(String(id));
          const row = document.getElementById(`product-row-${id}`);
          if (row) row.classList.toggle('selected-row', checked);
        }
      });
      updateProductBulkDeleteUI();
    }

    async function deleteSelectedProducts() {
      const ids = Array.from(selectedProductIds);
      if (!ids.length) return;
      if (!confirm(`Are you sure you want to delete ${ids.length} selected product(s) from the database?`)) return;

      try {
        const response = await fetch('/products/bulk-delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ ids }),
        });
        const data = await readJsonResponse(response);
        if (data.success) {
          alert(data.message || `${ids.length} product(s) deleted successfully`);
          selectedProductIds.clear();
          loadProducts(currentPage);
        } else {
          alert(data.message || 'Failed to delete selected products');
        }
      } catch (err) {
        alert('Error deleting selected products: ' + err.message);
      }
    }

    const productForm = document.getElementById('productForm');
    const bulkUploadForm = document.getElementById('bulkUploadForm');
    const imageUploadForm = document.getElementById('imageUploadForm');
    const tableBody = document.getElementById('productsTableBody');
    const nameFilter = document.getElementById('nameFilter');
    const categoryFilter = document.getElementById('categoryFilter');
    const subcategoryFilter = document.getElementById('subcategoryFilter');
    const brandFilter = document.getElementById('brandFilter');
    const pageInfo = document.getElementById('pageInfo');
    const prevPage = document.getElementById('prevPage');
    const nextPage = document.getElementById('nextPage');
    const productTabs = document.querySelectorAll('.product-approval-tab');

    function debounce(fn, delay) {
      let timer;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => fn(...args), delay);
      };
    }

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
    }

    function optionList(items, emptyLabel) {
      return `<option value="">${emptyLabel}</option>` + items
        .slice()
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
        .map((item) => `<option value="${item.id}">${escapeHtml(item.name)}</option>`)
        .join('');
    }

    function subcategoryKey(item) {
      return item.sub_category_id || item.subcategory_id;
    }

    function uniqueBrands(items) {
      const seen = new Set();
      return items.filter((item) => {
        const key = String(item.name || '').trim().toLowerCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
    }

    function brandOptionList(items) {
      return '<option value="">All Brands</option>' + items
        .slice()
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
        .map((item) => `<option value="${escapeHtml(item.name)}">${escapeHtml(item.name)}</option>`)
        .join('');
    }

    function brandLogoMarkup(brand) {
      const initial = String(brand.name || '?').trim().charAt(0).toUpperCase() || '?';
      const label = escapeHtml(brand.name || 'Brand');
      const logo = brand.logo_path
        ? `<img class="brand-logo" src="${escapeHtml(brand.logo_path)}" alt="${label} logo" />`
        : `<span class="brand-logo-fallback" aria-hidden="true">${escapeHtml(initial)}</span>`;
      return `<span class="brand-display">${logo}<span>${label}</span></span>`;
    }

    function weightToKg(value, unit) {
      const amount = Number(value || 0);
      if (!Number.isFinite(amount) || amount <= 0) return 0;
      if (unit === 'g' || unit === 'ml') return amount / 1000;
      return amount;
    }

    function weightLabel(product) {
      if (product.weight_label) return product.weight_label;
      const value = Number(product.weight_value ?? product.weight_kg ?? 0);
      if (!value) return 'Not set';
      return `${Number(value.toFixed(3))} ${product.weight_unit || 'kg'}`;
    }

    function approvalStatusForTab() {
      if (activeProductTab === 'requests') return 'pending,in_review';
      if (activeProductTab === 'rejected') return 'rejected';
      return 'approved';
    }

    function statusLabel(status) {
      return String(status || 'pending')
        .split('_')
        .filter(Boolean)
        .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
        .join(' ');
    }

    function statusOption(value, currentStatus) {
      return `<option value="${value}" ${String(currentStatus || 'approved') === value ? 'selected' : ''}>${statusLabel(value)}</option>`;
    }

    async function readJsonResponse(response) {
      const text = await response.text();
      try {
        return text ? JSON.parse(text) : {};
      } catch (error) {
        return {
          success: false,
          message: response.redirected || response.status === 401
            ? 'Login required. Please sign in again.'
            : `Server returned a non-JSON response (${response.status}).`,
        };
      }
    }

    async function loadCatalog() {
      const response = await fetch('/products/catalog', { headers: { Accept: 'application/json' } });
      const data = await readJsonResponse(response);
      if (!data.success) throw new Error(data.message || 'Unable to load catalog');
      catalog = {
        categories: data.categories || [],
        subcategories: data.subcategories || [],
        brands: data.brands || [],
      };
      renderCatalogSelects();
    }

    function renderCatalogSelects() {
      document.getElementById('productCategory').innerHTML = optionList(catalog.categories, 'Select Main Category');
      document.getElementById('bulkCategory').innerHTML = optionList(catalog.categories, 'Select Main Category');
      categoryFilter.innerHTML = optionList(catalog.categories, 'All Main Categories');
      updateProductSubcategories();
      updateProductBrands();
      updateFilterSubcategories();
      updateFilterBrands();
    }

    function updateProductSubcategories(selectedId) {
      const categoryId = document.getElementById('productCategory').value;
      const items = catalog.subcategories.filter((item) => String(item.category_id) === String(categoryId));
      const select = document.getElementById('productSubcategory');
      select.innerHTML = optionList(items, 'Select Subcategory');
      if (selectedId) select.value = selectedId;
    }

    function updateProductBrands(selectedId) {
      const categoryId = document.getElementById('productCategory').value;
      const subcategoryId = document.getElementById('productSubcategory').value;
      const items = catalog.brands
        .filter((item) => String(item.category_id) === String(categoryId))
        .filter((item) => String(subcategoryKey(item)) === String(subcategoryId));
      const select = document.getElementById('productBrand');
      select.innerHTML = optionList(items, 'Select Brand');
      if (selectedId) select.value = selectedId;
    }

    function updateFilterSubcategories() {
      const categoryId = categoryFilter.value;
      const items = categoryId
        ? catalog.subcategories.filter((item) => String(item.category_id) === String(categoryId))
        : catalog.subcategories;
      subcategoryFilter.innerHTML = optionList(items, 'All Subcategories');
    }

    function updateFilterBrands() {
      const categoryId = categoryFilter.value;
      const subcategoryId = subcategoryFilter.value;
      const items = uniqueBrands(catalog.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(subcategoryKey(item)) === String(subcategoryId)));
      brandFilter.innerHTML = brandOptionList(items);
    }

    async function loadProducts(page = 1) {
      const params = new URLSearchParams({
        format: 'json',
        page,
        limit: 10,
        name: nameFilter.value.trim(),
        category_id: categoryFilter.value,
        sub_category_id: subcategoryFilter.value,
        brand_name: brandFilter.value,
        approval_status: approvalStatusForTab(),
      });
      const response = await fetch(`/products?${params.toString()}`, { headers: { Accept: 'application/json' } });
      const data = await readJsonResponse(response);
      if (!data.success) {
        tableBody.innerHTML = `<tr><td colspan="14">${escapeHtml(data.message || 'Unable to load products')}</td></tr>`;
        return;
      }
      products = data.products || [];
      currentPage = data.pagination.page;
      totalPages = data.pagination.totalPages;

      // Update stat cards dynamically
      const totalCount = data.pagination ? data.pagination.total : products.length;
      document.getElementById('statTotalProducts').textContent = totalCount;
      if (activeProductTab === 'approved') document.getElementById('statApproved').textContent = totalCount;
      if (activeProductTab === 'requests') document.getElementById('statPending').textContent = totalCount;
      if (activeProductTab === 'rejected') document.getElementById('statRejected').textContent = totalCount;

      renderProducts();
    }

    function renderProducts() {
      if (!products.length) {
        tableBody.innerHTML = '<tr><td colspan="14">No products found</td></tr>';
      } else {
        tableBody.innerHTML = products.map((product) => `
          <tr id="product-row-${product.id}" class="${selectedProductIds.has(String(product.id)) ? 'selected-row' : ''}">
            <td style="text-align:center;">
              <input type="checkbox" class="product-select-cb" data-id="${product.id}" ${selectedProductIds.has(String(product.id)) ? 'checked' : ''} style="width:18px; height:18px; cursor:pointer;" onchange="toggleProductSelection(${product.id}, this.checked)" />
            </td>
            <td>#${product.id}</td>
            <td>${escapeHtml(product.name)}</td>
            <td><img class="product-thumb" src="${escapeHtml(product.image_url || '/default.png')}" alt="${escapeHtml(product.name)}" loading="lazy" /></td>
            <td class="product-description-cell">${escapeHtml(product.description || '-')}</td>
            <td>${escapeHtml(product.category_name)}</td>
            <td>${escapeHtml(product.sub_category_name)}</td>
            <td>${brandLogoMarkup({ name: product.brand_name, logo_path: product.brand_logo_path })}</td>
            <td>
              <strong>${escapeHtml(product.applied_tax_name || product.tax_name || product.category_tax_name || 'No tax')}</strong><br>
              <small>${Number(product.applied_tax_percentage || 0).toFixed(2)}%${product.tax_percentage === null || product.tax_percentage === undefined ? ' category' : ' product'}</small>
            </td>
            <td>
              <strong>${escapeHtml(weightLabel(product))}</strong><br>
              <small>${Number(product.weight_kg || 0).toFixed(3)} kg delivery</small>
            </td>
            <td>
              <div class="search-boost-cell">
                <label class="sponsored-toggle">
                  <input type="checkbox" id="sponsored-${product.id}" ${product.is_sponsored ? 'checked' : ''} />
                  Sponsored
                </label>
                <input class="priority-input" id="priority-${product.id}" type="number" step="1" value="${Number(product.sponsored_priority || 0)}" title="Sponsored priority" />
                <input class="keywords-input" id="keywords-${product.id}" type="text" value="${escapeHtml(product.keywords || '')}" placeholder="tags, keywords" />
                <button type="button" onclick="saveSearchSettings(${product.id})">Boost</button>
              </div>
            </td>
            <td>
              <input class="inline-price-input" id="price-${product.id}" type="number" min="0" step="0.01" value="${Number(product.price).toFixed(2)}" />
            </td>
            <td>
              <div class="product-status-cell">
                <span class="approval-status-badge ${escapeHtml(product.approval_status || 'approved')}">${statusLabel(product.approval_status || 'approved')}</span>
                <select class="product-status-select" id="status-${product.id}">
                  ${statusOption('pending', product.approval_status)}
                  ${statusOption('in_review', product.approval_status)}
                  ${statusOption('approved', product.approval_status)}
                  ${statusOption('rejected', product.approval_status)}
                </select>
                ${product.rejection_reason ? `<small>${escapeHtml(product.rejection_reason)}</small>` : ''}
              </div>
              ${activeProductTab !== 'approved' ? `
                <div class="approval-actions">
                  <button type="button" onclick="changeApprovalStatus(${product.id}, 'in_review')">In Review</button>
                  <button type="button" onclick="changeApprovalStatus(${product.id}, 'approved')">Approve</button>
                  <button type="button" onclick="changeApprovalStatus(${product.id}, 'rejected')">Reject</button>
                </div>
              ` : ''}
            </td>
            <td>
              <div class="user-actions">
                <button type="button" onclick="editProduct(${product.id})">Edit</button>
                <button type="button" onclick="saveProductRow(${product.id})">Save</button>
                <button type="button" onclick="askDelete(${product.id})">Delete</button>
              </div>
            </td>
          </tr>
        `).join('');
      }
      updateProductBulkDeleteUI();
      pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
      prevPage.disabled = currentPage <= 1;
      nextPage.disabled = currentPage >= totalPages;
    }

    function updateProductImagePreview(src) {
      const imgEl = document.getElementById('productImagePreview');
      const displayEl = document.getElementById('productImageUrlDisplay');
      const badgeEl = document.getElementById('productImageStatusBadge');

      if (!imgEl || !displayEl || !badgeEl) return;

      if (src instanceof File) {
        const blobUrl = URL.createObjectURL(src);
        imgEl.src = blobUrl;
        displayEl.textContent = `File selected: ${src.name}`;
        displayEl.title = src.name;
        badgeEl.textContent = 'Selected File';
        badgeEl.style.background = '#dcfce7';
        badgeEl.style.color = '#15803d';
      } else if (src && typeof src === 'string' && src.trim()) {
        const cleanSrc = src.trim();
        imgEl.src = cleanSrc;
        displayEl.textContent = cleanSrc;
        displayEl.title = cleanSrc;
        badgeEl.textContent = 'Linked Image';
        badgeEl.style.background = '#e0f2fe';
        badgeEl.style.color = '#0369a1';
      } else {
        imgEl.src = '/default.png';
        displayEl.textContent = 'No image linked yet';
        displayEl.title = 'No image linked yet';
        badgeEl.textContent = 'No Image';
        badgeEl.style.background = '#f1f5f9';
        badgeEl.style.color = '#64748b';
      }
    }

    function resetForm() {
      productForm.reset();
      document.getElementById('productId').value = '';
      document.getElementById('productFormTitle').textContent = 'Single Product';
      document.getElementById('productSubmit').textContent = 'Save Product';
      document.getElementById('productSponsored').checked = false;
      document.getElementById('productSponsoredPriority').value = 0;
      updateProductSubcategories();
      updateProductBrands();
      updateProductImagePreview('');
    }

    function editProduct(id) {
      const product = products.find((item) => item.id === id);
      if (!product) return;
      document.getElementById('productId').value = product.id;
      document.getElementById('productName').value = product.name;
      document.getElementById('productDescription').value = product.description || '';
      document.getElementById('productPrice').value = Number(product.price).toFixed(2);
      document.getElementById('productWeightValue').value = Number(product.weight_value ?? product.weight_kg ?? 0).toFixed(3);
      document.getElementById('productWeightUnit').value = product.weight_unit || 'kg';
      document.getElementById('productTaxName').value = product.tax_name || '';
      document.getElementById('productTaxPercentage').value = product.tax_percentage === null || product.tax_percentage === undefined ? '' : Number(product.tax_percentage).toFixed(2);
      document.getElementById('productImage').value = '';
      const currentImg = product.image_url || product.image || product.image_path || '';
      document.getElementById('productImageUrl').value = currentImg;
      updateProductImagePreview(currentImg);
      document.getElementById('productCategory').value = product.category_id;
      updateProductSubcategories(product.sub_category_id);
      updateProductBrands(product.brand_id);
      document.getElementById('productSponsored').checked = Boolean(product.is_sponsored);
      document.getElementById('productSponsoredPriority').value = Number(product.sponsored_priority || 0);
      document.getElementById('productFormTitle').textContent = 'Edit Product';
      document.getElementById('productSubmit').textContent = 'Update Product';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    async function saveProductRow(id) {
      const product = products.find((item) => Number(item.id) === Number(id));
      const price = document.getElementById(`price-${id}`).value;
      const status = document.getElementById(`status-${id}`).value;

      const priceResponse = await fetch(`/products/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ price }),
      });
      const priceData = await readJsonResponse(priceResponse);
      if (!priceData.success) {
        alert(priceData.message || 'Unable to save price');
        return;
      }

      if (!product || String(product.approval_status || 'approved') !== status) {
        const body = { status };
        if (status === 'rejected') {
          const reason = prompt('Reason for rejecting this product request?') || '';
          if (!reason.trim()) {
            loadProducts(currentPage);
            return;
          }
          body.rejection_reason = reason.trim();
        }
        const statusResponse = await fetch(`/products/${id}/approval-status`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(body),
        });
        const statusData = await readJsonResponse(statusResponse);
        if (!statusData.success) {
          alert(statusData.message || 'Unable to save product status');
          return;
        }
      }

      loadProducts(currentPage);
    }

    async function saveSearchSettings(id) {
      const response = await fetch(`/products/${id}/search-settings`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          is_sponsored: document.getElementById(`sponsored-${id}`).checked,
          sponsored_priority: document.getElementById(`priority-${id}`).value,
          keywords: document.getElementById(`keywords-${id}`).value,
        }),
      });
      const data = await readJsonResponse(response);
      if (!data.success) {
        alert(data.message || 'Unable to save search settings');
        return;
      }
      loadProducts(currentPage);
    }

    async function changeApprovalStatus(id, status) {
      const body = { status };
      if (status === 'rejected') {
        const reason = prompt('Reason for rejecting this product request?') || '';
        if (!reason.trim()) return;
        body.rejection_reason = reason.trim();
      }
      const response = await fetch(`/products/${id}/approval-status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await readJsonResponse(response);
      if (!data.success) {
        alert(data.message || 'Unable to update approval status');
        return;
      }
      loadProducts(currentPage);
    }

    function loadImageElement(file) {
      return new Promise((resolve, reject) => {
        const image = new Image();
        image.onload = () => resolve(image);
        image.onerror = () => reject(new Error('Unable to read selected image'));
        image.src = URL.createObjectURL(file);
      });
    }

    async function fitImageForProductCard(file) {
      const image = await loadImageElement(file);
      const canvas = document.createElement('canvas');
      canvas.width = 800;
      canvas.height = 600;
      const context = canvas.getContext('2d');
      context.fillStyle = '#ffffff';
      context.fillRect(0, 0, canvas.width, canvas.height);

      const scale = Math.min(canvas.width / image.naturalWidth, canvas.height / image.naturalHeight);
      const width = image.naturalWidth * scale;
      const height = image.naturalHeight * scale;
      const x = (canvas.width - width) / 2;
      const y = (canvas.height - height) / 2;
      context.drawImage(image, x, y, width, height);
      URL.revokeObjectURL(image.src);

      return new Promise((resolve) => {
        canvas.toBlob((blob) => {
          resolve(new File([blob], file.name.replace(/\.[^.]+$/, '') + '-fit.webp', { type: 'image/webp' }));
        }, 'image/webp', 0.92);
      });
    }

    function askDelete(id) {
      pendingDeleteId = id;
      document.getElementById('deleteModal').classList.add('active');
    }

    async function deleteProduct() {
      if (!pendingDeleteId) return;
      const response = await fetch(`/products/${pendingDeleteId}`, { method: 'DELETE', headers: { Accept: 'application/json' } });
      const data = await readJsonResponse(response);
      pendingDeleteId = null;
      document.getElementById('deleteModal').classList.remove('active');
      if (!data.success) {
        alert(data.message || 'Unable to delete product');
        return;
      }
      loadProducts(currentPage);
    }

    productForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = document.getElementById('productId').value;
      const payload = new FormData();
      payload.append('name', document.getElementById('productName').value);
      payload.append('description', document.getElementById('productDescription').value);
      payload.append('price', document.getElementById('productPrice').value);
      const weightValue = document.getElementById('productWeightValue').value;
      const weightUnit = document.getElementById('productWeightUnit').value;
      payload.append('weight_value', weightValue);
      payload.append('weight_unit', weightUnit);
      payload.append('weight_kg', weightToKg(weightValue, weightUnit));
      payload.append('tax_name', document.getElementById('productTaxName').value);
      payload.append('tax_percentage', document.getElementById('productTaxPercentage').value);
      payload.append('category_id', document.getElementById('productCategory').value);
      payload.append('sub_category_id', document.getElementById('productSubcategory').value);
      payload.append('brand_id', document.getElementById('productBrand').value);
      payload.append('is_sponsored', document.getElementById('productSponsored').checked ? 'true' : 'false');
      payload.append('sponsored_priority', document.getElementById('productSponsoredPriority').value || '0');
      const imageUrlVal = document.getElementById('productImageUrl').value.trim();
      if (imageUrlVal) payload.append('image_url', imageUrlVal);
      const image = document.getElementById('productImage').files[0];
      if (image) payload.append('image', await fitImageForProductCard(image));

      const response = await fetch(`/products${id ? `/${id}` : ''}`, {
        method: id ? 'PUT' : 'POST',
        headers: { Accept: 'application/json' },
        body: payload,
      });
      const data = await readJsonResponse(response);
      if (!data.success) {
        alert(data.message || (data.errors || []).join(', ') || 'Unable to save product');
        return;
      }
      resetForm();
      loadProducts(id ? currentPage : 1);
    });


    function csvCell(value) {
      const text = String(value === null || value === undefined ? '' : value);
      return /[",\r\n]/.test(text) ? `"${text.replace(/"/g, '""')}"` : text;
    }

    function csvFromRows(rows, fallbackHeaders) {
      const headers = fallbackHeaders && fallbackHeaders.length
        ? fallbackHeaders
        : Array.from(rows.reduce((set, row) => {
            Object.keys(row || {}).forEach((key) => set.add(key));
            return set;
          }, new Set()));
      return [headers.join(','), ...rows.map((row) => headers.map((key) => csvCell(row ? row[key] : '')).join(','))].join('\n');
    }

    function copyBulkReport(button) {
      const target = document.getElementById(button.dataset.copyTarget);
      if (!target) return;
      target.select();
      navigator.clipboard.writeText(target.value).then(() => {
        button.textContent = 'Copied';
        setTimeout(() => { button.textContent = 'Copy Error Text'; }, 1400);
      }).catch(() => document.execCommand('copy'));
    }

    function downloadBulkReport(button) {
      const target = document.getElementById(button.dataset.copyTarget);
      if (!target) return;
      const link = document.createElement('a');
      link.href = URL.createObjectURL(new Blob([target.value], { type: 'text/csv' }));
      link.download = button.dataset.filename || 'bulk-upload-errors.csv';
      link.click();
      URL.revokeObjectURL(link.href);
    }

    function errorLine(item) {
      const id = item.product_id || item.identifier || (item.row && (item.row['Product ID or SKU'] || item.row.product_id || item.row.id)) || '-';
      const name = item.product_name || (item.row && (item.row.name || item.row['Product Name'])) || '-';
      const reason = item.reason || (item.errors || []).join('; ') || 'Unable to upload';
      return `Row ${item.rowNumber || '-'} | ID/SKU: ${id} | Product: ${name} | Error: ${reason}`;
    }

    function editableErrorCsv(items, fallbackHeaders) {
      const rows = (items || []).map((item) => item.row || {
        row: item.rowNumber || '',
        product_id_or_sku: item.product_id || item.identifier || '',
        product_name: item.product_name || '',
        image_url: item.image_url || '',
        error: item.reason || (item.errors || []).join('; ') || '',
      });
      return csvFromRows(rows, fallbackHeaders);
    }

    function renderEditableErrorReport({ title, message, lines, csv, textareaId, tone = 'error', summary = [] }) {
      const safeLines = lines || [];
      const hasErrors = safeLines.length > 0;
      const summaryHtml = summary.length ? `
        <div class="upload-result-summary">
          ${summary.map((item) => `
            <div class="upload-result-stat ${escapeHtml(item.tone || '')}">
              <span>${escapeHtml(item.label)}</span>
              <strong>${escapeHtml(item.value)}</strong>
            </div>
          `).join('')}
        </div>
      ` : '';
      const list = hasErrors ? `<ul class="upload-error-list">${safeLines.slice(0, 12).map((line) => `<li>${escapeHtml(line)}</li>`).join('')}</ul>` : '';
      const more = safeLines.length > 12 ? `<small>${safeLines.length - 12} more error row(s) are in the copy box.</small>` : '';
      const tools = hasErrors ? `
        <div class="bulk-error-tools">
          <button class="bulk-error-copy" type="button" data-copy-target="${escapeHtml(textareaId)}" onclick="copyBulkReport(this)">Copy Error Text</button>
          <button class="bulk-error-copy" type="button" data-copy-target="${escapeHtml(textareaId)}" data-filename="${escapeHtml(textareaId)}.csv" onclick="downloadBulkReport(this)">Download CSV</button>
        </div>
        <textarea id="${escapeHtml(textareaId)}" class="bulk-error-textarea" spellcheck="false">${escapeHtml(csv)}</textarea>
      ` : '';
      return `
        <article class="upload-result-card ${escapeHtml(tone)}">
          <div class="upload-result-header">
            <div>
              <span>${hasErrors ? 'Needs Attention' : 'Upload Complete'}</span>
              <strong>${escapeHtml(title)}</strong>
            </div>
          </div>
          <p>${escapeHtml(message)}</p>
          ${summaryHtml}${list}${more}${tools}
        </article>
      `;
    }

    function renderUploadRequestError(title, error, textareaId) {
      const message = error && error.message ? error.message : 'Upload request failed';
      return renderEditableErrorReport({
        title,
        message,
        lines: [message],
        csv: message,
        textareaId,
        tone: 'error',
      });
    }

    function renderProductBulkResult(data) {
      const failed = data.failed || [];
      const duplicates = data.duplicate_products_skipped || [];
      const imageWarnings = data.image_warnings || [];
      const notUploaded = [...failed, ...duplicates];
      const createdCount = Number(data.created_count || data.total_products_uploaded || 0);
      const requestError = data.success === false && notUploaded.length === 0 && imageWarnings.length === 0;
      const requestLines = requestError ? [data.message || 'Upload failed'] : notUploaded.map(errorLine);
      const card = renderEditableErrorReport({
        title: requestError ? 'Product upload failed' : (notUploaded.length ? `Product upload completed with issues: ${notUploaded.length}` : 'Product upload successful'),
        message: requestError ? 'The upload could not be processed.' : (notUploaded.length ? 'Download the failed rows, correct them, and upload again.' : (imageWarnings.length ? 'Products were uploaded, but some image URLs could not be downloaded.' : (data.message || 'Upload complete'))),
        lines: requestLines,
        csv: requestError ? requestLines.join('\n') : editableErrorCsv(notUploaded, ['name', 'description', 'price', 'weight_value', 'weight_unit', 'tax_name', 'tax_percentage', 'subcategory', 'subcategory_code', 'brand', 'brand_code', 'image_url']),
        textareaId: 'productBulkErrorCsv',
        tone: requestError || notUploaded.length ? 'error' : (imageWarnings.length ? 'warning' : 'success'),
        summary: [
          { label: 'Products', value: createdCount, tone: 'success' },
          { label: 'New Subcategories', value: data.new_subcategories_count || 0, tone: 'success' },
          { label: 'New Brands', value: data.new_brands_count || 0, tone: 'success' },
          { label: 'Images', value: data.images_uploaded_count || 0, tone: 'success' },
          { label: 'Duplicates', value: data.duplicate_products_skipped_count || duplicates.length, tone: duplicates.length ? 'warning' : 'success' },
          { label: 'Errors', value: failed.length, tone: failed.length ? 'error' : 'success' },
          { label: 'Image Warnings', value: imageWarnings.length, tone: imageWarnings.length ? 'warning' : 'success' },
        ],
      });
      const warnings = imageWarnings.length
        ? `<div class="image-upload-group"><strong>Image warnings: ${imageWarnings.length}</strong><ul class="upload-error-list compact">${imageWarnings.slice(0, 8).map((item) => `<li>${escapeHtml(errorLine(item))}</li>`).join('')}</ul>${imageWarnings.length > 8 ? `<small>${imageWarnings.length - 8} more image warning(s).</small>` : ''}</div>`
        : '';
      return card.replace('</article>', `${warnings}</article>`);
    }

    function imageResultItems(items) {
      return (items || []).slice(0, 8).map((item) => {
        const label = item.product_name || item.identifier || item.product_id || `row ${item.rowNumber}`;
        const reason = item.reason ? ` - ${item.reason}` : item.action ? ` - ${item.action}` : '';
        return `<li>Row ${escapeHtml(item.rowNumber)}: ${escapeHtml(label)}${escapeHtml(reason)}</li>`;
      }).join('');
    }

    function renderImageUploadResult(data) {
      const requestError = data.success === false
        && !(data.successful_uploads || []).length
        && !(data.invalid_image_urls || []).length
        && !(data.failed_downloads || []).length
        && !(data.products_not_found || []).length
        && !(data.skipped_or_duplicates || []).length;
      if (requestError) {
        const message = data.message || 'Image upload failed';
        return renderEditableErrorReport({
          title: 'Image upload failed',
          message: 'The image upload could not be processed.',
          lines: [message],
          csv: message,
          textareaId: 'imageBulkErrorCsv',
          tone: 'error',
        });
      }
      const groups = [
        ['Uploaded', data.successful_uploads, 'success'],
        ['Invalid URLs', data.invalid_image_urls, 'error'],
        ['Download Failed', data.failed_downloads, 'error'],
        ['Not Found', data.products_not_found, 'error'],
        ['Skipped', data.skipped_or_duplicates, 'warning'],
      ];
      const problemRows = [
        ...(data.invalid_image_urls || []),
        ...(data.failed_downloads || []),
        ...(data.products_not_found || []),
        ...(data.skipped_or_duplicates || []),
      ];
      const detailHtml = groups.map(([title, items]) => {
        const count = (items || []).length;
        if (!count) return '';
        const details = `<ul class="upload-error-list compact">${imageResultItems(items)}</ul>`;
        const more = count > 8 ? `<small>${count - 8} more row(s) are in the copy box.</small>` : '';
        return `<div class="image-upload-group"><strong>${escapeHtml(title)}: ${count}</strong>${details}${more}</div>`;
      }).join('');
      const card = renderEditableErrorReport({
        title: problemRows.length ? `Image upload errors: ${problemRows.length}` : 'Image upload successful',
        message: problemRows.length ? 'Fix the image rows below and upload the corrected CSV again.' : (data.message || 'Image upload complete'),
        lines: problemRows.map(errorLine),
        csv: editableErrorCsv(problemRows, ['Product ID or SKU', 'Product Name', 'Brand Name', 'Weight', 'Image URL']),
        textareaId: 'imageBulkErrorCsv',
        tone: problemRows.length ? 'error' : 'success',
        summary: groups.map(([title, items, tone]) => ({ label: title, value: (items || []).length, tone })),
      });
      return card.replace('</article>', `${detailHtml}</article>`);
    }
    bulkUploadForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const result = document.getElementById('bulkResult');
      const categoryId = document.getElementById('bulkCategory').value;
      if (!categoryId) {
        result.innerHTML = renderUploadRequestError('Product upload failed', new Error('Select a main category before uploading products.'), 'productBulkRequestError');
        return;
      }
      const formData = new FormData(bulkUploadForm);
      formData.set('category_id', categoryId);
      result.innerHTML = '<article class="upload-result-card"><p>Uploading products... checking subcategories, brands, and image URLs.</p></article>';
      if (typeof showBulkUploadProgressModal === 'function') {
        showBulkUploadProgressModal({
          title: 'Uploading Products Bulk Data',
          subtitle: 'Processing CSV rows, subcategories, brands & product entries...',
          message: 'Reading uploaded product file, validating product columns, creating new subcategories/brands, and writing product catalog entries into the database.'
        });
      }
      try {
        const response = await fetch('/products/bulk-upload', { method: 'POST', headers: { Accept: 'application/json' }, body: formData });
        const data = await readJsonResponse(response);
        result.innerHTML = renderProductBulkResult(data);
        if (data.created_count) {
          bulkUploadForm.reset();
          loadCatalog().then(() => loadProducts(1));
        }
      } catch (error) {
        result.innerHTML = renderUploadRequestError('Product upload failed', error, 'productBulkRequestError');
      } finally {
        if (typeof hideBulkUploadProgressModal === 'function') {
          hideBulkUploadProgressModal();
        }
      }
    });

    imageUploadForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const result = document.getElementById('imageUploadResult');
      const formData = new FormData(imageUploadForm);
      result.innerHTML = '<article class="upload-result-card"><p>Uploading images...</p></article>';
      if (typeof showBulkUploadProgressModal === 'function') {
        showBulkUploadProgressModal({
          title: 'Uploading Bulk Product Images',
          subtitle: 'Processing and optimizing product image files...',
          message: 'Uploading image files, scaling dimensions, and matching product image associations in the database.'
        });
      }
      try {
        const response = await fetch('/products/bulk-image-upload', { method: 'POST', headers: { Accept: 'application/json' }, body: formData });
        const data = await readJsonResponse(response);
        result.innerHTML = renderImageUploadResult(data);
        if (data.successful_uploads && data.successful_uploads.length) {
          imageUploadForm.reset();
          loadProducts(currentPage);
        }
      } catch (error) {
        result.innerHTML = renderUploadRequestError('Image upload failed', error, 'imageBulkRequestError');
      } finally {
        if (typeof hideBulkUploadProgressModal === 'function') {
          hideBulkUploadProgressModal();
        }
      }
    });
    document.getElementById('productCategory').addEventListener('change', () => {
      updateProductSubcategories();
      updateProductBrands();
    });
    document.getElementById('resetProductForm').addEventListener('click', resetForm);
    const productImageInput = document.getElementById('productImage');
    const productImageUrlInput = document.getElementById('productImageUrl');
    if (productImageInput) {
      productImageInput.addEventListener('change', function () {
        if (this.files && this.files[0]) {
          updateProductImagePreview(this.files[0]);
        } else {
          updateProductImagePreview(productImageUrlInput ? productImageUrlInput.value : '');
        }
      });
    }
    if (productImageUrlInput) {
      const onUrlChange = () => {
        const hasFile = productImageInput && productImageInput.files && productImageInput.files[0];
        if (!hasFile) {
          updateProductImagePreview(productImageUrlInput.value);
        }
      };
      productImageUrlInput.addEventListener('input', onUrlChange);
      productImageUrlInput.addEventListener('change', onUrlChange);
    }
    document.getElementById('clearFilters').addEventListener('click', () => {
      nameFilter.value = '';
      categoryFilter.value = '';
      updateFilterSubcategories();
      updateFilterBrands();
      loadProducts(1);
    });
    categoryFilter.addEventListener('change', () => {
      updateFilterSubcategories();
      subcategoryFilter.value = '';
      updateFilterBrands();
      loadProducts(1);
    });
    subcategoryFilter.addEventListener('change', () => {
      updateFilterBrands();
      loadProducts(1);
    });
    brandFilter.addEventListener('change', () => loadProducts(1));
    productTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activeProductTab = tab.dataset.productTab;
        productTabs.forEach((item) => item.classList.toggle('active', item === tab));
        loadProducts(1);
      });
    });
    nameFilter.addEventListener('input', debounce(() => loadProducts(1), 300));
    prevPage.addEventListener('click', () => loadProducts(currentPage - 1));
    nextPage.addEventListener('click', () => loadProducts(currentPage + 1));
    document.getElementById('confirmDeleteYes').addEventListener('click', deleteProduct);
    document.getElementById('confirmDeleteNo').addEventListener('click', () => {
      pendingDeleteId = null;
      document.getElementById('deleteModal').classList.remove('active');
    });
    document.getElementById('downloadTemplate').addEventListener('click', () => {
      const csv = 'name,description,price,weight_value,weight_unit,tax_name,tax_percentage,subcategory,subcategory_code,brand,brand_code,image_url\nSample Rice,Long grain rice,120,5,kg,GST,5,Rice,rice,Fortune,fortune,https://example.com/sample-rice.jpg\n';
      const link = document.createElement('a');
      link.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
      link.download = 'product-upload-template.csv';
      link.click();
      URL.revokeObjectURL(link.href);
    });

    document.getElementById('downloadImageTemplate').addEventListener('click', () => {
      window.location.href = '/products/image-upload-template';
    });

    loadCatalog()
      .then(() => loadProducts())
      .catch((error) => {
        tableBody.innerHTML = `<tr><td colspan="12">${escapeHtml(error.message)}</td></tr>`;
      });
  </script>
  <script src="/image-upload-editor.js"></script>
  <%- include('partials/clean_modal') %>
  <%- include('partials/bulk_upload_progress_modal') %>
</body>
</html>
