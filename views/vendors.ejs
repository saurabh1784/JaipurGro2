<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vendor Management</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Vendors</p>
        <h1>Vendor Management</h1>
      </div>
      <div class="topbar-actions">
        <label class="system-search" aria-label="Search vendors">
          <input id="vendorSearch" type="search" placeholder="Search vendors" />
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/></svg>
        </label>
      </div>
    </header>

    <section class="vendor-management-shell">
      <div class="users-toolbar">
        <div>
          <h2>All Vendors</h2>
          <p>Register vendors, update business details, and control account status.</p>
        </div>
        <div class="vendor-toolbar-actions">
          <label>
            Country
            <select id="countryFilter"></select>
          </label>
          <label>
            State
            <select id="stateFilter"></select>
          </label>
          <label>
            City
            <select id="cityFilter"></select>
          </label>
          <label>
            Status
            <select id="statusFilter">
              <option value="">All Status</option>
              <option value="active">active</option>
              <option value="inactive">inactive</option>
            </select>
          </label>
          <button class="product-secondary-button" type="button" id="clearVendorFilters">Clear</button>
          <button class="settings-save" type="button" id="addVendorButton">Add New Vendor</button>
        </div>
      </div>

      <div class="users-table-card">
        <table class="users-table vendors-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Vendor</th>
              <th>Business</th>
              <th>Phone</th>
              <th>Location</th>
              <th>Services</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="vendorsTableBody">
            <tr><td colspan="8">Loading vendors...</td></tr>
          </tbody>
        </table>
      </div>

      <div class="users-pagination">
        <button type="button" id="prevPage">Previous</button>
        <span id="pageInfo">Page 1</span>
        <button type="button" id="nextPage">Next</button>
      </div>
    </section>
  </main>

  <div class="user-modal" id="vendorModal" aria-hidden="true">
    <div class="user-modal-card">
      <div class="user-modal-header">
        <h2 id="vendorModalTitle">Add Vendor</h2>
        <button type="button" onclick="closeVendorModal()">Close</button>
      </div>
      <form id="vendorForm" class="user-modal-grid">
        <input type="hidden" id="vendorId" />
        <label>
          Name
          <input id="vendorName" type="text" required minlength="2" />
        </label>
        <label>
          Business Name
          <input id="businessName" type="text" required minlength="2" />
        </label>
        <label>
          Email
          <input id="vendorEmail" type="email" required />
        </label>
        <label>
          Phone
          <input id="vendorPhone" type="text" required />
        </label>
        <label>
          Password
          <input id="vendorPassword" type="password" minlength="6" />
        </label>
        <label>
          Status
          <select id="vendorStatus" required>
            <option value="active">active</option>
            <option value="inactive">inactive</option>
          </select>
        </label>
        <label>
          GST Number
          <input id="gstNumber" type="text" />
        </label>
        <label>
          Aadhaar Front
          <input id="aadhaarFront" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
          <span class="vendor-file-preview" id="aadhaarFrontPreview"></span>
        </label>
        <label>
          Aadhaar Back
          <input id="aadhaarBack" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
          <span class="vendor-file-preview" id="aadhaarBackPreview"></span>
        </label>
        <label>
          Store Image
          <input id="storeImage" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
          <span class="vendor-file-preview" id="storeImagePreview"></span>
        </label>
        <label>
          Profile Image
          <input id="profileImage" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
          <span class="vendor-file-preview" id="profileImagePreview"></span>
        </label>
        <label>
          Country
          <select id="vendorCountry" required></select>
        </label>
        <label>
          State
          <select id="vendorState" required></select>
        </label>
        <label>
          City
          <select id="vendorCity" required></select>
        </label>
        <label>
          Services
          <input id="vendorServices" type="text" placeholder="Delivery, Wholesale" />
        </label>
        <label class="settings-wide">
          Address
          <textarea id="vendorAddress" rows="3"></textarea>
        </label>
        <button class="settings-save" type="submit" id="vendorSubmit">Save Vendor</button>
      </form>
    </div>
  </div>

  <div class="user-modal" id="deleteVendorModal" aria-hidden="true">
    <div class="confirm-card">
      <h2>Delete vendor?</h2>
      <div class="confirm-actions">
        <button type="button" id="deleteVendorYes">Yes</button>
        <button type="button" id="deleteVendorNo">No</button>
      </div>
    </div>
  </div>

  <script>
    const locationOptions = <%- JSON.stringify(locationOptions) %>;
    let vendors = [];
    let currentPage = 1;
    let totalPages = 1;
    let pendingDeleteId = null;

    const tableBody = document.getElementById('vendorsTableBody');
    const vendorSearch = document.getElementById('vendorSearch');
    const statusFilter = document.getElementById('statusFilter');
    const countryFilter = document.getElementById('countryFilter');
    const stateFilter = document.getElementById('stateFilter');
    const cityFilter = document.getElementById('cityFilter');
    const pageInfo = document.getElementById('pageInfo');
    const prevPage = document.getElementById('prevPage');
    const nextPage = document.getElementById('nextPage');

    function debounce(fn, delay) {
      let timer;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => fn(...args), delay);
      };
    }

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
    }

    function servicesText(services) {
      return Array.isArray(services) ? services.join(', ') : String(services || '');
    }

    function optionList(items, emptyLabel) {
      return `<option value="">${emptyLabel}</option>` + items
        .map((item) => `<option value="${escapeHtml(item)}">${escapeHtml(item)}</option>`)
        .join('');
    }

    function updateStateOptions(selectedState) {
      const country = document.getElementById('vendorCountry').value;
      const states = country && locationOptions.tree[country] ? Object.keys(locationOptions.tree[country]) : [];
      const stateSelect = document.getElementById('vendorState');
      stateSelect.innerHTML = optionList(states, 'Select State');
      if (selectedState) stateSelect.value = selectedState;
      updateCityOptions();
    }

    function updateCityOptions(selectedCity) {
      const country = document.getElementById('vendorCountry').value;
      const state = document.getElementById('vendorState').value;
      const cities = country && state && locationOptions.tree[country] && locationOptions.tree[country][state]
        ? locationOptions.tree[country][state]
        : [];
      const citySelect = document.getElementById('vendorCity');
      citySelect.innerHTML = optionList(cities, 'Select City');
      if (selectedCity) citySelect.value = selectedCity;
    }

    function renderLocationOptions() {
      document.getElementById('vendorCountry').innerHTML = optionList(locationOptions.countries, 'Select Country');
      updateStateOptions();
    }

    function updateFilterStates(selectedState) {
      const country = countryFilter.value;
      const states = country && locationOptions.tree[country] ? Object.keys(locationOptions.tree[country]) : locationOptions.states;
      stateFilter.innerHTML = optionList(states, 'All States');
      if (selectedState) stateFilter.value = selectedState;
      updateFilterCities();
    }

    function updateFilterCities(selectedCity) {
      const country = countryFilter.value;
      const state = stateFilter.value;
      let cities = locationOptions.cities;
      if (country && state && locationOptions.tree[country] && locationOptions.tree[country][state]) {
        cities = locationOptions.tree[country][state];
      } else if (country && locationOptions.tree[country]) {
        cities = [...new Set(Object.values(locationOptions.tree[country]).flat())];
      }
      cityFilter.innerHTML = optionList(cities, 'All Cities');
      if (selectedCity) cityFilter.value = selectedCity;
    }

    function renderFilterOptions() {
      countryFilter.innerHTML = optionList(locationOptions.countries, 'All Countries');
      updateFilterStates();
      updateFilterCities();
    }

    function vendorLocation(vendor) {
      return [vendor.city, vendor.state].filter(Boolean).join(', ') || '-';
    }

    function imagePreview(path, label) {
      if (!path) return '';
      return `<a href="${escapeHtml(path)}" target="_blank" rel="noopener">${escapeHtml(label)}</a>`;
    }

    function setImagePreview(id, path) {
      document.getElementById(id).innerHTML = imagePreview(path, 'View current image');
    }

    function appendIfFile(formData, fieldName, inputId) {
      const file = document.getElementById(inputId).files[0];
      if (file) formData.append(fieldName, file);
    }

    async function loadVendors(page = 1) {
      const params = new URLSearchParams({
        format: 'json',
        page,
        limit: 10,
        search: vendorSearch.value.trim(),
        status: statusFilter.value,
        country: countryFilter.value,
        state: stateFilter.value,
        city: cityFilter.value,
      });
      const response = await fetch(`/vendors?${params.toString()}`, { headers: { Accept: 'application/json' } });
      const data = await response.json();
      if (!data.success) {
        tableBody.innerHTML = `<tr><td colspan="8">${escapeHtml(data.message || 'Unable to load vendors')}</td></tr>`;
        return;
      }
      vendors = data.vendors || [];
      currentPage = data.pagination.page;
      totalPages = data.pagination.totalPages;
      renderVendors();
    }

    function renderVendors() {
      if (!vendors.length) {
        tableBody.innerHTML = '<tr><td colspan="8">No vendors found</td></tr>';
      } else {
        tableBody.innerHTML = vendors.map((vendor) => `
          <tr>
            <td>#${vendor.id}</td>
            <td>
              <div class="vendor-identity">
                <img src="${escapeHtml(vendor.profile_image_path || '/default.png')}" alt="" />
                <div>
                  <strong>${escapeHtml(vendor.name)}</strong>
                  <span class="vendor-subtext">${escapeHtml(vendor.email)}</span>
                </div>
              </div>
            </td>
            <td>
              ${escapeHtml(vendor.business_name)}
              <span class="vendor-subtext">${imagePreview(vendor.store_image_path, 'Store image') || '-'}</span>
            </td>
            <td>
              ${escapeHtml(vendor.phone)}
              <span class="vendor-subtext">
                ${imagePreview(vendor.aadhaar_front_path, 'Aadhaar front') || ''}
                ${vendor.aadhaar_front_path && vendor.aadhaar_back_path ? ' / ' : ''}
                ${imagePreview(vendor.aadhaar_back_path, 'back') || ''}
              </span>
            </td>
            <td>${escapeHtml(vendorLocation(vendor))}</td>
            <td class="vendor-services-cell">${escapeHtml(servicesText(vendor.services) || '-')}</td>
            <td><span class="user-status-pill ${vendor.status === 'active' ? 'active' : 'inactive'}">${escapeHtml(vendor.status)}</span></td>
            <td>
              <div class="user-actions">
                <button type="button" onclick="toggleVendorStatus(${vendor.id})">${vendor.status === 'active' ? 'Deactivate' : 'Active'}</button>
                <button type="button" onclick="openEditVendor(${vendor.id})">Edit</button>
                <button type="button" onclick="askDeleteVendor(${vendor.id})">Delete</button>
              </div>
            </td>
          </tr>
        `).join('');
      }

      pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
      prevPage.disabled = currentPage <= 1;
      nextPage.disabled = currentPage >= totalPages;
    }

    function openVendorModal() {
      document.getElementById('vendorModal').classList.add('active');
    }

    function closeVendorModal() {
      document.getElementById('vendorModal').classList.remove('active');
    }

    function resetVendorForm() {
      document.getElementById('vendorForm').reset();
      document.getElementById('vendorId').value = '';
      document.getElementById('vendorPassword').required = true;
      document.getElementById('aadhaarFrontPreview').innerHTML = '';
      document.getElementById('aadhaarBackPreview').innerHTML = '';
      document.getElementById('storeImagePreview').innerHTML = '';
      document.getElementById('profileImagePreview').innerHTML = '';
      document.getElementById('vendorModalTitle').textContent = 'Add Vendor';
      document.getElementById('vendorSubmit').textContent = 'Save Vendor';
      renderLocationOptions();
    }

    function openAddVendor() {
      resetVendorForm();
      openVendorModal();
    }

    function openEditVendor(id) {
      const vendor = vendors.find((item) => item.id === id);
      if (!vendor) return;
      document.getElementById('vendorId').value = vendor.id;
      document.getElementById('vendorName').value = vendor.name;
      document.getElementById('businessName').value = vendor.business_name;
      document.getElementById('vendorEmail').value = vendor.email;
      document.getElementById('vendorPhone').value = vendor.phone;
      document.getElementById('vendorPassword').value = '';
      document.getElementById('vendorPassword').required = false;
      document.getElementById('vendorStatus').value = vendor.status;
      document.getElementById('gstNumber').value = vendor.gst_number || '';
      document.getElementById('vendorCountry').value = vendor.country || '';
      updateStateOptions(vendor.state || '');
      updateCityOptions(vendor.city || '');
      document.getElementById('vendorServices').value = servicesText(vendor.services);
      document.getElementById('vendorAddress').value = vendor.address || '';
      setImagePreview('aadhaarFrontPreview', vendor.aadhaar_front_path);
      setImagePreview('aadhaarBackPreview', vendor.aadhaar_back_path);
      setImagePreview('storeImagePreview', vendor.store_image_path);
      setImagePreview('profileImagePreview', vendor.profile_image_path);
      document.getElementById('vendorModalTitle').textContent = 'Edit Vendor';
      document.getElementById('vendorSubmit').textContent = 'Update Vendor';
      openVendorModal();
    }

    async function toggleVendorStatus(id) {
      const vendor = vendors.find((item) => item.id === id);
      if (!vendor) return;
      const nextStatus = vendor.status === 'active' ? 'inactive' : 'active';
      const response = await fetch(`/vendors/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: nextStatus }),
      });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to update vendor status');
        return;
      }
      loadVendors(currentPage);
    }

    function askDeleteVendor(id) {
      pendingDeleteId = id;
      document.getElementById('deleteVendorModal').classList.add('active');
    }

    async function deleteVendor() {
      if (!pendingDeleteId) return;
      const id = pendingDeleteId;
      pendingDeleteId = null;
      document.getElementById('deleteVendorModal').classList.remove('active');
      const response = await fetch(`/vendors/${id}`, { method: 'DELETE' });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to delete vendor');
        return;
      }
      loadVendors(currentPage);
    }

    document.getElementById('vendorForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = document.getElementById('vendorId').value;
      const formData = new FormData();
      formData.append('name', document.getElementById('vendorName').value);
      formData.append('business_name', document.getElementById('businessName').value);
      formData.append('email', document.getElementById('vendorEmail').value);
      formData.append('phone', document.getElementById('vendorPhone').value);
      if (!id || document.getElementById('vendorPassword').value) {
        formData.append('password', document.getElementById('vendorPassword').value);
      }
      formData.append('status', document.getElementById('vendorStatus').value);
      formData.append('gst_number', document.getElementById('gstNumber').value);
      formData.append('country', document.getElementById('vendorCountry').value);
      formData.append('state', document.getElementById('vendorState').value);
      formData.append('city', document.getElementById('vendorCity').value);
      formData.append('services', document.getElementById('vendorServices').value);
      formData.append('address', document.getElementById('vendorAddress').value);
      appendIfFile(formData, 'aadhaar_front', 'aadhaarFront');
      appendIfFile(formData, 'aadhaar_back', 'aadhaarBack');
      appendIfFile(formData, 'store_image', 'storeImage');
      appendIfFile(formData, 'profile_image', 'profileImage');

      const response = await fetch(`/vendors${id ? `/${id}` : ''}`, {
        method: id ? 'PUT' : 'POST',
        body: formData,
      });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || (data.errors || []).join(', ') || 'Unable to save vendor');
        return;
      }
      closeVendorModal();
      resetVendorForm();
      loadVendors(id ? currentPage : 1);
    });

    document.getElementById('addVendorButton').addEventListener('click', openAddVendor);
    document.getElementById('vendorCountry').addEventListener('change', () => updateStateOptions());
    document.getElementById('vendorState').addEventListener('change', () => updateCityOptions());
    document.getElementById('deleteVendorYes').addEventListener('click', deleteVendor);
    document.getElementById('deleteVendorNo').addEventListener('click', () => {
      pendingDeleteId = null;
      document.getElementById('deleteVendorModal').classList.remove('active');
    });
    vendorSearch.addEventListener('input', debounce(() => loadVendors(1), 300));
    statusFilter.addEventListener('change', () => loadVendors(1));
    countryFilter.addEventListener('change', () => {
      updateFilterStates();
      updateFilterCities();
      loadVendors(1);
    });
    stateFilter.addEventListener('change', () => {
      updateFilterCities();
      loadVendors(1);
    });
    cityFilter.addEventListener('change', () => loadVendors(1));
    document.getElementById('clearVendorFilters').addEventListener('click', () => {
      vendorSearch.value = '';
      statusFilter.value = '';
      countryFilter.value = '';
      updateFilterStates();
      updateFilterCities();
      loadVendors(1);
    });
    prevPage.addEventListener('click', () => loadVendors(currentPage - 1));
    nextPage.addEventListener('click', () => loadVendors(currentPage + 1));

    renderLocationOptions();
    renderFilterOptions();
    loadVendors();
  </script>
</body>
</html>
