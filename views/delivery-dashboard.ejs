<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delivery Dashboard</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Delivery Dashboard / Dashboard</p>
        <h1>In-house Delivery Orders</h1>
      </div>
      <button class="settings-save" type="button" id="refreshBtn">Refresh</button>
    </header>

    <section class="delivery-admin-shell">
      <div class="delivery-filter-bar">
        <input id="searchInput" type="search" placeholder="Search order, vendor, client, delivery person">
        <select id="statusFilter">
          <option value="">All statuses</option>
          <option value="waiting">Waiting for delivery person</option>
          <option value="assigned">Delivery person assigned</option>
          <option value="accepted">Accepted</option>
          <option value="rejected">Rejected</option>
          <option value="pickup_pending">Pickup pending</option>
          <option value="picked_up">Picked up</option>
          <option value="out_for_delivery">Out for delivery</option>
          <option value="delivered">Delivered</option>
          <option value="cancelled">Cancelled</option>
        </select>
        <select id="cityFilter"><option value="">All cities</option></select>
        <select id="personFilter"><option value="">All delivery persons</option></select>
        <input id="dateFilter" type="date">
        <button class="product-secondary-button" type="button" id="clearFilters">Clear</button>
      </div>

      <div class="delivery-summary-grid" id="summary"></div>

      <div class="users-table-card">
        <table class="users-table orders-table delivery-dashboard-table">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Vendor</th>
              <th>Client</th>
              <th>Pickup Location</th>
              <th>Delivery Location</th>
              <th>Distance</th>
              <th>Order Value</th>
              <th>Delivery Person</th>
              <th>Status</th>
              <th>OTP</th>
              <th>OTP Attempts</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="ordersBody">
            <tr><td colspan="12">Loading in-house delivery orders...</td></tr>
          </tbody>
        </table>
      </div>

      <div class="users-pagination">
        <button type="button" id="previous">Previous</button>
        <span id="pageInfo">Page 1</span>
        <button type="button" id="next">Next</button>
      </div>
    </section>
  </main>

  <div class="user-modal" id="detailModal" aria-hidden="true">
    <div class="user-modal-card order-detail-modal-card">
      <div class="user-modal-header">
        <h2>Delivery Order Details</h2>
        <button type="button" onclick="closeDetailModal()">Close</button>
      </div>
      <div id="detailContent"><p>Loading...</p></div>
    </div>
  </div>

  <div class="user-modal" id="assignModal" aria-hidden="true">
    <div class="user-modal-card order-detail-modal-card">
      <div class="user-modal-header">
        <h2>Send to Delivery Partner</h2>
        <button type="button" onclick="closeAssignModal()">Close</button>
      </div>
      <div id="assignContent"><p>Loading free delivery partners...</p></div>
    </div>
  </div>

  <div class="user-modal" id="rejectionModal" aria-hidden="true">
    <div class="user-modal-card order-detail-modal-card">
      <div class="user-modal-header">
        <h2>Rejected Orders</h2>
        <button type="button" onclick="closeRejectionModal()">Close</button>
      </div>
      <div id="rejectionContent"><p>Loading...</p></div>
    </div>
  </div>

  <script>
    let orders = [];
    let assignOrderId = null;
    let selectedPartnerId = null;
    let rejectionPartnerId = null;
    let page = 1;
    let totalPages = 1;
    let filtersLoaded = false;
    const el = (id) => document.getElementById(id);
    const esc = (v) => String(v ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
    const money = (v) => `₹${Number(v || 0).toFixed(2)}`;
    const debounce = (fn, ms = 300) => { let t; return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), ms); }; };

    async function fetchJson(url, options = {}) {
      const response = await fetch(url, options);
      const contentType = response.headers.get('content-type') || '';
      if (!contentType.includes('application/json')) {
        const text = await response.text();
        const error = new Error(response.status === 404
          ? 'Delivery partner assignment endpoint was not found. Restart the JaipurGro2 server and try again.'
          : (text || `Request failed with status ${response.status}`));
        error.status = response.status;
        throw error;
      }
      const data = await response.json();
      if (!response.ok || !data.success) {
        const error = new Error(data.message || `Request failed with status ${response.status}`);
        error.status = response.status;
        throw error;
      }
      return data;
    }

    function statusClass(status) {
      return String(status || '').toLowerCase().replace(/[^a-z0-9]+/g, '_');
    }

    function distance(value) {
      return value === null || value === undefined ? '-' : `${Number(value).toFixed(2)} km`;
    }

    function params(nextPage = page) {
      const q = new URLSearchParams({
        page: String(nextPage),
        limit: '20',
        search: el('searchInput').value.trim(),
        status: el('statusFilter').value,
        city: el('cityFilter').value,
        delivery_person_id: el('personFilter').value,
        date: el('dateFilter').value,
      });
      return q;
    }

    function populateFilters(data) {
      if (filtersLoaded) return;
      const citySelect = el('cityFilter');
      const currentCity = citySelect.value;
      citySelect.innerHTML = '<option value="">All cities</option>' + (data.filters?.cities || []).map(city => `<option value="${esc(city)}">${esc(city)}</option>`).join('');
      citySelect.value = currentCity;

      const personSelect = el('personFilter');
      const currentPerson = personSelect.value;
      personSelect.innerHTML = '<option value="">All delivery persons</option>' + (data.filters?.deliveryPersons || []).map(person => `<option value="${Number(person.id)}">#DP-${Number(person.id)} · ${esc(person.name)}</option>`).join('');
      personSelect.value = currentPerson;
      filtersLoaded = true;
    }

    function renderSummary() {
      const counts = orders.reduce((acc, order) => {
        const key = order.order_status || 'Unknown';
        acc[key] = (acc[key] || 0) + 1;
        return acc;
      }, {});
      const assigned = orders.filter(o => o.delivery_person_assigned).length;
      const value = orders.reduce((sum, o) => sum + Number(o.order_value || 0), 0);
      el('summary').innerHTML = `
        <article><span>Orders on page</span><strong>${orders.length}</strong></article>
        <article><span>Assigned</span><strong>${assigned}</strong></article>
        <article><span>Waiting</span><strong>${counts['Waiting for delivery person'] || 0}</strong></article>
        <article><span>Out for delivery</span><strong>${counts['Out for delivery'] || 0}</strong></article>
        <article><span>Order value</span><strong>${money(value)}</strong></article>
      `;
    }

    function renderOrders() {
      const body = el('ordersBody');
      if (!orders.length) {
        body.innerHTML = '<tr><td colspan="12">No in-house delivery orders match these filters.</td></tr>';
        renderSummary();
        return;
      }
      body.innerHTML = orders.map(order => `
        <tr>
          <td><strong>${esc(order.order_number)}</strong><br><small>#${Number(order.id)}</small></td>
          <td>${esc(order.vendor_name)}</td>
          <td>${esc(order.client_name)}</td>
          <td class="delivery-location-cell">${esc(order.pickup_location)}</td>
          <td class="delivery-location-cell">${esc(order.delivery_location)}</td>
          <td>${distance(order.distance_km)}</td>
          <td>${money(order.order_value)}</td>
          <td>${deliveryProviderCell(order)}</td>
          <td><span class="badge ${statusClass(order.order_status)}">${esc(order.order_status)}</span></td>
          <td>${['out_for_delivery', 'delivered'].includes(String(order.delivery_status || '').toLowerCase()) ? `<strong>${esc(order.delivery_otp || '-')}</strong>` : '-'}</td>
          <td>${['out_for_delivery', 'delivered'].includes(String(order.delivery_status || '').toLowerCase()) ? `<strong>${Number(order.delivery_otp_attempts || 0)}/${Number(order.delivery_otp_max_attempts || 8)}</strong><br><small>${order.delivery_otp_locked ? 'Locked — admin support required' : `${Number(order.delivery_otp_remaining_attempts ?? 8)} remaining`}</small>` : '-'}</td>
          <td>
            <button class="product-secondary-button" type="button" onclick="viewOrder(${Number(order.id)})">View</button>
            ${!['out_for_delivery', 'delivered'].includes(String(order.delivery_status || '').toLowerCase()) ? `<button class="settings-save delivery-assign-button" type="button" onclick="openAssignModal(${Number(order.id)})">Send to Delivery Partner</button>` : ''}
            ${resendButton(order)}
            ${order.delivery_otp_locked && String(order.delivery_status || '').toLowerCase() === 'out_for_delivery' ? `<button class="settings-save delivery-manual-verify-button" type="button" onclick="manualVerifyDelivery(${Number(order.id)})">Manual Complete</button>` : ''}
          </td>
        </tr>
      `).join('');
      renderSummary();
      updateResendButtons();
    }

    function deliveryProviderCell(order) {
      if (order.external_delivery_provider_id) {
        return `<span class="badge delivery_person_assigned">External</span><br><strong>${esc(order.external_delivery_provider_name || order.delivery_person_name || 'External provider')}</strong>`;
      }
      if (order.delivery_person_id) {
        return `#DP-${Number(order.delivery_person_id)}<br><strong>${esc(order.delivery_person_name)}</strong>${!order.delivery_person_assigned ? `<br><small>${order.order_status === 'Rejected' ? 'Rejected this order' : 'Awaiting response'}</small>` : ''}`;
      }
      return 'Not assigned';
    }

    function resendButton(order) {
      if (!['Waiting for delivery person', 'Rejected'].includes(order.order_status) || !order.resend_available_at) return '';
      return `<button class="settings-save delivery-resend-button" id="resend-${Number(order.id)}" type="button" data-available-at="${esc(order.resend_available_at)}" onclick="resendDelivery(${Number(order.id)})">Resend</button>`;
    }

    function updateResendButtons() {
      document.querySelectorAll('.delivery-resend-button').forEach(button => {
        const remaining = Math.max(Math.ceil((new Date(button.dataset.availableAt).getTime() - Date.now()) / 1000), 0);
        button.disabled = remaining > 0;
        button.textContent = remaining > 0
          ? `Resend in ${Math.floor(remaining / 60)}:${String(remaining % 60).padStart(2, '0')}`
          : 'Resend';
      });
    }

    async function resendDelivery(orderId) {
      const button = el(`resend-${orderId}`);
      if (button) button.disabled = true;
      try {
        const response = await fetch(`/api/orders/admin/${orderId}/resend-delivery-offer`, {
          method: 'POST',
          headers: { Accept: 'application/json' },
        });
        const data = await response.json();
        if (!response.ok || !data.success) throw new Error(data.message || 'Unable to resend delivery');
        alert(data.message);
        await load(page);
      } catch (error) {
        alert(error.message);
        await load(page);
      }
    }

    async function manualVerifyDelivery(orderId) {
      if (!confirm('Manually verify and complete this locked delivery? The delivery charge will be credited to the delivery person.')) return;
      try {
        const response = await fetch(`/api/orders/admin/${orderId}/manual-verify-delivery`, {
          method: 'POST',
          headers: { Accept: 'application/json' },
        });
        const data = await response.json();
        if (!response.ok || !data.success) throw new Error(data.message || 'Unable to manually verify delivery');
        alert(data.message);
        closeDetailModal();
        await load(page);
      } catch (error) {
        alert(error.message);
      }
    }

    function partnerDistance(partner) {
      return partner.distance_km === null || partner.distance_km === undefined ? 'Distance not available' : `${Number(partner.distance_km).toFixed(2)} km away`;
    }

    function partnerLastSeen(partner) {
      return partner.last_seen_at ? `Last seen ${new Date(partner.last_seen_at).toLocaleString()}` : 'Last seen not available';
    }

    function partnerSubtitle(partner) {
      const label = partner.type === 'external' ? 'External provider' : `#DP-${Number(partner.id)}`;
      return `${label}${partner.phone ? ` - ${esc(partner.phone)}` : ''}`;
    }

    function partnerAreaLabel(partner) {
      return `${esc(partner.city || '-')}${partner.area ? ` - ${esc(partner.area)}` : ''}`;
    }

    function partnerRejectionMarkup(partner) {
      if (partner.type === 'external') return '<small>Manual external delivery provider assignment</small>';
      return `<small>
        <span class="product-secondary-button" role="button" tabindex="0" onclick="event.stopPropagation(); openRejectionModal(${Number(partner.id)})" onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); event.stopPropagation(); openRejectionModal(${Number(partner.id)}); }">
          ${Number(partner.rejected_count_7d || 0)} rejected in 7 days
        </span>
      </small>`;
    }

    function renderAssignablePartners(data) {
      const partners = data.partners || [];
      if (!partners.length) {
        el('assignContent').innerHTML = `
          <div class="delivery-assign-empty">
            <h3>No delivery partners found</h3>
            <p>There are no active delivery partners or external providers available for this area right now.</p>
          </div>
        `;
        return;
      }

      el('assignContent').innerHTML = `
        <div class="delivery-assign-summary">
          <p><strong>Pickup:</strong> ${esc(data.pickup?.location || '-')}</p>
          <p><strong>Available partners/providers:</strong> ${partners.length}</p>
        </div>
        <div class="delivery-partner-options">
          ${partners.map((partner, index) => `
            <button class="delivery-partner-option" type="button" data-partner-id="${esc(partner.id)}" onclick="selectPartner('${esc(partner.id)}')">
              <span class="delivery-partner-rank">${index + 1}</span>
              <span>
                <strong>${esc(partner.name)}</strong>
                <small>#DP-${Number(partner.id)} ${partner.phone ? `· ${esc(partner.phone)}` : ''}</small>
                <small>${esc(partner.city || '-')}${partner.area ? ` · ${esc(partner.area)}` : ''}</small>
                <small>
                  <span class="product-secondary-button" role="button" tabindex="0" onclick="event.stopPropagation(); openRejectionModal(${Number(partner.id)})" onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); event.stopPropagation(); openRejectionModal(${Number(partner.id)}); }">
                    ${Number(partner.rejected_count_7d || 0)} rejected in 7 days
                  </span>
                </small>
              </span>
              <span class="delivery-partner-distance">${esc(partnerDistance(partner))}</span>
              <small>${esc(partnerLastSeen(partner))}</small>
            </button>
          `).join('')}
        </div>
        <div class="delivery-assign-actions">
          <button class="product-secondary-button" type="button" onclick="closeAssignModal()">Cancel</button>
          <button class="settings-save" type="button" id="confirmAssignBtn" onclick="assignSelectedPartner()" disabled>Send Order</button>
        </div>
      `;
      partners.filter(partner => partner.type === 'external').forEach(partner => {
        const option = document.querySelector(`.delivery-partner-option[data-partner-id="${String(partner.id).replace(/"/g, '\\"')}"]`);
        if (!option) return;
        const smalls = option.querySelectorAll('small');
        if (smalls[0]) smalls[0].textContent = partner.phone ? `External provider - ${partner.phone}` : 'External provider';
        if (smalls[1]) smalls[1].textContent = `${partner.city || '-'}${partner.area ? ` - ${partner.area}` : ''}`;
        if (smalls[2]) smalls[2].textContent = 'Manual external delivery provider assignment';
        if (smalls[3]) smalls[3].textContent = '';
      });
    }

    async function openRejectionModal(partnerId) {
      rejectionPartnerId = partnerId;
      el('rejectionContent').innerHTML = '<p>Loading rejected orders...</p>';
      el('rejectionModal').style.display = 'flex';
      el('rejectionModal').setAttribute('aria-hidden', 'false');
      try {
        const data = await fetchJson(`/api/orders/admin/delivery-partners/${Number(partnerId)}/rejections`, { headers: { Accept: 'application/json' } });
        renderRejectionDetails(data);
      } catch (error) {
        el('rejectionContent').innerHTML = `<p>${esc(error.message)}</p>`;
      }
    }

    function closeRejectionModal() {
      rejectionPartnerId = null;
      el('rejectionModal').style.display = 'none';
      el('rejectionModal').setAttribute('aria-hidden', 'true');
    }

    function renderRejectionDetails(data) {
      const partner = data.partner || {};
      const rejectedOrders = data.rejected_orders || [];
      const isBlocked = Boolean(partner.is_blocked);
      el('rejectionContent').innerHTML = `
        <div class="delivery-detail-grid">
          <article>
            <h3>${esc(partner.name || 'Delivery Partner')}</h3>
            <p><strong>Delivery Partner ID:</strong> #DP-${Number(partner.id || 0)}</p>
            <p><strong>Phone:</strong> ${esc(partner.phone || '-')}</p>
            <p><strong>Total Rejected Orders (last 7 days):</strong> ${Number(data.total_rejected_orders_7d || 0)}</p>
          </article>
          <article>
            <h3>Block Status</h3>
            <p><strong>Status:</strong> <span class="badge ${isBlocked ? 'cancelled' : 'delivered'}">${isBlocked ? 'Blocked' : 'Active'}</span></p>
            <button class="settings-save" type="button" onclick="togglePartnerBlock(${Number(partner.id || 0)}, ${isBlocked ? 'false' : 'true'})">
              ${isBlocked ? 'Unblock' : 'Block'}
            </button>
          </article>
        </div>
        <h3>Rejected Orders</h3>
        <table class="users-table">
          <thead><tr><th>Order ID</th><th>Customer</th><th>Date</th><th>Reason</th></tr></thead>
          <tbody>
            ${rejectedOrders.length ? rejectedOrders.map(order => `
              <tr>
                <td>${esc(order.order_number || (order.order_id ? `#${order.order_id}` : '-'))}</td>
                <td>${esc(order.customer_name || '-')}</td>
                <td>${order.date ? new Date(order.date).toLocaleString() : '-'}</td>
                <td>${esc(order.reason || '-')}</td>
              </tr>
            `).join('') : '<tr><td colspan="4">No rejected orders in the last 7 days.</td></tr>'}
          </tbody>
        </table>
      `;
    }

    async function togglePartnerBlock(partnerId, shouldBlock) {
      const action = shouldBlock ? 'block' : 'unblock';
      if (!confirm(`${shouldBlock ? 'Block' : 'Unblock'} delivery partner #DP-${Number(partnerId)}?`)) return;
      try {
        const data = await fetchJson(`/api/orders/admin/delivery-partners/${Number(partnerId)}/block-status`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ action }),
        });
        renderRejectionDetails(data);
        await load(page);
        if (assignOrderId) {
          const currentOrderId = assignOrderId;
          closeAssignModal();
          await openAssignModal(currentOrderId);
        }
      } catch (error) {
        alert(error.message);
      }
    }

    function selectPartner(partnerId) {
      selectedPartnerId = partnerId;
      document.querySelectorAll('.delivery-partner-option').forEach(button => {
        button.classList.toggle('selected', Number(button.dataset.partnerId) === Number(partnerId));
      });
      const confirmButton = el('confirmAssignBtn');
      if (confirmButton) confirmButton.disabled = false;
    }

    async function openAssignModal(orderId) {
      assignOrderId = orderId;
      selectedPartnerId = null;
      el('assignContent').innerHTML = '<p>Loading free delivery partners...</p>';
      el('assignModal').style.display = 'flex';
      el('assignModal').setAttribute('aria-hidden', 'false');
      try {
        let data;
        try {
          data = await fetchJson(`/api/orders/admin/${orderId}/free-delivery-partners`, { headers: { Accept: 'application/json' } });
        } catch (error) {
          if (error.status !== 404) throw error;
          data = await fetchJson(`/orders/admin/${orderId}/free-delivery-partners`, { headers: { Accept: 'application/json' } });
        }
        renderAssignablePartners(data);
      } catch (error) {
        el('assignContent').innerHTML = `<p>${esc(error.message)}</p>`;
      }
    }

    function closeAssignModal() {
      assignOrderId = null;
      selectedPartnerId = null;
      el('assignModal').style.display = 'none';
      el('assignModal').setAttribute('aria-hidden', 'true');
    }

    async function assignSelectedPartner() {
      if (!assignOrderId || !selectedPartnerId) return;
      const button = el('confirmAssignBtn');
      if (button) {
        button.disabled = true;
        button.textContent = 'Sending...';
      }
      try {
        await fetchJson(`/api/orders/admin/${assignOrderId}/assign-delivery`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ partner_id: selectedPartnerId }),
        });
        closeAssignModal();
        closeDetailModal();
        await load(page);
      } catch (error) {
        alert(error.message);
        if (button) {
          button.disabled = false;
          button.textContent = 'Send Order';
        }
      }
    }

    async function load(nextPage = 1) {
      try {
        const response = await fetch(`/api/orders/admin/delivery-dashboard?${params(nextPage)}`, { headers: { Accept: 'application/json' } });
        const data = await response.json();
        if (!response.ok || !data.success) throw new Error(data.message || 'Unable to load delivery dashboard');
        populateFilters(data);
        orders = data.orders || [];
        page = data.pagination?.page || 1;
        totalPages = data.pagination?.totalPages || 1;
        renderOrders();
        el('pageInfo').textContent = `Page ${page} of ${totalPages}`;
        el('previous').disabled = page <= 1;
        el('next').disabled = page >= totalPages;
      } catch (error) {
        el('ordersBody').innerHTML = `<tr><td colspan="10">${esc(error.message)}</td></tr>`;
      }
    }

    function timeline(history = []) {
      if (!history.length) return '<p>No progress history yet.</p>';
      return `<ol class="order-timeline">${history.map(item => `<li><strong>${esc(item.new_status_label || item.new_status)}</strong><span>${new Date(item.created_at).toLocaleString()}</span><small>${esc(item.changed_by_name || 'System')} ${item.note ? `· ${esc(item.note)}` : ''}</small></li>`).join('')}</ol>`;
    }

    async function viewOrder(orderId) {
      el('detailContent').innerHTML = '<p>Loading...</p>';
      el('detailModal').style.display = 'flex';
      el('detailModal').setAttribute('aria-hidden', 'false');
      try {
        const response = await fetch(`/api/orders/admin/${orderId}`, { headers: { Accept: 'application/json' } });
        const data = await response.json();
        if (!response.ok || !data.success) throw new Error(data.message || 'Unable to load order details');
        const order = data.order;
        const dashboardOrder = orders.find(item => Number(item.id) === Number(orderId)) || {};
        el('detailContent').innerHTML = `
          <div class="delivery-detail-grid">
            <article>
              <h3>#${esc(order.order_number || order.id)}</h3>
              <p><strong>Vendor:</strong> ${esc(order.vendor_business_name || order.vendor_name || '-')}</p>
              <p><strong>Client:</strong> ${esc(order.client_name || '-')} ${order.client_phone ? `(${esc(order.client_phone)})` : ''}</p>
              <p><strong>Pickup:</strong> ${esc(dashboardOrder.pickup_location || order.vendor_address || '-')}</p>
              <p><strong>Delivery:</strong> ${esc(dashboardOrder.delivery_location || order.shipping_address || order.client_address || '-')}</p>
              <p><strong>Distance:</strong> ${distance(dashboardOrder.distance_km)}</p>
              <p><strong>Order Value:</strong> ${money(order.total_amount)}</p>
            </article>
            <article>
              <h3>Delivery Progress</h3>
              <p><strong>Status:</strong> ${esc(dashboardOrder.order_status || order.delivery_status || order.status)}</p>
              <p><strong>Delivery Person:</strong> ${dashboardOrder.delivery_person_id ? `#DP-${Number(dashboardOrder.delivery_person_id)} · ${esc(dashboardOrder.delivery_person_name)}${!dashboardOrder.delivery_person_assigned ? (dashboardOrder.order_status === 'Rejected' ? ' (rejected this order)' : ' (awaiting response)') : ''}` : esc(order.delivery_partner_name || 'Not assigned')}</p>
              <p><strong>Delivery Status:</strong> ${esc(order.delivery_status || '-')}</p>
              <p><strong>Order Status:</strong> ${esc(order.status_label || order.status || '-')}</p>
              <p><strong>Assigned:</strong> ${order.assigned_at ? new Date(order.assigned_at).toLocaleString() : '-'}</p>
              <p><strong>Delivered:</strong> ${order.delivered_at ? new Date(order.delivered_at).toLocaleString() : '-'}</p>
              <p><strong>Delivery OTP:</strong> ${['out_for_delivery', 'delivered'].includes(String(order.delivery_status || '').toLowerCase()) ? esc(order.delivery_otp || '-') : 'Available when out for delivery'}</p>
              <p><strong>OTP Attempts:</strong> ${Number(order.delivery_otp_attempts || 0)}/${Number(order.delivery_otp_max_attempts || 8)} ${order.delivery_otp_locked ? '— Locked; admin support required' : `(${Number(order.delivery_otp_remaining_attempts ?? 8)} remaining)`}</p>
            </article>
          </div>
          <h3>Items</h3>
          <table class="users-table">
            <thead><tr><th>Product</th><th>Qty</th><th>Unit</th><th>Total</th></tr></thead>
            <tbody>${(data.items || []).map(item => `<tr><td>${esc(item.product_name)}</td><td>${esc(item.quantity)}</td><td>${money(item.unit_price)}</td><td>${money(item.line_total)}</td></tr>`).join('') || '<tr><td colspan="4">No items found</td></tr>'}</tbody>
          </table>
          <h3>Progress Timeline</h3>
          ${timeline(data.history || [])}
        `;
      } catch (error) {
        el('detailContent').innerHTML = `<p>${esc(error.message)}</p>`;
      }
    }

    function closeDetailModal() {
      el('detailModal').style.display = 'none';
      el('detailModal').setAttribute('aria-hidden', 'true');
    }

    el('refreshBtn').onclick = () => load(page);
    el('previous').onclick = () => load(page - 1);
    el('next').onclick = () => load(page + 1);
    el('clearFilters').onclick = () => {
      ['searchInput', 'statusFilter', 'cityFilter', 'personFilter', 'dateFilter'].forEach(id => el(id).value = '');
      load(1);
    };
    el('searchInput').addEventListener('input', debounce(() => load(1)));
    ['statusFilter', 'cityFilter', 'personFilter', 'dateFilter'].forEach(id => el(id).addEventListener('change', () => load(1)));
    setInterval(updateResendButtons, 1000);
    load(1);
  </script>
</body>
</html>
