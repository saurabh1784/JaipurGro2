      if (!window.confirm(`Restore version ${version}? This creates a new current version.`)) return;
      try {
        const response = await fetch(`/settings/content-pages/${encodeURIComponent(appName)}/${encodeURIComponent(pageType)}/restore/${version}`, { method: 'POST' });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) throw new Error(data.message || 'Unable to restore version');
        applyLegalPage(data.page || {});
        await loadLegalPages();
        await loadLegalHistory();
        setContentMessage(data.message || 'Version restored.');
      } catch (error) {
        setContentMessage(error.message || 'Unable to restore version', true);
      }
    }

    async function seedDemoLegalPages() {
      setContentMessage('Creating demo legal pages...');
      try {
        const response = await fetch('/settings/content-pages/seed-demo', { method: 'POST' });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) throw new Error(data.message || 'Unable to create demo pages');
        await loadLegalPages();
        await loadSelectedContentPage();
        setContentMessage(data.message || 'Demo legal pages created.');
      } catch (error) {
        setContentMessage(error.message || 'Unable to create demo pages', true);
      }
    }
    async function loadRoleSettings() {
      const select = document.getElementById('roleSettingsSelect');
      const message = document.getElementById('roleSettingsMessage');
      select.innerHTML = '<option>Loading roles...</option>';
      document.getElementById('rolePermissionGrid').innerHTML = '';
      document.getElementById('roleSettingsSummary').textContent = 'Loading roles...';
      message.textContent = '';

      try {
        const response = await fetch('/settings/roles');
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to load roles');
        roleSettings = data.roles || [];
        select.innerHTML = roleSettings.map((role) => `<option value="${role.id}">${escapeCatalog(role.name)}</option>`).join('');
        renderRoleSettings();
      } catch (error) {
        select.innerHTML = '<option>Unable to load roles</option>';
        document.getElementById('roleSettingsSummary').textContent = error.message;
      }
    }

    function selectedRoleSetting() {
      const selectedId = document.getElementById('roleSettingsSelect').value;
      return roleSettings.find((role) => String(role.id) === String(selectedId));
    }

    function renderRoleSettings() {
      const role = selectedRoleSetting();
      const grid = document.getElementById('rolePermissionGrid');
      if (!role) {
        document.getElementById('roleSettingsSummary').textContent = 'No roles found';
        grid.innerHTML = '';
        return;
      }

      const permissions = Array.isArray(role.permissions) ? role.permissions : [];
      const userCount = Number(role.user_count || 0);
      document.getElementById('roleSettingsSummary').innerHTML = `
        <strong>${escapeCatalog(role.name)}</strong>
        <span>${escapeCatalog(role.description || 'No description')}</span>
        <small>Level ${role.level} &middot; ${userCount} assigned user${userCount === 1 ? '' : 's'}</small>
      `;

      grid.innerHTML = Object.entries(rolePermissionLabels).map(([value, label]) => `
        <label class="role-permission-option">
          <input type="checkbox" value="${escapeCatalog(value)}" ${permissions.includes(value) ? 'checked' : ''} />
          <span>${escapeCatalog(label)}</span>
        </label>
      `).join('');
    }

    async function saveRolePermissions() {
      const role = selectedRoleSetting();
      if (!role) return;

      const message = document.getElementById('roleSettingsMessage');
      const permissions = Array.from(document.querySelectorAll('#rolePermissionGrid input:checked')).map((input) => input.value);
      message.textContent = 'Saving role permissions...';

      try {
        const response = await fetch(`/settings/roles/${role.id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ permissions }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save role permissions');
        role.permissions = data.permissions || permissions;
        renderRoleSettings();
        message.textContent = 'Role permissions saved.';
      } catch (error) {
        message.textContent = error.message;
      }
    }

    async function loadCommissionSettings() {
      const body = document.getElementById('commissionPreviewBody');
      if (!body) return;
      body.innerHTML = '<tr><td colspan="7">Loading commission settings...</td></tr>';
      try {
        const response = await fetch('/settings/commissions');
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to load commission settings');
        const locationPayload = data.location_commissions || {};
        commissionSettings = locationPayload.settings || [];
        commissionCities = locationPayload.cities || [];
        commissionAreas = locationPayload.areas || [];
        renderCommissionCityOptions();
        renderCommissionAreaOptions();
        renderCommissionSettings();
      } catch (error) {
        body.innerHTML = `<tr><td colspan="7">${escapeCatalog(error.message)}</td></tr>`;
      }
    }

    function commissionKey(row) {
      return `${String(row.city || '').trim().toLowerCase()}::${String(row.area || '*').trim().toLowerCase() || '*'}`;
    }

    function commissionAreaLabel(area) {
      return area === '*' ? 'City Default' : area;
    }

    function renderCommissionCityOptions() {
      const datalist = document.getElementById('commissionCityOptions');
      if (!datalist) return;
      const citySet = new Set(commissionCities);
      commissionSettings.forEach((row) => {
        if (row.city) citySet.add(row.city);
      });
      datalist.innerHTML = Array.from(citySet)
        .sort((a, b) => a.localeCompare(b))
        .map((city) => `<option value="${escapeCatalog(city)}"></option>`)
        .join('');
    }

    function renderCommissionAreaOptions() {
      const select = document.getElementById('commissionAreaInput');
      if (!select) return;
      const city = document.getElementById('commissionCityInput').value.trim();
      const cityAreas = commissionAreas
        .filter((area) => !city || String(area.city || '').toLowerCase() === city.toLowerCase())
        .sort((a, b) => String(a.area || '').localeCompare(String(b.area || '')));
      const options = ['<option value="*">City Default</option>']
        .concat(cityAreas.map((area) => `<option value="${escapeCatalog(area.area)}">${escapeCatalog(area.area)}</option>`));
      select.innerHTML = options.join('');
    }

    function readCommissionForm() {
      const cityInput = document.getElementById('commissionCityInput');
      const areaInput = document.getElementById('commissionAreaInput');
      const orderInput = document.getElementById('commissionOrderInput');
      const deliveryInput = document.getElementById('commissionDeliveryInput');
      const city = cityInput.value.trim();
      const area = areaInput.value.trim() || '*';
      const orderPercent = Number(orderInput.value || 0);
      const deliveryPercent = Number(deliveryInput.value || 0);
      const message = document.getElementById('commissionMessage');

      if (!city) {
        message.textContent = 'Choose a city before adding a commission row.';
        return null;
      }
      if (orderPercent < 0 || orderPercent > 100 || deliveryPercent < 0 || deliveryPercent > 100) {
        message.textContent = 'Commission percentages must be between 0 and 100.';
        return null;
      }

      return {
        city,
        area,
        order_commission_percentage: orderPercent,
        delivery_commission_percentage: deliveryPercent,
        is_active: true,
      };
    }

    function upsertLocalCommissionSetting(next) {
      const existingIndex = commissionSettings.findIndex((row) => commissionKey(row) === commissionKey(next));
      if (existingIndex >= 0) {
        commissionSettings[existingIndex] = { ...commissionSettings[existingIndex], ...next };
      } else {
        commissionSettings.push(next);
      }
      renderCommissionCityOptions();
      renderCommissionSettings();
    }

    async function addCommissionSetting() {
      const message = document.getElementById('commissionMessage');
      const next = readCommissionForm();
      if (!next) return;
      upsertLocalCommissionSetting(next);
      message.textContent = `${commissionAreaLabel(next.area)} commission saved locally. Saving to server...`;
      try {
        await persistCommissionSetting(next);
      } catch (error) {
        message.textContent = error.message;
      }
    }

    function maybeStageCurrentCommissionForm() {
      const cityInput = document.getElementById('commissionCityInput');
      if (!cityInput || !cityInput.value.trim()) return true;
      const next = readCommissionForm();
      if (!next) return false;
      upsertLocalCommissionSetting(next);
      return true;
    }

    function replaceCommissionPayloadFromServer(locationPayload) {
      commissionSettings = locationPayload.settings || [];
      commissionCities = locationPayload.cities || commissionCities;
      commissionAreas = locationPayload.areas || commissionAreas;
      renderCommissionCityOptions();
      renderCommissionAreaOptions();
      renderCommissionSettings();
    }

    async function saveSingleCommissionSetting(next) {
      const response = await fetch('/settings/commissions', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ location_commission: next }),
      });
      const data = await response.json();
      if (!data.success) throw new Error(data.message || 'Unable to save commission setting');
      replaceCommissionPayloadFromServer(data.location_commissions || {});
      return data;
    }

    async function saveAllCommissionRows() {
      const response = await fetch('/settings/commissions', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ location_commissions: commissionSettings }),
      });
      const data = await response.json();
      if (!data.success) throw new Error(data.message || 'Unable to save commission settings');
      replaceCommissionPayloadFromServer(data.location_commissions || {});
      return data;
    }

    async function persistCommissionSetting(next) {
      const data = await saveSingleCommissionSetting(next);
      const message = document.getElementById('commissionMessage');
      message.textContent = data.message || `${commissionAreaLabel(next.area)} commission saved for ${next.city}.`;
    }

    function editCommissionSetting(index) {
      const row = commissionSettings[index];
      if (!row) return;
      document.getElementById('commissionCityInput').value = row.city || '';
      renderCommissionAreaOptions();
      document.getElementById('commissionAreaInput').value = row.area || '*';
      document.getElementById('commissionOrderInput').value = Number(row.order_commission_percentage || 0);
      document.getElementById('commissionDeliveryInput').value = Number(row.delivery_commission_percentage || 0);
      document.getElementById('commissionMessage').textContent = 'Edit the values, then click Add / Update Commission.';
    }

    async function toggleCommissionSetting(index) {
      const row = commissionSettings[index];
      if (!row) return;
      const nextActive = row.is_active === false;
      if (!row.id) {
        row.is_active = nextActive;
        renderCommissionSettings();
        return;
      }
      const message = document.getElementById('commissionMessage');
      message.textContent = nextActive ? 'Activating commission setting...' : 'Deactivating commission setting...';
      try {
        const response = await fetch(`/settings/commissions/location/${encodeURIComponent(row.id)}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ is_active: nextActive }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to update commission setting status');
        replaceCommissionPayloadFromServer(data.location_commissions || {});
        message.textContent = data.message || (nextActive ? 'Commission setting activated.' : 'Commission setting deactivated.');
      } catch (error) {
        message.textContent = error.message;
      }
    }

    async function deleteCommissionSetting(index) {
      const row = commissionSettings[index];
      if (!row) return;
      if (!confirm(`Remove commission for ${row.city} / ${commissionAreaLabel(row.area || '*')}?`)) return;
      if (!row.id) {
        commissionSettings.splice(index, 1);
        renderCommissionSettings();
        return;
      }
      const message = document.getElementById('commissionMessage');
      message.textContent = 'Removing commission setting...';
      try {
        const response = await fetch(`/settings/commissions/location/${encodeURIComponent(row.id)}`, { method: 'DELETE' });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to remove commission setting');
        const locationPayload = data.location_commissions || {};
        commissionSettings = locationPayload.settings || [];
        commissionCities = locationPayload.cities || commissionCities;
        commissionAreas = locationPayload.areas || commissionAreas;
        renderCommissionCityOptions();
        renderCommissionAreaOptions();
        renderCommissionSettings();
        message.textContent = data.message;
      } catch (error) {
        message.textContent = error.message;
      }
    }

    function renderCommissionSettings() {
      const body = document.getElementById('commissionPreviewBody');
      if (!body) return;
      const orderAmount = Number(document.getElementById('commissionPreviewAmount').value || 0);
      const deliveryCharge = Number(document.getElementById('deliveryCommissionPreviewAmount').value || 0);
      if (!commissionSettings.length) {
        body.innerHTML = '<tr><td colspan="7">No city or area commission settings yet.</td></tr>';
        return;
      }
      body.innerHTML = commissionSettings
        .map((row, index) => {
          const orderPercent = Number(row.order_commission_percentage || 0);
          const deliveryPercent = Number(row.delivery_commission_percentage || 0);
          const orderCommission = Number(Math.max((orderAmount * orderPercent) / 100, 0).toFixed(2));
          const deliveryCommission = Number(Math.max((deliveryCharge * deliveryPercent) / 100, 0).toFixed(2));
          const active = row.is_active !== false;
          return `
            <tr class="${active ? '' : 'commission-row-inactive'}">
              <td><strong>${escapeCatalog(row.city)}</strong></td>
              <td>${escapeCatalog(commissionAreaLabel(row.area || '*'))}</td>
              <td>
                <input class="commission-inline-input" type="number" min="0" max="100" step="0.01" value="${orderPercent}" onchange="commissionSettings[${index}].order_commission_percentage = Number(this.value || 0); renderCommissionSettings();" />
              </td>
              <td>
                <input class="commission-inline-input" type="number" min="0" max="100" step="0.01" value="${deliveryPercent}" onchange="commissionSettings[${index}].delivery_commission_percentage = Number(this.value || 0); renderCommissionSettings();" />
              </td>
              <td>
                <strong>Platform ${orderCommission.toFixed(2)}</strong>
                <span class="commission-subtext">Delivery ${deliveryCommission.toFixed(2)} / Partner ${(Math.max(deliveryCharge - deliveryCommission, 0)).toFixed(2)}</span>
              </td>
              <td>${active ? 'Active' : 'Inactive'}</td>
              <td>
                <button class="product-secondary-button area-row-button" type="button" onclick="editCommissionSetting(${index})">Edit</button>
                <button class="product-secondary-button area-row-button" type="button" onclick="toggleCommissionSetting(${index})">${active ? 'Deactivate' : 'Activate'}</button>
                <button class="danger-action-button area-row-button" type="button" onclick="deleteCommissionSetting(${index})">Delete</button>
              </td>
            </tr>
          `;
        })
        .join('');
    }

    async function saveCommissionSettings(options = {}) {
      const message = document.getElementById('commissionMessage');
      if (!message) return;
      if (options.includeCurrentForm !== false && !maybeStageCurrentCommissionForm()) return;
      message.textContent = 'Saving commission settings...';
      try {
        const data = await saveAllCommissionRows();
        message.textContent = data.message;
      } catch (error) {
        message.textContent = error.message;
      }
    }

    async function loadDeliveryPartnerSettings() {
      const body = document.getElementById('deliveryPartnerTableBody');
      body.innerHTML = '<tr><td colspan="5">Loading delivery partners...</td></tr>';
      try {
        const response = await fetch('/settings/delivery-partners');
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to load delivery partners');
        deliveryPartnerSettings = data.partners || [];
        deliveryCities = data.cities || [];
        deliveryAreas = data.areas || [];
        deliveryMappedAreas = data.mapped_areas || [];
        renderDeliveryCityOptions();
        renderDeliveryAreaOptions();
        renderDeliveryPartners();
      } catch (error) {
        body.innerHTML = `<tr><td colspan="5">${escapeCatalog(error.message)}</td></tr>`;
      }
    }

    function renderDeliveryCityOptions() {
      const options = ['<option value="">Select city</option>']
        .concat(deliveryCities.map((city) => `<option value="${escapeCatalog(city)}">${escapeCatalog(city)}</option>`))
        .join('');
      ['deliveryCityInput', 'deliveryPartnerCity'].forEach((id) => {
        const select = document.getElementById(id);
        if (select) select.innerHTML = options;
      });
    }

    function renderDeliveryAreaOptions() {
      ['deliveryAreaInput', 'deliveryPartnerArea'].forEach((id) => populateDeliveryAreaSelect(id));
    }

    function mappedAreasForCity(city) {
      const selectedCity = String(city || '').trim().toLowerCase();
      return deliveryMappedAreas.filter((area) => !selectedCity || String(area.city || '').trim().toLowerCase() === selectedCity);
    }

    function populateDeliveryAreaSelect(id) {
      const select = document.getElementById(id);
      if (!select) return;
      const citySelectId = id === 'deliveryPartnerArea' ? 'deliveryPartnerCity' : 'deliveryCityInput';
      const city = document.getElementById(citySelectId)?.value || '';
      const mappedAreas = mappedAreasForCity(city);
      const options = id === 'deliveryPartnerArea'
        ? []
        : ['<option value="">Select mapped area</option>'];
      if (city) options.push('<option value="*">All mapped areas in selected city</option>');
      mappedAreas.forEach((area) => {
        options.push(`<option value="${escapeCatalog(area.area)}" data-city="${escapeCatalog(area.city)}">${escapeCatalog(area.city)} - ${escapeCatalog(area.area)}</option>`);
      });
      select.innerHTML = options.join('');
    }

    function findMappedArea(city, area) {
      const cityKey = String(city || '').trim().toLowerCase();
      const areaKey = String(area || '').trim().toLowerCase();
      return deliveryMappedAreas.find((item) => (
        String(item.city || '').trim().toLowerCase() === cityKey
        && String(item.area || '').trim().toLowerCase() === areaKey
      ));
    }

    function normalizeDeliveryArea(entry) {
      if (typeof entry === 'string') return { city: entry.trim(), area: '*' };
      return {
        city: String(entry && entry.city || '').trim(),
        area: String(entry && entry.area || '*').trim() || '*',
      };
    }

    function deliveryAreaKey(entry) {
      return `${String(entry.city || '').toLowerCase()}::${String(entry.area || '*').toLowerCase()}`;
    }

    function deliveryAreaLabel(entry) {
      const area = String(entry.area || '*').trim();
      return `${entry.city} - ${area === '*' ? 'All areas' : area}`;
    }

    function partnerCities(partner) {
      return (partner.cities || [])
        .filter((entry) => entry && Number(entry.is_active) !== 0)
        .map(normalizeDeliveryArea)
        .filter((entry) => entry.city);
    }

    function renderDeliveryPartners() {
      const body = document.getElementById('deliveryPartnerTableBody');
      if (!deliveryPartnerSettings.length) {
        body.innerHTML = '<tr><td colspan="5">No delivery partners found.</td></tr>';
        return;
      }

      body.innerHTML = deliveryPartnerSettings.map((partner) => {
        const areas = partnerCities(partner);
        return `
          <tr data-partner-id="${partner.id}">
            <td>
              <strong>${escapeCatalog(partner.name)}</strong>
              <span class="commission-subtext">Staff ID ${partner.id}</span>
            </td>
            <td>
              <span>${escapeCatalog(partner.email || '')}</span>
              <span class="commission-subtext">${escapeCatalog(partner.phone || '')}</span>
            </td>
            <td>
              <div class="delivery-city-pills">
                ${areas.length ? areas.map((entry) => `
                  <button type="button" class="delivery-city-pill" onclick="removeDeliveryCity(${partner.id}, '${encodeURIComponent(entry.city)}', '${encodeURIComponent(entry.area)}')">${escapeCatalog(deliveryAreaLabel(entry))} x</button>
                `).join('') : '<span class="commission-subtext">No city assigned</span>'}
              </div>
            </td>
            <td>
              <button class="product-secondary-button" type="button" onclick="addDeliveryCity(${partner.id})">Add City</button>
            </td>
            <td>
              <button class="product-secondary-button" type="button" onclick="openDeliveryPartnerModal(${partner.id})">Edit</button>
              <button class="reject-button" type="button" onclick="deleteDeliveryPartner(${partner.id})">Delete</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    function addDeliveryCity(partnerId) {
      const city = document.getElementById('deliveryCityInput').value.trim();
      const area = document.getElementById('deliveryAreaInput').value.trim();
      if (!city) {
        alert('Select a city first.');
        return;
      }
      if (!area) {
        alert('Select a mapped area first.');
        return;
      }
      const mappedArea = area === '*' ? null : findMappedArea(city, area);
      if (area !== '*' && !mappedArea) {
        alert('Select an area created on the Area Definition page.');
        return;
      }
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!partner) return;
      const entry = { city, area, area_definition_id: mappedArea ? mappedArea.id : null };
      const areas = partnerCities(partner);
      if (!areas.some((item) => deliveryAreaKey(item) === deliveryAreaKey(entry))) {
        partner.cities = [...(partner.cities || []), { ...entry, is_active: 1 }];
      }
      renderDeliveryPartners();
    }

    function removeDeliveryCity(partnerId, city, area = '*') {
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!partner) return;
      const target = {
        city: decodeURIComponent(city || ''),
        area: decodeURIComponent(area || '*'),
      };
      partner.cities = (partner.cities || []).filter((entry) => deliveryAreaKey(normalizeDeliveryArea(entry)) !== deliveryAreaKey(target));
      renderDeliveryPartners();
    }

    async function saveDeliveryPartnerSettings() {
      const message = document.getElementById('deliveryPartnerMessage');
      message.textContent = 'Saving delivery partner settings...';
      const assignments = deliveryPartnerSettings.map((partner) => ({
        user_id: partner.id,
        delivery_areas: partnerCities(partner),
      }));
      try {
        const response = await fetch('/settings/delivery-partners', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ assignments }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save delivery partner settings');
        message.textContent = data.message;
        loadDeliveryPartnerSettings();
      } catch (error) {
        message.textContent = error.message;
      }
    }

    function openDeliveryPartnerModal(partnerId = null) {
      const partner = partnerId ? deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId)) : null;
      document.getElementById('deliveryPartnerModalTitle').textContent = partner ? 'Edit Delivery Partner' : 'Add Delivery Partner';
      document.getElementById('deliveryPartnerId').value = partner ? partner.id : '';
      document.getElementById('deliveryPartnerName').value = partner ? partner.name || '' : '';
      document.getElementById('deliveryPartnerEmail').value = partner ? partner.email || '' : '';
      document.getElementById('deliveryPartnerPhone').value = partner ? partner.phone || '' : '';
      document.getElementById('deliveryPartnerPassword').value = '';
      document.getElementById('deliveryPartnerPassword').required = !partner;
      document.getElementById('deliveryPartnerCity').value = '';
      document.getElementById('deliveryPartnerArea').value = '';
      populateDeliveryAreaSelect('deliveryPartnerArea');
      deliveryPartnerModalCities = partner ? partnerCities(partner) : [];
      renderModalDeliveryCities();
      document.getElementById('deliveryPartnerModal').style.display = 'flex';
      document.getElementById('deliveryPartnerModal').setAttribute('aria-hidden', 'false');
    }

    function closeDeliveryPartnerModal() {
      document.getElementById('deliveryPartnerModal').style.display = 'none';
      document.getElementById('deliveryPartnerModal').setAttribute('aria-hidden', 'true');
      document.getElementById('deliveryPartnerForm').reset();
      deliveryPartnerModalCities = [];
    }

    function renderModalDeliveryCities() {
      const target = document.getElementById('deliveryPartnerModalCities');
      target.innerHTML = deliveryPartnerModalCities.length
        ? deliveryPartnerModalCities.map((entry) => `
          <button type="button" class="delivery-city-pill" onclick="removeModalDeliveryCity('${encodeURIComponent(entry.city)}', '${encodeURIComponent(entry.area)}')">${escapeCatalog(deliveryAreaLabel(entry))} x</button>
        `).join('')
        : '<span class="commission-subtext">No city assigned</span>';
    }

    function addModalDeliveryCity() {
      const input = document.getElementById('deliveryPartnerCity');
      const areaInput = document.getElementById('deliveryPartnerArea');
      const city = input.value.trim();
      const selectedAreas = Array.from(areaInput.selectedOptions || [])
        .map((option) => option.value.trim())
        .filter(Boolean);
      if (!city) return;
      if (!selectedAreas.length) {
        alert('Select one or more mapped areas first.');
        return;
      }

      selectedAreas.forEach((area) => {
        const mappedArea = area === '*' ? null : findMappedArea(city, area);
        if (area !== '*' && !mappedArea) return;
        const entry = { city, area, area_definition_id: mappedArea ? mappedArea.id : null };
        if (!deliveryPartnerModalCities.some((item) => deliveryAreaKey(item) === deliveryAreaKey(entry))) {
          deliveryPartnerModalCities.push(entry);
        }
      });

      input.value = '';
      populateDeliveryAreaSelect('deliveryPartnerArea');
      renderModalDeliveryCities();
    }

    function removeModalDeliveryCity(city, area = '*') {
      const target = {
        city: decodeURIComponent(city || ''),
        area: decodeURIComponent(area || '*'),
      };
      deliveryPartnerModalCities = deliveryPartnerModalCities.filter((item) => deliveryAreaKey(item) !== deliveryAreaKey(target));
      renderModalDeliveryCities();
    }

    async function deleteDeliveryPartner(partnerId) {
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!confirm(`Delete ${partner ? partner.name : 'this delivery partner'}?`)) return;
      try {
        const response = await fetch(`/settings/delivery-partners/${partnerId}`, { method: 'DELETE' });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to delete delivery partner');
        document.getElementById('deliveryPartnerMessage').textContent = data.message;
        loadDeliveryPartnerSettings();
      } catch (error) {
        document.getElementById('deliveryPartnerMessage').textContent = error.message;
      }
    }

    document.getElementById('deliveryPartnerForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = document.getElementById('deliveryPartnerId').value;
      const payload = {
        name: document.getElementById('deliveryPartnerName').value.trim(),
        email: document.getElementById('deliveryPartnerEmail').value.trim(),
        phone: document.getElementById('deliveryPartnerPhone').value.trim(),
        password: document.getElementById('deliveryPartnerPassword').value,
        delivery_areas: deliveryPartnerModalCities,
      };
      try {
        const response = await fetch(`/settings/delivery-partners${id ? `/${id}` : ''}`, {
          method: id ? 'PUT' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save delivery partner');
        document.getElementById('deliveryPartnerMessage').textContent = data.message;
        closeDeliveryPartnerModal();
        loadDeliveryPartnerSettings();
      } catch (error) {
        document.getElementById('deliveryPartnerMessage').textContent = error.message;
      }
    });

    [
      'commissionPreviewAmount',
      'deliveryCommissionPreviewAmount',
      'commissionOrderInput',
      'commissionDeliveryInput',
    ].forEach((id) => {
      const input = document.getElementById(id);
      if (input) input.addEventListener('input', renderCommissionSettings);
    });
    document.getElementById('commissionCityInput')?.addEventListener('input', renderCommissionAreaOptions);
    document.getElementById('commissionAreaInput')?.addEventListener('change', () => {
      const city = document.getElementById('commissionCityInput').value.trim();
      const area = document.getElementById('commissionAreaInput').value.trim() || '*';
      const existing = commissionSettings.find((row) => commissionKey(row) === commissionKey({ city, area }));
      if (!existing) return;
      document.getElementById('commissionOrderInput').value = Number(existing.order_commission_percentage || 0);
      document.getElementById('commissionDeliveryInput').value = Number(existing.delivery_commission_percentage || 0);
    });
    document.getElementById('roleSettingsSelect').addEventListener('change', renderRoleSettings);
    document.getElementById('googleMapsForm').addEventListener('submit', saveGoogleMapSettings);
    document.getElementById('deliveryPartnerTestFilterForm').addEventListener('submit', (event) => {
      event.preventDefault();
      loadDeliveryPartnerTestPartners();
    });
    document.getElementById('deliveryPartnerTestClear').addEventListener('click', () => {
      document.getElementById('deliveryPartnerTestFilterForm').reset();
      loadDeliveryPartnerTestPartners();
    });
    document.getElementById('deliveryCityInput').addEventListener('change', () => populateDeliveryAreaSelect('deliveryAreaInput'));
    document.getElementById('deliveryPartnerCity').addEventListener('change', () => populateDeliveryAreaSelect('deliveryPartnerArea'));

    renderBiddingSettings();
    loadCatalog();
    loadRoleSettings();
    loadCommissionSettings();
    loadDeliveryPartnerSettings();
