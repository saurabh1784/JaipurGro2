    }

    function calculateCommissionPreview(setting) {
      const amount = Number(document.getElementById('commissionPreviewAmount').value || 0);
      if (!setting.is_active || amount <= 0) return { commission: 0, net: amount };
      let commission = setting.commission_type === 'percentage'
        ? (amount * Number(setting.commission_value || 0)) / 100
        : Number(setting.commission_value || 0);
      commission = Math.max(commission, Number(setting.min_commission || 0));
      if (setting.max_commission !== null && setting.max_commission !== undefined && setting.max_commission !== '') {
        commission = Math.min(commission, Number(setting.max_commission));
      }
      commission = Number(Math.max(commission, 0).toFixed(2));
      const net = setting.transaction_type === 'wallet_debit'
        ? amount + commission
        : Math.max(amount - commission, 0);
      return { commission, net: Number(net.toFixed(2)) };
    }

    function renderCommissionSettings() {
      const rows = activeCommissionRows();
      const body = document.getElementById('commissionTableBody');
      const transactionLabel = commissionLabel(document.getElementById('commissionTransactionFilter').value);
      if (rows.length === 0) {
        body.innerHTML = '<tr><td colspan="7">No commission settings found</td></tr>';
        return;
      }

      body.innerHTML = rows.map((setting) => {
        const preview = calculateCommissionPreview(setting);
        return `
          <tr data-commission-id="${setting.id}" data-transaction-type="${setting.transaction_type}">
            <td>
              <strong>${escapeCatalog(setting.role_name)}</strong>
              <span class="commission-subtext">${transactionLabel}</span>
            </td>
            <td>
              <label class="settings-toggle commission-toggle">
                <input class="commission-active" type="checkbox" ${setting.is_active ? 'checked' : ''} />
              </label>
            </td>
            <td>
              <select class="commission-type">
                <option value="percentage" ${setting.commission_type === 'percentage' ? 'selected' : ''}>Percentage</option>
                <option value="fixed" ${setting.commission_type === 'fixed' ? 'selected' : ''}>Fixed</option>
              </select>
            </td>
            <td><input class="commission-value" type="number" min="0" step="0.01" value="${setting.commission_value}" /></td>
            <td><input class="commission-min" type="number" min="0" step="0.01" value="${setting.min_commission}" /></td>
            <td><input class="commission-max" type="number" min="0" step="0.01" value="${setting.max_commission === null ? '' : setting.max_commission}" placeholder="No cap" /></td>
            <td class="commission-preview-cell">
              <strong>Fee ${preview.commission.toFixed(2)}</strong>
              <span class="commission-subtext">Net ${preview.net.toFixed(2)}</span>
            </td>
          </tr>
        `;
      }).join('');

      body.querySelectorAll('input, select').forEach((input) => {
        input.addEventListener('input', syncCommissionRow);
        input.addEventListener('change', syncCommissionRow);
      });
    }

    function syncCommissionRow(event) {
      const row = event.target.closest('tr');
      const id = Number(row.dataset.commissionId);
      const setting = commissionSettings.find((item) => item.id === id);
      if (!setting) return;
      setting.is_active = row.querySelector('.commission-active').checked;
      setting.commission_type = row.querySelector('.commission-type').value;
      setting.commission_value = Number(row.querySelector('.commission-value').value || 0);
      setting.min_commission = Number(row.querySelector('.commission-min').value || 0);
      setting.max_commission = row.querySelector('.commission-max').value;
      const preview = calculateCommissionPreview(setting);
      row.querySelector('.commission-preview-cell').innerHTML = `
        <strong>Fee ${preview.commission.toFixed(2)}</strong>
        <span class="commission-subtext">Net ${preview.net.toFixed(2)}</span>
      `;
    }

