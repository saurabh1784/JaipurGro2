  <script>
    let catalogData = { categories: [], subcategories: [], brands: [], tree: [] };
    let roleSettings = [];
    const rolePermissionLabels = <%- JSON.stringify(permissionLabels || {}) %>;

    function catalogEndpoint(type) {
      return {
        category: '/categories',
        subcategory: '/sub-categories',
        brand: '/brands',
      }[type];
    }

    async function loadCatalog() {
      const tree = document.getElementById('catalogTree');
      const categoryBody = document.getElementById('categoryTableBody');
      const subcategoryBody = document.getElementById('subcategoryTableBody');
      const brandBody = document.getElementById('brandTableBody');
      tree.textContent = 'Loading catalog...';
      categoryBody.innerHTML = '<tr><td colspan="6">Loading...</td></tr>';
      subcategoryBody.innerHTML = '<tr><td colspan="7">Loading...</td></tr>';
      brandBody.innerHTML = '<tr><td colspan="7">Loading...</td></tr>';

      try {
        const response = await fetch('/catalog-tree', {
          headers: { Accept: 'application/json' },
          credentials: 'same-origin',
        });
        const contentType = response.headers.get('content-type') || '';

        if (!contentType.includes('application/json')) {
          throw new Error('Catalog API returned an HTML page. Please refresh and login again.');
        }

        const data = await response.json();
        if (!response.ok || !data.success) {
          throw new Error(data.message || 'Unable to load catalog data');
        }

        catalogData = {
          categories: data.categories || [],
          subcategories: data.subcategories || [],
          brands: data.brands || [],
          tree: data.tree || [],
        };
        renderCatalogFilters();
        renderCatalogTree();
        renderCatalogTable();
      } catch (error) {
        console.error(error);
        tree.innerHTML = `<div class="catalog-error">${escapeCatalog(error.message)}</div>`;
        categoryBody.innerHTML = `<tr><td colspan="5">${escapeCatalog(error.message)}</td></tr>`;
        subcategoryBody.innerHTML = `<tr><td colspan="7">${escapeCatalog(error.message)}</td></tr>`;
        brandBody.innerHTML = `<tr><td colspan="7">${escapeCatalog(error.message)}</td></tr>`;
      }
    }

    function optionList(items, emptyLabel) {
      return `<option value="">${emptyLabel}</option>` + items.map((item) => `<option value="${item.id}">${escapeCatalog(item.name)}</option>`).join('');
    }

    function brandLogoMarkup(brand) {
      const initial = String(brand.name || '?').trim().charAt(0).toUpperCase() || '?';
      if (brand.logo_path) {
        return `<span class="brand-logo-wrap"><img class="brand-logo" src="${escapeCatalog(brand.logo_path)}" alt="${escapeCatalog(brand.name)} logo" /></span>`;
      }
      return `<span class="brand-logo-fallback" aria-label="${escapeCatalog(brand.name)} logo">${escapeCatalog(initial)}</span>`;
    }

    function subcategoryImageMarkup(subcategory) {
      const initial = String(subcategory.name || '?').trim().charAt(0).toUpperCase() || '?';
      if (subcategory.image_path) {
        return `<span class="brand-logo-wrap"><img class="brand-logo" src="${escapeCatalog(subcategory.image_path)}" alt="${escapeCatalog(subcategory.name)} picture" /></span>`;
      }
      return `<span class="brand-logo-fallback" aria-label="${escapeCatalog(subcategory.name)} picture">${escapeCatalog(initial)}</span>`;
    }

    function categoryIconMarkup(category) {
      const initial = String(category.name || '?').trim().charAt(0).toUpperCase() || '?';
      if (category.icon_path) {
        return `<span class="brand-logo-wrap"><img class="brand-logo" src="${escapeCatalog(category.icon_path)}" alt="${escapeCatalog(category.name)} icon" /></span>`;
      }
      return `<span class="brand-logo-fallback" aria-label="${escapeCatalog(category.name)} icon">${escapeCatalog(initial)}</span>`;
    }

    function loadImageElement(file) {
      return new Promise((resolve, reject) => {
        const image = new Image();
        image.onload = () => resolve(image);
        image.onerror = () => reject(new Error('Unable to read selected image'));
        image.src = URL.createObjectURL(file);
      });
    }

    async function fitImageForCatalogIcon(file) {
      const image = await loadImageElement(file);
      const canvas = document.createElement('canvas');
      const size = 512;
      canvas.width = size;
      canvas.height = size;
      const context = canvas.getContext('2d');
      context.fillStyle = '#ffffff';
      context.fillRect(0, 0, size, size);

      const scale = Math.min(size / image.naturalWidth, size / image.naturalHeight);
      const width = image.naturalWidth * scale;
      const height = image.naturalHeight * scale;
      const x = (size - width) / 2;
      const y = (size - height) / 2;
      context.drawImage(image, x, y, width, height);
      URL.revokeObjectURL(image.src);

      return new Promise((resolve) => {
        canvas.toBlob((blob) => {
          resolve(new File([blob], file.name.replace(/\.[^.]+$/, '') + '-icon.webp', { type: 'image/webp' }));
        }, 'image/webp', 0.92);
      });
    }

    function renderCatalogFilters() {
      const categoryFilter = document.getElementById('catalogCategoryFilter');
      const subcategoryFilter = document.getElementById('catalogSubcategoryFilter');
      const brandFilter = document.getElementById('catalogBrandFilter');
      categoryFilter.innerHTML = optionList(catalogData.categories, 'All Categories');
      updateSubcategoryFilter();
      updateBrandFilter();
      categoryFilter.onchange = () => {
        updateSubcategoryFilter();
        updateBrandFilter();
        renderCatalogTable();
      };
      subcategoryFilter.onchange = () => {
        updateBrandFilter();
        renderCatalogTable();
      };
      brandFilter.onchange = renderCatalogTable;

      document.getElementById('catalogCategoryInput').innerHTML = optionList(catalogData.categories, 'Select Category');
      updateCatalogSubcategoryInput();
    }

    function updateSubcategoryFilter() {
      const categoryId = document.getElementById('catalogCategoryFilter').value;
      const items = categoryId
        ? catalogData.subcategories.filter((item) => String(item.category_id) === String(categoryId))
        : catalogData.subcategories;
      document.getElementById('catalogSubcategoryFilter').innerHTML = optionList(items, 'All Subcategories');
    }

    function updateBrandFilter() {
      const categoryId = document.getElementById('catalogCategoryFilter').value;
      const subcategoryId = document.getElementById('catalogSubcategoryFilter').value;
      const items = catalogData.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.sub_category_id || item.subcategory_id) === String(subcategoryId));
      document.getElementById('catalogBrandFilter').innerHTML = optionList(items, 'All Brands');
    }

    function updateCatalogSubcategoryInput(selectedId) {
      const categoryId = document.getElementById('catalogCategoryInput').value;
      const items = categoryId
        ? catalogData.subcategories.filter((item) => String(item.category_id) === String(categoryId))
        : catalogData.subcategories;
      const select = document.getElementById('catalogSubcategoryInput');
      select.innerHTML = optionList(items, 'Select Subcategory');
      if (selectedId) select.value = selectedId;
    }

    function renderCatalogTree() {
      const tree = document.getElementById('catalogTree');
      tree.innerHTML = catalogData.tree.map((category) => `
        <details open>
          <summary>${escapeCatalog(category.name)}</summary>
          ${category.subcategories.map((subcategory) => `
            <details>
              <summary>${escapeCatalog(subcategory.name)}</summary>
              <ul>
                ${subcategory.brands.map((brand) => `<li>${escapeCatalog(brand.name)}</li>`).join('')}
              </ul>
            </details>
          `).join('')}
        </details>
      `).join('');
    }

    function catalogRows() {
      const categoryId = document.getElementById('catalogCategoryFilter').value;
      const subcategoryId = document.getElementById('catalogSubcategoryFilter').value;
      const brandId = document.getElementById('catalogBrandFilter').value;
      const rows = [];

      catalogData.categories
        .filter((item) => !categoryId || String(item.id) === String(categoryId))
        .forEach((item) => rows.push({ type: 'category', parent: '-', ...item }));

      catalogData.subcategories
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.id) === String(subcategoryId))
        .forEach((item) => rows.push({ type: 'subcategory', parent: item.category_name, ...item }));

      catalogData.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.subcategory_id) === String(subcategoryId))
        .filter((item) => !brandId || String(item.id) === String(brandId))
        .forEach((item) => rows.push({ type: 'brand', parent: `${item.category_name} / ${item.subcategory_name}`, ...item }));

      return rows;
    }

    function renderCatalogTable() {
      const categoryId = document.getElementById('catalogCategoryFilter').value;
      const subcategoryId = document.getElementById('catalogSubcategoryFilter').value;
      const brandId = document.getElementById('catalogBrandFilter').value;
      const categories = catalogData.categories.filter((item) => !categoryId || String(item.id) === String(categoryId));
      const subcategories = catalogData.subcategories
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.id) === String(subcategoryId));
      const brands = catalogData.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.sub_category_id || item.subcategory_id) === String(subcategoryId))
        .filter((item) => !brandId || String(item.id) === String(brandId));

      document.getElementById('categoryTableBody').innerHTML = categories.length
        ? categories.map((row) => `
          <tr>
            <td>${row.id}</td>
            <td>${escapeCatalog(row.name)}</td>
            <td>${escapeCatalog(row.slug)}</td>
            <td>${escapeCatalog(row.tax_name || '-')}<br><small>${row.tax_percentage === null || row.tax_percentage === undefined ? '-' : Number(row.tax_percentage || 0).toFixed(2) + '%'}</small></td>
            <td>${categoryIconMarkup(row)}</td>
            <td><span class="user-status-pill ${row.is_active ? 'active' : 'inactive'}">${row.is_active ? 'active' : 'inactive'}</span></td>
            <td>
              <div class="user-actions">
                <button type="button" onclick='openCatalogModal("category", ${JSON.stringify(row)})'>Edit</button>
                <button type="button" onclick='deleteCatalogItem("category", ${row.id})'>Delete</button>
              </div>
            </td>
          </tr>
        `).join('')
        : '<tr><td colspan="7">No categories found</td></tr>';

      document.getElementById('subcategoryTableBody').innerHTML = subcategories.length
        ? subcategories.map((row) => `
          <tr>
            <td>${row.id}</td>
            <td>${escapeCatalog(row.category_name)}</td>
            <td>${escapeCatalog(row.name)}</td>
            <td>${escapeCatalog(row.slug)}</td>
            <td>${subcategoryImageMarkup(row)}</td>
            <td><span class="user-status-pill ${row.is_active ? 'active' : 'inactive'}">${row.is_active ? 'active' : 'inactive'}</span></td>
            <td>
              <div class="user-actions">
                <button type="button" onclick='openCatalogModal("subcategory", ${JSON.stringify(row)})'>Edit</button>
                <button type="button" onclick='deleteCatalogItem("subcategory", ${row.id})'>Delete</button>
              </div>
            </td>
          </tr>
        `).join('')
        : '<tr><td colspan="7">No subcategories found</td></tr>';

      document.getElementById('brandTableBody').innerHTML = brands.length
        ? brands.map((row) => `
          <tr>
            <td>${row.id}</td>
            <td>${escapeCatalog(row.category_name)}</td>
            <td>${escapeCatalog(row.sub_category_name || row.subcategory_name)}</td>
            <td>${brandLogoMarkup(row)}</td>
            <td>${escapeCatalog(row.name)}</td>
            <td><span class="user-status-pill ${row.is_active ? 'active' : 'inactive'}">${row.is_active ? 'active' : 'inactive'}</span></td>
            <td>
              <div class="user-actions">
                <button type="button" onclick='openCatalogModal("brand", ${JSON.stringify(row)})'>Edit</button>
                <button type="button" onclick='deleteCatalogItem("brand", ${row.id})'>Delete</button>
              </div>
            </td>
          </tr>
        `).join('')
        : '<tr><td colspan="7">No brands found</td></tr>';
    }

    function openCatalogModal(type, item) {
      const modal = document.getElementById('catalogModal');
      document.getElementById('catalogType').value = type;
      document.getElementById('catalogId').value = item ? item.id : '';
      document.getElementById('catalogModalTitle').textContent = `${item ? 'Edit' : 'Add'} ${type}`;
      document.getElementById('catalogNameInput').value = item ? item.name : '';
      document.getElementById('catalogSlugInput').value = item ? item.slug : '';
      document.getElementById('catalogTaxNameInput').value = item && item.tax_name ? item.tax_name : '';
      document.getElementById('catalogTaxPercentageInput').value = item && item.tax_percentage !== null && item.tax_percentage !== undefined ? Number(item.tax_percentage).toFixed(2) : '';
      document.getElementById('catalogActiveInput').checked = item ? item.is_active : true;
      document.getElementById('catalogCategoryField').style.display = type === 'subcategory' || type === 'brand' ? 'block' : 'none';
      document.getElementById('catalogSubcategoryField').style.display = type === 'brand' ? 'block' : 'none';
      document.getElementById('catalogLogoField').style.display = 'block';
      document.getElementById('catalogTaxNameField').style.display = type === 'category' ? 'block' : 'none';
      document.getElementById('catalogTaxPercentageField').style.display = type === 'category' ? 'block' : 'none';
      document.getElementById('catalogLogoInput').value = '';
      document.getElementById('catalogCategoryInput').value = item && item.category_id ? item.category_id : '';
      updateCatalogSubcategoryInput(item && (item.sub_category_id || item.subcategory_id) ? (item.sub_category_id || item.subcategory_id) : '');
      modal.classList.add('active');
    }

    function closeCatalogModal() {
      document.getElementById('catalogModal').classList.remove('active');
    }

    document.getElementById('catalogCategoryInput').addEventListener('change', () => updateCatalogSubcategoryInput());

    document.getElementById('catalogForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const type = document.getElementById('catalogType').value;
      const id = document.getElementById('catalogId').value;
      let payload = {
        name: document.getElementById('catalogNameInput').value,
        slug: document.getElementById('catalogSlugInput').value,
        is_active: document.getElementById('catalogActiveInput').checked,
      };

      if (type === 'subcategory') payload.category_id = document.getElementById('catalogCategoryInput').value;
      if (type === 'category') {
        payload.tax_name = document.getElementById('catalogTaxNameInput').value;
        payload.tax_percentage = document.getElementById('catalogTaxPercentageInput').value;
      }
      const selectedLogo = document.getElementById('catalogLogoInput').files[0];
      const processedLogo = selectedLogo ? await fitImageForCatalogIcon(selectedLogo) : null;
      const needsMultipart = type === 'brand' || type === 'subcategory' || (type === 'category' && processedLogo);

      if (needsMultipart) {
        payload.category_id = document.getElementById('catalogCategoryInput').value;
        if (type === 'brand' || type === 'subcategory') {
          payload.sub_category_id = document.getElementById('catalogSubcategoryInput').value;
        }
        const formData = new FormData();
        Object.entries(payload).forEach(([key, value]) => formData.append(key, value));
        if (processedLogo) {
          formData.append(type === 'subcategory' ? 'image' : (type === 'brand' ? 'logo' : 'icon'), processedLogo);
        }
        payload = formData;
      }

      const response = await fetch(`${catalogEndpoint(type)}${id ? `/${id}` : ''}`, {
        method: id ? 'PUT' : 'POST',
        headers: needsMultipart ? undefined : { 'Content-Type': 'application/json' },
        body: needsMultipart ? payload : JSON.stringify(payload),
      });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || (data.errors || []).join(', ') || 'Unable to save item');
        return;
      }
      closeCatalogModal();
      loadCatalog();
    });

    async function deleteCatalogItem(type, id) {
      if (!confirm(`Delete this ${type}? Child items will also be hidden where applicable.`)) return;
      const response = await fetch(`${catalogEndpoint(type)}/${id}`, { method: 'DELETE' });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to delete item');
        return;
      }
      loadCatalog();
    }

    function escapeCatalog(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
    }

    let biddingSettings = <%- JSON.stringify(settings.bidding && settings.bidding.settings || []) %>;

    let commissionSettings = [];
    let commissionCities = [];
    let commissionAreas = [];
    let deliveryPartnerSettings = [];
    let deliveryCities = [];
    let deliveryAreas = [];
    let deliveryMappedAreas = [];
    let deliveryPartnerModalCities = [];
    let googleMapsLoadedKey = '';
    let googleMap = null;
    let googleDirectionsRenderer = null;
    let googleMapsAuthError = '';

    function googleMapPayload() {
      return {
        browserApiKey: document.getElementById('googleMapsBrowserKey').value.trim(),
        androidApiKey: document.getElementById('googleMapsAndroidKey').value.trim(),
        distanceApiKey: document.getElementById('googleDistanceApiKey').value.trim(),
        mapId: document.getElementById('googleMapsMapId').value.trim(),
        defaultOrigin: document.getElementById('googleMapsOrigin').value.trim(),
