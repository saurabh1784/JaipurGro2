<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Settings</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>
  <%
    const locationSettings = settings.locations || { countries: [], states: [], cities: [] };
    locationSettings.countries = locationSettings.countries || [];
    locationSettings.states = locationSettings.states || [];
    locationSettings.cities = locationSettings.cities || [];
  %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Settings</p>
        <h1>Settings</h1>
      </div>
      <div class="topbar-actions">
        <label class="system-search" aria-label="Search settings">
          <input type="search" placeholder="Search" />
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/></svg>
        </label>
      </div>
    </header>

    <section class="settings-shell">
      <div class="settings-tabs" role="tablist" aria-label="Settings tabs">
        <button class="settings-tab active" type="button" data-tab="general">General</button>
        <button class="settings-tab" type="button" data-tab="email">Email</button>
        <button class="settings-tab" type="button" data-tab="firebase">Firebase</button>
        <button class="settings-tab" type="button" data-tab="locations">Locations</button>
        <button class="settings-tab" type="button" data-tab="catalog">Catalog</button>
        <button class="settings-tab" type="button" data-tab="commissions">Commission</button>
        <button class="settings-tab" type="button" data-tab="delivery-partners">Delivery Partners</button>
        <button class="settings-tab" type="button" data-tab="role-permissions">Role Permissions</button>
        <button class="settings-tab" type="button" data-tab="security">Security</button>
      </div>

      <form class="settings-panel active" id="general" aria-labelledby="general-tab">
        <div class="panel-header green-panel-header">
          <h2>General Settings</h2>
          <p>Core application defaults and business display preferences.</p>
        </div>
        <div class="settings-grid">
          <label>
            App Name
            <input type="text" value="<%= settings.general.appName %>" />
          </label>
          <label>
            Support Email
            <input type="email" value="<%= settings.general.supportEmail %>" />
          </label>
          <label>
            Timezone
            <select>
              <option selected><%= settings.general.timezone %></option>
              <option>UTC</option>
              <option>America/New_York</option>
            </select>
          </label>
          <label>
            Currency
            <select>
              <option selected><%= settings.general.currency %></option>
              <option>USD</option>
              <option>EUR</option>
            </select>
          </label>
          <label class="settings-toggle">
            <input type="checkbox" <%= settings.general.maintenanceMode ? 'checked' : '' %> />
            Maintenance Mode
          </label>
        </div>
        <button class="settings-save" type="button">Save General Settings</button>
      </form>

      <form class="settings-panel" id="email" aria-labelledby="email-tab">
        <div class="panel-header orange-header">
          <h2>Email Settings</h2>
          <p>SMTP configuration for signup, invoices, and operational alerts.</p>
        </div>
        <div class="settings-grid">
          <label>
            Mail Driver
            <select>
              <option selected><%= settings.email.mailDriver %></option>
              <option>SendGrid</option>
              <option>Mailgun</option>
            </select>
          </label>
          <label>
            SMTP Host
            <input type="text" value="<%= settings.email.host %>" />
          </label>
          <label>
            SMTP Port
            <input type="number" value="<%= settings.email.port %>" />
          </label>
          <label>
            From Email
            <input type="email" value="<%= settings.email.fromEmail %>" />
          </label>
          <label>
            Encryption
            <select>
              <option selected><%= settings.email.encryption %></option>
              <option>SSL</option>
              <option>None</option>
            </select>
          </label>
        </div>
        <button class="settings-save" type="button">Save Email Settings</button>
      </form>

      <form class="settings-panel" id="firebase" aria-labelledby="firebase-tab">
        <div class="panel-header blue-header">
          <h2>Firebase Settings</h2>
          <p>Firebase project values for notifications, storage, and mobile clients.</p>
        </div>
        <div class="settings-grid">
          <label>
            Project ID
            <input type="text" value="<%= settings.firebase.projectId %>" />
          </label>
          <label>
            Messaging Sender ID
            <input type="text" value="<%= settings.firebase.messagingSenderId %>" />
          </label>
          <label>
            Storage Bucket
            <input type="text" value="<%= settings.firebase.storageBucket %>" />
          </label>
          <label class="settings-wide">
            Server Key
            <textarea placeholder="Paste Firebase server key"></textarea>
          </label>
          <label class="settings-toggle">
            <input type="checkbox" <%= settings.firebase.pushNotifications ? 'checked' : '' %> />
            Push Notifications
          </label>
        </div>
        <button class="settings-save" type="button">Save Firebase Settings</button>
      </form>

      <form class="settings-panel" id="locations" aria-labelledby="locations-tab">
        <div class="panel-header location-header">
          <h2>Country, State & City Settings</h2>
          <p>Add and review service locations used across vendor and client profiles.</p>
        </div>

        <div class="location-manager">
          <section class="location-card">
            <h3>Add Country</h3>
            <label>
              Country Name
              <input id="countryName" type="text" placeholder="e.g. India" />
            </label>
            <label>
              Country Code
              <input id="countryCode" type="text" placeholder="e.g. IN" />
            </label>
            <button class="settings-save" type="button" onclick="addLocation('country')">Add Country</button>
            <div class="location-list" id="countryList">
              <% locationSettings.countries.forEach((country) => { %>
                <div class="location-row">
                  <span><%= country %></span>
                  <div class="location-actions">
                    <button type="button" onclick="editLocation(this)">Edit</button>
                    <button type="button" onclick="deleteLocation(this)">Delete</button>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="location-card">
            <h3>Add State</h3>
            <label>
              Country
              <select id="stateCountry">
                <% locationSettings.countries.forEach((country) => { %>
                  <option><%= country %></option>
                <% }) %>
              </select>
            </label>
            <label>
              State Name
              <input id="stateName" type="text" placeholder="e.g. Rajasthan" />
            </label>
            <button class="settings-save" type="button" onclick="addLocation('state')">Add State</button>
            <div class="location-list" id="stateList">
              <% locationSettings.states.forEach((state) => { %>
                <div class="location-row">
                  <span><%= state %></span>
                  <div class="location-actions">
                    <button type="button" onclick="editLocation(this)">Edit</button>
                    <button type="button" onclick="deleteLocation(this)">Delete</button>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="location-card">
            <h3>Add City</h3>
            <label>
              State
              <select id="cityState">
                <% locationSettings.states.forEach((state) => { %>
                  <option><%= state %></option>
                <% }) %>
              </select>
            </label>
            <label>
              City Name
              <input id="cityName" type="text" placeholder="e.g. Jaipur" />
            </label>
            <button class="settings-save" type="button" onclick="addLocation('city')">Add City</button>
            <div class="location-list" id="cityList">
              <% locationSettings.cities.forEach((city) => { %>
                <div class="location-row">
                  <span><%= city %></span>
                  <div class="location-actions">
                    <button type="button" onclick="editLocation(this)">Edit</button>
                    <button type="button" onclick="deleteLocation(this)">Delete</button>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>
        </div>
      </form>

      <section class="settings-panel" id="catalog" aria-labelledby="catalog-tab">
        <div class="panel-header catalog-header">
          <h2>Categories, Subcategories & Brands</h2>
          <p>Manage the grocery hierarchy used by products and vendor listings.</p>
        </div>

        <div class="catalog-toolbar">
          <div class="catalog-selects">
            <label>
              Category
              <select id="catalogCategoryFilter"></select>
            </label>
            <label>
              Subcategory
              <select id="catalogSubcategoryFilter"></select>
            </label>
            <label>
              Brand
              <select id="catalogBrandFilter"></select>
            </label>
          </div>
          <div class="catalog-actions">
            <button class="settings-save" type="button" onclick="openCatalogModal('category')">Add Category</button>
            <button class="settings-save" type="button" onclick="openCatalogModal('subcategory')">Add Subcategory</button>
            <button class="settings-save" type="button" onclick="openCatalogModal('brand')">Add Brand</button>
          </div>
        </div>

        <div class="catalog-layout">
          <aside class="catalog-tree" id="catalogTree">Loading catalog...</aside>
          <div class="catalog-table-stack">
          <div class="catalog-inner-tabs" role="tablist" aria-label="Catalog tables">
            <button class="catalog-inner-tab active" type="button" data-catalog-tab="categoryTablePanel">Category</button>
            <button class="catalog-inner-tab" type="button" data-catalog-tab="subcategoryTablePanel">SubCategory</button>
            <button class="catalog-inner-tab" type="button" data-catalog-tab="brandTablePanel">Brand</button>
          </div>
          <div class="catalog-table-card catalog-table-panel active" id="categoryTablePanel">
            <h3>Category Table</h3>
            <table class="catalog-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Name</th>
                  <th>Slug</th>
                  <th>Tax</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="categoryTableBody">
                <tr><td colspan="6">Loading...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="catalog-table-card catalog-table-panel" id="subcategoryTablePanel">
            <h3>SubCategory Table</h3>
            <table class="catalog-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Category</th>
                  <th>Name</th>
                  <th>Slug</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="subcategoryTableBody">
                <tr><td colspan="6">Loading...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="catalog-table-card catalog-table-panel" id="brandTablePanel">
            <h3>Brand Table</h3>
            <table class="catalog-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Category</th>
                  <th>SubCategory</th>
                  <th>Logo</th>
                  <th>Name</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="brandTableBody">
                <tr><td colspan="7">Loading...</td></tr>
              </tbody>
            </table>
          </div>
          </div>
        </div>
      </section>

      <section class="settings-panel" id="commissions" aria-labelledby="commissions-tab">
        <div class="panel-header commission-header">
          <h2>Role Commission Settings</h2>
          <p>Set commission rules for roles involved in wallet, order, and refund transactions.</p>
        </div>

        <div class="commission-toolbar">
          <label>
            Transaction
            <select id="commissionTransactionFilter">
              <option value="wallet_credit">Wallet Credit</option>
              <option value="wallet_debit">Wallet Debit</option>
              <option value="order_payment">Order Payment</option>
              <option value="refund">Refund</option>
            </select>
          </label>
          <label>
            Preview Amount
            <input id="commissionPreviewAmount" type="number" min="0" step="0.01" value="1000" />
          </label>
          <button class="settings-save" type="button" onclick="saveCommissionSettings()">Save Commission</button>
        </div>

        <div class="catalog-table-card commission-table-card">
          <table class="catalog-table commission-table">
            <thead>
              <tr>
                <th>Role</th>
                <th>Enabled</th>
                <th>Type</th>
                <th>Value</th>
                <th>Minimum</th>
                <th>Maximum</th>
                <th>Preview</th>
              </tr>
            </thead>
            <tbody id="commissionTableBody">
              <tr><td colspan="7">Loading commission settings...</td></tr>
            </tbody>
          </table>
        </div>
        <p class="commission-message" id="commissionMessage"></p>
      </section>

      <section class="settings-panel" id="delivery-partners" aria-labelledby="delivery-partners-tab">
        <div class="panel-header blue-header">
          <h2>Delivery Partner Settings</h2>
          <p>Assign active delivery staff to service cities used by order delivery.</p>
        </div>

        <div class="delivery-partner-toolbar">
          <label>
            Add City
            <input id="deliveryCityInput" type="text" placeholder="e.g. Jaipur" list="deliveryCityOptions" />
            <datalist id="deliveryCityOptions"></datalist>
          </label>
          <button class="settings-save" type="button" onclick="openDeliveryPartnerModal()">Add Delivery Partner</button>
          <button class="settings-save" type="button" onclick="saveDeliveryPartnerSettings()">Save Delivery Partners</button>
        </div>

        <div class="catalog-table-card">
          <table class="catalog-table delivery-partner-table">
            <thead>
              <tr>
                <th>Partner</th>
                <th>Contact</th>
                <th>Assigned Cities</th>
                <th>Add Selected City</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="deliveryPartnerTableBody">
              <tr><td colspan="5">Loading delivery partners...</td></tr>
            </tbody>
          </table>
        </div>
        <p class="commission-message" id="deliveryPartnerMessage"></p>
      </section>

      <section class="settings-panel" id="role-permissions" aria-labelledby="role-permissions-tab">
        <div class="panel-header purple-header settings-purple-header">
          <h2>Role Permission Settings</h2>
          <p>Control dashboard access for Staff L1, Staff L2, Staff L3, Support Staff, Accountant, and other roles.</p>
        </div>

        <div class="role-settings-layout">
          <div class="catalog-table-card role-list-card">
            <div class="role-settings-toolbar">
              <label>
                Select Role
                <select id="roleSettingsSelect"></select>
              </label>
              <button class="settings-save" type="button" onclick="saveRolePermissions()">Save Permissions</button>
            </div>
            <div id="roleSettingsSummary" class="role-settings-summary">Loading roles...</div>
          </div>

          <div class="catalog-table-card role-permission-card">
            <h3>Permissions</h3>
            <div class="role-permission-grid" id="rolePermissionGrid"></div>
            <p class="commission-message" id="roleSettingsMessage"></p>
          </div>
        </div>
      </section>

      <form class="settings-panel" id="security" aria-labelledby="security-tab">
        <div class="panel-header purple-header settings-purple-header">
          <h2>Security Settings</h2>
          <p>Authentication defaults and account protection rules.</p>
        </div>
        <div class="settings-grid">
          <label>
            JWT Expiry
            <input type="text" value="<%= settings.security.jwtExpiry %>" />
          </label>
          <label>
            Minimum Password Length
            <input type="number" value="<%= settings.security.minPasswordLength %>" />
          </label>
          <label>
            Login Attempts
            <input type="number" value="<%= settings.security.loginAttempts %>" />
          </label>
          <label class="settings-toggle">
            <input type="checkbox" <%= settings.security.accountVerification ? 'checked' : '' %> />
            Email/Phone Verification
          </label>
        </div>
        <button class="settings-save" type="button">Save Security Settings</button>
      </form>
    </section>
  </main>

  <script>
    const tabs = document.querySelectorAll('.settings-tab');
    const panels = document.querySelectorAll('.settings-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((item) => item.classList.remove('active'));
        panels.forEach((panel) => panel.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.tab).classList.add('active');
      });
    });

    document.querySelectorAll('.catalog-inner-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.catalog-inner-tab').forEach((item) => item.classList.remove('active'));
        document.querySelectorAll('.catalog-table-panel').forEach((panel) => panel.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.catalogTab).classList.add('active');
      });
    });

    function createLocationRow(value) {
      const row = document.createElement('div');
      row.className = 'location-row';
      row.innerHTML = `
        <span></span>
        <div class="location-actions">
          <button type="button" onclick="editLocation(this)">Edit</button>
          <button type="button" onclick="deleteLocation(this)">Delete</button>
        </div>
      `;
      row.querySelector('span').textContent = value;
      return row;
    }

    function addLocation(type) {
      const config = {
        country: { input: 'countryName', code: 'countryCode', list: 'countryList', select: 'stateCountry' },
        state: { input: 'stateName', list: 'stateList', select: 'cityState' },
        city: { input: 'cityName', list: 'cityList' },
      }[type];

      const input = document.getElementById(config.input);
      const value = input.value.trim();
      if (!value) return;

      const label = type === 'country' && document.getElementById(config.code).value.trim()
        ? `${value} (${document.getElementById(config.code).value.trim().toUpperCase()})`
        : value;

      document.getElementById(config.list).appendChild(createLocationRow(label));

      if (config.select) {
        const option = document.createElement('option');
        option.textContent = value;
        option.value = value;
        document.getElementById(config.select).appendChild(option);
      }

      input.value = '';
      if (config.code) document.getElementById(config.code).value = '';
    }

    function editLocation(button) {
      const row = button.closest('.location-row');
      const label = row.querySelector('span');
      const nextValue = prompt('Update location name', label.textContent);
      if (nextValue && nextValue.trim()) {
        label.textContent = nextValue.trim();
      }
    }

    function deleteLocation(button) {
      if (confirm('Delete this location?')) {
        button.closest('.location-row').remove();
      }
    }
  </script>

  <div class="user-modal" id="catalogModal" aria-hidden="true">
    <div class="user-modal-card">
      <div class="user-modal-header">
        <h2 id="catalogModalTitle">Add Item</h2>
        <button type="button" onclick="closeCatalogModal()">Close</button>
      </div>
      <form class="user-modal-grid" id="catalogForm">
        <input type="hidden" id="catalogType" />
        <input type="hidden" id="catalogId" />
        <label class="catalog-parent-field" id="catalogCategoryField">
          Category
          <select id="catalogCategoryInput"></select>
        </label>
        <label class="catalog-parent-field" id="catalogSubcategoryField">
          Subcategory
          <select id="catalogSubcategoryInput"></select>
        </label>
        <label>
          Name
          <input id="catalogNameInput" type="text" required />
        </label>
        <label>
          Slug
          <input id="catalogSlugInput" type="text" placeholder="auto-generated when empty" />
        </label>
        <label class="catalog-tax-field" id="catalogTaxNameField">
          Tax Name
          <input id="catalogTaxNameInput" type="text" placeholder="Example: GST" />
        </label>
        <label class="catalog-tax-field" id="catalogTaxPercentageField">
          Tax %
          <input id="catalogTaxPercentageInput" type="number" min="0" max="100" step="0.01" />
        </label>
        <label class="catalog-logo-field" id="catalogLogoField">
          Logo
          <input id="catalogLogoInput" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
        </label>
        <label class="settings-toggle">
          <input id="catalogActiveInput" type="checkbox" checked />
          Active
        </label>
        <button class="settings-save" type="submit">Save</button>
      </form>
    </div>
  </div>

  <div class="user-modal" id="deliveryPartnerModal" aria-hidden="true">
    <div class="user-modal-card">
      <div class="user-modal-header">
        <h2 id="deliveryPartnerModalTitle">Add Delivery Partner</h2>
        <button type="button" onclick="closeDeliveryPartnerModal()">Close</button>
      </div>
      <form class="user-modal-grid" id="deliveryPartnerForm">
        <input type="hidden" id="deliveryPartnerId" />
        <label>
          Name
          <input id="deliveryPartnerName" type="text" required minlength="2" />
        </label>
        <label>
          Email
          <input id="deliveryPartnerEmail" type="email" required />
        </label>
        <label>
          Phone
          <input id="deliveryPartnerPhone" type="tel" />
        </label>
        <label>
          Password
          <input id="deliveryPartnerPassword" type="password" minlength="6" placeholder="Required for new partner" />
        </label>
        <label class="settings-wide">
          City
          <input id="deliveryPartnerCity" type="text" list="deliveryCityOptions" placeholder="Type city and click Add City" />
        </label>
        <div class="settings-wide">
          <button class="product-secondary-button" type="button" onclick="addModalDeliveryCity()">Add City</button>
          <div class="delivery-city-pills" id="deliveryPartnerModalCities"></div>
        </div>
        <div class="settings-wide">
          <button class="settings-save" type="submit">Save Partner</button>
          <button class="product-secondary-button" type="button" onclick="closeDeliveryPartnerModal()">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    let catalogData = { categories: [], subcategories: [], brands: [], tree: [] };
    let roleSettings = [];
    const rolePermissionLabels = <%- JSON.stringify(permissionLabels || {}) %>;

    function catalogEndpoint(type) {
      return {
        category: '/categories',
        subcategory: '/sub-categories',
        brand: '/brands',
      }[type];
    }

    async function loadCatalog() {
      const tree = document.getElementById('catalogTree');
      const categoryBody = document.getElementById('categoryTableBody');
      const subcategoryBody = document.getElementById('subcategoryTableBody');
      const brandBody = document.getElementById('brandTableBody');
      tree.textContent = 'Loading catalog...';
      categoryBody.innerHTML = '<tr><td colspan="6">Loading...</td></tr>';
      subcategoryBody.innerHTML = '<tr><td colspan="6">Loading...</td></tr>';
      brandBody.innerHTML = '<tr><td colspan="7">Loading...</td></tr>';

      try {
        const response = await fetch('/catalog-tree', {
          headers: { Accept: 'application/json' },
          credentials: 'same-origin',
        });
        const contentType = response.headers.get('content-type') || '';

        if (!contentType.includes('application/json')) {
          throw new Error('Catalog API returned an HTML page. Please refresh and login again.');
        }

        const data = await response.json();
        if (!response.ok || !data.success) {
          throw new Error(data.message || 'Unable to load catalog data');
        }

        catalogData = {
          categories: data.categories || [],
          subcategories: data.subcategories || [],
          brands: data.brands || [],
          tree: data.tree || [],
        };
        renderCatalogFilters();
        renderCatalogTree();
        renderCatalogTable();
      } catch (error) {
        console.error(error);
        tree.innerHTML = `<div class="catalog-error">${escapeCatalog(error.message)}</div>`;
        categoryBody.innerHTML = `<tr><td colspan="5">${escapeCatalog(error.message)}</td></tr>`;
        subcategoryBody.innerHTML = `<tr><td colspan="6">${escapeCatalog(error.message)}</td></tr>`;
        brandBody.innerHTML = `<tr><td colspan="7">${escapeCatalog(error.message)}</td></tr>`;
      }
    }

    function optionList(items, emptyLabel) {
      return `<option value="">${emptyLabel}</option>` + items.map((item) => `<option value="${item.id}">${escapeCatalog(item.name)}</option>`).join('');
    }

    function brandLogoMarkup(brand) {
      const initial = String(brand.name || '?').trim().charAt(0).toUpperCase() || '?';
      if (brand.logo_path) {
        return `<span class="brand-logo-wrap"><img class="brand-logo" src="${escapeCatalog(brand.logo_path)}" alt="${escapeCatalog(brand.name)} logo" /></span>`;
      }
      return `<span class="brand-logo-fallback" aria-label="${escapeCatalog(brand.name)} logo">${escapeCatalog(initial)}</span>`;
    }

    function renderCatalogFilters() {
      const categoryFilter = document.getElementById('catalogCategoryFilter');
      const subcategoryFilter = document.getElementById('catalogSubcategoryFilter');
      const brandFilter = document.getElementById('catalogBrandFilter');
      categoryFilter.innerHTML = optionList(catalogData.categories, 'All Categories');
      updateSubcategoryFilter();
      updateBrandFilter();
      categoryFilter.onchange = () => {
        updateSubcategoryFilter();
        updateBrandFilter();
        renderCatalogTable();
      };
      subcategoryFilter.onchange = () => {
        updateBrandFilter();
        renderCatalogTable();
      };
      brandFilter.onchange = renderCatalogTable;

      document.getElementById('catalogCategoryInput').innerHTML = optionList(catalogData.categories, 'Select Category');
      updateCatalogSubcategoryInput();
    }

    function updateSubcategoryFilter() {
      const categoryId = document.getElementById('catalogCategoryFilter').value;
      const items = categoryId
        ? catalogData.subcategories.filter((item) => String(item.category_id) === String(categoryId))
        : catalogData.subcategories;
      document.getElementById('catalogSubcategoryFilter').innerHTML = optionList(items, 'All Subcategories');
    }

    function updateBrandFilter() {
      const categoryId = document.getElementById('catalogCategoryFilter').value;
      const subcategoryId = document.getElementById('catalogSubcategoryFilter').value;
      const items = catalogData.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.sub_category_id || item.subcategory_id) === String(subcategoryId));
      document.getElementById('catalogBrandFilter').innerHTML = optionList(items, 'All Brands');
    }

    function updateCatalogSubcategoryInput(selectedId) {
      const categoryId = document.getElementById('catalogCategoryInput').value;
      const items = categoryId
        ? catalogData.subcategories.filter((item) => String(item.category_id) === String(categoryId))
        : catalogData.subcategories;
      const select = document.getElementById('catalogSubcategoryInput');
      select.innerHTML = optionList(items, 'Select Subcategory');
      if (selectedId) select.value = selectedId;
    }

    function renderCatalogTree() {
      const tree = document.getElementById('catalogTree');
      tree.innerHTML = catalogData.tree.map((category) => `
        <details open>
          <summary>${escapeCatalog(category.name)}</summary>
          ${category.subcategories.map((subcategory) => `
            <details>
              <summary>${escapeCatalog(subcategory.name)}</summary>
              <ul>
                ${subcategory.brands.map((brand) => `<li>${escapeCatalog(brand.name)}</li>`).join('')}
              </ul>
            </details>
          `).join('')}
        </details>
      `).join('');
    }

    function catalogRows() {
      const categoryId = document.getElementById('catalogCategoryFilter').value;
      const subcategoryId = document.getElementById('catalogSubcategoryFilter').value;
      const brandId = document.getElementById('catalogBrandFilter').value;
      const rows = [];

      catalogData.categories
        .filter((item) => !categoryId || String(item.id) === String(categoryId))
        .forEach((item) => rows.push({ type: 'category', parent: '-', ...item }));

      catalogData.subcategories
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.id) === String(subcategoryId))
        .forEach((item) => rows.push({ type: 'subcategory', parent: item.category_name, ...item }));

      catalogData.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.subcategory_id) === String(subcategoryId))
        .filter((item) => !brandId || String(item.id) === String(brandId))
        .forEach((item) => rows.push({ type: 'brand', parent: `${item.category_name} / ${item.subcategory_name}`, ...item }));

      return rows;
    }

    function renderCatalogTable() {
      const categoryId = document.getElementById('catalogCategoryFilter').value;
      const subcategoryId = document.getElementById('catalogSubcategoryFilter').value;
      const brandId = document.getElementById('catalogBrandFilter').value;
      const categories = catalogData.categories.filter((item) => !categoryId || String(item.id) === String(categoryId));
      const subcategories = catalogData.subcategories
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.id) === String(subcategoryId));
      const brands = catalogData.brands
        .filter((item) => !categoryId || String(item.category_id) === String(categoryId))
        .filter((item) => !subcategoryId || String(item.sub_category_id || item.subcategory_id) === String(subcategoryId))
        .filter((item) => !brandId || String(item.id) === String(brandId));

      document.getElementById('categoryTableBody').innerHTML = categories.length
        ? categories.map((row) => `
          <tr>
            <td>${row.id}</td>
            <td>${escapeCatalog(row.name)}</td>
            <td>${escapeCatalog(row.slug)}</td>
            <td>${escapeCatalog(row.tax_name || '-')}<br><small>${row.tax_percentage === null || row.tax_percentage === undefined ? '-' : Number(row.tax_percentage || 0).toFixed(2) + '%'}</small></td>
            <td><span class="user-status-pill ${row.is_active ? 'active' : 'inactive'}">${row.is_active ? 'active' : 'inactive'}</span></td>
            <td>
              <div class="user-actions">
                <button type="button" onclick='openCatalogModal("category", ${JSON.stringify(row)})'>Edit</button>
                <button type="button" onclick='deleteCatalogItem("category", ${row.id})'>Delete</button>
              </div>
            </td>
          </tr>
        `).join('')
        : '<tr><td colspan="6">No categories found</td></tr>';

      document.getElementById('subcategoryTableBody').innerHTML = subcategories.length
        ? subcategories.map((row) => `
          <tr>
            <td>${row.id}</td>
            <td>${escapeCatalog(row.category_name)}</td>
            <td>${escapeCatalog(row.name)}</td>
            <td>${escapeCatalog(row.slug)}</td>
            <td><span class="user-status-pill ${row.is_active ? 'active' : 'inactive'}">${row.is_active ? 'active' : 'inactive'}</span></td>
            <td>
              <div class="user-actions">
                <button type="button" onclick='openCatalogModal("subcategory", ${JSON.stringify(row)})'>Edit</button>
                <button type="button" onclick='deleteCatalogItem("subcategory", ${row.id})'>Delete</button>
              </div>
            </td>
          </tr>
        `).join('')
        : '<tr><td colspan="6">No subcategories found</td></tr>';

      document.getElementById('brandTableBody').innerHTML = brands.length
        ? brands.map((row) => `
          <tr>
            <td>${row.id}</td>
            <td>${escapeCatalog(row.category_name)}</td>
            <td>${escapeCatalog(row.sub_category_name || row.subcategory_name)}</td>
            <td>${brandLogoMarkup(row)}</td>
            <td>${escapeCatalog(row.name)}</td>
            <td><span class="user-status-pill ${row.is_active ? 'active' : 'inactive'}">${row.is_active ? 'active' : 'inactive'}</span></td>
            <td>
              <div class="user-actions">
                <button type="button" onclick='openCatalogModal("brand", ${JSON.stringify(row)})'>Edit</button>
                <button type="button" onclick='deleteCatalogItem("brand", ${row.id})'>Delete</button>
              </div>
            </td>
          </tr>
        `).join('')
        : '<tr><td colspan="7">No brands found</td></tr>';
    }

    function openCatalogModal(type, item) {
      const modal = document.getElementById('catalogModal');
      document.getElementById('catalogType').value = type;
      document.getElementById('catalogId').value = item ? item.id : '';
      document.getElementById('catalogModalTitle').textContent = `${item ? 'Edit' : 'Add'} ${type}`;
      document.getElementById('catalogNameInput').value = item ? item.name : '';
      document.getElementById('catalogSlugInput').value = item ? item.slug : '';
      document.getElementById('catalogTaxNameInput').value = item && item.tax_name ? item.tax_name : '';
      document.getElementById('catalogTaxPercentageInput').value = item && item.tax_percentage !== null && item.tax_percentage !== undefined ? Number(item.tax_percentage).toFixed(2) : '';
      document.getElementById('catalogActiveInput').checked = item ? item.is_active : true;
      document.getElementById('catalogCategoryField').style.display = type === 'subcategory' || type === 'brand' ? 'block' : 'none';
      document.getElementById('catalogSubcategoryField').style.display = type === 'brand' ? 'block' : 'none';
      document.getElementById('catalogLogoField').style.display = type === 'brand' ? 'block' : 'none';
      document.getElementById('catalogTaxNameField').style.display = type === 'category' ? 'block' : 'none';
      document.getElementById('catalogTaxPercentageField').style.display = type === 'category' ? 'block' : 'none';
      document.getElementById('catalogLogoInput').value = '';
      document.getElementById('catalogCategoryInput').value = item && item.category_id ? item.category_id : '';
      updateCatalogSubcategoryInput(item && (item.sub_category_id || item.subcategory_id) ? (item.sub_category_id || item.subcategory_id) : '');
      modal.classList.add('active');
    }

    function closeCatalogModal() {
      document.getElementById('catalogModal').classList.remove('active');
    }

    document.getElementById('catalogCategoryInput').addEventListener('change', () => updateCatalogSubcategoryInput());

    document.getElementById('catalogForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const type = document.getElementById('catalogType').value;
      const id = document.getElementById('catalogId').value;
      let payload = {
        name: document.getElementById('catalogNameInput').value,
        slug: document.getElementById('catalogSlugInput').value,
        is_active: document.getElementById('catalogActiveInput').checked,
      };

      if (type === 'subcategory') payload.category_id = document.getElementById('catalogCategoryInput').value;
      if (type === 'category') {
        payload.tax_name = document.getElementById('catalogTaxNameInput').value;
        payload.tax_percentage = document.getElementById('catalogTaxPercentageInput').value;
      }
      if (type === 'brand') {
        payload.category_id = document.getElementById('catalogCategoryInput').value;
        payload.sub_category_id = document.getElementById('catalogSubcategoryInput').value;
        const formData = new FormData();
        Object.entries(payload).forEach(([key, value]) => formData.append(key, value));
        const logo = document.getElementById('catalogLogoInput').files[0];
        if (logo) formData.append('logo', logo);
        payload = formData;
      }

      const response = await fetch(`${catalogEndpoint(type)}${id ? `/${id}` : ''}`, {
        method: id ? 'PUT' : 'POST',
        headers: type === 'brand' ? undefined : { 'Content-Type': 'application/json' },
        body: type === 'brand' ? payload : JSON.stringify(payload),
      });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || (data.errors || []).join(', ') || 'Unable to save item');
        return;
      }
      closeCatalogModal();
      loadCatalog();
    });

    async function deleteCatalogItem(type, id) {
      if (!confirm(`Delete this ${type}? Child items will also be hidden where applicable.`)) return;
      const response = await fetch(`${catalogEndpoint(type)}/${id}`, { method: 'DELETE' });
      const data = await response.json();
      if (!data.success) {
        alert(data.message || 'Unable to delete item');
        return;
      }
      loadCatalog();
    }

    function escapeCatalog(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
    }

    let commissionSettings = [];
    let deliveryPartnerSettings = [];
    let deliveryCities = [];
    let deliveryPartnerModalCities = [];

    async function loadRoleSettings() {
      const select = document.getElementById('roleSettingsSelect');
      const message = document.getElementById('roleSettingsMessage');
      select.innerHTML = '<option>Loading roles...</option>';
      document.getElementById('rolePermissionGrid').innerHTML = '';
      document.getElementById('roleSettingsSummary').textContent = 'Loading roles...';
      message.textContent = '';

      try {
        const response = await fetch('/settings/roles');
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to load roles');
        roleSettings = data.roles || [];
        select.innerHTML = roleSettings.map((role) => `<option value="${role.id}">${escapeCatalog(role.name)}</option>`).join('');
        renderRoleSettings();
      } catch (error) {
        select.innerHTML = '<option>Unable to load roles</option>';
        document.getElementById('roleSettingsSummary').textContent = error.message;
      }
    }

    function selectedRoleSetting() {
      const selectedId = document.getElementById('roleSettingsSelect').value;
      return roleSettings.find((role) => String(role.id) === String(selectedId));
    }

    function renderRoleSettings() {
      const role = selectedRoleSetting();
      const grid = document.getElementById('rolePermissionGrid');
      if (!role) {
        document.getElementById('roleSettingsSummary').textContent = 'No roles found';
        grid.innerHTML = '';
        return;
      }

      const permissions = Array.isArray(role.permissions) ? role.permissions : [];
      const userCount = Number(role.user_count || 0);
      document.getElementById('roleSettingsSummary').innerHTML = `
        <strong>${escapeCatalog(role.name)}</strong>
        <span>${escapeCatalog(role.description || 'No description')}</span>
        <small>Level ${role.level} &middot; ${userCount} assigned user${userCount === 1 ? '' : 's'}</small>
      `;

      grid.innerHTML = Object.entries(rolePermissionLabels).map(([value, label]) => `
        <label class="role-permission-option">
          <input type="checkbox" value="${escapeCatalog(value)}" ${permissions.includes(value) ? 'checked' : ''} />
          <span>${escapeCatalog(label)}</span>
        </label>
      `).join('');
    }

    async function saveRolePermissions() {
      const role = selectedRoleSetting();
      if (!role) return;

      const message = document.getElementById('roleSettingsMessage');
      const permissions = Array.from(document.querySelectorAll('#rolePermissionGrid input:checked')).map((input) => input.value);
      message.textContent = 'Saving role permissions...';

      try {
        const response = await fetch(`/settings/roles/${role.id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ permissions }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save role permissions');
        role.permissions = data.permissions || permissions;
        renderRoleSettings();
        message.textContent = 'Role permissions saved.';
      } catch (error) {
        message.textContent = error.message;
      }
    }

    function commissionLabel(value) {
      return {
        wallet_credit: 'Wallet Credit',
        wallet_debit: 'Wallet Debit',
        order_payment: 'Order Payment',
        refund: 'Refund',
      }[value] || value;
    }

    async function loadCommissionSettings() {
      const body = document.getElementById('commissionTableBody');
      body.innerHTML = '<tr><td colspan="7">Loading commission settings...</td></tr>';
      try {
        const response = await fetch('/settings/commissions');
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to load commission settings');
        commissionSettings = data.settings || [];
        renderCommissionSettings();
      } catch (error) {
        body.innerHTML = `<tr><td colspan="7">${escapeCatalog(error.message)}</td></tr>`;
      }
    }

    function activeCommissionRows() {
      const transactionType = document.getElementById('commissionTransactionFilter').value;
      return commissionSettings.filter((item) => item.transaction_type === transactionType);
    }

    function calculateCommissionPreview(setting) {
      const amount = Number(document.getElementById('commissionPreviewAmount').value || 0);
      if (!setting.is_active || amount <= 0) return { commission: 0, net: amount };
      let commission = setting.commission_type === 'percentage'
        ? (amount * Number(setting.commission_value || 0)) / 100
        : Number(setting.commission_value || 0);
      commission = Math.max(commission, Number(setting.min_commission || 0));
      if (setting.max_commission !== null && setting.max_commission !== undefined && setting.max_commission !== '') {
        commission = Math.min(commission, Number(setting.max_commission));
      }
      commission = Number(Math.max(commission, 0).toFixed(2));
      const net = setting.transaction_type === 'wallet_debit'
        ? amount + commission
        : Math.max(amount - commission, 0);
      return { commission, net: Number(net.toFixed(2)) };
    }

    function renderCommissionSettings() {
      const rows = activeCommissionRows();
      const body = document.getElementById('commissionTableBody');
      const transactionLabel = commissionLabel(document.getElementById('commissionTransactionFilter').value);
      if (rows.length === 0) {
        body.innerHTML = '<tr><td colspan="7">No commission settings found</td></tr>';
        return;
      }

      body.innerHTML = rows.map((setting) => {
        const preview = calculateCommissionPreview(setting);
        return `
          <tr data-commission-id="${setting.id}" data-transaction-type="${setting.transaction_type}">
            <td>
              <strong>${escapeCatalog(setting.role_name)}</strong>
              <span class="commission-subtext">${transactionLabel}</span>
            </td>
            <td>
              <label class="settings-toggle commission-toggle">
                <input class="commission-active" type="checkbox" ${setting.is_active ? 'checked' : ''} />
              </label>
            </td>
            <td>
              <select class="commission-type">
                <option value="percentage" ${setting.commission_type === 'percentage' ? 'selected' : ''}>Percentage</option>
                <option value="fixed" ${setting.commission_type === 'fixed' ? 'selected' : ''}>Fixed</option>
              </select>
            </td>
            <td><input class="commission-value" type="number" min="0" step="0.01" value="${setting.commission_value}" /></td>
            <td><input class="commission-min" type="number" min="0" step="0.01" value="${setting.min_commission}" /></td>
            <td><input class="commission-max" type="number" min="0" step="0.01" value="${setting.max_commission === null ? '' : setting.max_commission}" placeholder="No cap" /></td>
            <td class="commission-preview-cell">
              <strong>Fee ${preview.commission.toFixed(2)}</strong>
              <span class="commission-subtext">Net ${preview.net.toFixed(2)}</span>
            </td>
          </tr>
        `;
      }).join('');

      body.querySelectorAll('input, select').forEach((input) => {
        input.addEventListener('input', syncCommissionRow);
        input.addEventListener('change', syncCommissionRow);
      });
    }

    function syncCommissionRow(event) {
      const row = event.target.closest('tr');
      const id = Number(row.dataset.commissionId);
      const setting = commissionSettings.find((item) => item.id === id);
      if (!setting) return;
      setting.is_active = row.querySelector('.commission-active').checked;
      setting.commission_type = row.querySelector('.commission-type').value;
      setting.commission_value = Number(row.querySelector('.commission-value').value || 0);
      setting.min_commission = Number(row.querySelector('.commission-min').value || 0);
      setting.max_commission = row.querySelector('.commission-max').value;
      const preview = calculateCommissionPreview(setting);
      row.querySelector('.commission-preview-cell').innerHTML = `
        <strong>Fee ${preview.commission.toFixed(2)}</strong>
        <span class="commission-subtext">Net ${preview.net.toFixed(2)}</span>
      `;
    }

    async function saveCommissionSettings() {
      const message = document.getElementById('commissionMessage');
      const rows = activeCommissionRows();
      message.textContent = 'Saving commission settings...';
      try {
        const response = await fetch('/settings/commissions', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ settings: rows }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save commission settings');
        commissionSettings = data.settings || [];
        message.textContent = data.message;
        renderCommissionSettings();
      } catch (error) {
        message.textContent = error.message;
      }
    }

    async function loadDeliveryPartnerSettings() {
      const body = document.getElementById('deliveryPartnerTableBody');
      body.innerHTML = '<tr><td colspan="5">Loading delivery partners...</td></tr>';
      try {
        const response = await fetch('/settings/delivery-partners');
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to load delivery partners');
        deliveryPartnerSettings = data.partners || [];
        deliveryCities = data.cities || [];
        renderDeliveryCityOptions();
        renderDeliveryPartners();
      } catch (error) {
        body.innerHTML = `<tr><td colspan="5">${escapeCatalog(error.message)}</td></tr>`;
      }
    }

    function renderDeliveryCityOptions() {
      const list = document.getElementById('deliveryCityOptions');
      list.innerHTML = deliveryCities.map((city) => `<option value="${escapeCatalog(city)}"></option>`).join('');
    }

    function partnerCities(partner) {
      return (partner.cities || [])
        .filter((entry) => entry && Number(entry.is_active) !== 0)
        .map((entry) => String(entry.city || '').trim())
        .filter(Boolean);
    }

    function renderDeliveryPartners() {
      const body = document.getElementById('deliveryPartnerTableBody');
      if (!deliveryPartnerSettings.length) {
        body.innerHTML = '<tr><td colspan="5">No delivery partners found.</td></tr>';
        return;
      }

      body.innerHTML = deliveryPartnerSettings.map((partner) => {
        const cities = partnerCities(partner);
        return `
          <tr data-partner-id="${partner.id}">
            <td>
              <strong>${escapeCatalog(partner.name)}</strong>
              <span class="commission-subtext">Staff ID ${partner.id}</span>
            </td>
            <td>
              <span>${escapeCatalog(partner.email || '')}</span>
              <span class="commission-subtext">${escapeCatalog(partner.phone || '')}</span>
            </td>
            <td>
              <div class="delivery-city-pills">
                ${cities.length ? cities.map((city) => `
                  <button type="button" class="delivery-city-pill" onclick="removeDeliveryCity(${partner.id}, '${escapeCatalog(city)}')">${escapeCatalog(city)} x</button>
                `).join('') : '<span class="commission-subtext">No city assigned</span>'}
              </div>
            </td>
            <td>
              <button class="product-secondary-button" type="button" onclick="addDeliveryCity(${partner.id})">Add City</button>
            </td>
            <td>
              <button class="product-secondary-button" type="button" onclick="openDeliveryPartnerModal(${partner.id})">Edit</button>
              <button class="reject-button" type="button" onclick="deleteDeliveryPartner(${partner.id})">Delete</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    function addDeliveryCity(partnerId) {
      const city = document.getElementById('deliveryCityInput').value.trim();
      if (!city) {
        alert('Enter or select a city first.');
        return;
      }
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!partner) return;
      const cities = partnerCities(partner);
      if (!cities.some((item) => item.toLowerCase() === city.toLowerCase())) {
        partner.cities = [...(partner.cities || []), { city, is_active: 1 }];
      }
      if (!deliveryCities.some((item) => item.toLowerCase() === city.toLowerCase())) {
        deliveryCities.push(city);
        deliveryCities.sort();
        renderDeliveryCityOptions();
      }
      renderDeliveryPartners();
    }

    function removeDeliveryCity(partnerId, city) {
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!partner) return;
      partner.cities = (partner.cities || []).filter((entry) => String(entry.city || '').toLowerCase() !== String(city || '').toLowerCase());
      renderDeliveryPartners();
    }

    async function saveDeliveryPartnerSettings() {
      const message = document.getElementById('deliveryPartnerMessage');
      message.textContent = 'Saving delivery partner settings...';
      const assignments = deliveryPartnerSettings.map((partner) => ({
        user_id: partner.id,
        cities: partnerCities(partner),
      }));
      try {
        const response = await fetch('/settings/delivery-partners', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ assignments }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save delivery partner settings');
        message.textContent = data.message;
        loadDeliveryPartnerSettings();
      } catch (error) {
        message.textContent = error.message;
      }
    }

    function openDeliveryPartnerModal(partnerId = null) {
      const partner = partnerId ? deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId)) : null;
      document.getElementById('deliveryPartnerModalTitle').textContent = partner ? 'Edit Delivery Partner' : 'Add Delivery Partner';
      document.getElementById('deliveryPartnerId').value = partner ? partner.id : '';
      document.getElementById('deliveryPartnerName').value = partner ? partner.name || '' : '';
      document.getElementById('deliveryPartnerEmail').value = partner ? partner.email || '' : '';
      document.getElementById('deliveryPartnerPhone').value = partner ? partner.phone || '' : '';
      document.getElementById('deliveryPartnerPassword').value = '';
      document.getElementById('deliveryPartnerPassword').required = !partner;
      document.getElementById('deliveryPartnerCity').value = '';
      deliveryPartnerModalCities = partner ? partnerCities(partner) : [];
      renderModalDeliveryCities();
      document.getElementById('deliveryPartnerModal').style.display = 'flex';
      document.getElementById('deliveryPartnerModal').setAttribute('aria-hidden', 'false');
    }

    function closeDeliveryPartnerModal() {
      document.getElementById('deliveryPartnerModal').style.display = 'none';
      document.getElementById('deliveryPartnerModal').setAttribute('aria-hidden', 'true');
      document.getElementById('deliveryPartnerForm').reset();
      deliveryPartnerModalCities = [];
    }

    function renderModalDeliveryCities() {
      const target = document.getElementById('deliveryPartnerModalCities');
      target.innerHTML = deliveryPartnerModalCities.length
        ? deliveryPartnerModalCities.map((city) => `
          <button type="button" class="delivery-city-pill" onclick="removeModalDeliveryCity('${escapeCatalog(city)}')">${escapeCatalog(city)} x</button>
        `).join('')
        : '<span class="commission-subtext">No city assigned</span>';
    }

    function addModalDeliveryCity() {
      const input = document.getElementById('deliveryPartnerCity');
      const city = input.value.trim();
      if (!city) return;
      if (!deliveryPartnerModalCities.some((item) => item.toLowerCase() === city.toLowerCase())) {
        deliveryPartnerModalCities.push(city);
      }
      if (!deliveryCities.some((item) => item.toLowerCase() === city.toLowerCase())) {
        deliveryCities.push(city);
        deliveryCities.sort();
        renderDeliveryCityOptions();
      }
      input.value = '';
      renderModalDeliveryCities();
    }

    function removeModalDeliveryCity(city) {
      deliveryPartnerModalCities = deliveryPartnerModalCities.filter((item) => item.toLowerCase() !== String(city || '').toLowerCase());
      renderModalDeliveryCities();
    }

    async function deleteDeliveryPartner(partnerId) {
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!confirm(`Delete ${partner ? partner.name : 'this delivery partner'}?`)) return;
      try {
        const response = await fetch(`/settings/delivery-partners/${partnerId}`, { method: 'DELETE' });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to delete delivery partner');
        document.getElementById('deliveryPartnerMessage').textContent = data.message;
        loadDeliveryPartnerSettings();
      } catch (error) {
        document.getElementById('deliveryPartnerMessage').textContent = error.message;
      }
    }

    document.getElementById('deliveryPartnerForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = document.getElementById('deliveryPartnerId').value;
      const payload = {
        name: document.getElementById('deliveryPartnerName').value.trim(),
        email: document.getElementById('deliveryPartnerEmail').value.trim(),
        phone: document.getElementById('deliveryPartnerPhone').value.trim(),
        password: document.getElementById('deliveryPartnerPassword').value,
        cities: deliveryPartnerModalCities,
      };
      try {
        const response = await fetch(`/settings/delivery-partners${id ? `/${id}` : ''}`, {
          method: id ? 'PUT' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save delivery partner');
        document.getElementById('deliveryPartnerMessage').textContent = data.message;
        closeDeliveryPartnerModal();
        loadDeliveryPartnerSettings();
      } catch (error) {
        document.getElementById('deliveryPartnerMessage').textContent = error.message;
      }
    });

    document.getElementById('commissionTransactionFilter').addEventListener('change', renderCommissionSettings);
    document.getElementById('commissionPreviewAmount').addEventListener('input', renderCommissionSettings);
    document.getElementById('roleSettingsSelect').addEventListener('change', renderRoleSettings);

    loadCatalog();
    loadRoleSettings();
    loadCommissionSettings();
    loadDeliveryPartnerSettings();
  </script>
  <style>
    .role-settings-layout {
      display: grid;
      grid-template-columns: minmax(260px, 0.8fr) minmax(320px, 1.2fr);
      gap: 16px;
    }
    .role-settings-toolbar {
      display: flex;
      align-items: end;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .role-settings-summary {
      display: grid;
      gap: 6px;
      color: #475569;
    }
    .role-settings-summary strong {
      color: #0f172a;
      font-size: 18px;
    }
    .role-settings-summary small {
      color: #64748b;
      font-weight: 700;
    }
    .role-permission-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 10px;
    }
    .role-permission-option {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      background: #fff;
      font-weight: 700;
      color: #334155;
    }
    .delivery-partner-toolbar {
      display: flex;
      align-items: end;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }
    .delivery-city-pills {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .delivery-city-pill {
      border: 0;
      border-radius: 999px;
      padding: 6px 10px;
      background: #e0f2fe;
      color: #075985;
      font-weight: 800;
      cursor: pointer;
    }
    .reject-button {
      padding: 8px 12px;
      border: 0;
      border-radius: 6px;
      background: #fee2e2;
      color: #991b1b;
      font-weight: 800;
      cursor: pointer;
    }
    @media (max-width: 900px) {
      .role-settings-layout {
        grid-template-columns: 1fr;
      }
    }
  </style>
</body>
</html>
