    function googleServiceHelp(service, status, fallback) {
      const code = String(status || '').toUpperCase();
      const serviceName = String(service || 'Google Maps API');
      const defaultHelp = fallback || `Check ${serviceName} API enablement, billing, and key restrictions.`;
      const serviceActions = {
        'Maps JavaScript API': {
          REQUEST_DENIED: 'Enable Maps JavaScript API and allow this admin website referrer on the browser key.',
          AUTH_ERROR: 'Enable Maps JavaScript API and verify the browser key website referrer restrictions.',
          MISSING_KEY: 'Add a browser API key with Maps JavaScript API enabled.',
        },
        'Directions API': {
          REQUEST_DENIED: 'Enable Directions API and allow it on the browser map key.',
          ZERO_RESULTS: 'Directions API is enabled, but no route was found for the test addresses.',
          NOT_FOUND: 'Directions API is enabled, but one test address could not be found.',
        },
        'Distance Matrix API': {
          MISSING_KEY: 'Add a dedicated Distance API Server Key with Distance Matrix API enabled.',
          REQUEST_DENIED: 'Enable Distance Matrix API and allow it on the backend server key.',
          OVER_QUERY_LIMIT: 'Distance Matrix API quota is exhausted. Increase quota or wait for reset.',
          OVER_DAILY_LIMIT: 'Distance Matrix API daily limit or billing limit is reached.',
          INVALID_REQUEST: 'Distance Matrix API request is invalid. Check the test origin and destination.',
        },
      };
      return (serviceActions[serviceName] && serviceActions[serviceName][code]) || defaultHelp;
    }

    function renderGoogleApiDiagnostics(items) {
      const diagnostics = document.getElementById('googleApiDiagnostics');
      const rows = (items || []).filter(Boolean);
      if (!rows.length) {
        diagnostics.innerHTML = '';
        return;
      }
      diagnostics.innerHTML = rows.map((item) => {
        const ok = Boolean(item.ok);
        const status = item.status || (ok ? 'OK' : 'ERROR');
        const service = item.service || 'Google Maps API';
        const action = item.action || googleServiceHelp(service, status);
        return `
          <div class="google-api-diagnostic ${ok ? 'ok' : 'error'}">
            <strong>${escapeCatalog(service)}</strong>
            <span>${escapeCatalog(status)}</span>
            <small>${escapeCatalog(action)}</small>
          </div>
        `;
      }).join('');
    }

    async function saveGoogleMapSettings(event) {
      if (event) event.preventDefault();
