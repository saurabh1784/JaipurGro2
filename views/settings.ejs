  <script>
    function confirmMaintenanceClear() {
      return window.confirm('Warning: this will permanently delete all quotation and order data for every client and vendor. Continue?');
    }

    function confirmVendorPriceSync() {
      return window.confirm('This will set every vendor product price to the master product price one time for debugging. Vendors can change their own prices after this reset. Continue?');
    }

    function confirmDatabaseRestore() {
      return window.confirm('Warning: this will drop every table, permanently delete all current data, and recreate the database schema. Continue?');
    }

    function confirmDatabaseBackup() {
      return window.confirm('Create a complete JSON backup of the current database now?');
    }

    function confirmRestoreBackup() {
      return window.confirm('Warning: this will replace the current database data with the selected backup. Continue?');
    }

    function confirmRestoreUpload() {
      return window.confirm('Warning: this will upload a JSON backup and replace the current database data. Continue?');
    }

    function confirmCleanDatabase() {
      return window.confirm('Warning: this will drop every table, permanently delete all current data, and recreate the database schema with default seed data. Continue?');
    }

    (function setupUpdateDatabase() {
      const form = document.getElementById('updateDatabaseForm');
      if (!form) return;
      const button = document.getElementById('updateDatabaseButton');
      const progress = document.getElementById('updateDatabaseProgress');
      const barFill = document.getElementById('updateDatabaseBarFill');
      const statusEl = document.getElementById('updateDatabaseStatus');
      const logEl = document.getElementById('updateDatabaseLog');

      const totalSteps = 7;
      let doneSteps = 0;

      function setStep(message) {
        doneSteps += 1;
        statusEl.textContent = message;
        barFill.style.width = `${Math.min(100, Math.round((doneSteps / totalSteps) * 100))}%`;
        logEl.textContent += `\n• ${message}`;
        logEl.scrollTop = logEl.scrollHeight;
      }

      function reset() {
        doneSteps = 0;
        barFill.style.width = '0%';
        statusEl.textContent = 'Starting…';
        logEl.textContent = '';
        progress.hidden = false;
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!window.confirm('Create a safety backup and update the live database schema? Existing data will be preserved.')) {
          return;
        }
        reset();
        button.disabled = true;
        const originalLabel = button.textContent;
        button.textContent = 'Updating…';
        setStep('Preparing schema update');
        try {
          const response = await fetch(form.action, {
            method: 'POST',
            headers: { Accept: 'application/json' },
            credentials: 'same-origin',
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.success) {
            throw new Error(data.message || `Server returned ${response.status}`);
          }
          const result = data.result || {};
          const stepMessages = Array.isArray(result.steps) ? result.steps : [];
          stepMessages.forEach((message) => setStep(message));
          if (!stepMessages.length) {
            setStep('Schema update completed');
          }
          barFill.style.width = '100%';
          statusEl.textContent = data.message || 'Database schema updated successfully.';
          statusEl.classList.add('update-database-success');
        } catch (error) {
          statusEl.textContent = error.message || 'Unable to update database schema.';
          statusEl.classList.add('update-database-error');
        } finally {
          button.disabled = false;
          button.textContent = originalLabel;
        }
      });
    })();


    const tabs = document.querySelectorAll('.settings-tab');
    const panels = document.querySelectorAll('.settings-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((item) => item.classList.remove('active'));
        panels.forEach((panel) => panel.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.tab).classList.add('active');
      });
    });

    document.querySelectorAll('.debug-subtab').forEach((tab) => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.debug-subtab').forEach((item) => item.classList.remove('active'));
        document.querySelectorAll('.debug-tool-panel').forEach((panel) => panel.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(`debug-${tab.dataset.debugTab}`).classList.add('active');
        if (tab.dataset.debugTab === 'delivery-partner-test') {
          loadDeliveryPartnerTestPartners();
        }
      });
    });

    function deliveryPartnerTestFilters() {
      return {
        city: document.getElementById('deliveryPartnerTestCity').value.trim(),
        area: document.getElementById('deliveryPartnerTestArea').value.trim(),
        mobile: document.getElementById('deliveryPartnerTestMobile').value.trim(),
        email: document.getElementById('deliveryPartnerTestEmail').value.trim(),
        name: document.getElementById('deliveryPartnerTestName').value.trim(),
      };
    }

    function deliveryPartnerTestQuery() {
      const params = new URLSearchParams();
      Object.entries(deliveryPartnerTestFilters()).forEach(([key, value]) => {
        if (value) params.set(key, value);
      });
      return params.toString();
    }

    function renderDeliveryPartnerTestPartners(partners, adminCity) {
      const list = document.getElementById('deliveryPartnerTestList');
      if (!partners.length) {
        list.innerHTML = '<div class="debug-empty-state">No delivery partners found.</div>';
        return;
      }
      list.innerHTML = partners.map((partner) => `
        <div class="debug-delivery-row">
          <div>
            <span>Name</span>
            <strong>${escapeCatalog(partner.name || '-')}</strong>
          </div>
          <div>
            <span>City</span>
            <strong>${escapeCatalog(partner.city || adminCity || '-')}</strong>
          </div>
          <div>
            <span>Area</span>
            <strong>${escapeCatalog(partner.area || '*')}</strong>
          </div>
          <div>
            <span>Wallet Balance</span>
            <strong>INR ${Number(partner.wallet_balance || 0).toFixed(2)}</strong>
          </div>
          <button class="settings-save" type="button" onclick="sendTestDelivery(${Number(partner.id)})">Send Test Delivery</button>
        </div>
      `).join('');
    }

    async function loadDeliveryPartnerTestPartners() {
      const message = document.getElementById('deliveryPartnerTestMessage');
      message.textContent = 'Loading delivery partners...';
      try {
        const query = deliveryPartnerTestQuery();
        const response = await fetch(`/settings/debug/delivery-partner-test/partners${query ? `?${query}` : ''}`);
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to load delivery partners');
        renderDeliveryPartnerTestPartners(data.partners || [], data.admin_city || '');
        message.textContent = query
          ? `${(data.partners || []).length} delivery partner(s) found.`
          : `${(data.partners || []).length} delivery partner(s) from ${data.admin_city || 'admin city'}.`;
      } catch (error) {
        document.getElementById('deliveryPartnerTestList').innerHTML = '';
        message.textContent = error.message;
      }
    }

    async function sendTestDelivery(partnerId) {
      const message = document.getElementById('deliveryPartnerTestMessage');
      message.textContent = 'Sending test delivery...';
      try {
        const response = await fetch(`/settings/debug/delivery-partner-test/${partnerId}/send`, { method: 'POST' });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to send test delivery');
        message.textContent = `${data.message}. Order #${data.order_number}`;
      } catch (error) {
        message.textContent = error.message;
      }
    }

    async function readSettingsJson(response, fallbackMessage) {
      const text = await response.text();
      let data = {};
      try {
        data = text ? JSON.parse(text) : {};
      } catch (_) {
        throw new Error(response.ok ? fallbackMessage : `${fallbackMessage} Server replied: ${text || response.status}`);
      }
      if (!response.ok && !data.message) {
        data.message = fallbackMessage;
      }
      return data;
    }
    function biddingRowPayload() {
      return {
        city: document.getElementById('biddingCityInput').value.trim(),
        timer_minutes: Number(document.getElementById('biddingTimerInput').value || 0),
        daily_start_time: document.getElementById('biddingStartInput').value || '00:00',
        daily_end_time: document.getElementById('biddingEndInput').value || '23:59',
        is_enabled: document.getElementById('biddingEnabledInput').checked,
        auto_close_on_expiry: document.getElementById('biddingAutoCloseInput').checked,
      };
    }

    function editBiddingSetting(index) {
      const row = biddingSettings[index];
      if (!row) return;
      document.getElementById('biddingCityInput').value = row.city || '';
      document.getElementById('biddingTimerInput').value = Number(row.timer_minutes || 30);
      document.getElementById('biddingStartInput').value = String(row.daily_start_time || '00:00').slice(0, 5);
      document.getElementById('biddingEndInput').value = String(row.daily_end_time || '23:59').slice(0, 5);
      document.getElementById('biddingEnabledInput').checked = row.is_enabled !== false;
      document.getElementById('biddingAutoCloseInput').checked = row.auto_close_on_expiry !== false;
      document.getElementById('biddingSettingsMessage').textContent = 'Edit values, then click Save Bidding Setting.';
    }

    async function saveBiddingSetting() {
      const message = document.getElementById('biddingSettingsMessage');
      const payload = biddingRowPayload();
      if (!payload.city) {
        message.textContent = 'City is required.';
        return;
      }
      message.textContent = 'Saving bidding setting...';
      try {
        const response = await fetch('/settings/bidding', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save bidding setting');
        biddingSettings = data.settings || [];
        renderBiddingSettings();
        message.textContent = data.message || 'Bidding setting saved.';
      } catch (error) {
        message.textContent = error.message;
      }
    }

    async function deleteBiddingSetting(index) {
      const row = biddingSettings[index];
      if (!row || !row.id) return;
      if (!confirm(`Delete bidding settings for ${row.city}?`)) return;
      const message = document.getElementById('biddingSettingsMessage');
      message.textContent = 'Deleting bidding setting...';
      try {
        const response = await fetch(`/settings/bidding/${encodeURIComponent(row.id)}`, { method: 'DELETE' });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to delete bidding setting');
        biddingSettings = data.settings || [];
        renderBiddingSettings();
        message.textContent = data.message || 'Bidding setting deleted.';
      } catch (error) {
        message.textContent = error.message;
      }
    }

    function renderBiddingSettings() {
      const body = document.getElementById('biddingSettingsBody');
      if (!body) return;
      if (!biddingSettings.length) {
        body.innerHTML = '<tr><td colspan="6">No city-wise bidding settings yet. Default timer is 1440 minutes.</td></tr>';
        return;
      }
      body.innerHTML = biddingSettings.map((row, index) => `
        <tr class="${row.is_enabled === false ? 'commission-row-inactive' : ''}">
          <td><strong>${escapeCatalog(row.city || '-')}</strong></td>
          <td>${Number(row.timer_minutes || 0)} min</td>
          <td>${escapeCatalog(String(row.daily_start_time || '00:00').slice(0, 5))} - ${escapeCatalog(String(row.daily_end_time || '23:59').slice(0, 5))}</td>
          <td>${row.is_enabled === false ? 'Disabled' : 'Enabled'}</td>
          <td>${row.auto_close_on_expiry === false ? 'No' : 'Yes'}</td>
          <td>
            <button class="product-secondary-button area-row-button" type="button" onclick="editBiddingSetting(${index})">Edit</button>
            <button class="danger-action-button area-row-button" type="button" onclick="deleteBiddingSetting(${index})">Delete</button>
          </td>
        </tr>
      `).join('');
    }
    async function saveQuotationSettings() {
      const message = document.getElementById('quotationSettingsMessage');
      const input = document.getElementById('quotationSubmissionMinutes');
      message.textContent = 'Saving quotation settings...';
      try {
        const response = await fetch('/settings/quotations', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ submissionMinutes: Number(input.value || 0) }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save quotation settings');
        input.value = data.submissionMinutes;
        message.textContent = data.message;
      } catch (error) {
        message.textContent = error.message;
      }
    }

    async function saveInvoiceSettings() {
      const message = document.getElementById('invoiceSettingsMessage');
      const platformInput = document.getElementById('invoicePlatformName');
      const reverseChargeInput = document.getElementById('invoiceReverseChargeText');
      const serialInfoInput = document.getElementById('invoiceSerialInfoText');
      const legalNoteInput = document.getElementById('invoiceLegalNote');
      const deliveryFromNameInput = document.getElementById('invoiceDeliveryFromName');
      const deliveryFromAddressInput = document.getElementById('invoiceDeliveryFromAddress');
      const deliveryFromFssaiInput = document.getElementById('invoiceDeliveryFromFssai');
      const platformAddressInput = document.getElementById('invoicePlatformAddress');
      const platformFssaiInput = document.getElementById('invoicePlatformFssai');
      const platformEmailInput = document.getElementById('invoicePlatformEmail');
      const enabledProductColumns = [...document.querySelectorAll('input[name="invoiceProductColumn"]:checked')]
        .map((input) => input.value);
      message.textContent = 'Saving invoice settings...';
      try {
        const response = await fetch('/settings/invoice', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            platformName: platformInput.value,
            reverseChargeText: reverseChargeInput.value,
            serialInfoText: serialInfoInput.value,
            legalNote: legalNoteInput.value,
            deliveryFromName: deliveryFromNameInput.value,
            deliveryFromAddress: deliveryFromAddressInput.value,
            deliveryFromFssai: deliveryFromFssaiInput.value,
            platformAddress: platformAddressInput.value,
            platformFssai: platformFssaiInput.value,
            platformEmail: platformEmailInput.value,
            enabledProductColumns,
          }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save invoice settings');
        platformInput.value = data.settings.platformName;
        reverseChargeInput.value = data.settings.reverseChargeText;
        serialInfoInput.value = data.settings.serialInfoText;
        legalNoteInput.value = data.settings.legalNote;
        deliveryFromNameInput.value = data.settings.deliveryFromName;
        deliveryFromAddressInput.value = data.settings.deliveryFromAddress;
        deliveryFromFssaiInput.value = data.settings.deliveryFromFssai;
        platformAddressInput.value = data.settings.platformAddress;
        platformFssaiInput.value = data.settings.platformFssai;
        platformEmailInput.value = data.settings.platformEmail;
        message.textContent = data.message;
      } catch (error) {
        message.textContent = error.message;
      }
    }

    document.querySelectorAll('.catalog-inner-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.catalog-inner-tab').forEach((item) => item.classList.remove('active'));
        document.querySelectorAll('.catalog-table-panel').forEach((panel) => panel.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.catalogTab).classList.add('active');
      });
    });

    function createLocationRow(value) {
      const row = document.createElement('div');
      row.className = 'location-row';
      row.innerHTML = `
        <span></span>
        <div class="location-actions">
          <button type="button" onclick="editLocation(this)">Edit</button>
          <button type="button" onclick="deleteLocation(this)">Delete</button>
        </div>
      `;
      row.querySelector('span').textContent = value;
      return row;
    }

    function addLocation(type) {
      const config = {
        country: { input: 'countryName', code: 'countryCode', list: 'countryList', select: 'stateCountry' },
        state: { input: 'stateName', list: 'stateList', select: 'cityState' },
        city: { input: 'cityName', list: 'cityList' },
      }[type];

      const input = document.getElementById(config.input);
      const value = input.value.trim();
      if (!value) return;

      const label = type === 'country' && document.getElementById(config.code).value.trim()
        ? `${value} (${document.getElementById(config.code).value.trim().toUpperCase()})`
        : value;

      document.getElementById(config.list).appendChild(createLocationRow(label));

      if (config.select) {
        const option = document.createElement('option');
        option.textContent = value;
        option.value = value;
        document.getElementById(config.select).appendChild(option);
      }

      input.value = '';
      if (config.code) document.getElementById(config.code).value = '';
    }

    function editLocation(button) {
      const row = button.closest('.location-row');
      const label = row.querySelector('span');
      const nextValue = prompt('Update location name', label.textContent);
      if (nextValue && nextValue.trim()) {
        label.textContent = nextValue.trim();
      }
    }

    function deleteLocation(button) {
      if (confirm('Delete this location?')) {
        button.closest('.location-row').remove();
      }
    }
  </script>

