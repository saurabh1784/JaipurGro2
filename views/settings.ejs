    function renderDeliveryCityOptions() {
      const options = ['<option value="">Select city</option>']
        .concat(deliveryCities.map((city) => `<option value="${escapeCatalog(city)}">${escapeCatalog(city)}</option>`))
        .join('');
      ['deliveryCityInput', 'deliveryPartnerCity'].forEach((id) => {
        const select = document.getElementById(id);
        if (select) select.innerHTML = options;
      });
    }

    function renderDeliveryAreaOptions() {
      ['deliveryAreaInput', 'deliveryPartnerArea'].forEach((id) => populateDeliveryAreaSelect(id));
    }

    function mappedAreasForCity(city) {
      const selectedCity = String(city || '').trim().toLowerCase();
      return deliveryMappedAreas.filter((area) => !selectedCity || String(area.city || '').trim().toLowerCase() === selectedCity);
    }

    function populateDeliveryAreaSelect(id) {
      const select = document.getElementById(id);
      if (!select) return;
      const citySelectId = id === 'deliveryPartnerArea' ? 'deliveryPartnerCity' : 'deliveryCityInput';
      const city = document.getElementById(citySelectId)?.value || '';
      const mappedAreas = mappedAreasForCity(city);
      const options = id === 'deliveryPartnerArea'
        ? []
        : ['<option value="">Select mapped area</option>'];
      if (city) options.push('<option value="*">All mapped areas in selected city</option>');
      mappedAreas.forEach((area) => {
        options.push(`<option value="${escapeCatalog(area.area)}" data-city="${escapeCatalog(area.city)}">${escapeCatalog(area.city)} - ${escapeCatalog(area.area)}</option>`);
      });
      select.innerHTML = options.join('');
    }

    function findMappedArea(city, area) {
      const cityKey = String(city || '').trim().toLowerCase();
      const areaKey = String(area || '').trim().toLowerCase();
      return deliveryMappedAreas.find((item) => (
        String(item.city || '').trim().toLowerCase() === cityKey
        && String(item.area || '').trim().toLowerCase() === areaKey
      ));
    }

    function normalizeDeliveryArea(entry) {
      if (typeof entry === 'string') return { city: entry.trim(), area: '*' };
      return {
        city: String(entry && entry.city || '').trim(),
        area: String(entry && entry.area || '*').trim() || '*',
      };
    }

    function deliveryAreaKey(entry) {
      return `${String(entry.city || '').toLowerCase()}::${String(entry.area || '*').toLowerCase()}`;
    }

    function deliveryAreaLabel(entry) {
      const area = String(entry.area || '*').trim();
      return `${entry.city} - ${area === '*' ? 'All areas' : area}`;
    }

    function partnerCities(partner) {
      return (partner.cities || [])
        .filter((entry) => entry && Number(entry.is_active) !== 0)
        .map(normalizeDeliveryArea)
        .filter((entry) => entry.city);
    }

    function renderDeliveryPartners() {
      const body = document.getElementById('deliveryPartnerTableBody');
      if (!deliveryPartnerSettings.length) {
        body.innerHTML = '<tr><td colspan="5">No delivery partners found.</td></tr>';
        return;
      }

      body.innerHTML = deliveryPartnerSettings.map((partner) => {
        const areas = partnerCities(partner);
        return `
          <tr data-partner-id="${partner.id}">
            <td>
              <strong>${escapeCatalog(partner.name)}</strong>
              <span class="commission-subtext">Staff ID ${partner.id}</span>
            </td>
            <td>
              <span>${escapeCatalog(partner.email || '')}</span>
              <span class="commission-subtext">${escapeCatalog(partner.phone || '')}</span>
            </td>
            <td>
              <div class="delivery-city-pills">
                ${areas.length ? areas.map((entry) => `
                  <button type="button" class="delivery-city-pill" onclick="removeDeliveryCity(${partner.id}, '${encodeURIComponent(entry.city)}', '${encodeURIComponent(entry.area)}')">${escapeCatalog(deliveryAreaLabel(entry))} x</button>
                `).join('') : '<span class="commission-subtext">No city assigned</span>'}
              </div>
            </td>
            <td>
              <button class="product-secondary-button" type="button" onclick="addDeliveryCity(${partner.id})">Add City</button>
            </td>
            <td>
              <button class="product-secondary-button" type="button" onclick="openDeliveryPartnerModal(${partner.id})">Edit</button>
              <button class="reject-button" type="button" onclick="deleteDeliveryPartner(${partner.id})">Delete</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    function addDeliveryCity(partnerId) {
      const city = document.getElementById('deliveryCityInput').value.trim();
      const area = document.getElementById('deliveryAreaInput').value.trim();
      if (!city) {
        alert('Select a city first.');
        return;
      }
      if (!area) {
        alert('Select a mapped area first.');
        return;
      }
      const mappedArea = area === '*' ? null : findMappedArea(city, area);
      if (area !== '*' && !mappedArea) {
        alert('Select an area created on the Area Definition page.');
        return;
      }
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!partner) return;
      const entry = { city, area, area_definition_id: mappedArea ? mappedArea.id : null };
      const areas = partnerCities(partner);
      if (!areas.some((item) => deliveryAreaKey(item) === deliveryAreaKey(entry))) {
        partner.cities = [...(partner.cities || []), { ...entry, is_active: 1 }];
      }
      renderDeliveryPartners();
    }

    function removeDeliveryCity(partnerId, city, area = '*') {
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!partner) return;
      const target = {
        city: decodeURIComponent(city || ''),
        area: decodeURIComponent(area || '*'),
      };
      partner.cities = (partner.cities || []).filter((entry) => deliveryAreaKey(normalizeDeliveryArea(entry)) !== deliveryAreaKey(target));
      renderDeliveryPartners();
    }

    async function saveDeliveryPartnerSettings() {
      const message = document.getElementById('deliveryPartnerMessage');
      message.textContent = 'Saving delivery partner settings...';
      const assignments = deliveryPartnerSettings.map((partner) => ({
        user_id: partner.id,
        delivery_areas: partnerCities(partner),
      }));
      try {
        const response = await fetch('/settings/delivery-partners', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ assignments }),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save delivery partner settings');
        message.textContent = data.message;
        loadDeliveryPartnerSettings();
      } catch (error) {
        message.textContent = error.message;
      }
    }

    function openDeliveryPartnerModal(partnerId = null) {
      const partner = partnerId ? deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId)) : null;
      document.getElementById('deliveryPartnerModalTitle').textContent = partner ? 'Edit Delivery Partner' : 'Add Delivery Partner';
      document.getElementById('deliveryPartnerId').value = partner ? partner.id : '';
      document.getElementById('deliveryPartnerName').value = partner ? partner.name || '' : '';
      document.getElementById('deliveryPartnerEmail').value = partner ? partner.email || '' : '';
      document.getElementById('deliveryPartnerPhone').value = partner ? partner.phone || '' : '';
      document.getElementById('deliveryPartnerPassword').value = '';
      document.getElementById('deliveryPartnerPassword').required = !partner;
      document.getElementById('deliveryPartnerCity').value = '';
      document.getElementById('deliveryPartnerArea').value = '';
      populateDeliveryAreaSelect('deliveryPartnerArea');
      deliveryPartnerModalCities = partner ? partnerCities(partner) : [];
      renderModalDeliveryCities();
      document.getElementById('deliveryPartnerModal').style.display = 'flex';
      document.getElementById('deliveryPartnerModal').setAttribute('aria-hidden', 'false');
    }

    function closeDeliveryPartnerModal() {
      document.getElementById('deliveryPartnerModal').style.display = 'none';
      document.getElementById('deliveryPartnerModal').setAttribute('aria-hidden', 'true');
      document.getElementById('deliveryPartnerForm').reset();
      deliveryPartnerModalCities = [];
    }

    function renderModalDeliveryCities() {
      const target = document.getElementById('deliveryPartnerModalCities');
      target.innerHTML = deliveryPartnerModalCities.length
        ? deliveryPartnerModalCities.map((entry) => `
          <button type="button" class="delivery-city-pill" onclick="removeModalDeliveryCity('${encodeURIComponent(entry.city)}', '${encodeURIComponent(entry.area)}')">${escapeCatalog(deliveryAreaLabel(entry))} x</button>
        `).join('')
        : '<span class="commission-subtext">No city assigned</span>';
    }

    function addModalDeliveryCity() {
      const input = document.getElementById('deliveryPartnerCity');
      const areaInput = document.getElementById('deliveryPartnerArea');
      const city = input.value.trim();
      const selectedAreas = Array.from(areaInput.selectedOptions || [])
        .map((option) => option.value.trim())
        .filter(Boolean);
      if (!city) return;
      if (!selectedAreas.length) {
        alert('Select one or more mapped areas first.');
        return;
      }

      selectedAreas.forEach((area) => {
        const mappedArea = area === '*' ? null : findMappedArea(city, area);
        if (area !== '*' && !mappedArea) return;
        const entry = { city, area, area_definition_id: mappedArea ? mappedArea.id : null };
        if (!deliveryPartnerModalCities.some((item) => deliveryAreaKey(item) === deliveryAreaKey(entry))) {
          deliveryPartnerModalCities.push(entry);
        }
      });

      input.value = '';
      populateDeliveryAreaSelect('deliveryPartnerArea');
      renderModalDeliveryCities();
    }

    function removeModalDeliveryCity(city, area = '*') {
      const target = {
        city: decodeURIComponent(city || ''),
        area: decodeURIComponent(area || '*'),
      };
      deliveryPartnerModalCities = deliveryPartnerModalCities.filter((item) => deliveryAreaKey(item) !== deliveryAreaKey(target));
      renderModalDeliveryCities();
    }

    async function deleteDeliveryPartner(partnerId) {
      const partner = deliveryPartnerSettings.find((item) => Number(item.id) === Number(partnerId));
      if (!confirm(`Delete ${partner ? partner.name : 'this delivery partner'}?`)) return;
      try {
        const response = await fetch(`/settings/delivery-partners/${partnerId}`, { method: 'DELETE' });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to delete delivery partner');
        document.getElementById('deliveryPartnerMessage').textContent = data.message;
        loadDeliveryPartnerSettings();
      } catch (error) {
        document.getElementById('deliveryPartnerMessage').textContent = error.message;
      }
    }

    document.getElementById('deliveryPartnerForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = document.getElementById('deliveryPartnerId').value;
      const payload = {
        name: document.getElementById('deliveryPartnerName').value.trim(),
        email: document.getElementById('deliveryPartnerEmail').value.trim(),
        phone: document.getElementById('deliveryPartnerPhone').value.trim(),
        password: document.getElementById('deliveryPartnerPassword').value,
        delivery_areas: deliveryPartnerModalCities,
      };
      try {
        const response = await fetch(`/settings/delivery-partners${id ? `/${id}` : ''}`, {
          method: id ? 'PUT' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save delivery partner');
        document.getElementById('deliveryPartnerMessage').textContent = data.message;
        closeDeliveryPartnerModal();
        loadDeliveryPartnerSettings();
      } catch (error) {
        document.getElementById('deliveryPartnerMessage').textContent = error.message;
      }
    });

    document.getElementById('commissionTransactionFilter').addEventListener('change', renderCommissionSettings);
    document.getElementById('commissionPreviewAmount').addEventListener('input', renderCommissionSettings);
    document.getElementById('roleSettingsSelect').addEventListener('change', renderRoleSettings);
    document.getElementById('googleMapsForm').addEventListener('submit', saveGoogleMapSettings);
    document.getElementById('deliveryPartnerTestFilterForm').addEventListener('submit', (event) => {
      event.preventDefault();
      loadDeliveryPartnerTestPartners();
    });
    document.getElementById('deliveryPartnerTestClear').addEventListener('click', () => {
      document.getElementById('deliveryPartnerTestFilterForm').reset();
      loadDeliveryPartnerTestPartners();
    });
    document.getElementById('deliveryCityInput').addEventListener('change', () => populateDeliveryAreaSelect('deliveryAreaInput'));
    document.getElementById('deliveryPartnerCity').addEventListener('change', () => populateDeliveryAreaSelect('deliveryPartnerArea'));

    loadCatalog();
    loadRoleSettings();
    loadCommissionSettings();
    loadDeliveryPartnerSettings();
  </script>
