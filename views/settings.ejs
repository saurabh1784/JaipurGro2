    async function loadLegalPages(options = {}) {
      try {
        const response = await fetch('/api/content-pages');
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) throw new Error(data.message || 'Unable to load legal pages');
        legalPages = data.pages || [];
        if (!legalPages.length && !options.skipSeed) {
          await seedDemoLegalPages({ silent: true });
          return;
        }
        renderLegalPageButtons();
      } catch (error) {
        setContentMessage(error.message || 'Unable to load legal pages', true);
        renderLegalPageButtons();
      }
    }

    function legalPageKey(appName, pageType) {
      return `${appName}:${pageType}`;
    }

    function findLoadedLegalPage(appName, pageType) {
      return legalPages.find((page) => page.app_name === appName && page.page_type === pageType);
    }

    function renderLegalPageButtons() {
      const grid = document.getElementById('legalPageButtonGrid');
      if (!grid) return;
      const q = (document.getElementById('legalSearchInput')?.value || '').trim().toLowerCase();
      const appFilter = document.getElementById('legalAppFilter')?.value || '';
      const definitions = legalPageDefinitions.filter((item) => {
        const label = `${legalAppLabel(item.appName)} - ${legalPageLabel(item.pageType)}`.toLowerCase();
        return (!appFilter || item.appName === appFilter) && (!q || label.includes(q));
      });
      if (!definitions.length) {
        grid.innerHTML = '<p class="legal-empty-state">No legal pages match your filters.</p>';
        return;
      }
      grid.innerHTML = definitions.map((item) => {
        const page = findLoadedLegalPage(item.appName, item.pageType);
        const status = page ? `${page.status || 'draft'}${page.is_enabled ? '' : ' / disabled'}` : 'not created';
        return `<button type="button" onclick="openLegalPageDialog('${item.appName}', '${item.pageType}')">
          <strong>${escapeCatalog(legalAppLabel(item.appName))} - ${escapeCatalog(legalPageLabel(item.pageType))}</strong>
          <span>${escapeCatalog(status)}</span>
        </button>`;
      }).join('');
    }
    function closeLegalPageDialog() {
      const dialog = document.getElementById('legalPageDialog');
      dialog.hidden = true;
      document.body.classList.remove('legal-dialog-open');
    }

    async function openLegalPageDialog(appName, pageType) {
      const dialog = document.getElementById('legalPageDialog');
      const title = document.getElementById('legalDialogTitle');
      const meta = document.getElementById('legalDialogMeta');
      const content = document.getElementById('legalDialogContent');
      const displayTitle = `${legalAppLabel(appName)} - ${legalPageLabel(pageType)}`;
      title.textContent = displayTitle;
      meta.textContent = 'Loading legal content';
      content.innerHTML = '<p class="legal-empty-state">Loading...</p>';
      dialog.hidden = false;
      document.body.classList.add('legal-dialog-open');

      try {
        let page = findLoadedLegalPage(appName, pageType);
        if (!page) {
          const response = await fetch(`/api/content-pages?app_name=${encodeURIComponent(appName)}&page_type=${encodeURIComponent(pageType)}`);
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.success) throw new Error(data.message || 'Unable to load legal page');
          page = (data.pages || [])[0];
          if (page) {
            const existingIndex = legalPages.findIndex((item) => legalPageKey(item.app_name, item.page_type) === legalPageKey(appName, pageType));
            if (existingIndex >= 0) legalPages[existingIndex] = page;
            else legalPages.push(page);
            renderLegalPageButtons();
          }
        }

        const html = page && String(page.content_html || '').trim();
        title.textContent = page && page.title ? `${legalAppLabel(appName)} - ${page.title}` : displayTitle;
        meta.textContent = page && page.updated_at ? `Last updated: ${new Date(page.updated_at).toLocaleString()}` : 'No saved content';
        content.innerHTML = html || '<p class="legal-empty-state">No content available.</p>';
      } catch (error) {
        meta.textContent = 'Unable to load content';
        content.innerHTML = `<p class="legal-empty-state">${escapeCatalog(error.message || 'No content available.')}</p>`;
      }
    }

