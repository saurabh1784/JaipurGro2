    function loadGoogleMapsScript(apiKey) {
      if (!apiKey) return Promise.reject(new Error('Maps JavaScript API key is required'));
      if (window.google && window.google.maps && googleMapsLoadedKey === apiKey) {
        return Promise.resolve();
      }

      return new Promise((resolve, reject) => {
        const existing = document.getElementById('googleMapsScript');
        if (existing) existing.remove();
        googleMapsAuthError = '';
        window.gm_authFailure = () => {
          googleMapsAuthError = 'AUTH_ERROR';
          reject(new Error('Maps JavaScript API failed: AUTH_ERROR. Enable Maps JavaScript API and check browser key restrictions.'));
        };
        googleMapsLoadedKey = apiKey;
        window.handleGoogleMapsLoaded = () => {
          if (googleMapsAuthError) {
            reject(new Error('Maps JavaScript API failed: AUTH_ERROR. Enable Maps JavaScript API and check browser key restrictions.'));
            return;
          }
          resolve();
        };
        const script = document.createElement('script');
        script.id = 'googleMapsScript';
        script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(apiKey)}&callback=handleGoogleMapsLoaded`;
        script.async = true;
        script.defer = true;
        script.onerror = () => reject(new Error('Maps JavaScript API failed to load. Enable Maps JavaScript API and check browser key restrictions.'));
        document.head.appendChild(script);
      });
    }

    function ensureGoogleMap() {
      const payload = googleMapPayload();
      const canvas = document.getElementById('googleMapCanvas');
      if (!googleMap) {
        const options = {
          center: { lat: 26.9124, lng: 75.7873 },
          zoom: 11,
        };
        if (payload.mapId) options.mapId = payload.mapId;
        googleMap = new google.maps.Map(canvas, options);
        googleDirectionsRenderer = new google.maps.DirectionsRenderer({ map: googleMap });
      }
      return { map: googleMap, renderer: googleDirectionsRenderer };
    }

    async function testGoogleMapCredentials() {
      const message = document.getElementById('googleMapsMessage');
      const result = document.getElementById('googleRouteResult');
      const payload = googleMapPayload();
      const diagnostics = [];
      message.textContent = 'Testing Google Maps credentials...';
      result.textContent = 'Calculating route...';
      renderGoogleApiDiagnostics([]);

      try {
        await saveGoogleMapSettings();
        await loadGoogleMapsScript(payload.browserApiKey);
        diagnostics.push({
          service: 'Maps JavaScript API',
          ok: true,
          status: 'OK',
          action: 'Browser map loaded successfully.',
        });
        const { renderer } = ensureGoogleMap();
        const directionsService = new google.maps.DirectionsService();

        const distanceResponse = await fetch('/settings/google-maps/test-distance', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            origin: payload.defaultOrigin,
            destination: payload.defaultDestination,
          }),
        });
        const distanceData = await distanceResponse.json();
        if (Array.isArray(distanceData.diagnostics)) {
          diagnostics.push(...distanceData.diagnostics);
        }
        if (!distanceData.success) {
          renderGoogleApiDiagnostics(diagnostics);
          throw new Error(distanceData.message || 'Distance Matrix API test failed');
        }

        directionsService.route({
          origin: payload.defaultOrigin,
          destination: payload.defaultDestination,
          travelMode: google.maps.TravelMode.DRIVING,
        }, (routeResult, status) => {
          if (status !== 'OK') {
            diagnostics.push({
              service: 'Directions API',
              ok: false,
              status,
              action: googleServiceHelp('Directions API', status),
            });
            renderGoogleApiDiagnostics(diagnostics);
            result.textContent = `Distance Matrix API worked (${Number(distanceData.distanceKm || 0).toFixed(2)} km), but route failed: ${status}`;
            message.textContent = googleServiceHelp('Directions API', status);
            return;
          }
          diagnostics.push({
            service: 'Directions API',
            ok: true,
            status: 'OK',
            action: 'Route drawing is working.',
          });
          renderGoogleApiDiagnostics(diagnostics);
          renderer.setDirections(routeResult);
          const leg = routeResult.routes[0] && routeResult.routes[0].legs[0];
          result.innerHTML = `
            <div><strong>Distance Matrix</strong><span>${Number(distanceData.distanceKm || 0).toFixed(2)} km</span></div>
            <div><strong>Route distance</strong><span>${escapeCatalog(leg && leg.distance ? leg.distance.text : '-')}</span></div>
            <div><strong>Duration</strong><span>${escapeCatalog(leg && leg.duration ? leg.duration.text : '-')}</span></div>
          `;
          message.textContent = 'Google Maps credentials are working.';
        });
      } catch (error) {
        const text = String(error.message || '');
        if (text.includes('Maps JavaScript API')) {
          diagnostics.push({
            service: 'Maps JavaScript API',
            ok: false,
            status: googleMapsAuthError || (payload.browserApiKey ? 'LOAD_ERROR' : 'MISSING_KEY'),
            action: googleServiceHelp('Maps JavaScript API', googleMapsAuthError || (payload.browserApiKey ? 'LOAD_ERROR' : 'MISSING_KEY'), text),
          });
        }
        renderGoogleApiDiagnostics(diagnostics);
        result.textContent = error.message;
        message.textContent = error.message;
      }
    }

