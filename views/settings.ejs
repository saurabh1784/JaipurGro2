    function openCatalogModal(type, item) {
      const modal = document.getElementById('catalogModal');
      document.getElementById('catalogType').value = type;
      document.getElementById('catalogId').value = item ? item.id : '';
      document.getElementById('catalogModalTitle').textContent = `${item ? 'Edit' : 'Add'} ${type}`;
      document.getElementById('catalogNameInput').value = item ? item.name : '';
      document.getElementById('catalogSlugInput').value = item ? item.slug : '';
      document.getElementById('catalogTaxNameInput').value = item && item.tax_name ? item.tax_name : '';
      document.getElementById('catalogTaxPercentageInput').value = item && item.tax_percentage !== null && item.tax_percentage !== undefined ? Number(item.tax_percentage).toFixed(2) : '';
      document.getElementById('catalogActiveInput').checked = item ? item.is_active : true;
      document.getElementById('catalogCategoryField').style.display = type === 'subcategory' || type === 'brand' ? 'block' : 'none';
      document.getElementById('catalogSubcategoryField').style.display = type === 'brand' ? 'block' : 'none';
      document.getElementById('catalogLogoField').style.display = type === 'subcategory' || type === 'brand' ? 'block' : 'none';
      document.getElementById('catalogTaxNameField').style.display = type === 'category' ? 'block' : 'none';
      document.getElementById('catalogTaxPercentageField').style.display = type === 'category' ? 'block' : 'none';
      document.getElementById('catalogLogoInput').value = '';
      document.getElementById('catalogCategoryInput').value = item && item.category_id ? item.category_id : '';
      updateCatalogSubcategoryInput(item && (item.sub_category_id || item.subcategory_id) ? (item.sub_category_id || item.subcategory_id) : '');
      modal.classList.add('active');
    }

