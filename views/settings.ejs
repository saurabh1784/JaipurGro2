<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Settings</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>
  <%
    const locationSettings = settings.locations || { countries: [], states: [], cities: [] };
    locationSettings.countries = locationSettings.countries || [];
    locationSettings.states = locationSettings.states || [];
    locationSettings.cities = locationSettings.cities || [];
  %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Settings</p>
        <h1>Settings</h1>
      </div>
      <div class="topbar-actions">
        <label class="system-search" aria-label="Search settings">
          <input type="search" placeholder="Search" />
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/></svg>
        </label>
      </div>
    </header>

    <% if (error) { %>
      <div class="system-alert"><%= error %></div>
    <% } %>

    <% if (typeof message !== 'undefined' && message) { %>
      <div class="system-alert system-alert-success"><%= message %></div>
    <% } %>

    <section class="settings-shell">
      <div class="settings-tabs" role="tablist" aria-label="Settings tabs">
        <button class="settings-tab active" type="button" data-tab="general">General</button>
        <button class="settings-tab" type="button" data-tab="invoice">Invoice Settings</button>
        <button class="settings-tab" type="button" data-tab="email">Email</button>
        <button class="settings-tab" type="button" data-tab="firebase">Firebase</button>
        <button class="settings-tab" type="button" data-tab="google-maps">Google Maps</button>
        <button class="settings-tab" type="button" data-tab="locations">Locations</button>
        <button class="settings-tab" type="button" data-tab="catalog">Catalog</button>
        <% if (canManageCommissions) { %>
          <button class="settings-tab" type="button" data-tab="commissions">Commission</button>
        <% } %>
        <button class="settings-tab" type="button" data-tab="bidding-settings">Bidding Settings</button>
        <button class="settings-tab" type="button" data-tab="delivery-partners">Delivery Partners</button>
        <button class="settings-tab" type="button" data-tab="role-permissions">Role Permissions</button>
        <button class="settings-tab" type="button" data-tab="content-management">Legal Pages</button>
        <button class="settings-tab" type="button" data-tab="security">Security</button>
        <button class="settings-tab" type="button" data-tab="debug">Debug</button>
      </div>

      <section class="settings-panel active" id="general" aria-labelledby="general-tab">
        <div class="panel-header green-panel-header">
          <h2>General Settings</h2>
          <p>Core application defaults and business display preferences.</p>
        </div>
        <div class="settings-grid">
          <label>
            App Name
            <input type="text" value="<%= settings.general.appName %>" />
          </label>
          <label>
            Support Email
            <input type="email" value="<%= settings.general.supportEmail %>" />
          </label>
          <label>
            Timezone
            <select>
              <option selected><%= settings.general.timezone %></option>
              <option>UTC</option>
              <option>America/New_York</option>
            </select>
          </label>
          <label>
            Currency
            <select>
              <option selected><%= settings.general.currency %></option>
              <option>USD</option>
              <option>EUR</option>
            </select>
          </label>
          <label>
            Quotation Submission Time (minutes)
            <input id="quotationSubmissionMinutes" type="number" min="5" max="10080" step="5" value="<%= settings.general.quotationSubmissionMinutes %>" />
          </label>
          <label class="settings-toggle">
            <input type="checkbox" <%= settings.general.maintenanceMode ? 'checked' : '' %> />
            Maintenance Mode
          </label>
        </div>
        <button class="settings-save" type="button" onclick="saveQuotationSettings()">Save General Settings</button>
        <p class="commission-message" id="quotationSettingsMessage"></p>
      </section>

      <section class="settings-panel" id="debug" aria-labelledby="debug-tab">
        <div class="panel-header red-header">
          <h2>Debug Tools</h2>
          <p>Maintenance actions for testing and rebuilding the application database.</p>
        </div>
        <div class="debug-subtabs" role="tablist" aria-label="Debug tabs">
          <button class="debug-subtab active" type="button" data-debug-tab="maintenance">Maintenance</button>
          <button class="debug-subtab" type="button" data-debug-tab="delivery-partner-test">Delivery Partner Test</button>
        </div>
        <div class="debug-tool-panel active" id="debug-maintenance">
        <% if (maintenance) { %>
          <% const backupList = Array.isArray(databaseBackups) ? databaseBackups : []; %>
          <section class="maintenance-panel" aria-label="Admin maintenance">
            <div class="maintenance-copy">
              <span>Debug maintenance</span>
              <h2>Database backup, restore, and clean tools</h2>
              <p>Use these only for testing. Backup exports all app tables. Clean drops every table, recreates the schema, and reloads default seed data.</p>
            </div>
            <div class="maintenance-actions">
              <form method="post" action="/admin/maintenance/backup-database" onsubmit="return confirmDatabaseBackup();">
                <strong>Create a complete JSON database backup</strong>
                <button class="settings-save" type="submit">Backup database</button>
              </form>
              <form id="updateDatabaseForm" method="post" action="/admin/maintenance/update-database">
                <strong>Update live database schema to match development</strong>
                <span class="maintenance-hint">Safely creates a backup, then adds any missing tables, columns, indexes, and migrations without deleting existing data.</span>
                <button class="settings-save update-database-button" type="submit" id="updateDatabaseButton">Update database</button>
              </form>
              <div class="update-database-progress" id="updateDatabaseProgress" hidden>
                <div class="update-database-bar"><span id="updateDatabaseBarFill"></span></div>
                <p class="update-database-status" id="updateDatabaseStatus">Starting…</p>
                <pre class="update-database-log" id="updateDatabaseLog"></pre>
              </div>
              <form method="post" action="/admin/maintenance/restore-database-backup" onsubmit="return confirmRestoreBackup();">
                <strong>Restore from saved backup</strong>
                <select name="backup_name" required>
                  <option value="">Select backup</option>
                  <% backupList.forEach((backup) => { %>
                    <option value="<%= backup.name %>"><%= backup.name %></option>
                  <% }) %>
                </select>
                <button class="danger-action-button" type="submit" <%= backupList.length ? '' : 'disabled' %>>Restore backup</button>
              </form>
              <form method="post" action="/admin/maintenance/restore-database-upload" enctype="multipart/form-data" onsubmit="return confirmRestoreUpload();">
                <strong>Upload JSON backup and restore</strong>
                <input type="file" name="backup" accept="application/json,.json" required />
                <button class="danger-action-button" type="submit">Upload and restore</button>
              </form>
              <form method="post" action="/admin/maintenance/clean-database" onsubmit="return confirmCleanDatabase();">
                <strong>Drop all tables and recreate an empty/default database</strong>
                <button class="danger-action-button" type="submit">Clean database</button>
              </form>
              <form method="post" action="/admin/maintenance/clear-quotations-orders" onsubmit="return confirmMaintenanceClear();">
                <strong><%= maintenance.quotationCount %> quotation(s) / <%= maintenance.orderCount %> order(s)</strong>
                <button class="danger-action-button" type="submit">Clear quotes and orders</button>
              </form>
              <form method="post" action="/admin/maintenance/sync-vendor-prices" onsubmit="return confirmVendorPriceSync();">
                <strong><%= maintenance.vendorPriceDiffCount %> vendor price(s) different</strong>
                <button class="settings-save" type="submit">Reset vendor prices</button>
              </form>
            </div>
            <% if (backupList.length) { %>
              <div class="database-backup-list">
                <h3>Saved backups</h3>
                <% backupList.forEach((backup) => { %>
                  <div class="database-backup-row">
                    <span><%= backup.name %></span>
                    <small><%= Math.ceil(backup.size / 1024) %> KB</small>
                    <a class="settings-save backup-download-link" href="/admin/maintenance/database-backups/<%= encodeURIComponent(backup.name) %>">Download</a>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </section>
        <% } %>
        <% if (!maintenance) { %>
          <div class="system-alert">Only admin users can run debug maintenance actions.</div>
        <% } %>
        </div>
        <div class="debug-tool-panel" id="debug-delivery-partner-test">
          <form class="debug-filter-form" id="deliveryPartnerTestFilterForm">
            <label>
              City
              <input id="deliveryPartnerTestCity" type="text" placeholder="Admin city by default" />
            </label>
            <label>
              Area
              <input id="deliveryPartnerTestArea" type="text" placeholder="Area" />
            </label>
            <label>
              Mobile Number
              <input id="deliveryPartnerTestMobile" type="search" placeholder="Mobile" />
            </label>
            <label>
              Email
              <input id="deliveryPartnerTestEmail" type="search" placeholder="Email" />
            </label>
            <label>
              Name
              <input id="deliveryPartnerTestName" type="search" placeholder="Name" />
            </label>
            <button class="settings-save" type="submit">Search</button>
            <button class="reject-button" type="button" id="deliveryPartnerTestClear">Clear</button>
          </form>
          <p class="commission-message" id="deliveryPartnerTestMessage"></p>
          <div class="debug-delivery-list" id="deliveryPartnerTestList"></div>
        </div>
      </section>

      <form class="settings-panel" id="invoice" aria-labelledby="invoice-tab">
        <div class="panel-header purple-header settings-purple-header">
          <h2>Invoice Settings</h2>
          <p>Platform details and invoice product table visibility.</p>
        </div>
        <div class="settings-grid">
          <label class="settings-wide">
            Platform Name
            <input id="invoicePlatformName" type="text" value="<%= settings.invoice.platformName %>" />
          </label>
          <label class="settings-wide">
            Reverse Charge Text
            <input id="invoiceReverseChargeText" type="text" value="<%= settings.invoice.reverseChargeText %>" />
          </label>
          <label class="settings-wide">
            IMEI / Serial Number Text
            <input id="invoiceSerialInfoText" type="text" value="<%= settings.invoice.serialInfoText %>" />
          </label>
          <label class="settings-wide">
            Invoice Note
            <textarea id="invoiceLegalNote" rows="3"><%= settings.invoice.legalNote %></textarea>
          </label>
          <label>
            Delivered From Name
            <input id="invoiceDeliveryFromName" type="text" value="<%= settings.invoice.deliveryFromName %>" placeholder="Use vendor/store name if blank" />
          </label>
          <label class="settings-wide">
            Delivered From Address
            <textarea id="invoiceDeliveryFromAddress" rows="3" placeholder="Use vendor/store address if blank"><%= settings.invoice.deliveryFromAddress %></textarea>
          </label>
          <label>
            Delivered From FSSAI
            <input id="invoiceDeliveryFromFssai" type="text" value="<%= settings.invoice.deliveryFromFssai %>" placeholder="Use vendor FSSAI if blank" />
          </label>
          <label class="settings-wide">
            Platform Address
            <textarea id="invoicePlatformAddress" rows="3"><%= settings.invoice.platformAddress %></textarea>
          </label>
          <label>
            Platform FSSAI Lic. No.
            <input id="invoicePlatformFssai" type="text" value="<%= settings.invoice.platformFssai %>" />
          </label>
          <label>
            Platform Email
            <input id="invoicePlatformEmail" type="email" value="<%= settings.invoice.platformEmail %>" />
          </label>
          <div class="settings-wide">
            <div class="settings-section-title">
              Invoice Product Columns
            </div>
            <div class="invoice-column-grid">
              <% settings.invoice.productColumns.forEach((column) => { %>
                <label class="settings-toggle invoice-column-option">
                  <input
                    type="checkbox"
                    name="invoiceProductColumn"
                    value="<%= column.key %>"
                    <%= settings.invoice.enabledProductColumns.includes(column.key) ? 'checked' : '' %>
                  />
                  <span><%= column.label %></span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
        <button class="settings-save" type="button" onclick="saveInvoiceSettings()">Save Invoice Settings</button>
        <p class="commission-message" id="invoiceSettingsMessage"></p>
      </form>

      <form class="settings-panel" id="email" aria-labelledby="email-tab">
        <div class="panel-header orange-header">
          <h2>Email Settings</h2>
          <p>SMTP configuration for signup, invoices, and operational alerts.</p>
        </div>
        <div class="settings-grid">
          <label>
            Mail Driver
            <select>
              <option selected><%= settings.email.mailDriver %></option>
              <option>SendGrid</option>
              <option>Mailgun</option>
            </select>
          </label>
          <label>
            SMTP Host
            <input type="text" value="<%= settings.email.host %>" />
          </label>
          <label>
            SMTP Port
            <input type="number" value="<%= settings.email.port %>" />
          </label>
          <label>
            From Email
            <input type="email" value="<%= settings.email.fromEmail %>" />
          </label>
          <label>
            Encryption
            <select>
              <option selected><%= settings.email.encryption %></option>
              <option>SSL</option>
              <option>None</option>
            </select>
          </label>
        </div>
        <button class="settings-save" type="button">Save Email Settings</button>
      </form>

      <form class="settings-panel" id="firebase" aria-labelledby="firebase-tab">
        <div class="panel-header blue-header">
          <h2>Firebase Settings</h2>
          <p>Firebase project values for Google login, analytics, notifications, storage, and mobile clients.</p>
        </div>
        <div class="settings-grid">
          <label class="settings-wide">
            API Key
            <input type="text" value="<%= settings.firebase.apiKey %>" readonly />
          </label>
          <label>
            Auth Domain
            <input type="text" value="<%= settings.firebase.authDomain %>" readonly />
          </label>
          <label>
            Project ID
            <input type="text" value="<%= settings.firebase.projectId %>" readonly />
          </label>
          <label>
            Messaging Sender ID
            <input type="text" value="<%= settings.firebase.messagingSenderId %>" readonly />
          </label>
          <label>
            Storage Bucket
            <input type="text" value="<%= settings.firebase.storageBucket %>" readonly />
          </label>
          <label class="settings-wide">
            Firebase Web App ID
            <input type="text" value="<%= settings.firebase.appId %>" readonly />
          </label>
          <label>
            Measurement ID
            <input type="text" value="<%= settings.firebase.measurementId %>" readonly />
          </label>
          <label class="settings-wide">
            Google Web Client ID
            <input type="text" value="<%= settings.firebase.googleWebClientId || 'Set GOOGLE_WEB_CLIENT_ID in server environment' %>" readonly />
          </label>
          <label class="settings-wide">
            Firebase Admin SDK
            <input type="text" value="<%= settings.firebase.adminMessage %>" readonly />
          </label>
          <label>
            Admin Project ID
            <input type="text" value="<%= settings.firebase.adminProjectId || '-' %>" readonly />
          </label>
          <label class="settings-wide">
            Admin Client Email
            <input type="text" value="<%= settings.firebase.adminClientEmail || '-' %>" readonly />
          </label>
          <label class="settings-wide">
            Server Key
            <textarea placeholder="Paste Firebase server key"></textarea>
          </label>
          <label class="settings-toggle">
            <input type="checkbox" <%= settings.firebase.pushNotifications ? 'checked' : '' %> />
            Push Notifications
          </label>
        </div>
        <button class="settings-save" type="button" disabled>Loaded From Firebase Config</button>
      </form>

      <section class="settings-panel" id="google-maps" aria-labelledby="google-maps-tab">
        <div class="panel-header blue-header">
          <h2>Google Maps & Distance Settings</h2>
          <p>Configure map, route, and distance credentials used by delivery charge calculation.</p>
        </div>

        <div class="google-maps-help">
          <h3>How to get these keys</h3>
          <ol>
            <li>Open Google Cloud Console and create or select a project.</li>
            <li>Go to APIs & Services and enable the required services listed below before using the key.</li>
            <li>For the browser map key, enable Maps JavaScript API and Directions API. This key displays the map and route test in this admin page.</li>
            <li>For the distance server key, enable Distance Matrix API. This key calculates delivery distance and delivery charges from the backend.</li>
            <li>For address pickup/current location in Android apps, enable Maps SDK for Android and Geocoding API on the Android app key.</li>
            <li>Go to Credentials and create an API key for the browser map. Restrict it by website referrer, for example your admin domain.</li>
            <li>Create an Android API key for the apps. Restrict it by Android app package name and SHA-1 certificate fingerprint.</li>
            <li>Create another API key for server distance calculation. Restrict it by server IP if your hosting provider gives a fixed outbound IP.</li>
            <li>Paste the browser key into Maps JavaScript API Key, Android key into Android Maps SDK API Key, and server key into Distance API Server Key.</li>
            <li>Billing must be enabled in Google Cloud, otherwise Google Maps route and distance calls may fail.</li>
          </ol>
          <p>Use separate keys so the browser key can safely load the map, while the server key stays private for delivery charge distance calculation.</p>
        </div>

        <form class="settings-grid" id="googleMapsForm">
          <label class="settings-wide">
            Maps JavaScript API Key
            <input id="googleMapsBrowserKey" type="password" value="<%= settings.maps.browserApiKey %>" autocomplete="off" />
          </label>
          <label class="settings-wide">
            Android Maps SDK API Key
            <input id="googleMapsAndroidKey" type="password" value="<%= settings.maps.androidApiKey %>" autocomplete="off" />
            <small>Enable Maps SDK for Android. Restrict package names: com.example.vendorapp and com.example.clientapp.</small>
          </label>
          <label class="settings-wide">
            Distance API Server Key
            <input id="googleDistanceApiKey" type="password" value="<%= settings.maps.distanceApiKey %>" autocomplete="off" />
          </label>
          <label>
            Map ID
            <input id="googleMapsMapId" type="text" value="<%= settings.maps.mapId %>" placeholder="Optional" />
          </label>
          <label>
            Test Origin
            <input id="googleMapsOrigin" type="text" value="<%= settings.maps.defaultOrigin %>" />
          </label>
          <label class="settings-wide">
            Test Destination
            <input id="googleMapsDestination" type="text" value="<%= settings.maps.defaultDestination %>" />
          </label>
          <div class="settings-wide google-map-actions">
            <button class="settings-save" type="submit">Save Credentials</button>
            <button class="product-secondary-button" type="button" onclick="testGoogleMapCredentials()">Test Map & Route</button>
            <button class="product-secondary-button" type="button" onclick="toggleGoogleKeyVisibility()">Show Keys</button>
          </div>
        </form>

        <div class="google-map-test-grid">
          <div class="google-map-card">
            <div id="googleMapCanvas" class="google-map-canvas"></div>
          </div>
          <div class="google-map-card google-route-card">
            <h3>Route Test</h3>
            <div id="googleRouteResult" class="google-route-result">No route tested yet.</div>
            <div id="googleApiDiagnostics" class="google-api-diagnostics"></div>
          </div>
        </div>
        <p class="commission-message" id="googleMapsMessage"></p>
      </section>

      <form class="settings-panel" id="locations" aria-labelledby="locations-tab">
        <div class="panel-header location-header">
          <h2>Country, State & City Settings</h2>
          <p>Add and review service locations used across vendor and client profiles.</p>
        </div>

        <div class="location-manager">
          <section class="location-card">
            <h3>Add Country</h3>
            <label>
              Country Name
              <input id="countryName" type="text" placeholder="e.g. India" />
            </label>
            <label>
              Country Code
              <input id="countryCode" type="text" placeholder="e.g. IN" />
            </label>
            <button class="settings-save" type="button" onclick="addLocation('country')">Add Country</button>
            <div class="location-list" id="countryList">
              <% locationSettings.countries.forEach((country) => { %>
                <div class="location-row">
                  <span><%= country %></span>
                  <div class="location-actions">
                    <button type="button" onclick="editLocation(this)">Edit</button>
                    <button type="button" onclick="deleteLocation(this)">Delete</button>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="location-card">
            <h3>Add State</h3>
            <label>
              Country
              <select id="stateCountry">
                <% locationSettings.countries.forEach((country) => { %>
                  <option><%= country %></option>
                <% }) %>
              </select>
            </label>
            <label>
              State Name
              <input id="stateName" type="text" placeholder="e.g. Rajasthan" />
            </label>
            <button class="settings-save" type="button" onclick="addLocation('state')">Add State</button>
            <div class="location-list" id="stateList">
              <% locationSettings.states.forEach((state) => { %>
                <div class="location-row">
                  <span><%= state %></span>
                  <div class="location-actions">
                    <button type="button" onclick="editLocation(this)">Edit</button>
                    <button type="button" onclick="deleteLocation(this)">Delete</button>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="location-card">
            <h3>Add City</h3>
            <label>
              State
              <select id="cityState">
                <% locationSettings.states.forEach((state) => { %>
                  <option><%= state %></option>
                <% }) %>
              </select>
            </label>
            <label>
              City Name
              <input id="cityName" type="text" placeholder="e.g. Jaipur" />
            </label>
            <button class="settings-save" type="button" onclick="addLocation('city')">Add City</button>
            <div class="location-list" id="cityList">
              <% locationSettings.cities.forEach((city) => { %>
                <div class="location-row">
                  <span><%= city %></span>
                  <div class="location-actions">
                    <button type="button" onclick="editLocation(this)">Edit</button>
                    <button type="button" onclick="deleteLocation(this)">Delete</button>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>
        </div>
      </form>

      <section class="settings-panel" id="catalog" aria-labelledby="catalog-tab">
        <div class="panel-header catalog-header">
          <h2>Categories, Subcategories & Brands</h2>
          <p>Manage the grocery hierarchy used by products and vendor listings.</p>
        </div>

        <div class="catalog-toolbar">
          <div class="catalog-selects">
            <label>
              Main Category
              <select id="catalogCategoryFilter"></select>
            </label>
            <label>
              Subcategory
              <select id="catalogSubcategoryFilter"></select>
            </label>
            <label>
              Brand
              <select id="catalogBrandFilter"></select>
            </label>
          </div>
          <div class="catalog-actions">
            <button class="settings-save" type="button" onclick="openCatalogModal('category')">Add Main Category</button>
            <button class="settings-save" type="button" onclick="openCatalogModal('subcategory')">Add Subcategory</button>
            <button class="settings-save" type="button" onclick="openCatalogModal('brand')">Add Brand</button>
          </div>
        </div>

        <div class="catalog-layout">
          <aside class="catalog-tree" id="catalogTree">Loading catalog...</aside>
          <div class="catalog-table-stack">
          <div class="catalog-inner-tabs" role="tablist" aria-label="Catalog tables">
            <button class="catalog-inner-tab active" type="button" data-catalog-tab="categoryTablePanel">Main Category</button>
            <button class="catalog-inner-tab" type="button" data-catalog-tab="subcategoryTablePanel">SubCategory</button>
            <button class="catalog-inner-tab" type="button" data-catalog-tab="brandTablePanel">Brand</button>
          </div>
          <div class="catalog-table-card catalog-table-panel active" id="categoryTablePanel">
            <h3>Main Category Table</h3>
            <table class="catalog-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Name</th>
                  <th>Slug</th>
                  <th>Tax</th>
                  <th>Picture</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="categoryTableBody">
                <tr><td colspan="6">Loading...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="catalog-table-card catalog-table-panel" id="subcategoryTablePanel">
            <h3>SubCategory Table</h3>
            <table class="catalog-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Main Category</th>
                  <th>Name</th>
                  <th>Slug</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="subcategoryTableBody">
                <tr><td colspan="7">Loading...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="catalog-table-card catalog-table-panel" id="brandTablePanel">
            <h3>Brand Table</h3>
            <table class="catalog-table">
