<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= role.id ? 'Edit' : 'Create' %> Role</title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    body.system-theme {
      background: #eeeeef;
      min-height: 100vh;
    }
    .page-container {
      max-width: 700px;
      margin: 0 auto;
      padding: 1rem;
    }
    .page-header {
      margin-bottom: 1.5rem;
    }
    .page-title {
      color: #555f68;
      font-size: clamp(1.5rem, 3vw, 1.8rem);
      margin: 0;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: #60717d;
      text-decoration: none;
      font-size: 0.9rem;
      margin-bottom: 1rem;
      transition: all 0.2s;
    }
    .back-link:hover {
      color: #263238;
    }
    .form-card {
      background: white;
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 12px 40px rgba(0,0,0,0.15);
    }
    .form-group {
      margin-bottom: 1.25rem;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 600;
      color: #1e293b;
    }
    .form-group input[type="text"],
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 0.85rem 1rem;
      border: 2px solid #e2e8f0;
      border-radius: 0.75rem;
      font-size: 1rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-group input[type="text"]:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
    }
    .form-group textarea {
      min-height: 80px;
      resize: vertical;
    }
    .form-group .field-hint {
      font-size: 0.85rem;
      color: #64748b;
      margin-top: 0.3rem;
    }
    .checkbox-group {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.75rem;
      margin-top: 0.5rem;
    }
    .checkbox-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .checkbox-item input[type="checkbox"] {
      width: 18px;
      height: 18px;
      accent-color: #667eea;
    }
    .checkbox-item label {
      margin: 0;
      font-weight: 500;
      color: #475569;
      cursor: pointer;
    }
    .level-display {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: #f1f5f9;
      border-radius: 0.5rem;
      font-weight: 600;
      color: #1e293b;
    }
    .btn-group {
      display: flex;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.9rem 1.5rem;
      background: #667eea;
      color: white;
      border: none;
      border-radius: 0.75rem;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-primary:hover {
      background: #5a67d8;
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.9rem 1.5rem;
      background: transparent;
      color: #475569;
      border: 2px solid #cbd5e1;
      border-radius: 0.75rem;
      font-size: 1rem;
      text-decoration: none;
      transition: all 0.2s;
      cursor: pointer;
    }
    .btn-secondary:hover {
      border-color: #94a3b8;
      background: #f8fafc;
    }
    .danger-zone {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 2px solid #fee2e2;
    }
    .danger-zone h3 {
      color: #dc2626;
      font-size: 0.95rem;
      margin: 0 0 0.5rem 0;
    }
    .danger-zone p {
      color: #991b1b;
      font-size: 0.85rem;
      margin: 0 0 0.75rem 0;
    }
    @media (max-width: 640px) {
      .btn-group { flex-direction: column; }
      .btn-primary, .btn-secondary { width: 100%; }
    }
  </style>
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>
  <main class="system-main">
  <div class="page-container">
    <% const selectedPermissions = Array.isArray(role.permissions) ? role.permissions : JSON.parse(role.permissions || '[]'); %>
    <div class="page-header">
      <a class="back-link" href="/roles">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        Back to Roles
      </a>
      <h1 class="page-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
          <line x1="9" y1="9" x2="9.01" y2="9"/>
          <line x1="15" y1="9" x2="15.01" y2="9"/>
        </svg>
        <%= role.id ? 'Edit Role' : 'Create Role' %>
      </h1>
    </div>

    <div class="form-card">
      <form method="POST" action="<%= role.id ? '/roles/update/' + role.id : '/roles/store' %>">
        <div class="form-group">
          <label for="name">Role Name *</label>
          <input type="text" id="name" name="name" value="<%= role.name || '' %>" placeholder="e.g., Editor, Manager, Administrator" required />
          <p class="field-hint">A clear, descriptive name for this role</p>
        </div>

        <div class="form-group">
          <label for="slug">Role Slug *</label>
          <input type="text" id="slug" name="slug" value="<%= role.slug || '' %>" placeholder="e.g., editor, manager, admin" required />
          <p class="field-hint">Unique system identifier (lowercase, no spaces)</p>
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" placeholder="Briefly describe what this role does..."><%= role.description || '' %></textarea>
        </div>

        <div class="form-group">
          <label>Parent Role (Child Role Support)</label>
          <select name="parent_id">
            <option value="">-- No Parent (Top Level) --</option>
            <% availableRoles.forEach(function(availableRole) { %>
              <% if (role.id != availableRole.id) { %>
                <option value="<%= availableRole.id %>" <%= role.parent_id == availableRole.id ? 'selected' : '' %>>
                  <%= availableRole.name %> (Level <%= availableRole.level %>)
                </option>
              <% } %>
            <% }); %>
          </select>
          <p class="field-hint">This role inherits permissions from its parent role</p>
        </div>

        <div class="form-group">
          <label>Level: <span class="level-display">Level <%= role.level || 0 %></span></label>
          <select name="level" onchange="updateLevelDisplay(this.value)">
            <option value="0" <%= (role.level || 0) == 0 ? 'selected' : '' %>>Level 0 - System Admin</option>
            <option value="1" <%= (role.level || 0) == 1 ? 'selected' : '' %>>Level 1 - Senior Role</option>
            <option value="2" <%= (role.level || 0) == 2 ? 'selected' : '' %>>Level 2 - Mid Level</option>
            <option value="3" <%= (role.level || 0) == 3 ? 'selected' : '' %>>Level 3 - Junior Role</option>
          </select>
        </div>

        <div class="form-group">
          <label>Permissions</label>
          <div class="checkbox-group">
            <div class="checkbox-item">
              <input type="checkbox" id="perm_all" name="permissions" value="all" <%= selectedPermissions.includes('all') ? 'checked' : '' %> />
              <label for="perm_all">All Access</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_users" name="permissions" value="users.manage" <%= selectedPermissions.includes('users.manage') ? 'checked' : '' %> />
              <label for="perm_users">Manage Users</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_roles" name="permissions" value="roles.manage" <%= selectedPermissions.includes('roles.manage') ? 'checked' : '' %> />
              <label for="perm_roles">Manage Roles</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_clients" name="permissions" value="clients.manage" <%= selectedPermissions.includes('clients.manage') ? 'checked' : '' %> />
              <label for="perm_clients">Manage Clients</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_vendors" name="permissions" value="vendors.manage" <%= selectedPermissions.includes('vendors.manage') ? 'checked' : '' %> />
              <label for="perm_vendors">Manage Vendors</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_products" name="permissions" value="products.manage" <%= selectedPermissions.includes('products.manage') ? 'checked' : '' %> />
              <label for="perm_products">Manage Products</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_orders" name="permissions" value="orders.manage" <%= selectedPermissions.includes('orders.manage') ? 'checked' : '' %> />
              <label for="perm_orders">Manage Orders</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_reports" name="permissions" value="reports.view" <%= selectedPermissions.includes('reports.view') ? 'checked' : '' %> />
              <label for="perm_reports">View Reports</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_settings" name="permissions" value="settings.manage" <%= selectedPermissions.includes('settings.manage') ? 'checked' : '' %> />
              <label for="perm_settings">Manage Settings</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_inventory" name="permissions" value="inventory.manage" <%= selectedPermissions.includes('inventory.manage') ? 'checked' : '' %> />
              <label for="perm_inventory">Manage Inventory</label>
            </div>
            <div class="checkbox-item">
              <input type="checkbox" id="perm_support" name="permissions" value="support.manage" <%= selectedPermissions.includes('support.manage') ? 'checked' : '' %> />
              <label for="perm_support">Manage Support Tickets</label>
            </div>
          </div>
        </div>

        <div class="btn-group">
          <button type="submit" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
              <polyline points="17 21 17 13 7 13 7 21"/>
              <polyline points="7 3 7 8 15 8"/>
            </svg>
            <%= role.id ? 'Update Role' : 'Create Role' %>
          </button>
          <a class="btn-secondary" href="/roles">Cancel</a>
        </div>

        <% if (role.id) { %>
          <div class="danger-zone">
            <h3>Danger Zone</h3>
            <p>Deleting this role will disassociate it from all users. Child roles will have their parent removed.</p>
            <form method="POST" action="/roles/delete/<%= role.id %>" onsubmit="return confirmDelete()">
              <button type="submit" class="btn-danger" style="width: 100%;">
                Delete Role
              </button>
            </form>
          </div>
        <% } %>
      </form>
    </div>
  </div>
  </main>

  <script>
    function updateLevelDisplay(value) {
      // Could add real-time visual feedback here
    }
    function confirmDelete() {
      return confirm('Are you sure you want to delete this role?\nThis action cannot be undone.');
    }
  </script>
</body>
</html>
