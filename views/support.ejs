<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>
  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / <%= title %></p>
        <h1><%= title %></h1>
      </div>
      <% if (mode === 'self') { %>
        <button class="settings-save" type="button" onclick="openTicketForm()">Create Ticket</button>
      <% } %>
    </header>

    <section class="support-layout">
      <div>
        <% if (mode === 'staff') { %>
          <div class="support-filter">
            <select id="statusFilter" aria-label="Ticket status">
              <option value="">All Statuses</option>
              <option value="Open">Open</option>
              <option value="Closed">Closed</option>
            </select>
          </div>
        <% } %>
        <div class="support-list" id="ticketList">Loading tickets...</div>
      </div>

      <aside class="support-detail" id="ticketDetail">
        <p>Select a ticket to view details.</p>
      </aside>
    </section>
  </main>

  <div class="user-modal" id="ticketModal" aria-hidden="true">
    <div class="user-modal-card">
      <div class="user-modal-header">
        <h2>Create Support Ticket</h2>
        <button type="button" onclick="closeTicketForm()">Close</button>
      </div>
      <form class="user-modal-grid" id="ticketForm">
        <label class="settings-wide">
          Subject
          <input id="ticketSubject" type="text" required maxlength="200" />
        </label>
        <label class="settings-wide">
          Message
          <textarea id="ticketMessage" required></textarea>
        </label>
        <button class="settings-save" type="submit">Submit Ticket</button>
      </form>
    </div>
  </div>

  <script>
    const mode = '<%= mode %>';
    const roleType = '<%= roleType || '' %>';
    let tickets = [];
    let selectedTicketId = null;

    function esc(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[char]));
    }
    function date(value) {
      return value ? new Date(value).toLocaleString() : '';
    }

    async function loadTickets() {
      const params = new URLSearchParams();
      if (roleType) params.set('role_type', roleType);
      const status = document.getElementById('statusFilter')?.value;
      if (status) params.set('status', status);
      const response = await fetch(`/api/support/tickets?${params.toString()}`);
      const data = await response.json();
      if (!data.success) {
        document.getElementById('ticketList').innerHTML = `<div class="system-alert">${esc(data.message || 'Unable to load tickets')}</div>`;
        return;
      }
      tickets = data.tickets || [];
      renderTickets();
      if (selectedTicketId) {
        const stillExists = tickets.some((ticket) => Number(ticket.id) === Number(selectedTicketId));
        if (stillExists) loadTicketDetail(selectedTicketId);
      }
    }

    function renderTickets() {
      const list = document.getElementById('ticketList');
      if (!tickets.length) {
        list.innerHTML = '<div class="users-table-card support-empty">No tickets found.</div>';
        return;
      }
      list.innerHTML = tickets.map((ticket) => `
        <button type="button" class="support-card ${Number(ticket.id) === Number(selectedTicketId) ? 'active' : ''}" onclick="loadTicketDetail(${ticket.id})">
          <span class="support-status ${ticket.status.toLowerCase()}">${esc(ticket.status)}</span>
          <strong>#${ticket.id} ${esc(ticket.subject)}</strong>
          <small>${esc(ticket.requester_name)} · ${esc(ticket.requester_role)} · ${date(ticket.last_message_at)}</small>
          <span>${ticket.message_count} message${ticket.message_count === 1 ? '' : 's'}</span>
        </button>
      `).join('');
    }

    async function loadTicketDetail(ticketId) {
      selectedTicketId = ticketId;
      renderTickets();
      const response = await fetch(`/api/support/tickets/${ticketId}`);
      const data = await response.json();
      if (!data.success) {
        document.getElementById('ticketDetail').innerHTML = `<p>${esc(data.message || 'Unable to load ticket')}</p>`;
        return;
      }
      const ticket = data.ticket;
      const canReply = ticket.status === 'Open';
      document.getElementById('ticketDetail').innerHTML = `
        <div class="support-detail-header">
          <div>
            <span class="support-status ${ticket.status.toLowerCase()}">${esc(ticket.status)}</span>
            <h2>#${ticket.id} ${esc(ticket.subject)}</h2>
            <p>${esc(ticket.requester_name)} · ${esc(ticket.requester_email)} · ${date(ticket.created_at)}</p>
          </div>
          ${data.canManage ? `
            <select id="ticketStatusSelect" onchange="changeTicketStatus(${ticket.id}, this.value)">
              <option value="Open" ${ticket.status === 'Open' ? 'selected' : ''}>Open</option>
              <option value="Closed" ${ticket.status === 'Closed' ? 'selected' : ''}>Closed</option>
            </select>
          ` : ''}
        </div>
        <div class="support-messages">
          ${data.messages.map((message) => `
            <article class="support-message">
              <strong>${esc(message.sender_name)} <span>${esc(message.sender_role)}</span></strong>
              <p>${esc(message.message)}</p>
              <small>${date(message.created_at)}</small>
            </article>
          `).join('')}
        </div>
        ${canReply ? `
          <form class="support-reply-form" onsubmit="replyToTicket(event, ${ticket.id})">
            <textarea id="replyMessage" placeholder="Write a reply..." required></textarea>
            <button class="settings-save" type="submit">Reply</button>
          </form>
        ` : '<p class="support-empty">This ticket is closed.</p>'}
      `;
    }

    async function replyToTicket(event, ticketId) {
      event.preventDefault();
      const message = document.getElementById('replyMessage').value.trim();
      const response = await fetch(`/api/support/tickets/${ticketId}/replies`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message }),
      });
      const data = await response.json();
      if (!data.success) return alert(data.message || 'Unable to reply');
      await loadTickets();
      await loadTicketDetail(ticketId);
    }

    async function changeTicketStatus(ticketId, status) {
      const response = await fetch(`/api/support/tickets/${ticketId}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      });
      const data = await response.json();
      if (!data.success) return alert(data.message || 'Unable to update status');
      await loadTickets();
      await loadTicketDetail(ticketId);
    }

    function openTicketForm() {
      const openTicket = tickets.find((ticket) => ticket.status === 'Open');
      if (openTicket) {
        alert('You already have an open support ticket.');
        loadTicketDetail(openTicket.id);
        return;
      }
      document.getElementById('ticketModal').classList.add('active');
    }

    function closeTicketForm() {
      document.getElementById('ticketModal').classList.remove('active');
    }

    document.getElementById('ticketForm')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const response = await fetch('/api/support/tickets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          subject: document.getElementById('ticketSubject').value,
          message: document.getElementById('ticketMessage').value,
        }),
      });
      const data = await response.json();
      if (!data.success) return alert(data.message || 'Unable to create ticket');
      closeTicketForm();
      document.getElementById('ticketForm').reset();
      selectedTicketId = data.id;
      await loadTickets();
      await loadTicketDetail(data.id);
    });

    document.getElementById('statusFilter')?.addEventListener('change', loadTickets);
    loadTickets();
  </script>

  <style>
    .support-layout {
      display: grid;
      grid-template-columns: minmax(280px, 0.85fr) minmax(360px, 1.15fr);
      gap: 18px;
    }
    .support-filter {
      margin-bottom: 12px;
    }
    .support-filter select {
      min-width: 180px;
      padding: 10px 12px;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
    }
    .support-list {
      display: grid;
      gap: 10px;
    }
    .support-card {
      display: grid;
      gap: 8px;
      width: 100%;
      padding: 14px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      background: #fff;
      text-align: left;
      cursor: pointer;
    }
    .support-card.active {
      border-color: #26bcd4;
      box-shadow: 0 0 0 2px rgba(38, 188, 212, 0.14);
    }
    .support-card strong,
    .support-detail h2 {
      color: #0f172a;
    }
    .support-card small,
    .support-card span,
    .support-detail p,
    .support-message small {
      color: #64748b;
    }
    .support-status {
      justify-self: start;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 900;
      background: #dcfce7;
      color: #166534;
    }
    .support-status.closed {
      background: #e2e8f0;
      color: #334155;
    }
    .support-detail {
      min-height: 360px;
      padding: 18px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      background: #fff;
    }
    .support-detail-header {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: flex-start;
      border-bottom: 1px solid #e2e8f0;
      padding-bottom: 14px;
      margin-bottom: 14px;
    }
    .support-detail-header h2 {
      margin: 8px 0 4px;
    }
    .support-detail-header select {
      padding: 8px 10px;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      font-weight: 800;
    }
    .support-messages {
      display: grid;
      gap: 12px;
      margin-bottom: 14px;
    }
    .support-message {
      padding: 12px;
      border-radius: 8px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
    }
    .support-message strong span {
      color: #64748b;
      font-size: 12px;
      margin-left: 6px;
    }
    .support-reply-form {
      display: grid;
      gap: 10px;
    }
    .support-reply-form textarea,
    #ticketMessage {
      min-height: 110px;
    }
    .support-empty {
      padding: 16px;
      color: #64748b;
    }
    @media (max-width: 900px) {
      .support-layout {
        grid-template-columns: 1fr;
      }
    }
  </style>
</body>
</html>
