<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login</title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    body {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
    }
    .login-card {
      max-width: 420px;
      width: 100%;
    }
    .login-card h1 {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: #4f46e5;
      text-align: center;
      justify-content: center;
    }
  </style>
</head>
<body>
  <div class="login-page">
    <div class="login-card">
      <h1>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Admin Login
      </h1>
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <form method="POST" action="/admin/login">
        <label for="email">Email</label>
        <input id="email" type="email" name="email" placeholder="Enter your email" required autofocus />

        <label for="password">Password</label>
        <input id="password" type="password" name="password" placeholder="Enter your password" required />

        <button type="submit" style="margin-top: 0.5rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
            <polyline points="10 17 15 12 10 7"/>
            <line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          Sign In
        </button>
      </form>
      <div class="hint">
        <strong>Default superadmin:</strong><br />
        Email: <code style="background:#e5e7eb;padding:0.1rem 0.4rem;border-radius:0.3rem;font-size:0.85rem;">superadmin@example.com</code><br />
        Password: <code style="background:#e5e7eb;padding:0.1rem 0.4rem;border-radius:0.3rem;font-size:0.85rem;">admin123</code>
      </div>
      <div class="hint">
        <a href="/" style="color:#4f46e5;font-weight:700;text-decoration:none;">Back to landing page</a>
      </div>
    </div>
  </div>
</body>
</html>
