  <div class="role-summary">
    <span>Signed in as</span>
    <strong><%= shell.roleTitle %></strong>
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle light and dark mode" title="Toggle theme">
      <span class="theme-toggle-icon theme-toggle-sun">
        <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
      </span>
      <span class="theme-toggle-icon theme-toggle-moon">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.8 6.8 0 0 0 9.8 9.8z"/></svg>
      </span>
      <span data-theme-label><%= shell.themeMode === 'dark' ? 'Dark' : 'Light' %></span>
    </button>
  </div>
</aside>

<script>
  (() => {
    const button = document.querySelector('[data-theme-toggle]');
    if (!button) return;
    const label = button.querySelector('[data-theme-label]');

    button.addEventListener('click', async () => {
      const nextTheme = document.body.dataset.themeMode === 'dark' ? 'light' : 'dark';
      document.body.classList.toggle('theme-dark', nextTheme === 'dark');
      document.body.classList.toggle('theme-light', nextTheme === 'light');
      document.body.dataset.themeMode = nextTheme;
      if (label) label.textContent = nextTheme === 'dark' ? 'Dark' : 'Light';

      try {
        const response = await fetch('/theme', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ theme_mode: nextTheme }),
        });
        if (!response.ok) throw new Error('Unable to save theme');
      } catch (error) {
        const previousTheme = nextTheme === 'dark' ? 'light' : 'dark';
        document.body.classList.toggle('theme-dark', previousTheme === 'dark');
        document.body.classList.toggle('theme-light', previousTheme === 'light');
        document.body.dataset.themeMode = previousTheme;
        if (label) label.textContent = previousTheme === 'dark' ? 'Dark' : 'Light';
        alert(error.message);
      }
    });
  })();
</script>

<script>
  (() => {
    if (window.__systemFeedbackReady) return;
    window.__systemFeedbackReady = true;

    function feedbackType(message, requestedType) {
      if (requestedType) return requestedType;
      const text = String(message || '').toLowerCase();
      if (/error|unable|failed|invalid|required|not found|denied|select|cannot|must /.test(text)) return 'error';
      if (/success|saved|updated|deleted|created|sent|placed|approved|completed/.test(text)) return 'success';
      if (/warning|confirm|careful|pending/.test(text)) return 'warning';
      return 'info';
    }

    function feedbackStack() {
      let stack = document.getElementById('systemFeedbackStack');
      if (!stack) {
        stack = document.createElement('section');
        stack.id = 'systemFeedbackStack';
        stack.className = 'system-feedback-stack';
        stack.setAttribute('aria-live', 'polite');
        stack.setAttribute('aria-label', 'System notifications');
        document.body.appendChild(stack);
      }
      return stack;
    }

    window.systemNotify = (message, requestedType, options = {}) => {
      const text = String(message || '').trim();
      if (!text) return null;
      const type = feedbackType(text, requestedType);
      const card = document.createElement('article');
      card.className = `system-feedback-card ${type}`;
      card.setAttribute('role', type === 'error' ? 'alert' : 'status');
      const icons = { error: '!', success: '✓', warning: '!', info: 'i' };
      const titles = { error: 'Action needed', success: 'Success', warning: 'Please note', info: 'Information' };
      card.innerHTML = `<span class="system-feedback-icon">${icons[type]}</span><div class="system-feedback-copy"><strong>${titles[type]}</strong><p></p></div><button type="button" class="system-feedback-close" aria-label="Dismiss">×</button>`;
      card.querySelector('p').textContent = text;
      const dismiss = () => { card.classList.add('leaving'); setTimeout(() => card.remove(), 180); };
      card.querySelector('button').addEventListener('click', dismiss);
      feedbackStack().appendChild(card);
      requestAnimationFrame(() => card.classList.add('visible'));
      if (options.sticky !== true) setTimeout(dismiss, Number(options.duration || (type === 'error' ? 7000 : 4500)));
      return card;
    };

    window.alert = (message) => { window.systemNotify(message); };
    window.addEventListener('unhandledrejection', (event) => {
      const message = event.reason && event.reason.message ? event.reason.message : event.reason;
      if (message) window.systemNotify(message, 'error', { sticky: true });
    });
    window.addEventListener('error', (event) => {
      if (event.message) window.systemNotify(event.message, 'error', { sticky: true });
    });
  })();
</script>