<div id="bulkUploadProgressOverlay" class="bulk-progress-overlay" hidden>
  <div class="bulk-progress-card" role="dialog" aria-modal="true" aria-labelledby="bulkProgressTitle">
    <div class="bulk-progress-header">
      <div class="bulk-progress-badge">
        <svg class="bulk-progress-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="12" cy="12" r="10" stroke="dasharray 32" stroke-dashoffset="10"></circle>
        </svg>
      </div>
      <div>
        <h2 id="bulkProgressTitle" class="bulk-progress-title">Uploading Bulk Data</h2>
        <p id="bulkProgressSubtitle" class="bulk-progress-subtitle">Please wait while your data is being uploaded and saved</p>
      </div>
    </div>
    <div class="bulk-progress-body">
      <p id="bulkProgressMessage">Reading file, validating rows, syncing subcategories, brands, and writing entries to the database...</p>

      <div class="bulk-progress-bar-container">
        <div class="bulk-progress-bar-track">
          <div id="bulkProgressBarFill" class="bulk-progress-bar-fill" style="width: 15%;"></div>
        </div>
        <div class="bulk-progress-bar-info">
          <span id="bulkProgressStatusText">Uploading data...</span>
          <span id="bulkProgressPercentText">15%</span>
        </div>
      </div>

      <div class="bulk-progress-warning-box">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <div>
          <strong>Warning: Do not close or refresh!</strong>
          <p>Data processing is active. Navigating away or closing your browser will cancel incomplete records.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const overlay = document.getElementById('bulkUploadProgressOverlay');
  const titleEl = document.getElementById('bulkProgressTitle');
  const subtitleEl = document.getElementById('bulkProgressSubtitle');
  const messageEl = document.getElementById('bulkProgressMessage');
  const fillEl = document.getElementById('bulkProgressBarFill');
  const statusEl = document.getElementById('bulkProgressStatusText');
  const percentEl = document.getElementById('bulkProgressPercentText');

  let progressInterval = null;

  window.showBulkUploadProgressModal = function(options = {}) {
    if (!overlay) return;
    titleEl.textContent = options.title || 'Uploading Bulk Data';
    subtitleEl.textContent = options.subtitle || 'Please wait while your data is being uploaded and saved';
    messageEl.textContent = options.message || 'Reading file, validating rows, syncing subcategories, brands, and writing entries to the database...';

    fillEl.style.width = '10%';
    percentEl.textContent = '10%';
    statusEl.textContent = 'Uploading data to server...';

    overlay.removeAttribute('hidden');

    // Simulate steady progress while request runs
    let currentPercent = 10;
    if (progressInterval) clearInterval(progressInterval);
    progressInterval = setInterval(() => {
      if (currentPercent < 90) {
        currentPercent += Math.floor(Math.random() * 5) + 1;
        if (currentPercent > 90) currentPercent = 90;
        fillEl.style.width = currentPercent + '%';
        percentEl.textContent = currentPercent + '%';
        if (currentPercent > 50) {
          statusEl.textContent = 'Saving products & updating database...';
        }
      }
    }, 400);
  };

  window.updateBulkUploadProgress = function(percent, statusText) {
    if (progressInterval) clearInterval(progressInterval);
    const safePercent = Math.min(100, Math.max(0, Math.round(percent)));
    fillEl.style.width = safePercent + '%';
    percentEl.textContent = safePercent + '%';
    if (statusText) statusEl.textContent = statusText;
  };

  window.hideBulkUploadProgressModal = function() {
    if (!overlay) return;
    if (progressInterval) clearInterval(progressInterval);
    fillEl.style.width = '100%';
    percentEl.textContent = '100%';
    statusEl.textContent = 'Upload complete!';
    setTimeout(() => {
      overlay.setAttribute('hidden', '');
    }, 300);
  };
})();
</script>
