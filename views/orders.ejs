<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Management</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Orders</p>
        <h1>Order Management</h1>
      </div>
      <div class="topbar-actions">
        <label class="system-search" aria-label="Search orders">
          <input id="orderSearch" type="search" placeholder="Search by client name, phone, address" />
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/></svg>
        </label>
      </div>
    </header>

    <section class="vendor-management-shell">
      <div class="users-toolbar">
        <div>
          <h2>All Orders</h2>
          <p>View and manage all customer orders, assign delivery partners, and track delivery status.</p>
        </div>
        <div class="vendor-toolbar-actions">
          <label>
            Delivery Status
            <select id="deliveryStatusFilter">
              <option value="">All Statuses</option>
              <option value="pending">Pending</option>
              <option value="assigned">Assigned</option>
              <option value="ready_to_deliver">Ready to Deliver</option>
              <option value="out_for_delivery">Out for Delivery</option>
              <option value="delivered">Delivered</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </label>
          <label>
            Order Status
            <select id="statusFilter">
              <option value="">All Statuses</option>
              <option value="pending">Pending</option>
              <option value="completed">Completed</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </label>
          <label>
            Vendor
            <select id="vendorFilter">
              <option value="">All Vendors</option>
            </select>
          </label>
          <button class="product-secondary-button" type="button" id="clearFilters">Clear</button>
          <button class="settings-save" type="button" id="refreshBtn">Refresh</button>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="metric-grid" id="statsCards" aria-label="Order statistics">
        <article class="metric-card">
          <div class="metric-icon orange"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h14v16H5z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg></div>
          <span class="metric-label">Total Orders</span>
          <strong id="totalOrders">0</strong>
        </article>
        <article class="metric-card">
          <div class="metric-icon blue"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
          <span class="metric-label">Pending</span>
          <strong id="pendingOrders">0</strong>
        </article>
        <article class="metric-card">
          <div class="metric-icon yellow"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3 6 6 2-5 5 2 6-6-3-6 3 2-6-5-5 6-2 3-6z"/></svg></div>
          <span class="metric-label">Assigned</span>
          <strong id="assignedOrders">0</strong>
        </article>
        <article class="metric-card">
          <div class="metric-icon green"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg></div>
          <span class="metric-label">Ready to Deliver</span>
          <strong id="readyOrders">0</strong>
        </article>
        <article class="metric-card">
          <div class="metric-icon purple"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
          <span class="metric-label">Out for Delivery</span>
          <strong id="outDeliveryOrders">0</strong>
        </article>
        <article class="metric-card">
          <div class="metric-icon teal"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 11h-4.17l2-4H14v-2a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v2H4l2 4h3.83l-2 4H6a2 2 0 0 0 2 2v4a2 2 0 0 0 2-2h8a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2h-1.17z"/></svg></div>
          <span class="metric-label">Delivered</span>
          <strong id="deliveredOrders">0</strong>
        </article>
      </div>

      <div class="users-table-card">
        <table class="users-table orders-table">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Date</th>
              <th>Client</th>
              <th>Address</th>
              <th>Vendor</th>
              <th>Total</th>
              <th>Order Status</th>
              <th>Delivery Status</th>
              <th>Delivery Partner</th>
              <th>OTP</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="ordersTableBody">
            <tr><td colspan="11">Loading orders...</td></tr>
          </tbody>
        </table>
      </div>

      <div class="users-pagination">
        <button type="button" id="prevPage">Previous</button>
        <span id="pageInfo">Page 1</span>
        <button type="button" id="nextPage">Next</button>
      </div>
    </section>
  </main>

  <!-- Assign Delivery Partner Modal -->
  <div class="user-modal" id="assignModal" aria-hidden="true">
    <div class="user-modal-card">
      <div class="user-modal-header">
        <h2>Assign Delivery Partner</h2>
        <button type="button" onclick="closeAssignModal()">Close</button>
      </div>
      <form id="assignForm" class="user-modal-grid">
        <input type="hidden" id="assignOrderId" />
        <label>
          Order ID
          <input type="text" id="assignOrderIdDisplay" disabled />
        </label>
        <label>
          Client
          <input type="text" id="assignClientDisplay" disabled />
        </label>
        <label>
          Delivery Partner
          <select id="partnerSelect" required>
            <option value="">Select Partner</option>
          </select>
        </label>
        <label>
          OTP
          <input id="otpInput" type="text" placeholder="Enter 4-6 digit OTP" maxlength="6" required pattern="[0-9]{4,6}" />
        </label>
        <div class="settings-wide">
          <button class="settings-save" type="submit" id="assignSubmit">Assign Partner</button>
          <button class="product-secondary-button" type="button" onclick="closeAssignModal()">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Order Detail Modal -->
  <div class="user-modal" id="detailModal" aria-hidden="true">
    <div class="user-modal-card" style="max-width: 800px;">
      <div class="user-modal-header">
        <h2>Order Details</h2>
        <button type="button" onclick="closeDetailModal()">Close</button>
      </div>
      <div id="orderDetailContent">
        <!-- Populated dynamically -->
      </div>
    </div>
  </div>

  <script src="/api/orders/admin/partners/list"></script>
  <script>
    let orders = [];
    let currentPage = 1;
    let totalPages = 1;
    let deliveryPartners = [];

    // Fetch available delivery partners on load
    async function loadPartners() {
      try {
        const res = await fetch('/api/orders/admin/partners/list', { headers: { 'Accept': 'application/json' } });
        const data = await res.json();
        if (data.success) {
          deliveryPartners = data.partners;
          const select = document.getElementById('partnerSelect');
          select.innerHTML = '<option value="">Select Partner</option>';
          deliveryPartners.forEach(p => {
            const opt = document.createElement('option');
            opt.value = p.id;
            opt.textContent = p.name + ' (' + p.email + ')';
            select.appendChild(opt);
          });
        }
      } catch (e) { console.error('Failed to load partners', e); }
    }

    async function loadOrders(page = 1) {
      const params = new URLSearchParams({
        page: page.toString(),
        limit: '20',
        search: document.getElementById('orderSearch')?.value || '',
        status: document.getElementById('statusFilter')?.value || '',
        delivery_status: document.getElementById('deliveryStatusFilter')?.value || '',
        vendor_id: document.getElementById('vendorFilter')?.value || '',
      });
      try {
        const res = await fetch(`/api/orders/admin/dashboard?${params}`, {
          headers: { 'Accept': 'application/json' }
        });
        const data = await res.json();
        if (data.success) {
          orders = data.orders || [];
          currentPage = data.pagination?.page || 1;
          totalPages = data.pagination?.totalPages || 1;
          renderOrders();
          renderStats();
          document.getElementById('pageInfo').textContent = `Page ${currentPage} of ${totalPages}`;
        }
      } catch (e) { console.error('Failed to load orders', e); }
    }

    function renderStats() {
      const statusCounts = {};
      for (const o of orders) {
        statusCounts[o.delivery_status] = (statusCounts[o.delivery_status] || 0) + 1;
      }
      document.getElementById('totalOrders').textContent = orders.length;
      document.getElementById('pendingOrders').textContent = statusCounts['pending'] || 0;
      document.getElementById('assignedOrders').textContent = statusCounts['assigned'] || 0;
      document.getElementById('readyOrders').textContent = statusCounts['ready_to_deliver'] || 0;
      document.getElementById('outDeliveryOrders').textContent = statusCounts['out_for_delivery'] || 0;
      document.getElementById('deliveredOrders').textContent = statusCounts['delivered'] || 0;
    }

    function renderOrders() {
      const tbody = document.getElementById('ordersTableBody');
      if (!orders.length) {
        tbody.innerHTML = '<tr><td colspan="11">No orders found</td></tr>';
        return;
      }
      tbody.innerHTML = orders.map(o => `
        <tr>
          <td>${o.id}</td>
          <td>${new Date(o.created_at).toLocaleDateString()}</td>
          <td>${o.client_name}<br><small>${o.client_phone}</small></td>
          <td>${o.client_address}</td>
          <td>${o.vendor_business_name || o.vendor_name || 'N/A'}</td>
          <td>₹${Number(o.total_amount).toFixed(2)}</td>
          <td><span class="badge ${o.status}">${o.status}</span></td>
          <td><span class="badge ${o.delivery_status}">${o.delivery_status.replace('_', ' ')}</span></td>
          <td>${o.delivery_partner_name || 'Not assigned'}</td>
          <td>${o.delivery_otp || '-'}</td>
          <td>
            <button class="settings-save" style="padding: 4px 8px; font-size: 12px;" onclick="openAssignModal(${o.id}, '${o.client_name}')" ${o.delivery_status !== 'pending' ? 'disabled' : ''}>Assign</button>
            <button class="product-secondary-button" style="padding: 4px 8px; font-size: 12px;" onclick="markReady(${o.id})" ${o.delivery_status !== 'assigned' ? 'disabled' : ''}>Ready</button>
            <button class="product-secondary-button" style="padding: 4px 8px; font-size: 12px;" onclick="viewDetails(${o.id})">View</button>
          </td>
        </tr>
      `).join('');
    }

    async function openAssignModal(orderId, clientName) {
      document.getElementById('assignOrderId').value = orderId;
      document.getElementById('assignOrderIdDisplay').value = orderId;
      document.getElementById('assignClientDisplay').value = clientName;
      document.getElementById('assignModal').style.display = 'flex';
      document.getElementById('assignModal').setAttribute('aria-hidden', 'false');
    }

    function closeAssignModal() {
      document.getElementById('assignModal').style.display = 'none';
      document.getElementById('assignModal').setAttribute('aria-hidden', 'true');
      document.getElementById('assignForm').reset();
    }

    async function closeDetailModal() {
      document.getElementById('detailModal').style.display = 'none';
      document.getElementById('detailModal').setAttribute('aria-hidden', 'true');
    }

    async function viewDetails(orderId) {
      try {
        const res = await fetch(`/api/orders/admin/${orderId}`, { headers: { 'Accept': 'application/json' } });
        const data = await res.json();
        if (data.success) {
          const order = data.order;
          const items = data.items || [];
          const content = document.getElementById('orderDetailContent');
          content.innerHTML = `
            <div style="margin-bottom: 20px;">
              <h3>Order #${order.id}</h3>
              <p><strong>Client:</strong> ${order.client_name} (${order.client_phone})</p>
              <p><strong>Address:</strong> ${order.client_address}</p>
              <p><strong>Vendor:</strong> ${order.vendor_business_name || order.vendor_name || 'N/A'}</p>
              <p><strong>Total:</strong> ₹${Number(order.total_amount).toFixed(2)}</p>
              <p><strong>Order Status:</strong> ${order.status}</p>
              <p><strong>Delivery Status:</strong> ${order.delivery_status}</p>
              <p><strong>Delivery Partner:</strong> ${order.delivery_partner_name || 'Not assigned'}</p>
              <p><strong>OTP:</strong> ${order.delivery_otp || '-'}</p>
              ${order.assigned_at ? `<p><strong>Assigned At:</strong> ${new Date(order.assigned_at).toLocaleString()}</p>` : ''}
              ${order.ready_at ? `<p><strong>Ready At:</strong> ${new Date(order.ready_at).toLocaleString()}</p>` : ''}
              ${order.delivered_at ? `<p><strong>Delivered At:</strong> ${new Date(order.delivered_at).toLocaleString()}</p>` : ''}
            </div>
            <h4>Order Items</h4>
            <table class="users-table">
              <thead><tr><th>#</th><th>Product</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead>
              <tbody>
                ${items.map((item, i) => `
                  <tr>
                    <td>${i+1}</td>
                    <td>${item.product_name}</td>
                    <td>${item.quantity}</td>
                    <td>₹${Number(item.unit_price).toFixed(2)}</td>
                    <td>₹${Number(item.line_total).toFixed(2)}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          `;
          document.getElementById('detailModal').style.display = 'flex';
          document.getElementById('detailModal').setAttribute('aria-hidden', 'false');
        }
      } catch (e) { alert('Failed to load order details'); console.error(e); }
    }

    async function markReady(orderId) {
      if (!confirm('Mark this order as Ready to Deliver?')) return;
      try {
        const res = await fetch(`/api/orders/admin/${orderId}/ready-to-deliver`, {
          method: 'POST',
          headers: { 'Accept': 'application/json' }
        });
        const data = await res.json();
        if (data.success) {
          alert('Order marked as Ready to Deliver');
          loadOrders(currentPage);
        } else {
          alert('Failed: ' + data.message);
        }
      } catch (e) { alert('Error marking order ready'); }
    }

    document.getElementById('assignForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const orderId = document.getElementById('assignOrderId').value;
      const partnerId = document.getElementById('partnerSelect').value;
      const otp = document.getElementById('otpInput').value;
      try {
        const res = await fetch(`/api/orders/admin/${orderId}/assign-delivery`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ partner_id: partnerId, otp })
        });
        const data = await res.json();
        if (data.success) {
          alert('Delivery partner assigned successfully');
          closeAssignModal();
          loadOrders(currentPage);
        } else {
          alert('Failed: ' + data.message);
        }
      } catch (e) { alert('Error assigning partner'); }
    });

    document.getElementById('orderSearch')?.addEventListener('input', () => loadOrders(1));
    document.getElementById('statusFilter')?.addEventListener('change', () => loadOrders(1));
    document.getElementById('deliveryStatusFilter')?.addEventListener('change', () => loadOrders(1));
    document.getElementById('vendorFilter')?.addEventListener('change', () => loadOrders(1));
    document.getElementById('clearFilters')?.addEventListener('click', () => {
      document.getElementById('orderSearch').value = '';
      document.getElementById('statusFilter').value = '';
      document.getElementById('deliveryStatusFilter').value = '';
      document.getElementById('vendorFilter').value = '';
      loadOrders(1);
    });
    document.getElementById('refreshBtn')?.addEventListener('click', () => loadOrders(currentPage));
    document.getElementById('prevPage')?.addEventListener('click', () => { if (currentPage > 1) loadOrders(currentPage - 1); });
    document.getElementById('nextPage')?.addEventListener('click', () => { if (currentPage < totalPages) loadOrders(currentPage + 1); });

    // Load vendors for filter
    async function loadVendors() {
      try {
        const res = await fetch('/api/vendors?limit=100', { headers: { 'Accept': 'application/json' } });
        const data = await res.json();
        if (data.success) {
          const select = document.getElementById('vendorFilter');
          data.vendors?.forEach(v => {
            const opt = document.createElement('option');
            opt.value = v.id;
            opt.textContent = v.business_name || v.name;
            select.appendChild(opt);
          });
        }
      } catch (e) { console.error('Failed to load vendors', e); }
    }

    // Initial load
    loadPartners();
    loadOrders(1);
    loadVendors();
  </script>
</body>
</html>
