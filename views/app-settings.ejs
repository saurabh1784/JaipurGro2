<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    .app-settings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 24px;
      margin-top: 24px;
    }
    .logo-card {
      background: var(--surface-color, #ffffff);
      border: 1px solid var(--border-color, #e2e8f0);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      display: flex;
      flex-direction: column;
    }
    .logo-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    }
    .logo-card-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border-color, #f1f5f9);
    }
    .logo-badge {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #fff;
    }
    .logo-badge.client { background: linear-gradient(135deg, #10b981, #059669); }
    .logo-badge.vendor { background: linear-gradient(135deg, #6366f1, #4f46e5); }
    .logo-badge.delivery { background: linear-gradient(135deg, #f59e0b, #d97706); }
    
    .logo-preview-box {
      width: 100%;
      height: 150px;
      border-radius: 12px;
      background: #f8fafc;
      border: 2px dashed #cbd5e1;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
      overflow: hidden;
      position: relative;
    }
    .logo-preview-box img {
      max-width: 85%;
      max-height: 85%;
      object-fit: contain;
    }
    .form-section-title {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      color: #64748b;
      margin: 16px 0 10px;
      letter-spacing: 0.5px;
    }
    .file-input-wrapper {
      margin-bottom: 14px;
    }
    .file-input-wrapper label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #475569;
      margin-bottom: 6px;
    }
    .url-fallback-input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #cbd5e1;
      border-radius: 8px;
      font-size: 13px;
      margin-top: 4px;
      box-sizing: border-box;
    }
    .url-fallback-input:focus {
      border-color: #6366f1;
      outline: none;
    }
    .save-settings-bar {
      margin-top: 28px;
      background: #ffffff;
      padding: 20px 24px;
      border-radius: 16px;
      border: 1px solid #e2e8f0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .submit-btn {
      background: linear-gradient(135deg, #10b981, #059669);
      color: #fff;
      padding: 12px 28px;
      border-radius: 10px;
      border: none;
      font-weight: 600;
      font-size: 15px;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(16, 185, 129, 0.3);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .submit-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
    }
    .system-alert-success {
      background: #dcfce7;
      color: #166534;
      border: 1px solid #bbf7d0;
      padding: 14px 18px;
      border-radius: 10px;
      margin-bottom: 20px;
      font-weight: 600;
    }
    .system-alert-danger {
      background: #fee2e2;
      color: #991b1b;
      border: 1px solid #fca5a5;
      padding: 14px 18px;
      border-radius: 10px;
      margin-bottom: 20px;
      font-weight: 600;
    }
  </style>
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">System / App Settings</p>
        <h1>App Logos & Store Links Management</h1>
      </div>
      <div class="topbar-actions">
        <span class="badge" style="background:#e0e7ff; color:#3730a3; padding: 6px 12px; border-radius: 20px; font-weight:600;">
          Multi-App Unified Config
        </span>
      </div>
    </header>

    <% if (typeof message !== 'undefined' && message) { %>
      <div class="system-alert-success">✓ <%= message %></div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="system-alert-danger">⚠ <%= error %></div>
    <% } %>

    <form action="/app-settings/logos" method="POST" enctype="multipart/form-data">
      <div class="app-settings-grid">
        
        <!-- CLIENT APP CARD -->
        <div class="logo-card">
          <div class="logo-card-header">
            <div class="logo-badge client">C</div>
            <div>
              <h3 style="margin:0; font-size:17px; font-weight:700;">Client App</h3>
              <span style="font-size:12px; color:#64748b;">Customer Shopping Mobile & Web App</span>
            </div>
          </div>
          
          <div class="logo-preview-box">
            <img id="previewClient" src="<%= settings.clientAppLogo || '/assets/images/GroLogo.png' %>" alt="Client App Logo" onerror="this.src='/assets/images/GroLogo.png'" />
          </div>
          
          <div class="file-input-wrapper">
            <label for="client_app_logo">Upload Logo Image File (PNG, JPG, SVG)</label>
            <input type="file" id="client_app_logo" name="client_app_logo" accept="image/*" onchange="previewImage(this, 'previewClient')" style="font-size:13px;" />
          </div>
          
          <div class="file-input-wrapper">
            <label for="client_app_logo_url">Or Custom Logo Image Path / URL</label>
            <input type="text" id="client_app_logo_url" name="client_app_logo_url" class="url-fallback-input" placeholder="/uploads/app_settings/client_logo.png" value="<%= settings.clientAppLogo %>" />
          </div>

          <div class="form-section-title">📱 App Share & Store Links</div>
          <div class="file-input-wrapper">
            <label for="client_app_playstore_url">🤖 Google Play Store Link</label>
            <input type="url" id="client_app_playstore_url" name="client_app_playstore_url" class="url-fallback-input" placeholder="https://play.google.com/store/apps/details?id=com.jaipurgro.client" value="<%= settings.clientPlayStore %>" />
          </div>
          <div class="file-input-wrapper">
            <label for="client_app_appstore_url">🍏 Apple App Store Link</label>
            <input type="url" id="client_app_appstore_url" name="client_app_appstore_url" class="url-fallback-input" placeholder="https://apps.apple.com/app/jaipurgro-client/id123456789" value="<%= settings.clientAppStore %>" />
          </div>
        </div>

        <!-- VENDOR APP CARD -->
        <div class="logo-card">
          <div class="logo-card-header">
            <div class="logo-badge vendor">V</div>
            <div>
              <h3 style="margin:0; font-size:17px; font-weight:700;">Vendor App</h3>
              <span style="font-size:12px; color:#64748b;">Vendor Partner Management App</span>
            </div>
          </div>
          
          <div class="logo-preview-box">
            <img id="previewVendor" src="<%= settings.vendorAppLogo || '/assets/images/GroLogo.png' %>" alt="Vendor App Logo" onerror="this.src='/assets/images/GroLogo.png'" />
          </div>
          
          <div class="file-input-wrapper">
            <label for="vendor_app_logo">Upload Logo Image File (PNG, JPG, SVG)</label>
            <input type="file" id="vendor_app_logo" name="vendor_app_logo" accept="image/*" onchange="previewImage(this, 'previewVendor')" style="font-size:13px;" />
          </div>
          
          <div class="file-input-wrapper">
            <label for="vendor_app_logo_url">Or Custom Logo Image Path / URL</label>
            <input type="text" id="vendor_app_logo_url" name="vendor_app_logo_url" class="url-fallback-input" placeholder="/uploads/app_settings/vendor_logo.png" value="<%= settings.vendorAppLogo %>" />
          </div>

          <div class="form-section-title">📱 App Share & Store Links</div>
          <div class="file-input-wrapper">
            <label for="vendor_app_playstore_url">🤖 Google Play Store Link</label>
            <input type="url" id="vendor_app_playstore_url" name="vendor_app_playstore_url" class="url-fallback-input" placeholder="https://play.google.com/store/apps/details?id=com.jaipurgro.vendor" value="<%= settings.vendorPlayStore %>" />
          </div>
          <div class="file-input-wrapper">
            <label for="vendor_app_appstore_url">🍏 Apple App Store Link</label>
            <input type="url" id="vendor_app_appstore_url" name="vendor_app_appstore_url" class="url-fallback-input" placeholder="https://apps.apple.com/app/jaipurgro-vendor/id123456789" value="<%= settings.vendorAppStore %>" />
          </div>
        </div>

        <!-- DELIVERY APP CARD -->
        <div class="logo-card">
          <div class="logo-card-header">
            <div class="logo-badge delivery">D</div>
            <div>
              <h3 style="margin:0; font-size:17px; font-weight:700;">Delivery App</h3>
              <span style="font-size:12px; color:#64748b;">Delivery Rider Partner App</span>
            </div>
          </div>
          
          <div class="logo-preview-box">
            <img id="previewDelivery" src="<%= settings.deliveryAppLogo || '/assets/images/GroLogo.png' %>" alt="Delivery App Logo" onerror="this.src='/assets/images/GroLogo.png'" />
          </div>
          
          <div class="file-input-wrapper">
            <label for="delivery_app_logo">Upload Logo Image File (PNG, JPG, SVG)</label>
            <input type="file" id="delivery_app_logo" name="delivery_app_logo" accept="image/*" onchange="previewImage(this, 'previewDelivery')" style="font-size:13px;" />
          </div>
          
          <div class="file-input-wrapper">
            <label for="delivery_app_logo_url">Or Custom Logo Image Path / URL</label>
            <input type="text" id="delivery_app_logo_url" name="delivery_app_logo_url" class="url-fallback-input" placeholder="/uploads/app_settings/delivery_logo.png" value="<%= settings.deliveryAppLogo %>" />
          </div>

          <div class="form-section-title">📱 App Share & Store Links</div>
          <div class="file-input-wrapper">
            <label for="delivery_app_playstore_url">🤖 Google Play Store Link</label>
            <input type="url" id="delivery_app_playstore_url" name="delivery_app_playstore_url" class="url-fallback-input" placeholder="https://play.google.com/store/apps/details?id=com.jaipurgro.delivery" value="<%= settings.deliveryPlayStore %>" />
          </div>
          <div class="file-input-wrapper">
            <label for="delivery_app_appstore_url">🍏 Apple App Store Link</label>
            <input type="url" id="delivery_app_appstore_url" name="delivery_app_appstore_url" class="url-fallback-input" placeholder="https://apps.apple.com/app/jaipurgro-delivery/id123456789" value="<%= settings.deliveryAppStore %>" />
          </div>
        </div>

      </div>

      <div class="save-settings-bar">
        <div>
          <strong style="font-size:15px; color:#1e293b;">Save Changes</strong>
          <p style="margin:4px 0 0; font-size:13px; color:#64748b;">Changes update app logos and store share links across all mobile & web applications in real-time.</p>
        </div>
        <button type="submit" class="submit-btn">Save All App Settings</button>
      </div>
    </form>
  </main>

  <script>
    function previewImage(input, previewId) {
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
          document.getElementById(previewId).src = e.target.result;
        }
        reader.readAsDataURL(input.files[0]);
      }
    }
  </script>
</body>
</html>
