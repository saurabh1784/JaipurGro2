<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Area Definition</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="system-theme">
  <%- include('partials/system_sidebar', { shell }) %>

  <main class="system-main">
    <header class="topbar">
      <div>
        <p class="crumb">Dashboard / Area Definition</p>
        <h1>Area Definition</h1>
      </div>
      <div class="topbar-actions">
        <button class="product-secondary-button" type="button" id="resetArea">Reset</button>
        <button class="settings-save" type="button" id="saveArea">Save Area</button>
      </div>
    </header>

    <section class="area-definition-shell">
      <aside class="area-definition-panel">
        <form id="areaForm" class="settings-grid">
          <input id="areaId" type="hidden" />
          <label>
            Area Name
            <input id="areaName" type="text" placeholder="Mansarovar Zone A" required />
          </label>
          <label>
            City
            <input id="areaCity" type="text" list="cityOptions" value="Jaipur" />
          </label>
          <label class="settings-wide area-toggle-row">
            <input id="ownDeliveryActive" type="checkbox" />
            <span>Own Delivery active for this area</span>
          </label>
          <label class="settings-wide area-toggle-row">
            <input id="areaActive" type="checkbox" checked />
            <span>Area active</span>
          </label>
          <div class="settings-wide area-map-actions">
            <button class="settings-save" type="button" id="toggleMarking">Mark Points: Off</button>
            <button class="product-secondary-button" type="button" id="undoPoint">Undo Point</button>
            <button class="product-secondary-button" type="button" id="clearPolygon">Clear Polygon</button>
          </div>
        </form>

        <div class="area-help-card">
          <h2>How to mark an area</h2>
          <ol>
            <li>Enter the area name and city.</li>
            <li>Click Mark Points, then click on the map to add boundary points. You can also hold Ctrl and click.</li>
            <li>Add at least three points. The green shape shows the selected area.</li>
            <li>Drag any point on the shape to adjust the boundary.</li>
            <li>Use Undo Point or Clear Polygon if the boundary needs correction.</li>
            <li>Turn on Own Delivery active, then click Save Area.</li>
          </ol>
        </div>

        <div class="area-definition-status" id="areaStatus">Click Mark Points, then click on the map to mark the area boundary.</div>
        <div class="area-point-list" id="areaPointList">No points marked yet.</div>

        <div class="catalog-table-card area-list-card">
          <table class="catalog-table">
            <thead>
              <tr>
                <th>Area</th>
                <th>Own Delivery</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="areasBody">
              <tr><td colspan="4">Loading areas...</td></tr>
            </tbody>
          </table>
        </div>
      </aside>

      <section class="area-map-card">
        <div id="areaMap" class="area-map"></div>
        <div id="areaMarkerLayer" class="area-marker-layer" aria-hidden="true"></div>
      </section>
    </section>
  </main>

  <datalist id="cityOptions">
    <% (cityOptions || []).forEach((city) => { %>
      <option value="<%= city %>"></option>
    <% }) %>
  </datalist>

  <script>
    const mapsConfig = <%- JSON.stringify(maps || {}) %>;
    let map = null;
    let polygon = null;
    let markers = [];
    let areas = [];
    let selectedPath = [];
    let googleMapsLoadedKey = '';
    let manualMarkingMode = false;
    let lastPlacedAt = 0;
    let mapProjectionOverlay = null;
    let markerUiBound = false;
    let didChooseInitialAreaCity = false;
    let fallbackMapMode = false;
    const fallbackMapState = {
      zoom: 12,
      center: { lat: 26.9124, lng: 75.7873 },
      dragging: false,
      dragStart: null,
      dragCenter: null,
    };

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function setStatus(message, isError = false) {
      const status = document.getElementById('areaStatus');
      status.textContent = message;
      status.classList.toggle('error', isError);
    }

    function ensureMapScript() {
      const apiKey = mapsConfig.browserApiKey || '';
      if (!apiKey) {
        initFallbackMap('Google Maps browser key is missing. Using local fallback map for area marking.');
        return;
      }
      if (window.google && window.google.maps && googleMapsLoadedKey === apiKey) {
        initMap();
        return;
      }
      window.handleAreaMapsLoaded = initMap;
      window.gm_authFailure = () => initFallbackMap('Google Maps authentication failed. Using local fallback map for area marking.');
      const script = document.createElement('script');
      script.id = 'areaGoogleMapsScript';
      script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(apiKey)}&v=weekly&callback=handleAreaMapsLoaded`;
      script.async = true;
      script.defer = true;
      script.onerror = () => initFallbackMap('Unable to load Google Maps. Using local fallback map for area marking.');
      googleMapsLoadedKey = apiKey;
      document.head.appendChild(script);
    }

    function initFallbackMap(message = 'Using local fallback map for area marking.') {
      fallbackMapMode = true;
      const mapElement = document.getElementById('areaMap');
      if (!mapElement) return;
      mapElement.innerHTML = `
        <div class="fallback-map-grid">
          <div id="fallbackTileLayer" class="fallback-tile-layer"></div>
          <svg id="fallbackPolygonSvg" class="fallback-polygon-svg" viewBox="0 0 100 100" preserveAspectRatio="none"></svg>
          <div class="fallback-map-title">Jaipur Map</div>
          <div class="fallback-map-subtitle">${escapeHtml(message)} <a href="/settings#google-maps">Check Google Maps settings</a></div>
          <div class="fallback-map-controls">
            <button type="button" onclick="fallbackZoom(1)">+</button>
            <button type="button" onclick="fallbackZoom(-1)">−</button>
          </div>
          <div class="fallback-map-attribution">© OpenStreetMap contributors</div>
        </div>
      `;
      bindMarkerUi();
      bindFallbackMapUi();
      renderFallbackTiles();
      window.addEventListener('resize', () => {
        if (!fallbackMapMode) return;
        renderFallbackTiles();
        renderMarkers();
      });
      drawPath(selectedPath);
      refreshVisibleAreas();
      setStatus(message);
    }

    function bindFallbackMapUi() {
      const card = document.querySelector('.area-map-card');
      if (!card || card.dataset.fallbackBound === '1') return;
      card.dataset.fallbackBound = '1';
      card.addEventListener('wheel', (event) => {
        if (!fallbackMapMode) return;
        event.preventDefault();
        fallbackZoom(event.deltaY < 0 ? 1 : -1, clickPixel(event));
      }, { passive: false });
      card.addEventListener('pointerdown', (event) => {
        if (!fallbackMapMode || shouldPlacePoint(event)) return;
        fallbackMapState.dragging = true;
        fallbackMapState.dragStart = { x: event.clientX, y: event.clientY };
        fallbackMapState.dragCenter = { ...fallbackMapState.center };
        card.setPointerCapture?.(event.pointerId);
      });
      card.addEventListener('pointermove', (event) => {
        if (!fallbackMapMode || !fallbackMapState.dragging || !fallbackMapState.dragStart) return;
        const startCenter = fallbackWorldPixel(fallbackMapState.dragCenter.lat, fallbackMapState.dragCenter.lng);
        const dx = event.clientX - fallbackMapState.dragStart.x;
        const dy = event.clientY - fallbackMapState.dragStart.y;
        fallbackMapState.center = fallbackLatLngFromWorldPixel(startCenter.x - dx, startCenter.y - dy);
        renderFallbackTiles();
        renderMarkers();
      });
      const stopDrag = (event) => {
        if (!fallbackMapMode) return;
        fallbackMapState.dragging = false;
        fallbackMapState.dragStart = null;
        fallbackMapState.dragCenter = null;
        if (event && event.pointerId !== undefined) card.releasePointerCapture?.(event.pointerId);
      };
      card.addEventListener('pointerup', stopDrag);
      card.addEventListener('pointercancel', stopDrag);
      card.addEventListener('pointerleave', stopDrag);
    }

    function initMap() {
      const options = {
        center: { lat: 26.9124, lng: 75.7873 },
        zoom: 12,
        mapTypeControl: false,
        streetViewControl: false,
      };
      if (mapsConfig.mapId) options.mapId = mapsConfig.mapId;
      map = new google.maps.Map(document.getElementById('areaMap'), options);
      mapProjectionOverlay = new google.maps.OverlayView();
      mapProjectionOverlay.onAdd = function onAdd() {};
      mapProjectionOverlay.draw = function draw() {};
      mapProjectionOverlay.onRemove = function onRemove() {};
      mapProjectionOverlay.setMap(map);
      polygon = new google.maps.Polygon({
        paths: [],
        map,
        strokeColor: '#0f9f4f',
        strokeOpacity: 1,
        strokeWeight: 4,
        fillColor: '#22c55e',
        fillOpacity: 0.26,
        editable: true,
        clickable: false,
        zIndex: 50,
      });
      polygon.getPath().addListener('set_at', syncPathFromPolygon);
      polygon.getPath().addListener('insert_at', syncPathFromPolygon);
      polygon.getPath().addListener('remove_at', syncPathFromPolygon);
      bindMarkerUi();
      map.addListener('bounds_changed', renderMarkers);
      window.addEventListener('resize', renderMarkers);
      refreshVisibleAreas();
    }

    function bindMarkerUi() {
      if (markerUiBound) return;
      markerUiBound = true;
      const mapElement = document.getElementById('areaMap');
      const markerLayer = document.getElementById('areaMarkerLayer');
      const mapCard = document.querySelector('.area-map-card');
      mapElement.addEventListener('click', handleMapDomClick, true);
      markerLayer.addEventListener('pointerdown', handleMarkerLayerPointer);
      markerLayer.addEventListener('click', handleMarkerLayerPointer);
      mapCard.addEventListener('pointerdown', handleMarkerLayerPointer);
      document.addEventListener('keydown', handleMarkingKey);
      document.addEventListener('keyup', handleMarkingKey);
      document.addEventListener('mousemove', handleMarkingMouseMove, true);
      window.addEventListener('blur', () => setMarkingMode(false));
    }

    function syncPathFromPolygon() {
      selectedPath = polygon.getPath().getArray().map((point) => ({ lat: point.lat(), lng: point.lng() }));
      renderMarkers();
      renderPointList();
      setStatus(`${selectedPath.length} point${selectedPath.length === 1 ? '' : 's'} marked.`);
    }

    function drawPath(path) {
      selectedPath = path.map((point) => ({ lat: Number(point.lat), lng: Number(point.lng) }))
        .filter((point) => Number.isFinite(point.lat) && Number.isFinite(point.lng));
      if (polygon) {
        polygon.setPath(selectedPath);
        polygon.setOptions({ zIndex: 50 });
      }
      renderMarkers();
      renderPointList();
      if (!fallbackMapMode && map && window.google && selectedPath.length) {
        const bounds = new google.maps.LatLngBounds();
        selectedPath.forEach((point) => bounds.extend(point));
        map.fitBounds(bounds);
      }
      setStatus(`${selectedPath.length} point${selectedPath.length === 1 ? '' : 's'} marked.`);
    }

    function addPoint(latLng, domEvent = null) {
      addPointFromValues(latLng.lat(), latLng.lng(), domEvent ? clickPixel(domEvent) : null);
    }

    function addPointFromValues(lat, lng, screen = null) {
      selectedPath.push({ lat, lng, screen });
      if (polygon) {
        polygon.setPath(selectedPath);
        polygon.setOptions({ zIndex: 50 });
      }
      renderMarkers();
      renderPointList();
      setStatus(`${selectedPath.length} point${selectedPath.length === 1 ? '' : 's'} marked.`);
    }

    function handleMapDomClick(event) {
      if (!fallbackMapMode && (!map || !polygon)) return;
      if (!shouldPlacePoint(event)) {
        setStatus('Click Mark Points first, or hold Ctrl and click on the map to add a point.');
        return;
      }
      event.preventDefault();
      event.stopPropagation();
      const screen = clickPixel(event);
      if (!screen) return;
      const latLng = mapPixelToLatLng(screen);
      if (!latLng) return;
      const lastPoint = selectedPath[selectedPath.length - 1];
      if (
        lastPoint
        && Math.abs(lastPoint.lat - latLng.lat) < 0.0000001
        && Math.abs(lastPoint.lng - latLng.lng) < 0.0000001
      ) {
        return;
      }
      addPointFromValues(latLng.lat, latLng.lng, screen);
    }

    function handleMarkerLayerPointer(event) {
      if (!fallbackMapMode && (!map || !polygon)) {
        setStatus('Map is still loading. Please wait a moment, then try again.', true);
        return;
      }
      if (!shouldPlacePoint(event)) {
        setStatus(`Map click detected at ${Math.round(event.clientX)}, ${Math.round(event.clientY)}. Click Mark Points first to add a point.`);
        return;
      }
      event.preventDefault();
      event.stopPropagation();
      if (Date.now() - lastPlacedAt < 120) return;
      const screen = clickPixel(event);
      if (!screen) {
        setStatus('Map click detected, but screen position could not be read.', true);
        return;
      }
      const latLng = mapPixelToLatLng(screen);
      if (!latLng) {
        const center = map && map.getCenter && map.getCenter();
        if (center) {
          addPointFromValues(center.lat(), center.lng(), screen);
          setStatus('Point placed visually. Map projection was still loading, so the map center was used.');
          return;
        }
        setStatus('Map click detected, but map coordinates are not ready yet. Try again in one second.', true);
        return;
      }
      lastPlacedAt = Date.now();
      addPointFromValues(latLng.lat, latLng.lng, screen);
    }

    function handleMarkingKey(event) {
      if (event.key !== 'Control') return;
      setMarkingMode(event.type === 'keydown');
    }

    function handleMarkingMouseMove(event) {
      const card = document.querySelector('.area-map-card');
      if (!card) return;
      const rect = card.getBoundingClientRect();
      const insideMap = event.clientX >= rect.left
        && event.clientX <= rect.right
        && event.clientY >= rect.top
        && event.clientY <= rect.bottom;
      if (insideMap && shouldPlacePoint(event)) {
        setMarkingMode(true);
      } else if (!manualMarkingMode && !isCtrlPressed(event)) {
        setMarkingMode(false, false);
      }
    }

    function shouldPlacePoint(event) {
      return manualMarkingMode || isCtrlPressed(event);
    }

    function isCtrlPressed(event) {
      return Boolean(event && (event.ctrlKey || (event.getModifierState && event.getModifierState('Control'))));
    }

    function setMarkingMode(enabled, announce = true) {
      const card = document.querySelector('.area-map-card');
      if (!card) return;
      card.classList.toggle('marking-mode', Boolean(enabled));
      if (enabled && announce) setStatus('Point marking active. Click the map to add a point.');
    }

    function toggleManualMarking() {
      manualMarkingMode = !manualMarkingMode;
      const button = document.getElementById('toggleMarking');
      button.textContent = manualMarkingMode ? 'Mark Points: On' : 'Mark Points: Off';
      button.classList.toggle('area-marking-active', manualMarkingMode);
      setMarkingMode(manualMarkingMode);
      setStatus(manualMarkingMode
        ? 'Point marking active. Click the map to add a point.'
        : 'Click Mark Points, then click on the map to mark the area boundary.');
    }

    function renderMarkers() {
      const layer = document.getElementById('areaMarkerLayer');
      if (!layer || (!map && !fallbackMapMode)) return;
      layer.innerHTML = '';
      markers = [];

      selectedPath.forEach((point, index) => {
        const pixel = latLngToMapPixel(point) || point.screen;
        if (!pixel) return;
        const marker = document.createElement('span');
        marker.className = 'area-point-marker';
        marker.textContent = String(index + 1);
        marker.title = `Point ${index + 1}`;
        marker.style.left = `${pixel.x}px`;
        marker.style.top = `${pixel.y}px`;
        layer.appendChild(marker);
        markers.push(marker);
      });
      renderFallbackPolygons();
    }

    function latLngToMapPixel(point) {
      if (fallbackMapMode) return fallbackLatLngToPixel(point);
      const projection = mapProjectionOverlay && mapProjectionOverlay.getProjection();
      if (!projection) return point.screen || null;
      const pixel = projection.fromLatLngToContainerPixel(new google.maps.LatLng(point.lat, point.lng));
      return pixel ? { x: pixel.x, y: pixel.y } : point.screen || null;
    }

    function clickPixel(domEvent) {
      const mapDiv = document.getElementById('areaMap');
      if (!mapDiv || !domEvent || domEvent.clientX === undefined || domEvent.clientY === undefined) return null;
      const rect = mapDiv.getBoundingClientRect();
      return {
        x: domEvent.clientX - rect.left,
        y: domEvent.clientY - rect.top,
      };
    }

    function mapPixelToLatLng(pixel) {
      if (fallbackMapMode) return fallbackPixelToLatLng(pixel);
      const projection = mapProjectionOverlay && mapProjectionOverlay.getProjection();
      if (!projection) return null;
      const latLng = projection.fromContainerPixelToLatLng(new google.maps.Point(pixel.x, pixel.y));
      return latLng ? { lat: latLng.lat(), lng: latLng.lng() } : null;
    }

    function renderPointList() {
      const list = document.getElementById('areaPointList');
      if (!selectedPath.length) {
        list.textContent = 'No points marked yet.';
        return;
      }
      list.innerHTML = selectedPath.map((point, index) => (
        `<span>Point ${index + 1}: ${point.lat.toFixed(6)}, ${point.lng.toFixed(6)}</span>`
      )).join('');
    }

    function resetForm() {
      const currentCity = document.getElementById('areaCity').value.trim() || 'Jaipur';
      document.getElementById('areaId').value = '';
      document.getElementById('areaName').value = '';
      document.getElementById('areaCity').value = currentCity;
      document.getElementById('ownDeliveryActive').checked = false;
      document.getElementById('areaActive').checked = true;
      manualMarkingMode = false;
      const markingButton = document.getElementById('toggleMarking');
      if (markingButton) {
        markingButton.textContent = 'Mark Points: Off';
        markingButton.classList.remove('area-marking-active');
      }
      setMarkingMode(false, false);
      drawPath([]);
      renderPointList();
      refreshVisibleAreas();
      setStatus('Click Mark Points, then click on the map to mark the area boundary.');
    }

    async function loadAreas() {
      const body = document.getElementById('areasBody');
      body.innerHTML = '<tr><td colspan="4">Loading areas...</td></tr>';
      try {
        const response = await fetch('/area-definitions/list', { headers: { Accept: 'application/json' } });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to load areas');
        areas = data.areas || [];
        syncCityOptionsFromAreas();
        chooseInitialAreaCity();
        refreshVisibleAreas();
      } catch (error) {
        body.innerHTML = `<tr><td colspan="4">${escapeHtml(error.message)}</td></tr>`;
      }
    }

    function selectedAreaCity() {
      return String(document.getElementById('areaCity').value || '').trim().toLowerCase();
    }

    function visibleAreas() {
      const city = selectedAreaCity();
      if (!city) return areas;
      return areas.filter((area) => String(area.city || '').trim().toLowerCase() === city);
    }

    function syncCityOptionsFromAreas() {
      const datalist = document.getElementById('cityOptions');
      if (!datalist) return;
      const existing = new Set(Array.from(datalist.options || []).map((option) => String(option.value || '').trim().toLowerCase()));
      areas.forEach((area) => {
        const city = String(area.city || '').trim();
        if (!city || existing.has(city.toLowerCase())) return;
        const option = document.createElement('option');
        option.value = city;
        datalist.appendChild(option);
        existing.add(city.toLowerCase());
      });
    }

    function chooseInitialAreaCity() {
      if (didChooseInitialAreaCity || !areas.length) return;
      didChooseInitialAreaCity = true;
      if (visibleAreas().length) return;
      const firstMappedCity = areas.map((area) => String(area.city || '').trim()).find(Boolean);
      if (firstMappedCity) {
        document.getElementById('areaCity').value = firstMappedCity;
      }
    }

    function refreshVisibleAreas() {
      renderAreas();
      drawExistingAreas();
      renderFallbackPolygons();
    }

    function renderAreas() {
      const body = document.getElementById('areasBody');
      const cityAreas = visibleAreas();
      if (!cityAreas.length) {
        const cityName = document.getElementById('areaCity').value.trim();
        body.innerHTML = `<tr><td colspan="4">No mapped areas${cityName ? ` for ${escapeHtml(cityName)}` : ''} yet.</td></tr>`;
        return;
      }
      body.innerHTML = cityAreas.map((area) => `
        <tr>
          <td><strong>${escapeHtml(area.name)}</strong><br><small>${escapeHtml(area.city || 'Any city')}</small></td>
          <td>${area.own_delivery_active ? 'Active' : 'Off'}</td>
          <td>${area.is_active ? 'Active' : 'Inactive'}</td>
          <td>
            <button class="product-secondary-button area-row-button" type="button" onclick="editArea(${Number(area.id)})">Edit</button>
            <button class="danger-action-button area-row-button" type="button" onclick="deleteArea(${Number(area.id)})">Delete</button>
          </td>
        </tr>
      `).join('');
    }

    let existingAreaPolygons = [];
    function drawExistingAreas() {
      if (fallbackMapMode) {
        renderFallbackPolygons();
        return;
      }
      if (!map || !window.google) return;
      existingAreaPolygons.forEach((item) => item.setMap(null));
      existingAreaPolygons = visibleAreas().map((area) => new google.maps.Polygon({
        paths: area.polygon || [],
        map,
        strokeColor: area.own_delivery_active ? '#178f49' : '#64748b',
        strokeOpacity: 0.65,
        strokeWeight: 2,
        fillColor: area.own_delivery_active ? '#28b446' : '#94a3b8',
        fillOpacity: area.is_active ? 0.10 : 0.04,
        clickable: false,
        zIndex: 5,
      }));
      if (polygon) polygon.setOptions({ zIndex: 50 });
    }

    function fallbackBounds() {
      return {
        minLat: 26.78,
        maxLat: 27.05,
        minLng: 75.62,
        maxLng: 75.95,
      };
    }

    function fallbackWorldPixel(lat, lng, zoom = fallbackMapState.zoom) {
      const sinLat = Math.sin((Number(lat) * Math.PI) / 180);
      const scale = 256 * Math.pow(2, zoom);
      return {
        x: ((Number(lng) + 180) / 360) * scale,
        y: (0.5 - Math.log((1 + sinLat) / (1 - sinLat)) / (4 * Math.PI)) * scale,
      };
    }

    function fallbackZoom(delta, focusPixel = null) {
      if (!fallbackMapMode) return;
      const oldZoom = fallbackMapState.zoom;
      const nextZoom = Math.max(10, Math.min(18, oldZoom + delta));
      if (nextZoom === oldZoom) return;

      if (focusPixel) {
        const before = fallbackPixelToLatLng(focusPixel);
        fallbackMapState.zoom = nextZoom;
        const mapDiv = document.getElementById('areaMap');
        const rect = mapDiv ? mapDiv.getBoundingClientRect() : { width: 1, height: 1 };
        const world = fallbackWorldPixel(before.lat, before.lng);
        const centerWorld = {
          x: world.x - focusPixel.x + rect.width / 2,
          y: world.y - focusPixel.y + rect.height / 2,
        };
        fallbackMapState.center = fallbackLatLngFromWorldPixel(centerWorld.x, centerWorld.y);
      } else {
        fallbackMapState.zoom = nextZoom;
      }
      renderFallbackTiles();
      renderMarkers();
      setStatus(`Fallback map zoom ${fallbackMapState.zoom}. Drag to pan, scroll to zoom, or turn Mark Points on to draw.`);
    }

    function fallbackLatLngFromWorldPixel(x, y, zoom = fallbackMapState.zoom) {
      const scale = 256 * Math.pow(2, zoom);
      const lng = (x / scale) * 360 - 180;
      const n = Math.PI - (2 * Math.PI * y) / scale;
      const lat = (180 / Math.PI) * Math.atan(0.5 * (Math.exp(n) - Math.exp(-n)));
      return { lat, lng };
    }

    function fallbackViewportOrigin() {
      const mapDiv = document.getElementById('areaMap');
      const rect = mapDiv ? mapDiv.getBoundingClientRect() : { width: 1, height: 1 };
      const center = fallbackWorldPixel(fallbackMapState.center.lat, fallbackMapState.center.lng);
      return {
        x: center.x - rect.width / 2,
        y: center.y - rect.height / 2,
        width: rect.width,
        height: rect.height,
      };
    }

    function renderFallbackTiles() {
      if (!fallbackMapMode) return;
      const layer = document.getElementById('fallbackTileLayer');
      if (!layer) return;
      const origin = fallbackViewportOrigin();
      const zoom = fallbackMapState.zoom;
      const tileSize = 256;
      const maxTile = Math.pow(2, zoom);
      const startX = Math.floor(origin.x / tileSize);
      const endX = Math.floor((origin.x + origin.width) / tileSize);
      const startY = Math.floor(origin.y / tileSize);
      const endY = Math.floor((origin.y + origin.height) / tileSize);
      const tiles = [];
      for (let x = startX; x <= endX; x += 1) {
        for (let y = startY; y <= endY; y += 1) {
          if (y < 0 || y >= maxTile) continue;
          const wrappedX = ((x % maxTile) + maxTile) % maxTile;
          tiles.push(`
            <img
              class="fallback-map-tile"
              alt=""
              src="https://tile.openstreetmap.org/${zoom}/${wrappedX}/${y}.png"
              style="left:${(x * tileSize) - origin.x}px;top:${(y * tileSize) - origin.y}px"
              onerror="this.style.display='none'; document.getElementById('fallbackTileLayer').classList.add('tiles-failed');"
            />`);
        }
      }
      layer.innerHTML = tiles.join('');
    }

    function fallbackLatLngToPixel(point) {
      const mapDiv = document.getElementById('areaMap');
      if (!mapDiv) return point.screen || null;
      const origin = fallbackViewportOrigin();
      const world = fallbackWorldPixel(point.lat, point.lng);
      return {
        x: world.x - origin.x,
        y: world.y - origin.y,
      };
    }

    function fallbackPixelToLatLng(pixel) {
      const mapDiv = document.getElementById('areaMap');
      if (!mapDiv || !pixel) return null;
      const origin = fallbackViewportOrigin();
      return fallbackLatLngFromWorldPixel(origin.x + pixel.x, origin.y + pixel.y);
    }

    function fallbackPointsAttr(points) {
      const mapDiv = document.getElementById('areaMap');
      if (!mapDiv) return '';
      const rect = mapDiv.getBoundingClientRect();
      return points
        .map((point) => fallbackLatLngToPixel(point))
        .filter(Boolean)
        .map((pixel) => `${(pixel.x / Math.max(rect.width, 1)) * 100},${(pixel.y / Math.max(rect.height, 1)) * 100}`)
        .join(' ');
    }

    function renderFallbackPolygons() {
      if (!fallbackMapMode) return;
      const svg = document.getElementById('fallbackPolygonSvg');
      if (!svg) return;
      const existing = visibleAreas()
        .filter((area) => Array.isArray(area.polygon) && area.polygon.length >= 3)
        .map((area) => `<polygon points="${fallbackPointsAttr(area.polygon)}" class="fallback-existing-polygon ${area.own_delivery_active ? 'own-active' : ''}" />`)
        .join('');
      const selected = selectedPath.length >= 2
        ? `<polyline points="${fallbackPointsAttr(selectedPath)}" class="fallback-selected-line" />`
        : '';
      const selectedPolygon = selectedPath.length >= 3
        ? `<polygon points="${fallbackPointsAttr(selectedPath)}" class="fallback-selected-polygon" />`
        : '';
      svg.innerHTML = existing + selectedPolygon + selected;
    }

    function editArea(id) {
      const area = areas.find((item) => Number(item.id) === Number(id));
      if (!area) return;
      document.getElementById('areaId').value = area.id;
      document.getElementById('areaName').value = area.name;
      document.getElementById('areaCity').value = area.city || '';
      document.getElementById('ownDeliveryActive').checked = Boolean(area.own_delivery_active);
      document.getElementById('areaActive').checked = Boolean(area.is_active);
      drawPath(area.polygon || []);
      refreshVisibleAreas();
    }

    async function saveArea() {
      const payload = {
        name: document.getElementById('areaName').value.trim(),
        city: document.getElementById('areaCity').value.trim(),
        polygon: selectedPath,
        own_delivery_active: document.getElementById('ownDeliveryActive').checked,
        is_active: document.getElementById('areaActive').checked,
      };
      const id = document.getElementById('areaId').value;
      const url = id ? `/area-definitions/${encodeURIComponent(id)}` : '/area-definitions';
      const method = id ? 'PUT' : 'POST';
      try {
        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to save area');
        setStatus(data.message || 'Area saved');
        resetForm();
        await loadAreas();
      } catch (error) {
        setStatus(error.message, true);
      }
    }

    async function deleteArea(id) {
      if (!confirm('Delete this mapped area?')) return;
      try {
        const response = await fetch(`/area-definitions/${encodeURIComponent(id)}`, {
          method: 'DELETE',
          headers: { Accept: 'application/json' },
        });
        const data = await response.json();
        if (!data.success) throw new Error(data.message || 'Unable to delete area');
        resetForm();
        await loadAreas();
      } catch (error) {
        setStatus(error.message, true);
      }
    }

    document.getElementById('saveArea').addEventListener('click', saveArea);
    document.getElementById('resetArea').addEventListener('click', resetForm);
    document.getElementById('toggleMarking').addEventListener('click', toggleManualMarking);
    document.getElementById('undoPoint').addEventListener('click', () => drawPath(selectedPath.slice(0, -1)));
    document.getElementById('clearPolygon').addEventListener('click', () => drawPath([]));
    document.getElementById('areaCity').addEventListener('input', refreshVisibleAreas);
    document.getElementById('areaCity').addEventListener('change', refreshVisibleAreas);
    bindMarkerUi();
    loadAreas();
    ensureMapScript();
  </script>

